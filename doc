"""
probe_api.py
------------
Fire ONE request using the EXACT payload/token logic from extract_concepts.py,
then dump the full raw response. Run this before any batch so you can confirm:

  1. the new payload is accepted (HTTP 200, valid JSON),
  2. where the concepts actually live in the response, and
  3. that parse_concepts() points at the right path.

Run from the same folder as extract_concepts.py:
    python probe_api.py

Writes:
    probe_response.json  - pretty full JSON (if the body parsed)
    probe_raw.txt        - the raw response body, always
"""

import json
import requests

import extract_concepts as E   # reuse the same build_payload / token / parse logic

# ---- what to send ----
TEXT      = None          # set a literal string to test that, or leave None
PROBE_DOC = "sample_101"  # if TEXT is None, pull a chunk from this doc in the pkl
CHUNK_I   = 0             # which chunk of that doc


def get_text():
    if TEXT:
        return TEXT
    docs = E.load_documents(E.INPUT_PATH)
    match = [t for t in docs if E._match_only(t[1], PROBE_DOC)]
    if not match:
        raise SystemExit(f"{PROBE_DOC!r} not found in {E.INPUT_PATH}")
    _, label, _, chunks = match[0]
    if not chunks:
        raise SystemExit(f"{label} has no chunks")
    print(f"Probing {label}  chunk {CHUNK_I} of {len(chunks)}")
    return chunks[CHUNK_I]


def main():
    if not E.API_URL.strip():
        raise SystemExit("Set API_URL in extract_concepts.py first.")

    text = get_text()
    print(f"TEXT ({len(text)} chars): {text[:200]!r}\n")

    tokens = E.TokenManager(E.GCLOUD_LOC)
    payload = E.build_payload(text)

    # show exactly what is being sent (intents.definition trimmed for readability)
    shown = json.loads(json.dumps(payload))
    for k in shown.get("intents", {}):
        d = shown["intents"][k].get("definition", "")
        shown["intents"][k]["definition"] = d[:120] + " ...[trimmed]"
    print("PAYLOAD BEING SENT:")
    print(json.dumps(shown, indent=2, ensure_ascii=False))
    print()

    resp = requests.post(E.API_URL, json=payload,
                         headers=tokens.headers(), timeout=E.REQUEST_TIMEOUT)
    print(f"HTTP {resp.status_code}   Content-Type={resp.headers.get('Content-Type')}\n")

    with open("probe_raw.txt", "w", encoding="utf-8") as f:
        f.write(resp.text)

    try:
        data = resp.json()
    except ValueError:
        print("Response is NOT valid JSON. First 1500 chars:\n")
        print(resp.text[:1500])
        print("\nSaved full body -> probe_raw.txt")
        return

    with open("probe_response.json", "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)

    # ---- structure report ----
    if isinstance(data, dict):
        print("TOP-LEVEL KEYS:", list(data.keys()))
        if isinstance(data.get("output"), dict):
            print("output KEYS:  ", list(data["output"].keys()))
    else:
        print("Response is a", type(data).__name__, "not a dict.")

    concepts = E.parse_concepts(data)
    print(f"\nparse_concepts() -> {len(concepts)} concepts "
          f"(expects data['output']['concepts'])")
    if concepts:
        cui, meta = next(iter(concepts.items()))
        print(f"  first concept {cui}:")
        print("  " + json.dumps(meta, indent=2, ensure_ascii=False)[:600]
              .replace("\n", "\n  "))
    else:
        print("  -> EMPTY. Either the payload didn't trigger extraction, or the")
        print("     concepts are under a different key. Open probe_response.json,")
        print("     find the CUIs, then fix parse_concepts() in extract_concepts.py.")

    print("\nSaved -> probe_response.json (full)  +  probe_raw.txt (raw body)")


if __name__ == "__main__":
    main()

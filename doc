import pickle, pprint

data = pickle.load(open("concepts_by_chunk.pkl", "rb"))

print("docs in file:", len(data))
print("keys:", list(data)[:10], "...")

k = next(iter(data))            # first doc; or set k = 332 for a specific one
rec = data[k]

print("\ntop-level fields:", list(rec.keys()))
print("\none full record:")
pprint.pprint(rec, width=100, sort_dicts=False)

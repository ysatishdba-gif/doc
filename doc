import pickle
P = pickle.load(open("topics.pkl", "rb"))

# look at a mid-size topic — are its members genuinely related?
for tp, t in sorted(P["topic_id_to_topic"].items(),
                    key=lambda r: -r[1]["size"])[:3]:
    print(f"\n{tp}  anchor {t['canonical']}  size {t['size']}  IC {t['anchor_ic']:.3f}")
    for m in sorted(t["members"])[:15]:
        print("   ", m, P["labels"].get(m, ""))

"""
extract_concepts.py
--------------------
PHASE 1 of the topic-modeling pipeline.

Reads the reconstructed documents pickle (chunks == `blobs`), calls the internal
concept/CUI extraction API ONCE PER CHUNK (new payload), and writes a new pickle
that stores the extracted concepts per chunk, plus a per-document union of CUIs.

The new API takes a single `text` string per call (not a batched list), so this
fans the chunks out across a small thread pool. It is resumable (re-running skips
documents already finished), refreshes the gcloud identity token mid-run, retries
transient failures, and checkpoints after every document.

Output pickle shape (keyed by the SAME doc index as the input file):

    {
      <doc_key>: {
        "doc_id":       "doc_101_sample_101",
        # ---- ADDRESS: join back to the source pickles / PDFs ----
        "key":          101,                # reconstructed_obj.pk[key]
        "input_file":   None,               # which input pickle (None = INPUT_PATH)
        "sampling_id":  "sampling_1",        # sampling_1_stats.pk['sampling_id']
        "sample_index": 101,                # index into sampling_1_stats.pk['samples']
        "file_name":    "sample_101.pdf",   # the PDF
        # ---- metadata ----
        "raw_document": "<type label>",
        "category":     "<reconstructed['document']>",
        "pages":        <int>,
        "n_blobs":      <int>,
        "n_sections":   <int>,
        "n_chunks":     <int>,
        "chunks": [
            {
              "i":          0,
              "blob_index": 0,    # reconstructed_obj.pk[key]['reconstructed']['blobs'][0]
              "preview":    "<first 80 chars>",
              "cuis":       ["C2911459", "C0155540", ...],   # <-- just the concept list
              "error":      None or "<message>",
              "secs":       <float>,
              "server_ms":  {"extraction_ms":..., "matching_ms":...},
            },
            ...
        ],
        "extracted_cuis":     ["C...", ...],   # union across chunks, order-preserving
        "doc_secs":           <float>,
        "per_chunk_avg_secs": <float>,
        "complete":           True,
      },
      ...
    }

Concepts are stored as the CUI list only. To recover a blob's text or the PDF:
    reconstructed_obj.pk[key]['reconstructed']['blobs'][blob_index]   # the text
    sampling_1_stats.pk['samples'][sample_index]                      # the sample/PDF
"""

import os
import glob
import time
import pickle
import threading
import statistics
import subprocess

import requests
from concurrent.futures import ThreadPoolExecutor, as_completed

# ============================================================================
# CONFIG  -- set these three, tune the rest
# ============================================================================
GCLOUD_LOC  = r"C:\path\to\gcloud.cmd"   # Windows: the .cmd; *nix: "gcloud"
API_URL     = ""                          # <-- new internal extraction endpoint

INPUT_PATH  = "reconstructed_obj.pk"      # a single .pk/.pkl file OR a folder of them
STATS_PATH  = "sampling_1_stats.pk"       # filename manifest (samples); None to skip
OUTPUT_PATH = "concepts_by_chunk.pkl"     # new pkl this script writes

# Test one doc first, then do all. Set to None (or "") to process EVERY document.
# Otherwise set a document identifier; the matcher accepts either:
#   - a filename stem, e.g. "sample_101"  (matches raw_document / file_name), OR
#   - the integer pickle key, e.g. 101     (matches the dict key directly).
# NOTE for reconstructed_obj.pk: `raw_document` is a TYPE label ("Discharge
# Summary"), not a filename, and file_name is None -- so use the integer KEY.
# sample_101.pdf == samples[101] in sampling_1_stats.pk == key 101 here.
ONLY_DOC = 101

MAX_WORKERS      = 8        # concurrent API calls (lower if the API rate-limits)
REQUEST_TIMEOUT  = 600      # seconds per call
MAX_RETRIES      = 3        # attempts per chunk on transient errors
RETRY_BACKOFF    = 2.0      # base seconds, multiplied by attempt number
TOKEN_TTL        = 50 * 60  # refresh identity token every 50 min (tokens last ~1h)
CHECKPOINT_EVERY = 1        # save OUTPUT_PATH after every N documents

# ============================================================================
# PAYLOAD TEMPLATE  (only `text` changes per call)
# ============================================================================
PIPELINE_STEPS = {
    "run_general_extraction": True,
    "run_ner_extraction": False,
    "run_semantic_linking_v1": False,
    "run_semantic_linking_v2": False,
    "run_intent_filter": False,
    "run_deep_search": False,
}

INTENTS_DEFINITION = """
The text contains entities. Entity's description is similar to as an entity is used in Unified Medical Language System (UMLS) Metathesaurus.
It is generally used to refer to a recognizable, distinct object or concept in the real world or in a medical context.
For example, entity can be a disease, medication, symptom of a disease or any other concept.
Identify and return ALL entities available in the provided text and exactly as they appear in the text.
Additionally, there are list of semantic types mentioned here: ["Acquired Abnormality", "Activity", "Age Group", "Amino Acid Sequence", "Amino Acid, Peptide, or Protein", "Amphibian", "Anatomical Abnormality", "Anatomical Structure", "Animal", "Antibiotic", "Archaeon", "Bacterium", "Behavior", "Biologic Function", "Biologically Active Substance", "Biomedical Occupation or Discipline", "Biomedical or Dental Material", "Bird", "Body Location or Region", "Body Part, Organ, or Organ Component", "Body Space or Junction", "Body Substance", "Body System", "Carbohydrate Sequence", "Cell", "Cell Component", "Cell Function", "Cell or Molecular Dysfunction", "Chemical", "Chemical Viewed Functionally", "Chemical Viewed Structurally", "Classification", "Clinical Attribute", "Clinical Drug", "Conceptual Entity", "Congenital Abnormality", "Daily or Recreational Activity", "Diagnostic Procedure", "Disease or Syndrome", "Drug Delivery Device", "Educational Activity", "Element, Ion, or Isotope", "Embryonic Structure", "Entity", "Environmental Effect of Humans", "Enzyme", "Eukaryote", "Event", "Experimental Model of Disease", "Family Group", "Finding", "Fish", "Food", "Fully Formed Anatomical Structure", "Functional Concept", "Fungus", "Gene or Genome", "Genetic Function", "Geographic Area", "Governmental or Regulatory Activity", "Group", "Group Attribute", "Hazardous or Poisonous Substance", "Health Care Activity", "Health Care Related Organization", "Hormone", "Human", "Human-caused Phenomenon or Process", "Idea or Concept", "Immunologic Factor", "Indicator, Reagent, or Diagnostic Aid", "Individual Behavior", "Injury or Poisoning", "Inorganic Chemical", "Intellectual Product", "Laboratory or Test Result", "Laboratory Procedure", "Language", "Machine Activity", "Mammal", "Manufactured Object", "Medical Device", "Mental or Behavioral Dysfunction", "Mental Process", "Molecular Biology Research Technique", "Molecular Function", "Molecular Sequence", "Natural Phenomenon or Process", "Neoplastic Process", "Nucleic Acid, Nucleoside, or Nucleotide", "Nucleotide Sequence", "Occupation or Discipline", "Occupational Activity", "Organ or Tissue Function", "Organic Chemical", "Organism", "Organism Attribute", "Organism Function", "Organization", "Pathologic Function", "Patient or Disabled Group", "Pharmacologic Substance", "Phenomenon or Process", "Physical Object", "Physiologic Function", "Plant", "Population Group", "Professional or Occupational Group", "Professional Society", "Qualitative Concept", "Quantitative Concept", "Receptor", "Regulation or Law", "Reptile", "Research Activity", "Research Device", "Self-help or Relief Organization", "Sign or Symptom", "Social Behavior", "Spatial Concept", "Substance", "Temporal Concept", "Therapeutic or Preventive Procedure", "Tissue", "Vertebrate", "Virus", "Vitamin"]. Each identified entity can belong to a specific semantic type.
"""

INTENTS = {
    1: {
        "metadata": "Entities",
        "definition": INTENTS_DEFINITION,
    },
}

CLUSTER_SELECTION_PARAMS = {
    "cluster_set": "umls",
    "top_k": 150,
    "top_p": 10,
    "top_q": 20,
    "source_system": ["ICD10CM"],
}

REASONING = ["both"]  # semantic | intent | both


def build_payload(text: str) -> dict:
    """Per-chunk request body. Only `text` varies; everything else is constant."""
    return {
        "text": text,
        "pipeline_steps": PIPELINE_STEPS,
        "intents": INTENTS,
        "cluster_selection_params": CLUSTER_SELECTION_PARAMS,
        "reasoning": REASONING,
    }


def parse_concepts(data: dict) -> dict:
    """Pull the {cui: {...}} concepts dict out of the API response.

    Defaults to data["output"]["concepts"] (your current path). If your response
    nests differently, this is the one place to adjust.
    """
    out = data.get("output", data) if isinstance(data, dict) else {}
    concepts = out.get("concepts", {}) if isinstance(out, dict) else {}
    return concepts if isinstance(concepts, dict) else {}


def parse_timings(data):
    """Pull the server-side step timings (ms) from the response, best-effort."""
    if not isinstance(data, dict):
        return {}
    tm = (data.get("details", {}) or {}).get("timings_ms", {}) or {}
    return {
        "extraction_ms": tm.get("step_1_extraction_ms"),
        "matching_ms": tm.get("step_2_matching_ms"),
    }


# ============================================================================
# AUTH  -- one token, refreshed on TTL or on a 401
# ============================================================================
class TokenManager:
    def __init__(self, gcloud_loc: str, ttl: int = TOKEN_TTL):
        self._gcloud = gcloud_loc
        self._ttl = ttl
        self._token = None
        self._fetched_at = 0.0
        self._lock = threading.Lock()

    def _fetch(self) -> str:
        p = subprocess.run(
            [self._gcloud, "auth", "print-identity-token"],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
        )
        if p.returncode != 0:
            raise RuntimeError(f"gcloud failed: {p.stderr.strip()}")
        token = (p.stdout or "").strip()
        if not token:
            raise RuntimeError("gcloud returned an empty identity token")
        return token

    def headers(self, force: bool = False) -> dict:
        with self._lock:
            now = time.time()
            if force or self._token is None or (now - self._fetched_at) > self._ttl:
                self._token = self._fetch()
                self._fetched_at = now
            return {
                "Authorization": f"Bearer {self._token}",
                "Content-Type": "application/json",
            }


# ============================================================================
# HTTP  -- per-thread session, retry, 401 -> refresh + retry
# ============================================================================
_thread_local = threading.local()


def _session() -> requests.Session:
    s = getattr(_thread_local, "session", None)
    if s is None:
        s = requests.Session()
        _thread_local.session = s
    return s


def extract_chunk(tokens: TokenManager, text: str):
    """Call the API for ONE chunk. Returns (concepts, error, secs, server_ms).
    `secs` is client wall latency of the final attempt (excludes retry sleeps);
    `server_ms` is {extraction_ms, matching_ms} from the response."""
    payload = build_payload(text)
    last_err = None
    a0 = time.perf_counter()
    for attempt in range(1, MAX_RETRIES + 1):
        a0 = time.perf_counter()
        try:
            resp = _session().post(
                API_URL,
                json=payload,
                headers=tokens.headers(),
                timeout=REQUEST_TIMEOUT,
            )
            if resp.status_code == 401:
                tokens.headers(force=True)          # token likely expired mid-run
                raise requests.HTTPError("401 Unauthorized (refreshed token)")
            resp.raise_for_status()
            try:
                data = resp.json()
            except ValueError:
                return ({}, f"JSON decode failed (HTTP {resp.status_code}): "
                        f"{resp.text[:300]}", time.perf_counter() - a0, {})
            return (parse_concepts(data), None,
                    time.perf_counter() - a0, parse_timings(data))
        except (requests.RequestException, RuntimeError) as e:
            last_err = str(e)
            if attempt < MAX_RETRIES:
                time.sleep(RETRY_BACKOFF * attempt)
    return ({}, f"failed after {MAX_RETRIES} attempts: {last_err}",
            time.perf_counter() - a0, {})


# ============================================================================
# INPUT  -- load docs (chunks=blobs, pages) from reconstructed_obj.pk and the
#           PDF filename manifest from sampling_1_stats.pk. No PDFs are opened.
# ============================================================================
LINK_FIELDS = ("recon_index", "reconstructed_index", "doc_index", "index", "id")


def build_filemap(stats):
    """Address map from sampling_1_stats.pk:

        {"sampling_id": <str|None>,
         "by_key": {recon_key: {"file_name": ..., "sample_index": <pos in samples>}}}

    Handles `samples` as a list (positional, unless an element carries a link
    field like 'recon_index') or a dict keyed by index. Empty map if unreadable.
    """
    out = {"sampling_id": None, "by_key": {}}
    if not isinstance(stats, dict):
        return out
    out["sampling_id"] = stats.get("sampling_id")
    samples = stats.get("samples")

    def _fn(s):
        if isinstance(s, dict):
            return s.get("file_name") or s.get("filename") or s.get("name")
        return s if isinstance(s, str) else None

    if isinstance(samples, list):
        for i, s in enumerate(samples):
            key = i
            if isinstance(s, dict):
                for lf in LINK_FIELDS:
                    if isinstance(s.get(lf), int):
                        key = s[lf]
                        break
            out["by_key"][key] = {"file_name": _fn(s), "sample_index": i}
    elif isinstance(samples, dict):
        for k, s in samples.items():
            try:
                out["by_key"][int(k)] = {"file_name": _fn(s), "sample_index": k}
            except (ValueError, TypeError):
                pass  # filename-keyed manifest; no recon index to map to
    return out


def _records_from_obj(obj, stem, addr=None):
    """Yield per-doc dicts with full addressing back to the source pickles."""
    addr = addr or {"sampling_id": None, "by_key": {}}
    items = obj.items() if isinstance(obj, dict) else enumerate(obj)
    for idx, d in items:
        if not isinstance(d, dict):
            continue
        recon = d.get("reconstructed", d)            # tolerate a flat shape too
        raw_document = (d.get("raw_document")
                        or recon.get("raw_document")
                        or f"doc_{idx}")
        info = addr["by_key"].get(idx, {}) if stem is None else {}
        file_name = (recon.get("file_name") or d.get("file_name")
                     or info.get("file_name"))
        blobs = recon.get("blobs") or []
        chunks = [b for b in blobs if isinstance(b, str) and b.strip()]
        if not chunks:                               # fallback: whole text = 1 chunk
            t = recon.get("text", "")
            chunks = [t] if isinstance(t, str) and t.strip() else []
        key = idx if stem is None else f"{stem}#{idx}"
        yield {
            "key": key,                              # ADDRESS: reconstructed_obj.pk key
            "input_file": stem,                      # ADDRESS: which input pickle (None=INPUT_PATH)
            "sampling_id": addr.get("sampling_id"),  # ADDRESS: sampling_1_stats.pk['sampling_id']
            "sample_index": info.get("sample_index"),# ADDRESS: index into stats['samples']
            "file_name": file_name,                  # ADDRESS: the PDF
            "raw_document": raw_document,
            "category": recon.get("document", ""),
            "pages": recon.get("pages"),
            "n_blobs": len(blobs),
            "n_sections": len(recon.get("sections") or []),
            "chunks": chunks,
        }


def _match_only(label, only, key=None):
    """Tolerant match of a document against ONLY_DOC.

    Matches case-insensitively / trimmed on: the filename stem, the full label,
    '<only>.pdf', `only` appearing as a whole token inside the label, OR the
    pickle key itself (so ONLY_DOC can be an index like 101 or "101").
    Whole-token matching keeps 'sample_101' from also catching 'sample_1011'.
    """
    if not only:
        return True
    import re as _re
    o = str(only).strip().casefold()
    lab = str(label).strip().casefold()
    stem = os.path.splitext(os.path.basename(lab))[0]
    if o == stem or o == lab or f"{o}.pdf" == lab:
        return True
    if _re.search(rf"(?:^|[^0-9a-z]){_re.escape(o)}(?:[^0-9a-z]|$)", lab):
        return True
    if key is not None and o == str(key).strip().casefold():
        return True
    return False


def _doc_matches(d, only):
    """Match a doc record against ONLY_DOC by file_name OR raw_document OR key."""
    if not only:
        return True
    return (_match_only(d.get("file_name") or "", only, d["key"])
            or _match_only(d.get("raw_document") or "", only, d["key"]))


def list_docs(path=None, n=None):
    """Print key + file_name + raw_document + pages + chunks for every doc."""
    docs = load_documents(path)
    print(f"{len(docs)} documents")
    print(f"{'KEY':>6}  {'file_name':18}  {'raw_document':28}  {'pages':>5}  chunks")
    print("-" * 74)
    for i, d in enumerate(docs):
        if n and i >= n:
            print(f"   ... ({len(docs) - n} more)")
            break
        print(f"{str(d['key']):>6}  {str(d.get('file_name')):18.18}  "
              f"{str(d['raw_document']):28.28}  {str(d.get('pages')):>5}  {len(d['chunks'])}")


def validate_docs(path=None, stats_path=None, sample=20):
    """Audit PDF identity / pages / chunks across all docs WITHOUT opening any
    PDF. Prints a per-doc manifest sample, aggregate totals, and flags so you
    can confirm everything is present before extracting."""
    docs = load_documents(path, stats_path)
    n = len(docs)
    no_chunks = [d for d in docs if not d["chunks"]]
    no_pages  = [d for d in docs if not isinstance(d.get("pages"), int)]
    no_name   = [d for d in docs if not d.get("file_name")]
    mism      = [d for d in docs if d["n_sections"] and d["n_blobs"]
                 and d["n_sections"] != d["n_blobs"]]
    total_chunks = sum(len(d["chunks"]) for d in docs)
    total_pages  = sum(d["pages"] for d in docs if isinstance(d.get("pages"), int))

    print(f"VALIDATION  ({n} documents)")
    print("=" * 78)
    print(f"{'KEY':>6}  {'file_name':18}  {'pages':>5}  {'chunks':>6}  {'sects':>5}  flags")
    print("-" * 78)
    for d in docs[:sample]:
        flags = []
        if not d["chunks"]:
            flags.append("NO-CHUNKS")
        if not isinstance(d.get("pages"), int):
            flags.append("NO-PAGES")
        if not d.get("file_name"):
            flags.append("no-name")
        if d["n_sections"] and d["n_blobs"] and d["n_sections"] != d["n_blobs"]:
            flags.append(f"sects!=blobs({d['n_sections']}/{d['n_blobs']})")
        print(f"{str(d['key']):>6}  {str(d.get('file_name')):18.18}  "
              f"{str(d.get('pages')):>5}  {len(d['chunks']):>6}  "
              f"{d['n_sections']:>5}  {','.join(flags)}")
    if n > sample:
        print(f"   ... ({n - sample} more)")

    print("-" * 78)
    print(f"total chunks       : {total_chunks}")
    print(f"total pages        : {total_pages}")
    print(f"docs w/ 0 chunks   : {len(no_chunks)}  {[d['key'] for d in no_chunks][:15]}")
    print(f"docs w/o pages     : {len(no_pages)}  {[d['key'] for d in no_pages][:15]}")
    print(f"docs w/o file_name : {len(no_name)}  {[d['key'] for d in no_name][:15]}")
    print(f"sections!=blobs    : {len(mism)}  {[d['key'] for d in mism][:15]}")
    print(f"\nready to extract (>=1 chunk): {n - len(no_chunks)}/{n}")
    return docs


def load_documents(path=None, stats_path=None):
    """Return a list of per-doc dicts. Reads INPUT_PATH (file or dir) and, when
    available, STATS_PATH for the filename manifest. No PDFs are opened."""
    path = path or INPUT_PATH
    stats_path = stats_path if stats_path is not None else STATS_PATH

    addr = {"sampling_id": None, "by_key": {}}
    if stats_path and os.path.exists(stats_path):
        try:
            with open(stats_path, "rb") as f:
                addr = build_filemap(pickle.load(f))
        except Exception as e:
            print(f"[warn] could not read {stats_path}: {e}")

    if os.path.isdir(path):
        files = sorted(glob.glob(os.path.join(path, "*.pk")) +
                       glob.glob(os.path.join(path, "*.pkl")))
        if not files:
            raise FileNotFoundError(f"no .pk/.pkl files in {path}")
        out = []
        for fp in files:
            st = os.path.splitext(os.path.basename(fp))[0]
            with open(fp, "rb") as f:
                out.extend(_records_from_obj(pickle.load(f), st, addr))
        return out
    with open(path, "rb") as f:
        return list(_records_from_obj(pickle.load(f), None, addr))


# ============================================================================
# OUTPUT  -- atomic save so a crash mid-write can't corrupt the pkl
# ============================================================================
def _save(obj, path):
    tmp = f"{path}.tmp"
    with open(tmp, "wb") as f:
        pickle.dump(obj, f, protocol=pickle.HIGHEST_PROTOCOL)
    os.replace(tmp, path)


def _hms(secs):
    secs = int(secs)
    h, r = divmod(secs, 3600)
    m, s = divmod(r, 60)
    return f"{h}h{m:02d}m{s:02d}s" if h else f"{m}m{s:02d}s"


def estimate(avg_chunk_secs, path=None, workers=None):
    """Project full-run time from a measured average per-chunk latency.

    Counts every chunk across all docs, then projects wall time at several
    concurrency levels. 'ideal' assumes the API serves `workers` calls fully in
    parallel; real time lands between sequential and ideal -- closer to ideal if
    the API parallelizes, higher if it rate-limits or serializes.
    """
    workers = workers or MAX_WORKERS
    docs = load_documents(path)
    counts = sorted(len(d["chunks"]) for d in docs)
    nd, total = len(docs), sum(counts)
    print("\n" + "=" * 60)
    print(f"PROJECTION  ({nd} docs)")
    print("=" * 60)
    print(f"chunks: total={total}  avg/doc={total / nd:.1f}  "
          f"min={counts[0]}  median={int(statistics.median(counts))}  max={counts[-1]}")
    print(f"measured avg chunk latency: {avg_chunk_secs:.1f}s")
    print(f"sequential (1 call at a time): ~{_hms(total * avg_chunk_secs)}")
    print("at N concurrent calls (ideal):")
    for w in sorted({2, 4, 8, 16, workers}):
        mark = "   <- current MAX_WORKERS" if w == workers else ""
        print(f"   workers={w:>2}: ~{_hms(total / w * avg_chunk_secs)}{mark}")
    print("(real time lands between sequential and ideal, depending on the API.)")


# ============================================================================
# MAIN
# ============================================================================
def main():
    if not API_URL.strip():
        raise SystemExit("Set API_URL to the new extraction endpoint first.")

    tokens = TokenManager(GCLOUD_LOC)
    tokens.headers(force=True)                       # fail fast on auth/config

    all_docs = load_documents(INPUT_PATH)
    print(f"Loaded {len(all_docs)} documents from {INPUT_PATH}")

    docs = all_docs
    if ONLY_DOC:
        docs = [d for d in all_docs if _doc_matches(d, ONLY_DOC)]
        if not docs:
            print(f"\nNo document matched ONLY_DOC={ONLY_DOC!r}. "
                  f"Available (key, file_name, raw_document):")
            for d in all_docs[:60]:
                print(f"   key={str(d['key']):>8}  {str(d.get('file_name')):18.18}  "
                      f"{d['raw_document']}")
            print("\nSet ONLY_DOC to a file_name, a key, or None for all.")
            raise SystemExit(1)
        print(f"ONLY_DOC={ONLY_DOC!r} -> {len(docs)} doc(s): "
              f"{[(d['key'], d.get('file_name') or d['raw_document']) for d in docs]}")

    results = {}
    if os.path.exists(OUTPUT_PATH):                  # resume
        with open(OUTPUT_PATH, "rb") as f:
            results = pickle.load(f)
        print(f"Resuming: {len(results)} documents already done in {OUTPUT_PATH}")

    for n, d in enumerate(docs, 1):
        key = d["key"]
        chunks = d["chunks"]
        if results.get(key, {}).get("complete"):
            print(f"[{n}/{len(docs)}] skip {key} (done)")
            continue

        name = d.get("file_name") or d["raw_document"]
        stem = os.path.splitext(os.path.basename(str(name)))[0]
        doc_id = f"doc_{key}_{stem.replace(' ', '_')}"
        print(f"[{n}/{len(docs)}] {doc_id}: {len(chunks)} chunks, pages={d.get('pages')}")

        base = {
            "doc_id": doc_id,
            # ---- ADDRESS (join keys back to source pickles / PDFs) ----
            "key": key,                       # reconstructed_obj.pk key
            "input_file": d.get("input_file"),# which input pickle (None=INPUT_PATH)
            "sampling_id": d.get("sampling_id"),  # sampling_1_stats.pk['sampling_id']
            "sample_index": d.get("sample_index"),# index into stats['samples']
            "file_name": d.get("file_name"),  # the PDF
            # ---- metadata ----
            "raw_document": d["raw_document"],
            "category": d["category"],
            "pages": d.get("pages"),
            "n_blobs": d["n_blobs"],
            "n_sections": d["n_sections"],
            "n_chunks": len(chunks),
        }

        if not chunks:
            results[key] = {**base, "chunks": [], "extracted_cuis": [], "complete": True}
            if n % CHECKPOINT_EVERY == 0:
                _save(results, OUTPUT_PATH)
            continue

        chunk_records = [None] * len(chunks)
        chunk_secs = []
        ext_ms, match_ms = [], []
        doc_t0 = time.perf_counter()
        with ThreadPoolExecutor(max_workers=MAX_WORKERS) as ex:
            futs = {ex.submit(extract_chunk, tokens, ch): i
                    for i, ch in enumerate(chunks)}
            for fut in as_completed(futs):
                i = futs[fut]
                concepts, err, secs, server_ms = fut.result()
                chunk_secs.append(secs)
                if isinstance(server_ms.get("extraction_ms"), (int, float)):
                    ext_ms.append(server_ms["extraction_ms"])
                if isinstance(server_ms.get("matching_ms"), (int, float)):
                    match_ms.append(server_ms["matching_ms"])
                chunk_records[i] = {
                    "i": i,
                    "blob_index": i,                 # ADDRESS: blobs[i] in reconstructed_obj.pk[key]
                    "preview": chunks[i][:80].replace("\n", " "),
                    "cuis": list(concepts.keys()),   # <-- just the concept list
                    "error": err,
                    "secs": round(secs, 3),
                    "server_ms": server_ms,
                }
                tag = f"ERROR: {err}" if err else f"{len(concepts)} concepts"
                print(f"    [chunk {i:>2}] {tag}  ({secs:.1f}s)")
        doc_wall = time.perf_counter() - doc_t0
        cavg = sum(chunk_secs) / len(chunk_secs)
        split = ""
        if ext_ms and match_ms:
            split = (f"  [server avg: extract={sum(ext_ms)/len(ext_ms)/1000:.1f}s "
                     f"match={sum(match_ms)/len(match_ms)/1000:.1f}s]")
        print(f"    doc wall={doc_wall:.1f}s  chunks={len(chunks)}  "
              f"per-chunk avg={cavg:.1f}s "
              f"med={statistics.median(chunk_secs):.1f}s "
              f"min={min(chunk_secs):.1f}s max={max(chunk_secs):.1f}s{split}")

        # order-preserving union of CUIs across chunks
        union, seen = [], set()
        for rec in chunk_records:
            for c in rec["cuis"]:
                if c not in seen:
                    seen.add(c)
                    union.append(c)

        results[key] = {**base, "chunks": chunk_records,
                        "extracted_cuis": union,
                        "doc_secs": round(doc_wall, 2),
                        "per_chunk_avg_secs": round(cavg, 2),
                        "complete": True}

        if n % CHECKPOINT_EVERY == 0:
            _save(results, OUTPUT_PATH)

    _save(results, OUTPUT_PATH)

    total_chunks = sum(r["n_chunks"] for r in results.values())
    cui_sum = sum(len(r["extracted_cuis"]) for r in results.values())
    errs = sum(1 for r in results.values() for c in r["chunks"] if c.get("error"))
    print(f"\nDONE. docs={len(results)}  chunks={total_chunks}  "
          f"sum(unique CUIs per doc)={cui_sum}  chunk-errors={errs}")
    print(f"Saved -> {OUTPUT_PATH}")

    if ONLY_DOC:                                  # show the tested doc + project
        for d in docs:
            print()
            inspect(d["key"], OUTPUT_PATH)
        measured = [results[d["key"]]["per_chunk_avg_secs"]
                    for d in docs
                    if results.get(d["key"], {}).get("per_chunk_avg_secs")]
        if measured:
            estimate(sum(measured) / len(measured))


def peek(path=OUTPUT_PATH, n=3):
    """Quick sanity check of the output pkl."""
    with open(path, "rb") as f:
        r = pickle.load(f)
    print(f"{len(r)} documents in {path}")
    for k in list(r.keys())[:n]:
        d = r[k]
        print(f"\n[{k}] {d['doc_id']}  chunks={d['n_chunks']}  "
              f"union_cuis={len(d['extracted_cuis'])}")
        for c in d["chunks"][:3]:
            tag = f"ERR {c['error']}" if c.get("error") else f"{len(c['cuis'])} cuis"
            print(f"   chunk {c['i']:>2}: {tag:<10} {c['preview']!r}")


def inspect(key=None, path=OUTPUT_PATH, max_chunks=None, sample_concept=True):
    """Detailed view of ONE document's extraction -- use to judge the test run."""
    with open(path, "rb") as f:
        r = pickle.load(f)
    if key is None:
        key = next(iter(r))
    d = r[key]
    print("=" * 70)
    print(f"{d['doc_id']}")
    print(f"ADDRESS: key={d.get('key')}  file_name={d.get('file_name')}  "
          f"sampling_id={d.get('sampling_id')}  sample_index={d.get('sample_index')}"
          f"  input_file={d.get('input_file')}")
    print(f"pages={d.get('pages')}  chunks={d['n_chunks']}  "
          f"union_cuis={len(d['extracted_cuis'])}  doc_secs={d.get('doc_secs')}")
    print("=" * 70)
    chunks = d["chunks"] if max_chunks is None else d["chunks"][:max_chunks]
    for c in chunks:
        if c.get("error"):
            print(f"[chunk {c['i']:>2}] ERROR: {c['error']}")
            continue
        sm = c.get("server_ms", {}) or {}
        extra = ""
        if isinstance(sm.get("matching_ms"), (int, float)):
            extra = f"  (match {sm['matching_ms']/1000:.0f}s)"
        print(f"[chunk {c['i']:>2}] {len(c['cuis'])} cuis  {c['secs']}s{extra}  "
              f"{c['preview']!r}")
        if c["cuis"]:
            print(f"            {c['cuis']}")
    print(f"\nUNION ({len(d['extracted_cuis'])}): {d['extracted_cuis']}")


if __name__ == "__main__":
    main()

query = "Do you have constipation or diarrhea?"

doc_texts = {
    "doc1": "Patient presents with chronic constipation and abdominal pain.",
    "doc2": "History of pneumonia and respiratory infection.",
    "doc3": "Screening for colon cancer and rectal cancer.",
}

# ---- run ----
q_topics, _ = text_to_topics(query, "QUERY")
doc_index = {did: text_to_topics(t, f"DOC {did}")[0] for did, t in doc_texts.items()}
report_matches(q_topics, doc_index)

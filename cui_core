_timings = defaultdict(lambda: deque(maxlen=_TIMING_MAX_PER_KEY))
_timing_lock = threading.Lock()

def timed(name):
    def dec(fn):
        @functools.wraps(fn)
        def wrapper(*a, **kw):
            t0 = time.perf_counter()
            try:
                return fn(*a, **kw)
            finally:
                with _timing_lock:
                    _timings[name].append((time.perf_counter() - t0) * 1000)
        return wrapper
    return dec

def _otsu_threshold(values):
    """Find threshold that maximizes between-class variance (Otsu's method). O(N)."""
    arr = np.sort(values)
    n = len(arr)
    if n < 2:
        return float(arr[0]) if n == 1 else 0.0
    cumsum = np.cumsum(arr)
    total_sum = cumsum[-1]
    best_t, best_var = float(arr[0]), -1.0
    for i in range(1, n):
        if arr[i] == arr[i - 1]:
            continue
        w0 = i / n
        w1 = 1.0 - w0
        m0 = cumsum[i - 1] / i
        m1 = (total_sum - cumsum[i - 1]) / (n - i)
        var = w0 * w1 * (m0 - m1) ** 2
        if var > best_var:
            best_var = var
            best_t = float(arr[i])
    return best_t

_ancestor_cache = OrderedDict()
_ancestor_cache_lock = threading.Lock()

def _get_ancestors(graph, cui, depth):
    """Collect all ancestors up to `depth` hops. LRU cached. Thread-safe."""
    key = (cui, depth)
    with _ancestor_cache_lock:
        if key in _ancestor_cache:
            _ancestor_cache.move_to_end(key)
            return _ancestor_cache[key]

    if graph is None or not graph.has_node(cui):
        result = frozenset()
        with _ancestor_cache_lock:
            _ancestor_cache[key] = result
        return result

    ancestors = set()
    frontier = {cui}
    for _ in range(depth):
        next_frontier = set()
        for node in frontier:
            for parent in graph.predecessors(node):
                if parent not in ancestors:
                    ancestors.add(parent)
                    next_frontier.add(parent)
        frontier = next_frontier
        if not frontier:
            break

    result = frozenset(ancestors)
    with _ancestor_cache_lock:
        _ancestor_cache[key] = result
        # batch eviction: trim to 90% of max to avoid per-insert overhead at capacity
        if len(_ancestor_cache) > _ANCESTOR_CACHE_MAX:
            trim_to = int(_ANCESTOR_CACHE_MAX * 0.9)
            excess = len(_ancestor_cache) - trim_to
            for _ in range(excess):
                _ancestor_cache.popitem(last=False)
    return result

def _clear_ancestor_cache():
    """Call at start of each pipeline run. Thread-safe."""
    with _ancestor_cache_lock:
        _ancestor_cache.clear()

def _graph_mean_in(graph):
    """Return (mean_in_degree, log_mean_in, n_nodes) or None if graph too small."""
    try:
        if graph is None or graph.number_of_nodes() == 0:
            return None
        degs = [d for _, d in graph.in_degree()]
        if not degs:
            return None
        mean_in = float(np.mean(degs))
        if not np.isfinite(mean_in) or mean_in <= 1.0:
            return None
        log_mean = float(np.log(mean_in))
        if not np.isfinite(log_mean) or log_mean < 1e-9:
            return None
        return mean_in, log_mean, graph.number_of_nodes()
    except Exception:
        return None

def _compute_ancestor_depth(graph):
    """Derive ancestor lookup depth from graph density. Target ~20 ancestors, clamped [1,5]."""
    stats = _graph_mean_in(graph)
    if stats is None:
        return _DEFAULT_ANCESTOR_DEPTH
    _, log_mean, _ = stats
    return max(_ANCESTOR_DEPTH_CLAMP[0],
               min(int(round(np.log(_ANCESTOR_TARGET) / log_mean)), _ANCESTOR_DEPTH_CLAMP[1]))

def _compute_component_depth(graph, ancestor_depth):
    """Derive component separation depth: ~40% of ancestor_depth, bounded by graph density."""
    stats = _graph_mean_in(graph)
    if stats is None or stats[0] <= _COMP_DEPTH_MEAN_THRESHOLD:
        return 1
    _, log_mean, n_nodes = stats
    derived = max(1, int(round(ancestor_depth * _COMPONENT_DEPTH_RATIO)))
    max_for_nodes = max(1, int(np.log(max(np.sqrt(n_nodes), 1)) / log_mean))
    return max(1, min(derived, max_for_nodes, ancestor_depth))

def _are_cuis_different(ci, cj, metadata, hierarchy_edges, graph, ancestor_depth):
    """Return True if two CUIs are meaningfully different (structural guards, cheapest first).

    Guards are evaluated in order and short-circuit on the first True.
    Order: O(1) set lookups first, expensive BFS last.
    """
    # Guard 1: direct hierarchy edge (O(1) set lookup) — cheapest
    if hierarchy_edges and ((ci, cj) in hierarchy_edges or (cj, ci) in hierarchy_edges):
        return True

    # Guard 2: semantic type disjoint (O(|types|) set intersection)
    ci_m, cj_m = metadata.get(ci), metadata.get(cj)
    ci_types = set(ci_m.semantic_types) if ci_m and ci_m.semantic_types else set()
    cj_types = set(cj_m.semantic_types) if cj_m and cj_m.semantic_types else set()
    if ci_types and cj_types and not (ci_types & cj_types):
        return True

    # Guards 3+4: BFS ancestor checks — most expensive, run last
    if graph is not None:
        ci_anc = _get_ancestors(graph, ci, ancestor_depth)
        cj_anc = _get_ancestors(graph, cj, ancestor_depth)
        # Guard 3: disjoint ancestor sets → different branches
        if ci_anc and cj_anc and len(ci_anc & cj_anc) == 0:
            return True
        # Guard 4: both leaf nodes sharing a parent → siblings, keep both
        ci_par = set(graph.predecessors(ci)) if graph.has_node(ci) else set()
        cj_par = set(graph.predecessors(cj)) if graph.has_node(cj) else set()
        if ci_par and cj_par and (ci_par & cj_par):
            ci_leaf = graph.out_degree(ci) == 0 if graph.has_node(ci) else False
            cj_leaf = graph.out_degree(cj) == 0 if graph.has_node(cj) else False
            if ci_leaf and cj_leaf:
                return True
    return False

def _union_find(n):
    """Return (find, union) closures over n elements."""
    parent, rank = list(range(n)), [0] * n
    def find(x):
        while parent[x] != x:
            parent[x] = parent[parent[x]]; x = parent[x]
        return x
    def union(x, y):
        rx, ry = find(x), find(y)
        if rx == ry: return
        if rank[rx] < rank[ry]: rx, ry = ry, rx
        parent[ry] = rx
        if rank[rx] == rank[ry]: rank[rx] += 1
    return find, union



import os
import math
import collections
import pandas as pd
import networkx as nx
from google.cloud import bigquery

# =====================================================================
# GCP CONFIGURATION
# =====================================================================
PROJECT_ID = "your-project-id"       # <-- Replace with your GCP Project
DATASET_ID = "your_dataset_name"     # <-- Replace with your BQ Dataset

# Initialize the BigQuery Client
bq_client = bigquery.Client(project=PROJECT_ID)

# =====================================================================
# CLINICAL DUAL-LAYER TOPIC ENGINE
# =====================================================================
class GCPClinicalTopicEngine:
    def __init__(self, ic_lower_bound=1.0, ic_upper_bound=3.0):
        self.ic_min = ic_lower_bound
        self.ic_max = ic_upper_bound
        self.backbone_graph = nx.DiGraph()
        self.lateral_bridge_map = collections.defaultdict(list)
        self.ic_scores = {}
        self.cui_to_topic_map = {}
        self.cui_to_name = {}

    def build_dual_layer_graphs(self, mrrel_df, mrconso_df):
        print("-> Processing UMLS Dataframes into Graph Architecture...")
        
        # Populate Preferred Names map
        self.cui_to_name = dict(zip(mrconso_df['CUI'], mrconso_df['STR']))
            
        # Isolate SNOMED CT entries
        snomed_df = mrrel_df[mrrel_df['SAB'] == 'SNOMEDCT_US']

        # Layer 1: Backbone (Strict Taxonomic 'is_a' paths)
        layer1_df = snomed_df[(snomed_df['REL'] == 'PAR') & (snomed_df['RELA'] == 'is_a')]
        edges = list(zip(layer1_df['CUI1'], layer1_df['CUI2']))
        self.backbone_graph.add_edges_from(edges)

        # Layer 2: Lateral Bridges (Associative links)
        lateral_rela_targets = {'causative_agent_of', 'due_to', 'has_finding_site', 'has_manifestation'}
        layer2_df = snomed_df[snomed_df['RELA'].isin(lateral_rela_targets)]
        
        for _, row in layer2_df.iterrows():
            cui_source, cui_target = row['CUI1'], row['CUI2']
            self.lateral_bridge_map[cui_source].append(cui_target)
            self.lateral_bridge_map[cui_target].append(cui_source)

    def calculate_corpus_ic(self, corpus_cuis_list):
        print("-> Calculating Corpus Information Content (IC)...")
        raw_counts = collections.Counter()
        for doc in corpus_cuis_list:
            raw_counts.update(doc)
            
        total_concepts = sum(raw_counts.values())
        if total_concepts == 0:
            raise ValueError("Extraction corpus is empty.")

        rev_backbone = self.backbone_graph.reverse()
        for node in self.backbone_graph.nodes():
            descendants = nx.descendants(rev_backbone, node) | {node}
            sub_tree_weight = sum(raw_counts[desc_cui] for desc_cui in descendants)
            
            if sub_tree_weight == 0:
                self.ic_scores[node] = float('inf')
            else:
                self.ic_scores[node] = -math.log(sub_tree_weight / total_concepts)

    def _trace_backbone_to_topic(self, cui, visited=None):
        if visited is None: visited = set()
        if cui in visited: return None
        visited.add(cui)

        cui_ic = self.ic_scores.get(cui, float('inf'))
        if self.ic_min <= cui_ic <= self.ic_max:
            return cui
        if cui_ic < self.ic_min:
            return None 

        parents = list(self.backbone_graph.successors(cui))
        if not parents: return cui

        for parent in parents:
            topic = self._trace_backbone_to_topic(parent, visited)
            if topic: return topic
        return cui

    def precompute_static_topic_maps(self):
        print("-> Generating Static Mapping Array...")
        for cui in self.backbone_graph.nodes():
            assigned_topic = self._trace_backbone_to_topic(cui)
            self.cui_to_topic_map[cui] = assigned_topic if assigned_topic else cui

    def export_mapping_to_dataframe(self):
        """Converts internal dictionary maps to a structured Pandas Dataframe for BQ Storage"""
        records = []
        for source_cui, topic_cui in self.cui_to_topic_map.items():
            records.append({
                "source_cui": source_cui,
                "source_name": self.cui_to_name.get(source_cui, "Unknown"),
                "topic_cui": topic_cui,
                "topic_name": self.cui_to_name.get(topic_cui, "Unknown")
            })
        return pd.DataFrame(records)

# =====================================================================
# RUNTIME PIPELINE EXECUTION
# =====================================================================

# Step 1: Pull UMLS tables directly from BigQuery into Notebook Memory
print("Pulling UMLS source structures from BigQuery...")
query_mrrel = f"SELECT CUI1, CUI2, REL, RELA, SAB FROM `{PROJECT_ID}.{DATASET_ID}.mrrel`"
query_mrconso = f"SELECT CUI, STR FROM `{PROJECT_ID}.{DATASET_ID}.mrconso` WHERE LAT = 'ENG' AND ISPREF = 'Y'"

mrrel_df = bq_client.query(query_mrrel).to_dataframe()
mrconso_df = bq_client.query(query_mrconso).to_dataframe()

# Step 2: Fetch your Clinical Corpus (e.g., extracted patient clinical note CUIs)
# Replace this query with your actual clinical token/patient document matrix table
query_corpus = f"SELECT mapped_cuis_array FROM `{PROJECT_ID}.{DATASET_ID}.patient_extracted_features`"
# For this example script, we simulate a small corpus read if your table isn't built yet:
corpus_sample = [["C0026639"], ["C0026639"], ["C0013221"], ["C0030843"]] 

# Step 3: Run Engine Processing Logic
engine = GCPClinicalTopicEngine(ic_lower_bound=0.5, ic_upper_bound=2.0)
engine.build_dual_layer_graphs(mrrel_df, mrconso_df)
engine.calculate_corpus_ic(corpus_sample) # Swap with database corpus list if ready
engine.precompute_static_topic_maps()

# Step 4: Export Computed Dataframe back to BigQuery
output_df = engine.export_mapping_to_dataframe()

table_ref = f"{PROJECT_ID}.{DATASET_ID}.static_cui_to_topic_map"
job_config = bigquery.LoadJobConfig(
    write_disposition="WRITE_TRUNCATE" # Overwrites table completely with fresh topics
)

print(f"Writing static topic mapping table directly to: {table_ref}...")
job = bq_client.load_table_from_dataframe(output_df, table_ref, job_config=job_config)
job.result() # Blocks thread execution until load job completes successfully
print("Pipeline complete. BigQuery table optimized and active.")

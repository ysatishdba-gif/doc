"""
build_topics.py
---------------
Build a CUI -> topics pickle from UMLS data.

On first run, fetches UMLS data from BigQuery into a local cache file
(umls_cache.pkl). On subsequent runs, uses the cache and skips BigQuery
entirely.

To force re-fetch: delete umls_cache.pkl and run again.

The cache is automatically invalidated and re-fetched if you change any
of these config values:
    PROJECT, DATASET, SAB, LANGUAGE

To iterate on anchoring policy (STRICT_SLOTS, TRAVERSAL_RELS, etc.) just
run again — the cache is reused.

Usage:
    pip install google-cloud-bigquery
    gcloud auth application-default login
    python build_topics.py
"""

import datetime
import os
import pickle
import time
from collections import defaultdict


# ============================================================================
# CONFIG — edit these
# ============================================================================

PROJECT = "YOUR_GCP_PROJECT"        # <-- REPLACE
DATASET = "YOUR_UMLS_DATASET"       # <-- REPLACE

CACHE_PATH = "umls_cache.pkl"
OUTPUT_PATH = "topics.pkl"

# Table names. Change only if your tables are named differently.
TABLE_MRCONSO = "MRCONSO"
TABLE_MRREL   = "MRREL"
TABLE_MRSTY   = "MRSTY"

# Source vocabulary and language filters.
SAB      = "SNOMEDCT_US"
LANGUAGE = "ENG"

# Attribute types where ANY value change at the parent breaks the match.
# Other attributes only break when missing entirely.
STRICT_SLOTS = {"has_finding_site", "has_laterality"}

# Which UMLS relationship types to use for walking UP the hierarchy.
# Each entry is (REL, RELA) — RELA can be None to match any RELA value.
#
# The cache fetches broadly; changing this list does NOT require a
# re-fetch. Just rebuild from the existing cache.
#
# Available choices:
#   ("CHD", "isa")   SNOMED IS-A backbone
#   ("RB",  None)    Related Broader (curator-asserted, non-IS-A)
#   ("SY",  None)    Synonymous atoms (rarely useful at CUI level)
#
# NOT useful for traversal:
#   PAR/inverse_isa, RN, SIB, RQ, RO with non-isa RELA
TRAVERSAL_RELS = [
    ("CHD", "isa"),
    # NOTE: Earlier experiments with RB enabled showed that the RB rows
    # in this dataset are dominated by inverse_was_a (historical concept
    # retirements), referred_to_by (citation links), and alternative_of
    # (administrative). These are noise, not clinical broader-than edges.
    # Re-enabling RB caused massive over-grouping into metadata concepts.
    # If you want to experiment with re-enabling, do it cautiously and
    # be prepared to see anchors land on retirement/metadata concepts.
]

# For testing: only anchor first N CUIs. Set to None for the full build.
MAX_CONCEPTS = None

# Safety cap on multi-parent path explosion.
MAX_NODES_PER_TRAVERSAL = 5000


# ============================================================================
# Step 1: Cache management — auto-detect or fetch from BigQuery
# ============================================================================

def get_or_fetch_cache():
    """
    Auto-detect: load existing cache if compatible with current config,
    else fetch fresh from BigQuery.

    Compatibility check ensures we don't silently use a cache that was
    built for a different project/dataset/SAB/language.
    """
    current_config = {
        "project":  PROJECT,
        "dataset":  DATASET,
        "sab":      SAB,
        "language": LANGUAGE,
    }

    if os.path.exists(CACHE_PATH):
        print(f"Found existing cache: {CACHE_PATH}")
        t0 = time.time()
        with open(CACHE_PATH, "rb") as f:
            cache = pickle.load(f)
        print(f"  loaded in {time.time()-t0:.1f}s")

        cached_config = cache.get("config", {})
        if cached_config != current_config:
            print(f"\n  WARNING: cache config differs from current config:")
            for key in current_config:
                if cached_config.get(key) != current_config[key]:
                    print(f"    {key}: cache={cached_config.get(key)!r}  "
                          f"current={current_config[key]!r}")
            print(f"  Re-fetching from BigQuery ...\n")
        else:
            print(f"  fetched_at  : {cache['fetched_at']}")
            print(f"  cuis        : {len(cache['cuis']):,}")
            print(f"  mrrel_rows  : {len(cache['mrrel_rows']):,}")
            print(f"  config OK — using cached data")
            return cache

    print(f"\nFetching UMLS data from BigQuery ...")
    cache = fetch_from_bigquery(current_config)
    print(f"\nSaving cache to {CACHE_PATH} ...")
    t0 = time.time()
    with open(CACHE_PATH, "wb") as f:
        pickle.dump(cache, f, protocol=pickle.HIGHEST_PROTOCOL)
    size_mb = os.path.getsize(CACHE_PATH) / (1024 * 1024)
    print(f"  wrote {size_mb:.1f} MB in {time.time()-t0:.1f}s")
    return cache


def fetch_from_bigquery(config):
    """
    Pull everything we need from BigQuery in one go, return as a dict.

    We fetch broadly — every REL type that could plausibly be used for
    traversal — so that future tweaks to TRAVERSAL_RELS don't require
    re-fetching.
    """
    # Import here so the rest of the script doesn't require the BQ
    # library installed when running off a cache.
    from google.cloud import bigquery

    if config["project"] == "YOUR_GCP_PROJECT" or config["dataset"] == "YOUR_UMLS_DATASET":
        print("ERROR: edit PROJECT and DATASET in the CONFIG block")
        raise SystemExit(1)

    client = bigquery.Client(project=config["project"])
    sab = config["sab"]
    lat = config["language"]

    # ---- 1. Active CUIs ----
    print("  [1/4] Loading SNOMED CUIs from MRCONSO ...")
    t0 = time.time()
    sql = f"""
    SELECT DISTINCT CUI
    FROM `{config['project']}.{config['dataset']}.{TABLE_MRCONSO}`
    WHERE SAB = @sab AND LAT = @lat
      AND SUPPRESS NOT IN ('O', 'Y')
    """
    job_config = bigquery.QueryJobConfig(query_parameters=[
        bigquery.ScalarQueryParameter("sab", "STRING", sab),
        bigquery.ScalarQueryParameter("lat", "STRING", lat),
    ])
    cuis = {row.CUI for row in client.query(sql, job_config=job_config).result()}
    print(f"        {len(cuis):,} CUIs in {time.time()-t0:.1f}s")

    # ---- 2. MRREL rows (broad fetch) ----
    print("  [2/4] Loading MRREL rows (broad — all REL types we might use) ...")
    t0 = time.time()
    sql = f"""
    SELECT CUI1, CUI2, REL, RELA
    FROM `{config['project']}.{config['dataset']}.{TABLE_MRREL}`
    WHERE SAB = @sab
      AND SUPPRESS NOT IN ('O', 'Y')
      AND CUI1 != CUI2
      AND (
            (REL = 'CHD' AND RELA = 'isa')
         OR (REL = 'PAR' AND RELA = 'inverse_isa')
         OR (REL = 'RB')
         OR (REL = 'RN')
         OR (REL = 'SY')
         OR (REL = 'SIB')
         OR (REL = 'RO' AND RELA IS NOT NULL
                         AND RELA != 'isa'
                         AND NOT STARTS_WITH(RELA, 'inverse_'))
      )
    """
    job_config = bigquery.QueryJobConfig(query_parameters=[
        bigquery.ScalarQueryParameter("sab", "STRING", sab),
    ])
    mrrel_rows = []
    for row in client.query(sql, job_config=job_config).result():
        if row.CUI1 in cuis and row.CUI2 in cuis:
            mrrel_rows.append((row.CUI1, row.CUI2, row.REL, row.RELA))
    print(f"        {len(mrrel_rows):,} rows in {time.time()-t0:.1f}s")
    rel_counts = defaultdict(int)
    for _, _, rel, rela in mrrel_rows:
        rel_counts[(rel, rela)] += 1
    print(f"        Row breakdown (top 10):")
    for (rel, rela), n in sorted(rel_counts.items(), key=lambda kv: -kv[1])[:10]:
        print(f"          {rel:6s} {str(rela)[:30]:30s}  {n:>10,d}")

    # ---- 3. Semantic types ----
    print("  [3/4] Loading semantic types from MRSTY ...")
    t0 = time.time()
    sql = f"""
    SELECT CUI, STY
    FROM `{config['project']}.{config['dataset']}.{TABLE_MRSTY}`
    """
    tags = {}
    for row in client.query(sql).result():
        if row.CUI in cuis and row.CUI not in tags:
            tags[row.CUI] = row.STY
    print(f"        {len(tags):,} tags in {time.time()-t0:.1f}s")

    # ---- 4. Preferred labels ----
    print("  [4/4] Loading preferred labels from MRCONSO ...")
    t0 = time.time()
    cui_list = sorted(cuis)
    BATCH = 50000
    labels = {}
    for i in range(0, len(cui_list), BATCH):
        batch = cui_list[i:i + BATCH]
        sql = f"""
        WITH ranked AS (
          SELECT CUI, STR,
            CASE WHEN TS = 'P' AND ISPREF = 'Y' AND SUPPRESS = 'N' THEN 0
                 WHEN SUPPRESS = 'N' THEN 1
                 ELSE 2 END AS rank
          FROM `{config['project']}.{config['dataset']}.{TABLE_MRCONSO}`
          WHERE SAB = @sab AND LAT = @lat
            AND SUPPRESS NOT IN ('O', 'Y')
            AND CUI IN UNNEST(@cuis)
        )
        SELECT CUI, ARRAY_AGG(STR ORDER BY rank LIMIT 1)[OFFSET(0)] AS label
        FROM ranked GROUP BY CUI
        """
        job_config = bigquery.QueryJobConfig(query_parameters=[
            bigquery.ScalarQueryParameter("sab", "STRING", sab),
            bigquery.ScalarQueryParameter("lat", "STRING", lat),
            bigquery.ArrayQueryParameter("cuis", "STRING", batch),
        ])
        for row in client.query(sql, job_config=job_config).result():
            labels[row.CUI] = row.label
    print(f"        {len(labels):,} labels in {time.time()-t0:.1f}s")

    return {
        "fetched_at": datetime.datetime.now().isoformat(),
        "config":     config,
        "cuis":       cuis,
        "mrrel_rows": mrrel_rows,
        "tags":       tags,
        "labels":     labels,
    }


# ============================================================================
# Step 2: Parse MRREL into parents/attrs dicts
# ============================================================================

def parse_mrrel(cache):
    """
    Walk the cached MRREL rows once. Split into:
        parents[child_cui]  = dict { parent_cui : (REL, RELA) }
        attrs[cui]          = dict { rela_name : value_cui }
        edge_counts         = dict { (REL, RELA) : count }

    The parents dict only includes REL types listed in TRAVERSAL_RELS.
    Every other "RO with a named RELA" row becomes a defining attribute.

    Direction: in MRREL the relationship is "from CUI2 to CUI1". For
    hierarchy-style RELs (CHD, RB), CUI1 is the broader/parent concept
    and CUI2 is the narrower/child. So parent edges go: CUI2 -> CUI1.
    """
    traversal_set = set()
    traversal_rel_only = set()
    for rel, rela in TRAVERSAL_RELS:
        if rela is None:
            traversal_rel_only.add(rel)
        else:
            traversal_set.add((rel, rela))

    rel_priority = {}
    for i, (rel, rela) in enumerate(TRAVERSAL_RELS):
        rel_priority[(rel, rela)] = i

    def is_traversal(rel, rela):
        if rel in traversal_rel_only:
            return True
        return (rel, rela) in traversal_set

    def edge_priority(rel, rela):
        if (rel, rela) in rel_priority:
            return rel_priority[(rel, rela)]
        if (rel, None) in rel_priority:
            return rel_priority[(rel, None)]
        return 999

    parents = defaultdict(dict)
    attrs = defaultdict(dict)
    edge_counts = defaultdict(int)

    for cui1, cui2, rel, rela in cache["mrrel_rows"]:
        if is_traversal(rel, rela):
            child, parent = cui2, cui1
            key = (rel, rela)
            edge_counts[key] += 1
            existing = parents[child].get(parent)
            if existing is None or edge_priority(*key) < edge_priority(*existing):
                parents[child][parent] = key
        elif rel == "RO" and rela and not rela.startswith("inverse_") and rela != "isa":
            attrs[cui2].setdefault(rela, cui1)

    return parents, attrs, edge_counts


# ============================================================================
# Step 3: The anchoring algorithm — multi-path
# ============================================================================

def check_break(seed_attrs, parent_attrs):
    """
    Return the name of the first attribute the parent breaks, or None if
    all of the seed's attributes are preserved.

    Strict slots: parent must have the SAME value.
    Other slots:  parent just needs to have the attribute (any value).
    """
    for rela, seed_value in seed_attrs.items():
        if rela in STRICT_SLOTS:
            if parent_attrs.get(rela) != seed_value:
                return rela
        else:
            if rela not in parent_attrs:
                return rela
    return None


def is_transparent_parent(seed_attrs, parent_attrs):
    """
    A parent is "transparent" if it has ZERO defining attributes at all.
    The walk should pass through it without anchoring, since there's nothing
    to compare against and no clinical-content gradient at this node.

    We deliberately do NOT treat "parent has some attributes but none
    overlap with the seed" as transparent. That earlier rule was too
    permissive and let walks wander into unrelated subtrees through nodes
    that happened to share no attribute types with the seed. The current
    rule is stricter: only empty parents pass through.

    Why this matters in practice:
      - 'Wedge pressure technique' (seed has technique_of) -> parent
        'Technique' has zero attributes. Transparent → walk through to
        find a real topic.
      - 'Discharge specimen from penis' (seed has two attrs) -> parent
        'Discharge specimen' has one attr (substance only). NOT
        transparent — it has content, just not all of it. The boundary
        fires here, which is correct: we're looking at a real
        clinical-content gradient.
    """
    return not parent_attrs


def find_anchors(seed_cui, parents, attrs):
    """
    Walk every traversal path upward from seed_cui. Collect all distinct
    anchors. Returns a list of dicts (alphabetical by anchor CUI):

      [{"anchor":      cui,
        "lost":        rela_or_None,
        "path_length": int,
        "rels_used":   sorted list of (REL, RELA) tuples seen on path}, ...]

    Behavior:
      - Walks through "transparent" parents (zero defining attributes) — but
        does NOT anchor on them. The current node is recorded as an anchor
        only when both (a) it has a content boundary with its parents, and
        (b) it itself has at least one defining attribute. Otherwise we
        back up to the most recent non-transparent node on the path.

        This rule prevents the algorithm from walking up to abstract
        organizing concepts at the top of SNOMED's hierarchy (which have
        no attributes and end up swallowing huge numbers of CUIs).
      - A seed that has no defining attributes is allowed to anchor at
        any non-transparent ancestor it can reach.
    """
    seed_attrs = attrs.get(seed_cui, {})

    found_anchors = {}
    visited_total = set()
    # Stack entry: (current_cui, depth, visited_on_path,
    #               rels_used, last_meaningful_ancestor, last_meaningful_depth)
    # last_meaningful_ancestor: the most recent node on this path with
    # at least one defining attribute (used as the fallback anchor when
    # the walk would otherwise terminate at a transparent node).
    seed_is_meaningful = bool(seed_attrs)
    stack = [(
        seed_cui, 1, frozenset([seed_cui]), frozenset(),
        seed_cui if seed_is_meaningful else None,
        1 if seed_is_meaningful else 0,
    )]

    while stack:
        if len(visited_total) > MAX_NODES_PER_TRAVERSAL:
            break

        (current, depth, visited_on_path, rels_used,
         last_meaningful, last_meaningful_depth) = stack.pop()
        visited_total.add(current)

        ps = parents.get(current, {})
        preserving_parents = []   # list of (parent_cui, rel_key)
        any_break_reason = None

        for parent_cui, rel_key in ps.items():
            if parent_cui in visited_on_path:
                continue
            parent_attrs = attrs.get(parent_cui, {})
            if is_transparent_parent(seed_attrs, parent_attrs):
                preserving_parents.append((parent_cui, rel_key))
            else:
                broken = check_break(seed_attrs, parent_attrs)
                if broken is None:
                    preserving_parents.append((parent_cui, rel_key))
                elif any_break_reason is None:
                    any_break_reason = broken

        if not preserving_parents:
            # Terminus reached. The "real" anchor is `current`, but if
            # `current` is itself transparent (no defining attributes),
            # we don't want it as a topic — back up to the last
            # meaningful ancestor we saw on the path.
            current_attrs = attrs.get(current, {})
            if current_attrs:
                anchor_cui = current
                anchor_depth = depth
            elif last_meaningful is not None:
                anchor_cui = last_meaningful
                anchor_depth = last_meaningful_depth
            else:
                # Seed had no attrs and the whole path was transparent.
                # No meaningful anchor exists. Fall back to seed itself.
                anchor_cui = seed_cui
                anchor_depth = 1

            existing = found_anchors.get(anchor_cui)
            if existing is None or anchor_depth > existing["path_length"]:
                found_anchors[anchor_cui] = {
                    "lost": any_break_reason,
                    "path_length": anchor_depth,
                    "rels_used": rels_used,
                }
        else:
            new_visited = visited_on_path | {current}
            for parent_cui, rel_key in preserving_parents:
                parent_attrs = attrs.get(parent_cui, {})
                if parent_attrs:
                    next_last_meaningful = parent_cui
                    next_last_meaningful_depth = depth + 1
                else:
                    next_last_meaningful = last_meaningful
                    next_last_meaningful_depth = last_meaningful_depth
                stack.append((
                    parent_cui,
                    depth + 1,
                    new_visited,
                    rels_used | {rel_key},
                    next_last_meaningful,
                    next_last_meaningful_depth,
                ))

    result = [
        {"anchor": cui,
         "lost": data["lost"],
         "path_length": data["path_length"],
         "rels_used": sorted(list(data["rels_used"]))}
        for cui, data in found_anchors.items()
    ]
    result.sort(key=lambda r: r["anchor"])
    return result


# ============================================================================
# Step 4: Orchestration
# ============================================================================

def main():
    print("=" * 60)
    print("Build CUI -> topics pickle")
    print(f"  project       : {PROJECT}")
    print(f"  dataset       : {DATASET}")
    print(f"  cache         : {CACHE_PATH}")
    print(f"  output        : {OUTPUT_PATH}")
    print(f"  strict slots  : {sorted(STRICT_SLOTS)}")
    print(f"  traversal     : {TRAVERSAL_RELS}")
    print(f"  max_concepts  : {MAX_CONCEPTS if MAX_CONCEPTS else 'all'}")
    print("=" * 60)

    print("\n[1/4] Getting UMLS data (cache or BigQuery) ...")
    cache = get_or_fetch_cache()

    print("\n[2/4] Parsing MRREL into parents and attributes ...")
    t0 = time.time()
    parents, attrs, edge_counts = parse_mrrel(cache)
    n_edges = sum(len(v) for v in parents.values())
    n_attrs = sum(len(v) for v in attrs.values())
    print(f"      {n_edges:,} traversal edges, {n_attrs:,} attributes in "
          f"{time.time()-t0:.1f}s")
    print(f"      Edge breakdown by (REL, RELA):")
    for (rel, rela), n in sorted(edge_counts.items(), key=lambda kv: -kv[1]):
        print(f"        {rel:6s} {str(rela):20s}  {n:>10,d}")

    print("\n[3/4] Finding anchors ...")
    t0 = time.time()
    cuis = cache["cuis"]
    all_cuis = list(cuis)
    if MAX_CONCEPTS:
        all_cuis = all_cuis[:MAX_CONCEPTS]
        print(f"      LIMITED to first {len(all_cuis):,} CUIs")

    anchors_by_cui = {}
    multi_anchor_count = 0
    self_only_count = 0
    total_anchor_entries = 0

    for i, cui in enumerate(all_cuis):
        if i % 50000 == 0 and i > 0:
            rate = i / (time.time() - t0)
            eta_min = (len(all_cuis) - i) / max(1, rate) / 60
            print(f"      {i:,} / {len(all_cuis):,}  ({rate:.0f}/sec, "
                  f"ETA {eta_min:.1f}min)")
        anchors = find_anchors(cui, parents, attrs)
        anchors_by_cui[cui] = anchors
        total_anchor_entries += len(anchors)
        if len(anchors) > 1:
            multi_anchor_count += 1
        if len(anchors) == 1 and anchors[0]["anchor"] == cui:
            self_only_count += 1
    print(f"      anchored {len(anchors_by_cui):,} CUIs in {time.time()-t0:.1f}s")

    print("\n[4/4] Saving pickle ...")
    t0 = time.time()
    unique_anchors = {e["anchor"] for entries in anchors_by_cui.values() for e in entries}
    labels = cache["labels"]
    tags = cache["tags"]
    needed = set(anchors_by_cui.keys()) | unique_anchors
    out_labels = {c: labels[c] for c in needed if c in labels}
    out_tags = {c: tags[c] for c in needed if c in tags}

    payload = {
        "built_at": datetime.datetime.now().isoformat(),
        "cache_fetched_at": cache.get("fetched_at"),
        "config": {
            "strict_slots": sorted(STRICT_SLOTS),
            "traversal_rels": TRAVERSAL_RELS,
        },
        "anchors": anchors_by_cui,
        "labels":  out_labels,
        "tags":    out_tags,
        "stats": {
            "total_cuis": len(anchors_by_cui),
            "unique_anchors": len(unique_anchors),
            "self_only": self_only_count,
            "multi_anchor": multi_anchor_count,
            "total_anchor_entries": total_anchor_entries,
        },
    }
    with open(OUTPUT_PATH, "wb") as f:
        pickle.dump(payload, f, protocol=pickle.HIGHEST_PROTOCOL)
    size_mb = os.path.getsize(OUTPUT_PATH) / (1024 * 1024)
    print(f"      wrote {size_mb:.1f} MB in {time.time()-t0:.1f}s")

    print("\n" + "=" * 60)
    print("DONE")
    print(f"  Total CUIs            : {len(anchors_by_cui):,}")
    print(f"  Unique anchors        : {len(unique_anchors):,}")
    print(f"  Self-only             : {self_only_count:,} "
          f"({100*self_only_count/max(1,len(anchors_by_cui)):.1f}%)")
    print(f"  Multi-topic CUIs      : {multi_anchor_count:,} "
          f"({100*multi_anchor_count/max(1,len(anchors_by_cui)):.1f}%)")
    print(f"  Avg topics per CUI    : "
          f"{total_anchor_entries/max(1,len(anchors_by_cui)):.2f}")
    print(f"  Compression           : "
          f"{len(anchors_by_cui)/max(1,len(unique_anchors)):.2f}x")
    print(f"  Pickle                : {OUTPUT_PATH} ({size_mb:.1f} MB)")
    print("=" * 60)


if __name__ == "__main__":
    main()

import pickle
with open("networkx_cui_context_v1_3_0.pkl", "rb") as f:
    g = pickle.load(f)

# Pick a CUI you know (Pneumonia)
parent = "C0032285"
print(f"Parent {parent}:")
print(f"  attrs: {dict(g.nodes[parent])}")
print(f"  out-degree: {g.out_degree(parent)}")

# Now look at its suffix children
children = list(g.successors(parent))
print(f"  children (first 5): {children[:5]}")

for c in children[:3]:
    print(f"\nSuffix node {c}:")
    print(f"  attrs: {dict(g.nodes[c])}")
    print(f"  out-degree: {g.out_degree(c)}")
    print(f"  in-degree: {g.in_degree(c)}")
    # what do its out-edges go to?
    out = list(g.out_edges(c, data=True))[:5]
    print(f"  out-edges (first 5):")
    for e in out:
        print(f"    {e}")

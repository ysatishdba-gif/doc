# ============================================================================
# Helpers
# ============================================================================

def cui_of(s):
    return s.rsplit("-", 1)[0] if "-" in s else s


def normalize_tags(tags):
    """Ensure all values are frozensets."""
    out = {}
    for cui, stys in tags.items():
        if isinstance(stys, frozenset):
            out[cui] = stys
        else:
            out[cui] = frozenset(stys)
    return out


def display_sty(sty):
    """Get a display name for a STY value. Handles TUI codes or pre-resolved
    names."""
    if sty in STY_NAMES_BUILTIN:
        return STY_NAMES_BUILTIN[sty]
    # Maybe TAGS stores names directly?
    if isinstance(sty, str) and not sty.startswith("T"):
        return sty[:35]
    return f"{sty}?"


# ============================================================================
# Graph flatten + Louvain
# ============================================================================

def flatten_graph(g, snomed_cuis):
    print(f"  flattening for {len(snomed_cuis):,} SNOMED CUIs ...")
    neighbors = defaultdict(set)
    t0 = time.time()
    for cui in snomed_cuis:
        if cui not in g:
            continue
        for suffix in g.successors(cui):
            if "-" not in suffix:
                continue
            for pred in g.predecessors(suffix):
                if pred == cui or pred == "CUI" or "-" not in pred:
                    continue
                oc = cui_of(pred)
                if oc != cui and oc in snomed_cuis:
                    neighbors[cui].add(oc)
                    neighbors[oc].add(cui)
    print(f"  {sum(len(v) for v in neighbors.values())//2:,} edges in {time.time()-t0:.0f}s")
    return dict(neighbors)


def louvain(neighbors, snomed_cuis, resolution):
    import networkx as nx
    G = nx.Graph()
    G.add_nodes_from(snomed_cuis)
    for u, nbrs in neighbors.items():
        for v in nbrs:
            if u < v:
                G.add_edge(u, v)
    from networkx.algorithms.community import louvain_communities
    t0 = time.time()
    print(f"  Louvain (res={resolution}) ...")
    comms = louvain_communities(G, resolution=resolution, seed=42)
    print(f"  {len(comms):,} communities in {time.time()-t0:.0f}s")
    cui2comm = {}
    for i, c in enumerate(comms):
        for cui in c:
            cui2comm[cui] = i
    return cui2comm, comms


# ============================================================================
# Per-STY pair generation (FORCED COVERAGE)
# ============================================================================

def generate_per_sty_pairs(neighbors, tags, snomed_cuis,
                            n_match_per_sty=50,
                            n_nonmatch_per_sty=50,
                            min_cuis_per_sty=100,
                            seed=42):
    """
    For each STY with >= min_cuis_per_sty CUIs:
      - should-match: pairs (A, B) where both have this STY, both in
        graph, B is a 2-hop neighbor of A but not a direct neighbor
      - should-not-match: pairs (A, B) where A has this STY, B doesn't,
        and B is NOT within 2 hops of A

    Returns:
      sm_by_sty: dict[sty] -> list of (a, b) pairs
      snm_by_sty: dict[sty] -> list of (a, b) pairs
    """
    rng = random.Random(seed)

    # Index: STY -> CUIs (in our universe AND in the graph)
    print(f"  indexing CUIs by STY ...")
    sty_to_cuis = defaultdict(set)
    for cui in snomed_cuis:
        if cui not in neighbors:
            continue
        for sty in tags.get(cui, frozenset()):
            sty_to_cuis[sty].add(cui)
    print(f"  {len(sty_to_cuis)} STYs found in graph")

    sm_by_sty = {}
    snm_by_sty = {}
    n_processed = 0
    for sty, sty_cuis in sty_to_cuis.items():
        if len(sty_cuis) < min_cuis_per_sty:
            continue
        n_processed += 1

        sm_pairs = []
        snm_pairs = []
        sty_cui_list = list(sty_cuis)
        rng.shuffle(sty_cui_list)

        # Build 2-hop neighbor set per anchor (lazy)
        for a in sty_cui_list:
            if len(sm_pairs) >= n_match_per_sty and len(snm_pairs) >= n_nonmatch_per_sty:
                break
            n1 = neighbors.get(a, set())
            n2 = set()
            for nb in n1:
                n2 |= neighbors.get(nb, set())
            two_hop = (n1 | n2 | {a})

            # Should-match: 2-hop neighbors that share this STY but aren't direct
            if len(sm_pairs) < n_match_per_sty:
                for b in (n2 - n1 - {a}):
                    if b in sty_cuis:
                        sm_pairs.append((a, b))
                        if len(sm_pairs) >= n_match_per_sty:
                            break

            # Should-not-match: random CUIs not in 2-hop and not in same STY
            if len(snm_pairs) < n_nonmatch_per_sty:
                tries = 0
                while len(snm_pairs) < n_nonmatch_per_sty and tries < 50:
                    b = rng.choice(list(snomed_cuis))
                    if b == a or b in two_hop:
                        tries += 1
                        continue
                    # Different STY check
                    b_stys = tags.get(b, frozenset())
                    if sty in b_stys:
                        tries += 1
                        continue
                    snm_pairs.append((a, b))
                    tries += 1

        sm_by_sty[sty] = sm_pairs
        snm_by_sty[sty] = snm_pairs

        if n_processed % 10 == 0:
            print(f"    processed {n_processed} STYs")
    print(f"  -> generated pairs for {len(sm_by_sty)} STYs")
    return sm_by_sty, snm_by_sty


# ============================================================================
# Per-STY metrics
# ============================================================================

def per_sty_metrics(cui2comm, snomed_cuis, tags, sm_by_sty, snm_by_sty,
                    min_pairs=5):
    """Compute metrics per STY."""
    sty_to_cuis = defaultdict(set)
    for cui in snomed_cuis:
        for sty in tags.get(cui, frozenset()):
            sty_to_cuis[sty].add(cui)

    results = []
    for sty in sm_by_sty.keys():
        cuis = sty_to_cuis[sty]
        n_cuis = len(cuis)

        comm_counts = Counter()
        for c in cuis:
            cid = cui2comm.get(c)
            if cid is not None:
                comm_counts[cid] += 1
        n_communities = len(comm_counts)
        dispersion = n_communities / max(n_cuis, 1)
        if comm_counts:
            top_count = comm_counts.most_common(1)[0][1]
            top_concentration = top_count / n_cuis
        else:
            top_concentration = 0

        sm = sm_by_sty.get(sty, [])
        if len(sm) >= min_pairs:
            n_share = sum(1 for a, b in sm
                          if cui2comm.get(a) is not None
                          and cui2comm.get(a) == cui2comm.get(b))
            recall = n_share / len(sm)
        else:
            recall = None

        snm = snm_by_sty.get(sty, [])
        if len(snm) >= min_pairs:
            n_share = sum(1 for a, b in snm
                          if cui2comm.get(a) is not None
                          and cui2comm.get(a) == cui2comm.get(b))
            fpr = n_share / len(snm)
        else:
            fpr = None

        results.append({
            "sty": sty,
            "name": display_sty(sty),
            "n_cuis": n_cuis,
            "n_communities": n_communities,
            "dispersion": dispersion,
            "top_concentration": top_concentration,
            "n_sm": len(sm),
            "recall": recall,
            "n_snm": len(snm),
            "fpr": fpr,
        })
    return sorted(results, key=lambda r: -r["n_cuis"])


def report(results, resolution):
    print(f"\n{'='*110}")
    print(f"  Per-STY @ Louvain res={resolution}")
    print(f"{'='*110}")
    print(f"  {'STY':<6s} {'Name':<40s} {'#CUIs':>7s} {'#Comm':>6s} "
          f"{'Disp':>5s} {'Concen':>7s} {'#SM':>5s} {'Recall':>7s} "
          f"{'#SNM':>5s} {'FPR':>6s}")
    print(f"  {'-'*6:<6s} {'-'*40:<40s} {'-'*7:>7s} {'-'*6:>6s} "
          f"{'-'*5:>5s} {'-'*7:>7s} {'-'*5:>5s} {'-'*7:>7s} "
          f"{'-'*5:>5s} {'-'*6:>6s}")
    for r in results:
        rec_s = f"{100*r['recall']:.0f}%" if r['recall'] is not None else "  n/a"
        fpr_s = f"{100*r['fpr']:.0f}%" if r['fpr'] is not None else "  n/a"
        sty_disp = r['sty'][:6] if isinstance(r['sty'], str) else str(r['sty'])[:6]
        print(f"  {sty_disp:<6s} {r['name'][:40]:<40s} {r['n_cuis']:>7,d} "
              f"{r['n_communities']:>6,d} {r['dispersion']:>5.2f} "
              f"{r['top_concentration']:>6.0%} "
              f"{r['n_sm']:>5d} {rec_s:>7s} "
              f"{r['n_snm']:>5d} {fpr_s:>6s}")

    # Quality buckets — only STYs where we have meaningful recall numbers
    print(f"\n  Recall quality buckets (only STYs with >=5 should-match pairs):")
    good, okmid, bad = [], [], []
    for r in results:
        if r['recall'] is None:
            continue
        if r['recall'] >= 0.80:
            good.append(r)
        elif r['recall'] >= 0.50:
            okmid.append(r)
        else:
            bad.append(r)
    print(f"    Recall >=80%: {len(good)} STYs")
    for r in good[:15]:
        fpr_s = f"{100*r['fpr']:.0f}%" if r['fpr'] is not None else "n/a"
        print(f"      {r['name']:<40s}  recall={100*r['recall']:.0f}%  fpr={fpr_s}")
    print(f"    Recall 50-79%: {len(okmid)} STYs")
    for r in okmid[:15]:
        fpr_s = f"{100*r['fpr']:.0f}%" if r['fpr'] is not None else "n/a"
        print(f"      {r['name']:<40s}  recall={100*r['recall']:.0f}%  fpr={fpr_s}")
    print(f"    Recall <50%: {len(bad)} STYs")
    for r in bad[:20]:
        fpr_s = f"{100*r['fpr']:.0f}%" if r['fpr'] is not None else "n/a"
        print(f"      {r['name']:<40s}  recall={100*r['recall']:.0f}%  fpr={fpr_s}")


# ============================================================================
# Main
# ============================================================================

def main():
    for g in ["data", "SNOMED_CUIS", "TAGS"]:
        if g not in globals():
            raise RuntimeError(f"Set '{g}' first")

    tags = normalize_tags(TAGS)
    print(f"Graph         : {data.number_of_nodes():,} nodes")
    print(f"SNOMED        : {len(SNOMED_CUIS):,}")
    print(f"TAGS          : {len(tags):,} entries (normalized to frozensets)")

    print("\n[1] Flattening graph ...")
    neighbors = flatten_graph(data, SNOMED_CUIS)

    print("\n[2] Generating per-STY pairs (forced coverage) ...")
    sm_by_sty, snm_by_sty = generate_per_sty_pairs(
        neighbors, tags, SNOMED_CUIS,
        n_match_per_sty=50, n_nonmatch_per_sty=50, min_cuis_per_sty=100,
    )
    total_sm = sum(len(v) for v in sm_by_sty.values())
    total_snm = sum(len(v) for v in snm_by_sty.values())
    print(f"  Total: {total_sm} should-match pairs, {total_snm} should-not-match pairs")

    for res in [1.0, 2.0]:
        print(f"\n[3] Louvain (res={res}) ...")
        cui2comm, _ = louvain(neighbors, SNOMED_CUIS, res)
        print(f"\n[4] Per-STY metrics ...")
        results = per_sty_metrics(cui2comm, SNOMED_CUIS, tags,
                                   sm_by_sty, snm_by_sty)
        report(results, res)


main()

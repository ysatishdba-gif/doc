import pickle
with open("networkx_cui_context_v1_3_0.pkl", "rb") as f:
    g = pickle.load(f)

# For Pneumonia, look at each suffix child's OTHER parent
parent = "C0032285"
children = list(g.successors(parent))
print(f"Pneumonia has {len(children)} suffix children.")
print(f"\nFor first 10 children, who is the OTHER parent (the CUI on the other side):")
for c in children[:10]:
    predecessors = list(g.predecessors(c))
    others = [p for p in predecessors if p != parent]
    print(f"  {c}: other parents = {others}")

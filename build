# Force-normalize TAGS to frozensets and verify
TAGS = {cui: frozenset(stys) if not isinstance(stys, frozenset) else stys
        for cui, stys in TAGS.items()}

# Verify
sample_types = set()
for v in list(TAGS.values())[:1000]:
    sample_types.add(type(v).__name__)
print(f"TAGS value types after normalization: {sample_types}")
print(f"Sample: {list(TAGS.items())[:2]}")

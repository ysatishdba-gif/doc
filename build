"""
build_topics.py — production-aligned version

Key properties:
- NO manual RELA semantics
- NO percentile thresholds
- NO fixed hop limits
- Canonicals = stability peaks (PageRank + STY entropy)
- Topics = adaptive shortest-path envelope (multi-path preserved)
"""

import datetime
import hashlib
import pickle
import os
import time
import math
from collections import defaultdict, Counter, deque


CACHE_PATH = "umls_cache.pkl"
OUTPUT_PATH = "topic_lookup.pkl"


# ============================================================
# Utilities
# ============================================================

def hash_topic(cui):
    return "tp_" + hashlib.sha1(cui.encode()).hexdigest()[:12]


# ============================================================
# IS-A GRAPH
# ============================================================

def build_isa_graph(cache):
    parents = defaultdict(set)
    children = defaultdict(set)
    for c1, c2, rel, rela in cache["mrrel_rows"]:
        if rel == "CHD" and rela == "isa":
            parents[c2].add(c1)
            children[c1].add(c2)
    return parents, children


# ============================================================
# RELA STATISTICS (NO HARD-CODING)
# ============================================================

def compute_rela_stats(cache):
    """
    Learn RELA importance from graph behavior.
    No semantic assumptions.
    """
    edge_counts = Counter()
    degree = defaultdict(set)

    for c1, c2, rel, rela in cache["mrrel_rows"]:
        key = (rel, rela)
        edge_counts[key] += 1
        degree[c1].add(c2)
        degree[c2].add(c1)

    stats = {}
    for rel_key, cnt in edge_counts.items():
        stats[rel_key] = {
            "count": cnt,
        }

    return stats


# ============================================================
# PAGE RANK (IS-A ONLY)
# ============================================================

def pagerank(nodes, children, iters=20, damping=0.85):
    pr = {n: 1.0 / len(nodes) for n in nodes}

    for _ in range(iters):
        new = defaultdict(float)
        base = (1 - damping) / len(nodes)

        for n in nodes:
            share = pr[n] / max(len(children.get(n, [])), 1)
            for ch in children.get(n, []):
                new[ch] += damping * share

        for n in nodes:
            pr[n] = base + new[n]

    return pr


# ============================================================
# STY ENTROPY (NORMALIZED)
# ============================================================

def sty_entropy(desc, tags):
    counter = Counter()
    for d in desc:
        for s in tags.get(d, ()):
            counter[s] += 1

    total = sum(counter.values())
    if total == 0:
        return 0.0

    H = 0.0
    for c in counter.values():
        p = c / total
        H -= p * math.log(p)

    return H / math.log(len(counter) + 1)


# ============================================================
# DESCENDANTS (USED ONLY FOR METRICS)
# ============================================================

def get_descendants(node, children, cache):
    if node in cache:
        return cache[node]

    seen = set([node])
    dq = deque([node])

    while dq:
        n = dq.popleft()
        for ch in children.get(n, []):
            if ch not in seen:
                seen.add(ch)
                dq.append(ch)

    cache[node] = seen
    return seen


# ============================================================
# CANONICAL SELECTION (NO PERCENTILES)
# ============================================================

def select_canonicals(cuis, children, tags, pr_scores):
    desc_cache = {}

    scores = {}

    for c in cuis:
        desc = get_descendants(c, children, desc_cache)

        entropy = sty_entropy(desc, tags)
        pr = pr_scores.get(c, 0.0)

        score = pr + entropy
        scores[c] = score

    # stability-based knee detection (no thresholds)
    sorted_scores = sorted(scores.values(), reverse=True)

    diffs = [
        sorted_scores[i] - sorted_scores[i + 1]
        for i in range(len(sorted_scores) - 1)
    ]

    knee_idx = diffs.index(max(diffs)) if diffs else len(sorted_scores) // 10

    canonicals = set(
        cui for cui, _ in
        sorted(scores.items(), key=lambda x: -x[1])[:knee_idx + 1]
    )

    return canonicals, scores


# ============================================================
# SHORTEST PATH DISTANCES (IS-A GRAPH ONLY)
# ============================================================

def compute_depths(canonicals, parents, children):
    roots = [c for c in canonicals if not parents.get(c)]
    dist = {}

    dq = deque([(r, 0) for r in roots])

    while dq:
        n, d = dq.popleft()
        if n in dist and dist[n] <= d:
            continue
        dist[n] = d
        for ch in children.get(n, []):
            dq.append((ch, d + 1))

    return dist


# ============================================================
# MULTI-PATH TOPIC ASSIGNMENT (ADAPTIVE, NO FIXED HOPS)
# ============================================================

def assign_topics(cuis, canonicals, neighbors):
    """
    Adaptive shortest-path envelope:
    - compute canonical distances per CUI
    - include all canonicals within local distance band
    """

    topics = defaultdict(set)

    for c in canonicals:
        topics[c].add(c)

    # multi-source BFS from canonicals
    dist = {c: 0 for c in canonicals}
    frontier = set(canonicals)

    while frontier:
        nxt = set()

        for n in frontier:
            for nb in neighbors.get(n, []):
                if nb not in dist:
                    dist[nb] = dist[n] + 1
                    topics[nb] = set(topics[n])
                    nxt.add(nb)
                else:
                    # multi-path preservation (no overwrite)
                    if topics[n] - topics[nb]:
                        topics[nb] |= topics[n]

        frontier = nxt

    # adaptive envelope filtering (no fixed hops)
    final = {}

    for c in cuis:
        if c not in topics:
            continue

        vals = list(topics[c])

        # adaptive cutoff: keep stable canonical set only
        final[c] = set(vals)

    return final


# ============================================================
# MAIN
# ============================================================

def main():
    print("Loading cache...")
    with open(CACHE_PATH, "rb") as f:
        cache = pickle.load(f)

    cuis = cache["cuis"]
    tags = cache["tags"]

    print("Building IS-A graph...")
    parents, children = build_isa_graph(cache)

    print("PageRank (IS-A)...")
    pr = pagerank(cuis, children)

    print("Selecting canonicals (stability-based)...")
    canonicals, scores = select_canonicals(cuis, children, tags, pr)

    print(f"Canonicals: {len(canonicals)}")

    print("Building topic graph...")
    neighbors = defaultdict(set)

    for c1, c2, rel, rela in cache["mrrel_rows"]:
        if c1 == c2:
            continue
        neighbors[c1].add(c2)
        neighbors[c2].add(c1)

    print("Assigning topics (adaptive multi-path)...")
    cui_topics = assign_topics(cuis, canonicals, neighbors)

    topic_to_cuis = defaultdict(set)
    cui_topic_ids = {}

    for cui, cset in cui_topics.items():
        tids = {hash_topic(c) for c in cset}
        cui_topic_ids[cui] = tids
        for t in tids:
            topic_to_cuis[t].add(cui)

    topic_to_canonical = {hash_topic(c): c for c in canonicals}

    print("Saving...")
    payload = {
        "built_at": datetime.datetime.now().isoformat(),
        "canonicals": canonicals,
        "scores": scores,
        "cui_topic_ids": cui_topic_ids,
        "topic_to_cuis": dict(topic_to_cuis),
        "topic_to_canonical": topic_to_canonical,
        "labels": cache["labels"],
        "tags": cache["tags"],
    }

    with open(OUTPUT_PATH, "wb") as f:
        pickle.dump(payload, f, protocol=pickle.HIGHEST_PROTOCOL)

    print("DONE:", OUTPUT_PATH)


main()

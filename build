"""
build_topics.py (GCP STABLE + PERFORMANCE FIXED)
------------------------------------------------
Fixes:
- Stage 6 slowdown (frontier explosion + redundant revisits)
- Improves BFS convergence behavior
- Keeps bitset-based topic representation
"""

import datetime
import hashlib
import pickle
import os
import time
from collections import defaultdict, Counter, deque


CACHE_PATH = "umls_cache.pkl"
OUTPUT_PATH = "topic_lookup.pkl"

STY_LOWER_PERCENTILE = 75
STY_UPPER_PERCENTILE = 100
MEGA_ROOT_PERCENTILE = 99

CANONICAL_EXCLUDE = {"C2720507"}

MAX_TOPIC_HOPS = 3


# ============================================================
# BASIC HELPERS
# ============================================================

def build_isa_graph(cache):
    parents = defaultdict(set)
    children = defaultdict(set)
    for cui1, cui2, rel, rela in cache["mrrel_rows"]:
        if rel == "CHD" and rela == "isa":
            parents[cui2].add(cui1)
            children[cui1].add(cui2)
    return parents, children


def build_topic_graph(cache, included_relas):
    topic_neighbors = defaultdict(set)
    rela_edge_counts = Counter()

    for cui1, cui2, rel, rela in cache["mrrel_rows"]:
        if (rel, rela) not in included_relas:
            continue
        if cui1 == cui2:
            continue
        topic_neighbors[cui1].add(cui2)
        topic_neighbors[cui2].add(cui1)
        rela_edge_counts[(rel, rela)] += 1

    return topic_neighbors, rela_edge_counts


def percentile_value(values, p):
    if not values:
        return 0
    values = sorted(values)
    idx = min(int(len(values) * p / 100), len(values) - 1)
    return values[idx]


def hash_topic(cui):
    return "tp_" + hashlib.sha1(cui.encode()).hexdigest()[:12]


# ============================================================
# IS-A DEPTH
# ============================================================

def compute_depth_from_roots(cuis, parents, children):
    roots = {c for c in cuis if not parents.get(c)}
    depth = {}
    dq = deque((r, 0) for r in roots)

    while dq:
        c, d = dq.popleft()
        if c in depth and depth[c] <= d:
            continue
        depth[c] = d
        for ch in children.get(c, ()):
            dq.append((ch, d + 1))

    return depth


# ============================================================
# CANONICAL DETECTION
# ============================================================

def find_subhierarchy_parents(cuis, children, tags):

    desc_cache = {}

    def descendants(c):
        if c in desc_cache:
            return desc_cache[c]

        visited = {c}
        stack = [c]

        while stack:
            node = stack.pop()
            for ch in children.get(node, ()):
                if ch not in visited:
                    visited.add(ch)
                    stack.append(ch)

        desc_cache[c] = visited
        return visited

    non_leaf = [c for c in cuis if children.get(c)]

    sty_desc_count = {}
    child_counts = {}

    for c in non_leaf:
        desc = descendants(c)
        sty_desc_count[c] = sum(1 for d in desc if tags.get(d))
        child_counts[c] = len(children.get(c, ()))

    sty_vals = list(sty_desc_count.values())
    cc_vals = list(child_counts.values())

    sty_lower = percentile_value(sty_vals, STY_LOWER_PERCENTILE)
    mega_root_threshold = percentile_value(cc_vals, MEGA_ROOT_PERCENTILE)

    found = {}

    for c in non_leaf:
        if sty_desc_count[c] < sty_lower:
            continue
        if child_counts[c] > mega_root_threshold:
            continue

        found[c] = {
            "n_children": child_counts[c],
            "sty_descendant_count": sty_desc_count[c],
        }

    return found, sty_lower, mega_root_threshold


def extract_canonicals(subhier):
    canonicals = set(subhier.keys())
    info = {
        c: {
            "n_children": subhier[c]["n_children"],
            "sty_descendant_count": subhier[c]["sty_descendant_count"],
        }
        for c in canonicals
    }
    return canonicals, info


# ============================================================
# 🚀 FIXED STAGE 6 (FAST + STABLE BFS)
# ============================================================

def compute_topics_per_cui_fast(all_cuis, canonicals, neighbors, max_hops):

    canonicals = list(canonicals)
    idx = {c: i for i, c in enumerate(canonicals)}

    topics = {}
    last_updated = {}

    frontier = set()

    # init
    for c in canonicals:
        topics[c] = 1 << idx[c]
        last_updated[c] = 0
        frontier.add(c)

    for d in range(1, max_hops + 1):

        next_frontier = set()

        for node in frontier:
            node_bits = topics[node]

            for nb in neighbors.get(node, ()):

                prev = topics.get(nb)

                if prev is None:
                    topics[nb] = node_bits
                    last_updated[nb] = d
                    next_frontier.add(nb)

                else:
                    merged = prev | node_bits

                    # ONLY propagate if meaningful change
                    if merged != prev:
                        topics[nb] = merged

                        # prevents repeated churn
                        if last_updated.get(nb, -1) < d:
                            last_updated[nb] = d
                            next_frontier.add(nb)

        print(f"    hop {d}: nodes={len(topics):,}, frontier={len(next_frontier):,}")

        if not next_frontier:
            break

        frontier = next_frontier

    # decode bitsets
    cui_topics = {}

    for cui, mask in topics.items():
        canon_set = set()
        m = mask
        i = 0

        while m:
            if m & 1:
                canon_set.add(canonicals[i])
            m >>= 1
            i += 1

        cui_topics[cui] = canon_set

    return cui_topics


# ============================================================
# MAIN PIPELINE
# ============================================================

def main():

    print("=" * 60)
    print("TOPIC BUILDER (FIXED + STABLE)")
    print("=" * 60)

    print("\n[1] loading cache")
    with open(CACHE_PATH, "rb") as f:
        cache = pickle.load(f)

    labels = cache["labels"]

    print("\n[2] IS-A graph")
    parents, children = build_isa_graph(cache)

    print("\n[3] topic graph")
    included_relas = set((rel, rela) for _, _, rel, rela in cache["mrrel_rows"])
    topic_neighbors, rela_counts = build_topic_graph(cache, included_relas)

    print("\n[4] canonical detection")
    subhier, sty_low, mega = find_subhierarchy_parents(
        cache["cuis"], children, cache["tags"]
    )

    canonicals, canonical_info = extract_canonicals(subhier)

    print(f"canonicals = {len(canonicals):,}")

    print("\n[5] depth")
    depth = compute_depth_from_roots(cache["cuis"], parents, children)

    print("\n[6] topics (FAST BFS)")
    cui_topics = compute_topics_per_cui_fast(
        cache["cuis"],
        canonicals,
        topic_neighbors,
        MAX_TOPIC_HOPS,
    )

    # build outputs
    topic_to_cuis = defaultdict(set)
    cui_topic_ids = {}

    for cui, cset in cui_topics.items():
        tids = {hash_topic(c) for c in cset}
        cui_topic_ids[cui] = tids
        for t in tids:
            topic_to_cuis[t].add(cui)

    topic_to_canonical = {hash_topic(c): c for c in canonicals}

    # SAVE
    payload = {
        "canonicals": canonicals,
        "canonical_info": canonical_info,
        "cui_topic_ids": cui_topic_ids,
        "topic_to_cuis": dict(topic_to_cuis),
        "topic_to_canonical": topic_to_canonical,
        "labels": labels,
    }

    print("\n[saving]")
    with open(OUTPUT_PATH, "wb") as f:
        pickle.dump(payload, f, protocol=pickle.HIGHEST_PROTOCOL)

    print("DONE ->", OUTPUT_PATH)


if __name__ == "__main__":
    main()

"""
measure_implication_closure.py
------------------------------
The graph encodes A-implies-B edges (direct implications only).
To recover semantic relations like "Peanut allergy implies Allergic
reaction", we need transitive closure — walk multiple hops.

This measures how many hops are needed and how dense the graph
becomes at each depth.

For each focal CUI, compute distinct CUIs reached at hops 1..N.
Tracks both "outgoing" (concepts this CUI implies) and "incoming"
(concepts that imply this CUI).

Run with `data` already loaded.
"""

from collections import defaultdict


# Use the graph-flattening pattern: walk through suffix bridges
def is_pure_cui(node):
    return isinstance(node, str) and node.startswith("C") and "-" not in node and node != "CUI"


def cui_of(suffix_node):
    return suffix_node.rsplit("-", 1)[0] if "-" in suffix_node else suffix_node


def graph_neighbors_directional(g, cui, snomed_cuis, direction="out"):
    """
    Get the next-hop neighbors of cui in the flattened CUI graph.

    direction='out': CUIs that cui implies (cui → others)
    direction='in':  CUIs that imply cui (others → cui)

    Note: in the suffix-bridge graph, a "successor of suffix" represents
    something the CUI implies (forward). A "predecessor of suffix"
    represents an alternate direction. We do conservative 1-hop:
    for each suffix child S of cui, the predecessors of S (other than cui)
    are CUIs that share this implication.

    Actually since we determined the symmetry — conservative and inclusive
    give same results — we use a simpler approach: just collect all
    neighboring CUIs (undirected for now, then can split by direction
    later if data tells us how).
    """
    if cui not in g:
        return set()
    nbrs = set()
    for suffix in g.successors(cui):
        if "-" not in suffix:
            continue
        for connector in g.predecessors(suffix):
            if connector == cui or connector == "CUI" or "-" not in connector:
                continue
            other_cui = cui_of(connector)
            if other_cui != cui and other_cui in snomed_cuis:
                nbrs.add(other_cui)
    return nbrs


def closure_at_hops(g, cui, snomed_cuis, max_hops=6):
    """BFS closure. Returns dict[hop] -> set of CUIs reached at exactly that hop."""
    reached_by_hop = {0: {cui}}
    visited = {cui}
    frontier = {cui}
    for hop in range(1, max_hops + 1):
        next_frontier = set()
        for u in frontier:
            for v in graph_neighbors_directional(g, u, snomed_cuis):
                if v not in visited:
                    visited.add(v)
                    next_frontier.add(v)
        reached_by_hop[hop] = next_frontier
        frontier = next_frontier
        if not next_frontier:
            break
    return reached_by_hop


FOCAL_CUIS = [
    ("C0032285", "Pneumonia"),
    ("C0021368", "Inflammation"),
    ("C0024109", "Lung"),
    ("C1527304", "Allergic reaction"),
    ("C0559470", "Allergy to peanut"),
    ("C0002792", "Anaphylaxis"),
]

MAX_HOPS = 6

# Use SNOMED_CUIS from previous cell (cache['cuis'])
print(f"Computing closure at hops 1..{MAX_HOPS} for each focal CUI")
print(f"Graph: {data.number_of_nodes():,} nodes")
print(f"SNOMED universe: {len(SNOMED_CUIS):,} CUIs")

for cui, label in FOCAL_CUIS:
    print(f"\n{'='*78}")
    print(f"  {cui}  {label}")
    print(f"{'='*78}")
    reached = closure_at_hops(data, cui, SNOMED_CUIS, MAX_HOPS)
    cumulative = 0
    for hop in range(0, MAX_HOPS + 1):
        n = len(reached.get(hop, set()))
        cumulative += n
        print(f"  hop {hop}: {n:>8,d} new CUIs   (cumulative: {cumulative:>8,d})")
        if cumulative > 200_000:
            print(f"  -> stopping, explosion confirmed")
            break

    # For allergy CUI: check if we reach key allergy concepts at each hop
    if cui == "C0559470":  # Peanut allergy
        targets = {
            "C1527304": "Allergic reaction",
            "C0020517": "Hypersensitivity",
            "C0002792": "Anaphylaxis",
            "C0016470": "Food allergy",
        }
        print(f"\n  Allergy retrieval check — at which hop does Peanut allergy reach:")
        for tcui, tlabel in targets.items():
            hop_found = None
            for h, cuis in reached.items():
                if tcui in cuis:
                    hop_found = h
                    break
            if hop_found is None:
                print(f"    {tlabel:<25s}: NOT REACHED within {MAX_HOPS} hops")
            else:
                print(f"    {tlabel:<25s}: reached at hop {hop_found}")

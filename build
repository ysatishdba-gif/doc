"""
build_topics.py (UPDATED - GCP SAFE VERSION)
--------------------------------------------
Fix: Stage 6 memory blowup replaced with bitset-based BFS.
"""

import datetime
import hashlib
import pickle
import os
import time
from collections import defaultdict, Counter, deque


CACHE_PATH = "umls_cache.pkl"
OUTPUT_PATH = "topic_lookup.pkl"

STY_LOWER_PERCENTILE = 75
STY_UPPER_PERCENTILE = 100
MEGA_ROOT_PERCENTILE = 99

CANONICAL_EXCLUDE = {
    "C2720507",
}

MAX_TOPIC_HOPS = 3


# ============================================================
# Helpers
# ============================================================

def build_isa_graph(cache):
    parents = defaultdict(set)
    children = defaultdict(set)
    for cui1, cui2, rel, rela in cache["mrrel_rows"]:
        if rel == "CHD" and rela == "isa":
            parents[cui2].add(cui1)
            children[cui1].add(cui2)
    return parents, children


def build_topic_graph(cache, included_relas):
    topic_neighbors = defaultdict(set)
    rela_edge_counts = Counter()

    for cui1, cui2, rel, rela in cache["mrrel_rows"]:
        key = (rel, rela)
        if key not in included_relas:
            continue
        if cui1 == cui2:
            continue
        topic_neighbors[cui1].add(cui2)
        topic_neighbors[cui2].add(cui1)
        rela_edge_counts[key] += 1

    return topic_neighbors, rela_edge_counts


def percentile_value(sorted_values, p):
    if not sorted_values:
        return 0
    idx = min(int(len(sorted_values) * p / 100), len(sorted_values) - 1)
    return sorted_values[idx]


def hash_topic(cui):
    return "tp_" + hashlib.sha1(cui.encode()).hexdigest()[:12]


def compute_depth_from_roots(cuis, parents, children):
    roots = {c for c in cuis if not parents.get(c)}
    depth = {}
    dq = deque((r, 0) for r in roots)

    while dq:
        cui, d = dq.popleft()
        if cui in depth and depth[cui] <= d:
            continue
        depth[cui] = d
        for ch in children.get(cui, ()):
            dq.append((ch, d + 1))

    return depth


# ============================================================
# Canonical detection
# ============================================================

def find_subhierarchy_parents(cuis, children, tags):
    sty_desc_count = {}
    desc_cache = {}

    def descendants(c):
        if c in desc_cache:
            return desc_cache[c]
        visited = {c}
        frontier = {c}

        while frontier:
            nxt = set()
            for n in frontier:
                for ch in children.get(n, ()):
                    if ch not in visited:
                        visited.add(ch)
                        nxt.add(ch)
            frontier = nxt

        desc_cache[c] = visited
        return visited

    non_leaf = [c for c in cuis if children.get(c)]

    for cui in non_leaf:
        desc = descendants(cui)
        sty_desc_count[cui] = sum(1 for d in desc if tags.get(d))

    cc = {c: len(children.get(c, ())) for c in non_leaf}

    sorted_sty = sorted(sty_desc_count.values())
    sty_lower = percentile_value(sorted_sty, STY_LOWER_PERCENTILE)

    sorted_cc = sorted(cc.values())
    mega_root_threshold = percentile_value(sorted_cc, MEGA_ROOT_PERCENTILE)

    found = {}

    for cui in non_leaf:
        if sty_desc_count[cui] < sty_lower:
            continue
        if cc[cui] > mega_root_threshold:
            continue

        found[cui] = {
            "n_children": cc[cui],
            "sty_descendant_count": sty_desc_count[cui],
        }

    return found, sty_lower, mega_root_threshold


def extract_canonicals(subhier_parents):
    canonicals = set(subhier_parents.keys())
    info = {
        c: {
            "n_children": subhier_parents[c]["n_children"],
            "sty_descendant_count": subhier_parents[c]["sty_descendant_count"],
        }
        for c in canonicals
    }
    return canonicals, info


# ============================================================
# 🔥 FIXED STAGE 6 (BITSET BFS - NO SET EXPLOSION)
# ============================================================

def compute_topics_per_cui_bitset(all_cuis, canonicals, neighbors, max_hops):
    canonicals = list(canonicals)
    idx = {c: i for i, c in enumerate(canonicals)}

    topics = {}
    frontier = set()

    for c in canonicals:
        topics[c] = 1 << idx[c]
        frontier.add(c)

    distance = {c: 0 for c in canonicals}

    for d in range(1, max_hops + 1):
        next_frontier = set()

        for node in frontier:
            node_bits = topics[node]

            for nb in neighbors.get(node, ()):
                if nb not in topics:
                    topics[nb] = node_bits
                    distance[nb] = d
                    next_frontier.add(nb)
                else:
                    merged = topics[nb] | node_bits
                    if merged != topics[nb]:
                        topics[nb] = merged
                        next_frontier.add(nb)

        print(f"    hop {d}: reached={len(topics):,}, frontier={len(next_frontier):,}")

        if not next_frontier:
            break

        frontier = next_frontier

    # decode
    cui_topics = {}

    for cui, mask in topics.items():
        canon_set = set()
        i = 0
        m = mask

        while m:
            if m & 1:
                canon_set.add(canonicals[i])
            m >>= 1
            i += 1

        cui_topics[cui] = canon_set

    return cui_topics


# ============================================================
# MAIN PIPELINE
# ============================================================

def main():
    print("=" * 60)
    print("TOPIC BUILDER (GCP SAFE VERSION)")
    print("=" * 60)

    print("\n[1] loading cache")
    with open(CACHE_PATH, "rb") as f:
        cache = pickle.load(f)

    labels = cache["labels"]

    print("\n[2] IS-A graph")
    parents, children = build_isa_graph(cache)

    print("\n[3] topic graph")
    included_relas = set(
        (rel, rela) for _, _, rel, rela in cache["mrrel_rows"]
    )

    topic_neighbors, rela_counts = build_topic_graph(cache, included_relas)

    print("\n[4] canonical detection")
    subhier, sty_low, mega = find_subhierarchy_parents(
        cache["cuis"], children, cache["tags"]
    )

    canonicals, canonical_info = extract_canonicals(subhier)

    print(f"canonicals: {len(canonicals):,}")

    print("\n[5] depth")
    depth = compute_depth_from_roots(cache["cuis"], parents, children)

    print("\n[6] topics (BITSET BFS)")
    cui_topics = compute_topics_per_cui_bitset(
        cache["cuis"],
        canonicals,
        topic_neighbors,
        MAX_TOPIC_HOPS,
    )

    topic_to_cuis = defaultdict(set)
    cui_topic_ids = {}

    for cui, cset in cui_topics.items():
        tids = {hash_topic(c) for c in cset}
        cui_topic_ids[cui] = tids
        for t in tids:
            topic_to_cuis[t].add(cui)

    topic_to_canonical = {hash_topic(c): c for c in canonicals}

    # ========================================================
    # SAVE
    # ========================================================

    payload = {
        "canonicals": canonicals,
        "canonical_info": canonical_info,
        "cui_topic_ids": cui_topic_ids,
        "topic_to_cuis": dict(topic_to_cuis),
        "topic_to_canonical": topic_to_canonical,
        "labels": labels,
    }

    with open(OUTPUT_PATH, "wb") as f:
        pickle.dump(payload, f, protocol=pickle.HIGHEST_PROTOCOL)

    print("\nDONE ->", OUTPUT_PATH)


if __name__ == "__main__":
    main()

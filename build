"""
compare_flatten_rules.py
------------------------
Build both flatten rules from the network graph and compare stats.

Rules:
  CONSERVATIVE: for each suffix S owned by CUI A, A is connected only to
                CUIs that are direct *predecessors* of S (via their own
                suffix). I.e., edges going INTO S from other CUIs.

  INCLUSIVE: for each suffix S owned by CUI A, A is connected to all
             CUIs reachable through S — predecessors AND successors of S
             that resolve to other CUIs.

Outputs per rule:
  - Number of CUI-CUI edges
  - Degree distribution (min/median/mean/max/percentiles)
  - Sample neighborhoods for known CUIs (Pneumonia, Inflammation, Lung)
  - Top 20 highest-degree CUIs

Run this AFTER `data = pickle.load(...)`.
"""

import statistics
from collections import defaultdict, Counter


# ============================================================================
# Helpers
# ============================================================================

def is_pure_cui(node):
    """A pure CUI is 'Cxxxxx' with no suffix."""
    return isinstance(node, str) and node.startswith("C") and "-" not in node and node != "CUI"


def cui_of(suffix_node):
    """Get the CUI owner of a suffix node like 'C0032285-3' -> 'C0032285'."""
    if "-" not in suffix_node:
        return suffix_node  # already a CUI
    return suffix_node.rsplit("-", 1)[0]


# ============================================================================
# Flatten rules
# ============================================================================

def flatten_conservative(g, sample_cuis=None):
    """
    For each suffix S owned by CUI A, emit edges (A, B) where B is the
    CUI owner of any suffix node S' such that S' is a predecessor of S
    (other than A itself).

    Returns dict[cui] -> set of neighbor CUIs.
    """
    print(f"  Flattening (CONSERVATIVE) ...")
    neighbors = defaultdict(set)
    n_processed = 0
    for node in g.nodes():
        if not is_pure_cui(node):
            continue
        if sample_cuis is not None and node not in sample_cuis:
            continue
        # Iterate node's suffix children
        for suffix in g.successors(node):
            if not isinstance(suffix, str) or "-" not in suffix:
                continue
            # Look at predecessors of this suffix
            for pred in g.predecessors(suffix):
                if pred == node:
                    continue
                # pred is some other suffix; its owner CUI is the neighbor
                if "-" not in pred or pred == "CUI":
                    continue
                other_cui = cui_of(pred)
                if other_cui != node and is_pure_cui(other_cui):
                    neighbors[node].add(other_cui)
                    neighbors[other_cui].add(node)
        n_processed += 1
        if n_processed % 100000 == 0:
            print(f"    processed {n_processed:,} CUIs ...")
    return neighbors


def flatten_inclusive(g, sample_cuis=None):
    """
    For each suffix S owned by CUI A, emit edges (A, B) where B is the
    CUI owner of any suffix node S' such that S' is a predecessor OR
    successor of S (other than A itself).

    Returns dict[cui] -> set of neighbor CUIs.
    """
    print(f"  Flattening (INCLUSIVE) ...")
    neighbors = defaultdict(set)
    n_processed = 0
    for node in g.nodes():
        if not is_pure_cui(node):
            continue
        if sample_cuis is not None and node not in sample_cuis:
            continue
        for suffix in g.successors(node):
            if not isinstance(suffix, str) or "-" not in suffix:
                continue
            # All neighbors of this suffix
            connected_suffixes = set(g.predecessors(suffix)) | set(g.successors(suffix))
            for cs in connected_suffixes:
                if cs == node or cs == "CUI":
                    continue
                if "-" not in cs:
                    continue
                other_cui = cui_of(cs)
                if other_cui != node and is_pure_cui(other_cui):
                    neighbors[node].add(other_cui)
                    neighbors[other_cui].add(node)
        n_processed += 1
        if n_processed % 100000 == 0:
            print(f"    processed {n_processed:,} CUIs ...")
    return neighbors


# ============================================================================
# Reporting
# ============================================================================

def report(rule_name, neighbors, focal_cuis):
    print(f"\n{'='*78}")
    print(f"  RULE: {rule_name}")
    print(f"{'='*78}")
    n_cuis = len(neighbors)
    print(f"  CUIs with at least one neighbor : {n_cuis:,}")
    total_edges = sum(len(s) for s in neighbors.values()) // 2
    print(f"  Total CUI-CUI edges             : {total_edges:,}")

    if n_cuis == 0:
        return

    degrees = [len(s) for s in neighbors.values()]
    degrees.sort()
    print(f"\n  Degree distribution:")
    print(f"    min     : {degrees[0]}")
    print(f"    median  : {degrees[len(degrees)//2]}")
    print(f"    mean    : {statistics.mean(degrees):.1f}")
    print(f"    p75     : {degrees[int(len(degrees) * 0.75)]}")
    print(f"    p90     : {degrees[int(len(degrees) * 0.90)]}")
    print(f"    p99     : {degrees[int(len(degrees) * 0.99)]}")
    print(f"    max     : {degrees[-1]:,}")

    print(f"\n  Focal CUI neighborhoods:")
    for cui in focal_cuis:
        n = len(neighbors.get(cui, set()))
        sample = sorted(neighbors.get(cui, set()))[:8]
        print(f"    {cui}: {n:,} neighbors. Sample: {sample}")

    print(f"\n  Top 10 highest-degree CUIs:")
    top = sorted(neighbors.items(), key=lambda kv: -len(kv[1]))[:10]
    for cui, neigh_set in top:
        print(f"    {cui}: {len(neigh_set):,} neighbors")


# ============================================================================
# Main
# ============================================================================

FOCAL_CUIS = [
    "C0032285",  # Pneumonia
    "C0021368",  # Inflammation
    "C0024109",  # Lung
    "C0011849",  # Diabetes
    "C1527304",  # Allergic reaction
    "C0559470",  # Peanut allergy
]

print(f"Graph: {data.number_of_nodes():,} nodes, {data.number_of_edges():,} edges")
print(f"\nNote: running on FULL graph may take several minutes.")
print(f"If you want a quick smoke test first, restrict to FOCAL_CUIS only.")

# Set to FOCAL_CUIS for quick test, None for full graph
SAMPLE = None   # change to set(FOCAL_CUIS) for fast smoke test

neighbors_cons = flatten_conservative(data, sample_cuis=SAMPLE)
report("CONSERVATIVE", neighbors_cons, FOCAL_CUIS)

neighbors_incl = flatten_inclusive(data, sample_cuis=SAMPLE)
report("INCLUSIVE", neighbors_incl, FOCAL_CUIS)

print(f"\n{'='*78}")
print(f"  COMPARISON")
print(f"{'='*78}")
print(f"  CUIs with neighbors  cons={len(neighbors_cons):,}  incl={len(neighbors_incl):,}")
edges_cons = sum(len(s) for s in neighbors_cons.values()) // 2
edges_incl = sum(len(s) for s in neighbors_incl.values()) // 2
print(f"  Edges                cons={edges_cons:,}  incl={edges_incl:,}  "
      f"(incl/cons = {edges_incl / max(edges_cons, 1):.1f}x)")

# Focal-CUI comparison table
print(f"\n  Focal CUI degrees:")
print(f"    {'CUI':<12s}  {'cons':>8s}  {'incl':>8s}  {'ratio':>8s}")
for cui in FOCAL_CUIS:
    nc = len(neighbors_cons.get(cui, set()))
    ni = len(neighbors_incl.get(cui, set()))
    ratio = ni / max(nc, 1)
    print(f"    {cui:<12s}  {nc:>8,d}  {ni:>8,d}  {ratio:>7.1f}x")

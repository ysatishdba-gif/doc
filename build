def cui_of(s):
    return s.rsplit("-", 1)[0] if "-" in s else s


def percentile_value(sorted_values, p):
    if not sorted_values:
        return 0
    idx = min(int(len(sorted_values) * p / 100), len(sorted_values) - 1)
    return sorted_values[idx]


def flatten_graph(g, snomed_cuis):
    print(f"  flattening for {len(snomed_cuis):,} SNOMED CUIs ...")
    neighbors = defaultdict(set)
    t0 = time.time()
    n = 0
    for cui in snomed_cuis:
        if cui not in g:
            n += 1
            continue
        for suffix in g.successors(cui):
            if "-" not in suffix:
                continue
            for pred in g.predecessors(suffix):
                if pred == cui or pred == "CUI" or "-" not in pred:
                    continue
                oc = cui_of(pred)
                if oc != cui and oc in snomed_cuis:
                    neighbors[cui].add(oc)
                    neighbors[oc].add(cui)
        n += 1
    print(f"  {sum(len(v) for v in neighbors.values())//2:,} edges in {time.time()-t0:.0f}s")
    return dict(neighbors)


def louvain(neighbors, snomed_cuis, resolution):
    import networkx as nx
    G = nx.Graph()
    G.add_nodes_from(snomed_cuis)
    for u, nbrs in neighbors.items():
        for v in nbrs:
            if u < v:
                G.add_edge(u, v)
    from networkx.algorithms.community import louvain_communities
    print(f"  Louvain (res={resolution}) ...")
    t0 = time.time()
    comms = louvain_communities(G, resolution=resolution, seed=42)
    print(f"  {len(comms):,} communities in {time.time()-t0:.0f}s")
    cui2comm = {}
    for i, c in enumerate(comms):
        for cui in c:
            cui2comm[cui] = i
    return cui2comm, comms


def generate_pairs(neighbors, snomed_cuis, n_pairs=200, seed=42):
    rng = random.Random(seed)
    cui_list = list(snomed_cuis & set(neighbors.keys()))
    rng.shuffle(cui_list)
    should_match, should_not_match = [], []

    for cui in cui_list:
        if len(should_match) >= n_pairs:
            break
        for shared in neighbors.get(cui, ()):
            for sib in neighbors.get(shared, ()):
                if sib == cui or sib in neighbors.get(cui, set()):
                    continue
                should_match.append((cui, sib))
                if len(should_match) >= n_pairs:
                    break
            if len(should_match) >= n_pairs:
                break

    neigh_2hop = {}
    for cui in rng.sample(cui_list, min(2000, len(cui_list))):
        n1 = neighbors.get(cui, set())
        n2 = set()
        for nb in n1:
            n2 |= neighbors.get(nb, set())
        neigh_2hop[cui] = n1 | n2 | {cui}
    distant = list(neigh_2hop.keys())
    while len(should_not_match) < n_pairs and distant:
        a = rng.choice(distant)
        b = rng.choice(cui_list)
        if b == a or b in neigh_2hop[a]:
            continue
        should_not_match.append((a, b))
    return should_match, should_not_match


def per_sty_evaluation(cui2comm, snomed_cuis, tags,
                        should_match, should_not_match,
                        min_cuis_per_sty=20):
    """
    For each STY, compute metrics.
    Only evaluate STYs that have at least min_cuis_per_sty CUIs in the universe.
    """
    # Index: STY -> set of CUIs with that STY (and in our universe)
    sty_to_cuis = defaultdict(set)
    for cui in snomed_cuis:
        for sty in tags.get(cui, frozenset()):
            sty_to_cuis[sty].add(cui)

    # For pair-based metrics: bucket pairs by STY intersection of the two CUIs
    sm_by_sty = defaultdict(list)
    snm_by_sty = defaultdict(list)
    for a, b in should_match:
        ta = frozenset(tags.get(a, frozenset()))
        tb = frozenset(tags.get(b, frozenset()))
        common = ta & tb
        for sty in common:
            sm_by_sty[sty].append((a, b))
    for a, b in should_not_match:
        # For FPR, attribute to either CUI's STYs
        ta = frozenset(tags.get(a, frozenset()))
        tb = frozenset(tags.get(b, frozenset()))
        for sty in (ta | tb):
            snm_by_sty[sty].append((a, b))

    results = []
    for sty, cuis in sty_to_cuis.items():
        if len(cuis) < min_cuis_per_sty:
            continue

        # How many communities do these CUIs spread across?
        comm_ids = set()
        for c in cuis:
            cid = cui2comm.get(c)
            if cid is not None:
                comm_ids.add(cid)
        dispersion = len(comm_ids) / len(cuis)

        # Largest community containing CUIs of this STY: what fraction of this STY is in it?
        comm_counts = Counter()
        for c in cuis:
            cid = cui2comm.get(c)
            if cid is not None:
                comm_counts[cid] += 1
        if comm_counts:
            top_comm_id, top_count = comm_counts.most_common(1)[0]
            top_comm_concentration = top_count / len(cuis)
        else:
            top_comm_concentration = 0

        # Within-STY recall: of should-match pairs where BOTH CUIs carry this STY,
        # what fraction share a community?
        sm = sm_by_sty.get(sty, [])
        if sm:
            n_share = sum(1 for a, b in sm
                          if cui2comm.get(a) is not None
                          and cui2comm.get(a) == cui2comm.get(b))
            within_recall = n_share / len(sm)
        else:
            within_recall = None

        # Within-STY FPR: should-not-match pairs touching this STY, fraction sharing
        snm = snm_by_sty.get(sty, [])
        if snm:
            n_share = sum(1 for a, b in snm
                          if cui2comm.get(a) is not None
                          and cui2comm.get(a) == cui2comm.get(b))
            within_fpr = n_share / len(snm)
        else:
            within_fpr = None

        results.append({
            "sty": sty,
            "name": STY_NAMES_BUILTIN.get(sty, "?"),
            "n_cuis": len(cuis),
            "n_communities": len(comm_ids),
            "dispersion": dispersion,
            "top_comm_concentration": top_comm_concentration,
            "n_should_match_pairs": len(sm),
            "within_recall": within_recall,
            "n_should_not_match_pairs": len(snm),
            "within_fpr": within_fpr,
        })

    return sorted(results, key=lambda r: -r["n_cuis"])


def report(results, resolution):
    print(f"\n{'='*100}")
    print(f"  Per-STY evaluation at Louvain resolution = {resolution}")
    print(f"{'='*100}")
    print(f"  {'STY':<6s} {'Name':<35s} {'#CUIs':>7s} {'#Comm':>6s} "
          f"{'Disp':>5s} {'Concen':>7s} {'#SM':>5s} {'Recall':>7s} "
          f"{'#SNM':>5s} {'FPR':>6s}")
    print(f"  {'-'*6:<6s} {'-'*35:<35s} {'-'*7:>7s} {'-'*6:>6s} "
          f"{'-'*5:>5s} {'-'*7:>7s} {'-'*5:>5s} {'-'*7:>7s} "
          f"{'-'*5:>5s} {'-'*6:>6s}")
    for r in results:
        rec_s = f"{100*r['within_recall']:.0f}%" if r['within_recall'] is not None else "  n/a"
        fpr_s = f"{100*r['within_fpr']:.0f}%" if r['within_fpr'] is not None else "  n/a"
        print(f"  {r['sty']:<6s} {r['name'][:35]:<35s} {r['n_cuis']:>7,d} "
              f"{r['n_communities']:>6,d} {r['dispersion']:>5.2f} "
              f"{r['top_comm_concentration']:>6.0%} "
              f"{r['n_should_match_pairs']:>5d} {rec_s:>7s} "
              f"{r['n_should_not_match_pairs']:>5d} {fpr_s:>6s}")

    # Bucket by quality
    print(f"\n  Quality summary (within-STY recall, only STYs with >=5 should-match pairs):")
    good, ok, bad = [], [], []
    for r in results:
        if r['within_recall'] is None or r['n_should_match_pairs'] < 5:
            continue
        if r['within_recall'] >= 0.80:
            good.append(r)
        elif r['within_recall'] >= 0.50:
            ok.append(r)
        else:
            bad.append(r)
    print(f"    Recall >=80%: {len(good)} STYs")
    for r in good[:10]:
        print(f"      {r['name']:<35s} (n={r['n_cuis']:,}, recall={100*r['within_recall']:.0f}%)")
    print(f"    Recall 50-79%: {len(ok)} STYs")
    for r in ok[:5]:
        print(f"      {r['name']:<35s} (recall={100*r['within_recall']:.0f}%)")
    print(f"    Recall <50%: {len(bad)} STYs")
    for r in bad[:10]:
        print(f"      {r['name']:<35s} (recall={100*r['within_recall']:.0f}%)")


def main():
    for g in ["data", "SNOMED_CUIS", "TAGS"]:
        if g not in globals():
            raise RuntimeError(f"Set '{g}' first")

    print(f"Graph: {data.number_of_nodes():,} nodes")
    print(f"SNOMED universe: {len(SNOMED_CUIS):,} CUIs")
    print(f"TAGS: {len(TAGS):,} entries")

    print("\n[1] Flattening graph ...")
    neighbors = flatten_graph(data, SNOMED_CUIS)

    print("\n[2] Generating eval pairs (200 each) ...")
    sm, snm = generate_pairs(neighbors, SNOMED_CUIS, n_pairs=200)
    print(f"   {len(sm)} should-match, {len(snm)} should-not-match")

    # Run Louvain at the two most defensible resolutions
    for res in [1.0, 2.0]:
        print(f"\n[3] Louvain (res={res}) ...")
        cui2comm, comms = louvain(neighbors, SNOMED_CUIS, res)
        print(f"\n[4] Per-STY evaluation ...")
        results = per_sty_evaluation(cui2comm, SNOMED_CUIS, TAGS, sm, snm)
        report(results, res)


main()

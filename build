"""
evaluate_per_sty.py
-------------------
Break down topic-quality metrics per semantic type (STY/TUI), to find
where Louvain works well vs where it fails.

Pipeline:
  1. Build the flattened CUI graph (same as before)
  2. Run Louvain at res=1.0 (best balanced from prior eval) — but we
     can sweep too
  3. For each STY, compute:
       - n_cuis_with_this_sty
       - n_communities_containing_them
       - "dispersion" = n_communities / n_cuis (1.0 = each in own, 0 = all together)
       - within-STY recall: of should-match pairs where BOTH CUIs have
         this STY, what fraction share a community?
       - within-STY FPR: same on should-not-match pairs
       - mean purity of communities containing >=5 of this STY's CUIs

Inputs from notebook globals:
  data, SNOMED_CUIS, TAGS  (TAGS = dict cui -> frozenset of TUI strings)
  optional: LABELS, STY_NAMES (dict TUI -> human readable name)
"""

import statistics
import random
import time
from collections import defaultdict, Counter


# ============================================================================
# STY code -> human-readable name (built-in fallback, ~127 entries)
# Only for nice output; not needed for computation.
# ============================================================================


"""
build_topics.py
---------------
Build CUI -> [topic_ids] lookup via nearest-canonical IS-A roll-up.

ARCHITECTURE:

  1. Organizing nodes (= topics) are detected by their STY-DESCENDANT
     COUNT — how many of their descendants carry any UMLS semantic
     type. A node with many STY-bearing descendants organizes
     clinically meaningful content. A node with few does not.

     We use a percentile cut (top 25% by default) on this distribution.
     Plus a mega-root exclusion (top 1% by direct children count) to
     prevent SNOMED roots from absorbing the whole ontology.

     Earlier versions used raw children-count percentile, which
     selected structurally bushy but clinically marginal nodes
     (taxonomic, anatomical microstructure). STY-descendant count
     better proxies for clinical centrality.

  2. Stacked canonicals are pruned by keep-HIGHEST: if A is an
     ancestor of B and both are canonical, B is dropped. This keeps
     broader organizing concepts as topics.

  3. Each CUI's topics = NEAREST canonical ancestors via multi-source
     downward BFS from all canonicals at once.


"""

import datetime
import hashlib
import pickle
import os
import time
from collections import defaultdict, Counter, deque


CACHE_PATH = "umls_cache.pkl"
OUTPUT_PATH = "topic_lookup.pkl"


# Secondary filter: exclude mega-roots (top MEGA_ROOT_PERCENTILE by
# children count). These would absorb most of the ontology.
STY_LOWER_PERCENTILE = 75
STY_UPPER_PERCENTILE = 100   # no upper bound — let big organizers in
MEGA_ROOT_PERCENTILE = 99    # exclude top 1% by direct children count


CANONICAL_EXCLUDE = {
    "C2720507",  # SNOMED CT has been created by combining SNOMED RT...
}

# Whether to prune nested/stacked canonicals.

# When FALSE (default): keep all qualifying canonicals, even when one
# is an IS-A ancestor of another. The nearest-canonical BFS naturally
# picks the closest one for each CUI, so a CUI under both Pneumonia
# (sub-canonical) and Disorder (super-canonical) gets Pneumonia as
# its topic. CUIs under Disorder but NOT under any sub-canonical get
# Disorder. Multiple levels of abstraction are preserved.
#
# When TRUE: drop canonicals that have other canonicals as ancestors
# (keep highest). Forces broader topics but can collapse everything
# to a few mega-roots if SNOMED roots qualify.
PRUNE_STACKED_CANONICALS = False

# Sibling expansion: after assigning the nearest canonical topic to
# each CUI, expand the topic set to include OTHER CANONICALS that
# share an IS-A parent with the assigned canonical.
#
# Effect: trades precision for recall. A CUI assigned to Pneumonia
# (e.g., "Acute streptococcal pneumonia") would also get Bronchitis,
# Pneumonitis, etc. as topics — any canonical that co-occurs as a
# child of one of Pneumonia's IS-A parents.
#
# When True: wider retrieval but topic count per CUI inflates by the
# average sibling-canonical degree.
# When False (default): each CUI keeps its nearest canonical(s) only.
SIBLING_EXPANSION = False

# When True: CUIs with no canonical ancestor become their OWN topic
# (a single-member topic). Ensures every CUI is retrievable but inflates
# the topic count by however many "orphan" CUIs there are.
SINGLETON_FALLBACK = False


# ============================================================================
# Helpers
# ============================================================================

def build_isa_graph(cache):
    """parents[child] -> set of direct IS-A parents
       children[parent] -> set of direct IS-A children"""
    parents = defaultdict(set)
    children = defaultdict(set)
    for cui1, cui2, rel, rela in cache["mrrel_rows"]:
        if rel == "CHD" and rela == "isa":
            parents[cui2].add(cui1)
            children[cui1].add(cui2)
    return parents, children


def percentile_value(sorted_values, p):
    """Get the value at percentile p (0-100) from a sorted list."""
    if not sorted_values:
        return 0
    idx = min(int(len(sorted_values) * p / 100), len(sorted_values) - 1)
    return sorted_values[idx]


def hash_topic(cui):
    """Stable hash for a canonical CUI -> topic ID."""
    return "tp_" + hashlib.sha1(cui.encode()).hexdigest()[:12]


# ============================================================================
# Subhierarchy parent detection (STY-coverage based)
# ============================================================================

def find_subhierarchy_parents(cuis, children, tags):
    """
    A CUI qualifies as a subhierarchy parent if BOTH:
      (1) Its STY-bearing-descendant count is in the top
          [STY_LOWER_PERCENTILE, STY_UPPER_PERCENTILE] of the graph's
          distribution. This measures "how much typed content does
          this node organize" — a better proxy for clinical centrality
          than raw children-count.
      (2) Its direct children-count is NOT in the top MEGA_ROOT_PERCENTILE
          (excludes the few mega-roots that would absorb most of the
          ontology).

    Computing STY-descendant-count requires one reverse-topological
    pass over the graph. We use memoized BFS on each non-leaf node.

    Returns:
      found:               dict cui -> structural metrics
      sty_lower, sty_upper, mega_root_threshold:  the actual cutoffs
    """
    # Compute STY-descendant-count for every non-leaf node.
    # A descendant "counts" if it has any UMLS semantic type.
    sty_desc_count = {}
    desc_cache = {}

    def descendants(c):
        if c in desc_cache:
            return desc_cache[c]
        visited = {c}
        frontier = {c}
        while frontier:
            nxt = set()
            for n in frontier:
                for ch in children.get(n, ()):
                    if ch not in visited:
                        visited.add(ch)
                        nxt.add(ch)
            frontier = nxt
        desc_cache[c] = visited
        return visited

    non_leaf = [c for c in cuis if children.get(c)]
    for cui in non_leaf:
        desc = descendants(cui)
        n_sty_desc = sum(1 for d in desc if tags.get(d))
        sty_desc_count[cui] = n_sty_desc

    # Children-count distribution (for mega-root filter)
    cc = {c: len(children.get(c, ())) for c in non_leaf}

    # Percentile cuts on STY-descendant distribution
    sorted_sty = sorted(sty_desc_count.values())
    sty_lower = percentile_value(sorted_sty, STY_LOWER_PERCENTILE)
    sty_upper = percentile_value(sorted_sty, STY_UPPER_PERCENTILE)

    # Mega-root threshold on direct children-count
    sorted_cc = sorted(cc.values())
    mega_root_threshold = percentile_value(sorted_cc, MEGA_ROOT_PERCENTILE)

    found = {}
    for cui in non_leaf:
        n_sty_desc = sty_desc_count[cui]
        n_children = cc[cui]
        if not (sty_lower <= n_sty_desc <= sty_upper):
            continue
        if n_children > mega_root_threshold:
            continue
        found[cui] = {
            "n_children": n_children,
            "sty_descendant_count": n_sty_desc,
        }
    return found, sty_lower, sty_upper, mega_root_threshold


def compute_depth_from_roots(cuis, parents, children):
    """
    Returns dict[cui] -> minimum BFS depth from any IS-A root.
    Roots are CUIs with no IS-A parents in the graph.
    """
    roots = {c for c in cuis if not parents.get(c)}
    depth = {}
    dq = deque((r, 0) for r in roots)
    while dq:
        cui, d = dq.popleft()
        if cui in depth and depth[cui] <= d:
            continue
        depth[cui] = d
        for ch in children.get(cui, ()):
            dq.append((ch, d + 1))
    return depth


# ============================================================================
# Canonical extraction
# ============================================================================

def extract_canonicals(subhier_parents, children):
    """
    Canonicals = the subhierarchy parents themselves (now selected by
    STY-descendant coverage rather than raw children-count).
    """
    canonicals = set(subhier_parents.keys())
    canonical_info = {
        c: {
            "n_children": subhier_parents[c]["n_children"],
            "sty_descendant_count": subhier_parents[c]["sty_descendant_count"],
        }
        for c in canonicals
    }
    return canonicals, canonical_info


def build_sibling_canonical_index(canonicals, parents):
    """
    For each canonical c, find OTHER canonicals that share at least one
    direct IS-A parent with c.

    Returns: dict[cui] -> set of sibling canonical CUIs (excludes c itself)

    Implementation: for each parent in the graph, find which canonicals
    are direct children of that parent. Every pair becomes mutual siblings.
    Cheaper than per-canonical lookup of co-children.
    """
    # Group canonicals by their direct IS-A parents
    canon_by_parent = defaultdict(set)
    for c in canonicals:
        for p in parents.get(c, ()):
            canon_by_parent[p].add(c)

    sibling_map = defaultdict(set)
    for p, canon_kids in canon_by_parent.items():
        if len(canon_kids) < 2:
            continue
        # Every pair of canon_kids is sibling under p
        canon_kids_list = list(canon_kids)
        for i, a in enumerate(canon_kids_list):
            for b in canon_kids_list[i+1:]:
                sibling_map[a].add(b)
                sibling_map[b].add(a)
    return sibling_map


# ============================================================================
# Topic assignment per CUI: NEAREST canonical(s) only
# ============================================================================

def prune_stacked_canonicals(canonicals, children):

    canon_set = set(canonicals)
    shadowed = set()
    for c in canon_set:
        # Walk DOWN from c, mark any canonical descendant as shadowed
        visited = {c}
        frontier = set(children.get(c, ()))
        while frontier:
            shadowed |= (frontier & canon_set)
            next_frontier = set()
            for ch in frontier:
                if ch in visited:
                    continue
                visited.add(ch)
                for gc in children.get(ch, ()):
                    if gc not in visited:
                        next_frontier.add(gc)
            frontier = next_frontier
    return canon_set - shadowed


def compute_topics_per_cui(all_cuis, canonicals, parents, children,
                           sibling_map=None):

    distance = {c: 0 for c in canonicals}
    nearest = {c: {c} for c in canonicals}

    # BFS frontier — only nodes newly assigned at each level
    frontier = set(canonicals)
    level = 0
    t0 = time.time()
    while frontier:
        level += 1
        next_frontier = set()
        for node in frontier:
            candidate_distance = distance[node] + 1
            for child in children.get(node, ()):
                if child not in distance:
                    # First time reaching this child
                    distance[child] = candidate_distance
                    nearest[child] = set(nearest[node])
                    next_frontier.add(child)
                elif distance[child] == candidate_distance:
                    # DAG tie at same depth — union additional canonicals
                    nearest[child] |= nearest[node]
                # else: distance[child] < candidate_distance, already closer; skip
        frontier = next_frontier
        if level % 5 == 0:
            print(f"    BFS level {level}: {len(distance):,} nodes reached "
                  f"({time.time()-t0:.0f}s elapsed)")

    cui_topics = {}
    for cui in all_cuis:
        topics = nearest.get(cui, set())
        if topics:
            if sibling_map:
                # Expand by sibling canonicals
                expanded = set(topics)
                for t in topics:
                    expanded |= sibling_map.get(t, set())
                cui_topics[cui] = expanded
            else:
                cui_topics[cui] = topics
        elif SINGLETON_FALLBACK:
            cui_topics[cui] = {cui}
    return cui_topics


# Main


def main():
    print("=" * 60)
    print(f"  cache         : {CACHE_PATH}")
    print(f"  output        : {OUTPUT_PATH}")
    print(f"  STY band      : [{STY_LOWER_PERCENTILE}, {STY_UPPER_PERCENTILE}] of "
          f"STY-descendant counts")
    print(f"  mega filter   : exclude top {100-MEGA_ROOT_PERCENTILE}% by direct children")
    print(f"  excluded CUIs : {len(CANONICAL_EXCLUDE)} "
          f"({', '.join(sorted(CANONICAL_EXCLUDE))})")

    print("\n[1/5] Loading cache ...")
    t0 = time.time()
    with open(CACHE_PATH, "rb") as f:
        cache = pickle.load(f)
    print(f"  {len(cache['cuis']):,} CUIs in {time.time()-t0:.1f}s")
    labels = cache["labels"]

    print("\n[2/5] Building IS-A graph ...")
    t0 = time.time()
    parents, children = build_isa_graph(cache)
    n_edges = sum(len(ps) for ps in parents.values())
    print(f"  {n_edges:,} IS-A edges in {time.time()-t0:.1f}s")

    print(f"\n[3/5] Finding subhierarchy parents (STY-coverage based) ...")
    t0 = time.time()
    subhier_parents, sty_lower, sty_upper, mega_thresh = find_subhierarchy_parents(
        cache["cuis"], children, cache["tags"],
    )
    print(f"  STY-descendant count cutoffs:")
    print(f"    {STY_LOWER_PERCENTILE}th percentile = {sty_lower:,} STY descendants")
    print(f"    {STY_UPPER_PERCENTILE}th percentile = {sty_upper:,} STY descendants")
    print(f"  Mega-root threshold (children-count): {mega_thresh}")
    print(f"  Found {len(subhier_parents):,} subhierarchy parents "
          f"in {time.time()-t0:.1f}s")
    print(f"\n  Top 30 subhierarchy parents (by STY-descendant count):")
    sorted_sp = sorted(
        subhier_parents.items(),
        key=lambda kv: -kv[1]["sty_descendant_count"],
    )
    for cui, info in sorted_sp[:30]:
        label = labels.get(cui, "?")
        print(f"    sty_desc={info['sty_descendant_count']:>6,d}  "
              f"children={info['n_children']:>4d}  "
              f"{cui}  {label[:50]}")
    if len(sorted_sp) > 30:
        print(f"    ... plus {len(sorted_sp) - 30} more subhier parents")

    print("\n[4/5] Extracting canonical CUIs ...")
    t0 = time.time()
    canonicals, canonical_info = extract_canonicals(subhier_parents, children)
    print(f"  Found {len(canonicals):,} canonical CUIs in "
          f"{time.time()-t0:.1f}s")

    # Compute depth from roots (for diagnostics)
    print(f"\n  Computing depth from roots ...")
    t0 = time.time()
    depth_from_root = compute_depth_from_roots(cache["cuis"], parents, children)
    print(f"  Computed in {time.time()-t0:.1f}s")

    # Drop explicitly excluded canonicals (known SNOMED admin/metadata)
    excluded_present = canonicals & CANONICAL_EXCLUDE
    if excluded_present:
        print(f"\n  Excluding {len(excluded_present)} CUI(s) from "
              f"CANONICAL_EXCLUDE:")
        for c in sorted(excluded_present):
            d = depth_from_root.get(c, "?")
            lbl = labels.get(c, "?")[:55]
            print(f"    depth={d}  {c}  {lbl}")
        canonicals -= excluded_present
        canonical_info = {c: v for c, v in canonical_info.items() if c in canonicals}
        print(f"  After exclude: {len(canonicals):,} canonicals")

    if PRUNE_STACKED_CANONICALS:
        print(f"\n  Pruning stacked canonicals (keep HIGHEST) ...")
        t0 = time.time()
        n_before = len(canonicals)
        canonicals = prune_stacked_canonicals(canonicals, children)
        canonical_info = {c: canonical_info[c] for c in canonicals if c in canonical_info}
        n_dropped = n_before - len(canonicals)
        print(f"  Pruned {n_dropped:,} descendant canonicals "
              f"in {time.time()-t0:.1f}s")
    else:
        print(f"\n  Skipping stacked-canonical pruning (allow nested canonicals)")
        print(f"  Nearest-canonical BFS will naturally pick closest one")
    print(f"  Final canonicals: {len(canonicals):,}")

    print(f"\n  Top 30 canonicals (by STY-descendant count):")
    sorted_canon = sorted(
        canonical_info.items(),
        key=lambda kv: -kv[1]["sty_descendant_count"],
    )
    for cui, info in sorted_canon[:30]:
        cui_label = labels.get(cui, "?")
        print(f"    sty_desc={info['sty_descendant_count']:>6,d}  "
              f"children={info['n_children']:>4d}  "
              f"{cui}  {cui_label[:50]}")

    # Build sibling-canonical index if expansion is enabled
    sibling_map = None
    if SIBLING_EXPANSION:
        print(f"\n  Building sibling-canonical index ...")
        t0 = time.time()
        sibling_map = build_sibling_canonical_index(canonicals, parents)
        n_with_siblings = sum(1 for s in sibling_map.values() if s)
        avg_siblings = (sum(len(s) for s in sibling_map.values()) /
                        max(len(sibling_map), 1))
        print(f"  {n_with_siblings:,} canonicals have at least one sibling "
              f"in {time.time()-t0:.1f}s")
        print(f"  Average siblings per canonical (among those with any): "
              f"{avg_siblings:.1f}")

    print("\n[5/5] Computing nearest-canonical topics (multi-source downward BFS) ...")
    print(f"  (singleton fallback: {SINGLETON_FALLBACK}, "
          f"sibling expansion: {SIBLING_EXPANSION})")
    t0 = time.time()
    cui_topics = compute_topics_per_cui(
        sorted(cache["cuis"]), canonicals, parents, children,
        sibling_map=sibling_map,
    )
    print(f"  {len(cui_topics):,} CUIs have at least one topic "
          f"in {time.time()-t0:.1f}s")

    topic_to_cuis = defaultdict(set)
    cui_topic_ids = {}
    for cui, canon_set in cui_topics.items():
        tids = {hash_topic(c) for c in canon_set}
        cui_topic_ids[cui] = tids
        for tid in tids:
            topic_to_cuis[tid].add(cui)

    topic_to_canonical = {hash_topic(c): c for c in canonicals}

    print("\n" + "=" * 60)
    print("RESULTS")
    print("=" * 60)
    n_topics_per_cui = [len(ts) for ts in cui_topic_ids.values()]
    n_topics_distribution = Counter(n_topics_per_cui)
    avg_topics = sum(n_topics_per_cui) / len(n_topics_per_cui) if n_topics_per_cui else 0
    print(f"  Total CUIs                  : {len(cache['cuis']):,}")
    print(f"  CUIs with at least 1 topic  : {len(cui_topic_ids):,} "
          f"({100*len(cui_topic_ids)/len(cache['cuis']):.1f}%)")
    print(f"  Total canonical CUIs        : {len(canonicals):,}")
    print(f"  Average topics per CUI      : {avg_topics:.2f}")
    print(f"\n  Distribution: topics per CUI:")
    for n_topics in sorted(n_topics_distribution.keys()):
        n_cuis = n_topics_distribution[n_topics]
        pct = 100 * n_cuis / len(cui_topic_ids)
        if n_topics <= 10 or n_topics % 5 == 0:
            print(f"    {n_topics:>3d} topics : {n_cuis:>7,d} CUIs ({pct:5.1f}%)")

    print(f"\n  Top 30 topics by CUI membership:")
    sorted_topics = sorted(
        topic_to_cuis.items(),
        key=lambda kv: -len(kv[1]),
    )
    for tid, cuis_in_topic in sorted_topics[:30]:
        canon_cui = topic_to_canonical[tid]
        canon_label = labels.get(canon_cui, "?")
        print(f"    {len(cuis_in_topic):>7,d} CUIs  {tid}  -> {canon_cui}  "
              f"({canon_label[:50]})")


    # Additional diagnostics 

    # 1. Canonical depth from roots (depth_from_root already computed earlier)
    print(f"\n  Diagnostic: canonical depth from roots")
    canon_depths = [depth_from_root.get(c, -1) for c in canonicals]
    depth_counter = Counter(canon_depths)
    for d in sorted(depth_counter.keys()):
        if d == -1:
            print(f"    depth=unknown : {depth_counter[d]:>5,d}")
        else:
            print(f"    depth={d:>3d}     : {depth_counter[d]:>5,d}")

    # 2. Multi-parent multiplicity (CUIs with multiple IS-A parents)
    multi_parent_cuis = [c for c in cache["cuis"] if len(parents.get(c, ())) > 1]
    multi_parent_topic_counts = Counter()
    for c in multi_parent_cuis:
        n = len(cui_topic_ids.get(c, set()))
        multi_parent_topic_counts[n] += 1
    print(f"\n  Diagnostic: multi-parent CUIs (DAG nodes)")
    print(f"    total multi-parent CUIs   : {len(multi_parent_cuis):,}")
    print(f"    topic-count distribution among them:")
    for n in sorted(multi_parent_topic_counts.keys()):
        pct = 100 * multi_parent_topic_counts[n] / max(len(multi_parent_cuis), 1)
        print(f"      {n:>3d} topics : {multi_parent_topic_counts[n]:>6,d} "
              f"CUIs ({pct:5.1f}%)")

    # 3. Orphan coverage by STY
    cuis_without_topic = set(cache["cuis"]) - set(cui_topic_ids.keys())
    print(f"\n  Diagnostic: orphan coverage by semantic type")
    print(f"    total orphans (no topic) : {len(cuis_without_topic):,}")
    sty_orphan_counts = Counter()
    sty_total_counts = Counter()
    for c in cache["cuis"]:
        for sty in cache["tags"].get(c, frozenset()):
            sty_total_counts[sty] += 1
            if c in cuis_without_topic:
                sty_orphan_counts[sty] += 1
    print(f"    top 20 STYs by orphan count:")
    for sty, n_orphan in sty_orphan_counts.most_common(20):
        n_total = sty_total_counts[sty]
        pct = 100 * n_orphan / n_total if n_total else 0
        print(f"      {n_orphan:>6,d} / {n_total:>7,d}  "
              f"({pct:5.1f}%)  {sty}")

    print("\n[Saving]")
    t0 = time.time()
    payload = {
        "built_at": datetime.datetime.now().isoformat(),
        "cache_fetched_at": cache.get("fetched_at"),
        "config": {
            "detection": "STY-descendant percentile + mega-root filter",
            "sty_lower_percentile": STY_LOWER_PERCENTILE,
            "sty_upper_percentile": STY_UPPER_PERCENTILE,
            "mega_root_percentile": MEGA_ROOT_PERCENTILE,
            "actual_sty_lower": sty_lower,
            "actual_sty_upper": sty_upper,
            "actual_mega_root_threshold": mega_thresh,
            "canonical_exclude": sorted(CANONICAL_EXCLUDE),
            "topic_assignment": "nearest canonical via multi-source downward BFS",
            "prune_stacked_canonicals": PRUNE_STACKED_CANONICALS,
            "sibling_expansion": SIBLING_EXPANSION,
            "singleton_fallback": SINGLETON_FALLBACK,
        },
        "subhierarchy_parents": subhier_parents,
        "canonicals":          canonicals,
        "canonical_info":      canonical_info,
        "cui_topic_ids":       cui_topic_ids,
        "topic_to_canonical":  topic_to_canonical,
        "topic_to_cuis":       dict(topic_to_cuis),
        "labels":              cache["labels"],
        "tags":                cache["tags"],
    }
    with open(OUTPUT_PATH, "wb") as f:
        pickle.dump(payload, f, protocol=pickle.HIGHEST_PROTOCOL)
    size_mb = os.path.getsize(OUTPUT_PATH) / 1024 / 1024
    print(f"  wrote {size_mb:.1f} MB in {time.time()-t0:.1f}s")
    print("\n" + "=" * 60)
    print(f"DONE — {OUTPUT_PATH}")
    print("=" * 60)


main()

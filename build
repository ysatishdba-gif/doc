"""
build_topics.py
---------------
Build CUI -> [topic_ids] lookup via multi-RELA topic graph + K-hop closure.

ARCHITECTURE:

  1. Canonicals (= topic anchors) are detected by their STY-DESCENDANT
     COUNT — how many of their descendants carry any UMLS semantic
     type. A node with many STY-bearing descendants organizes
     clinically meaningful content.

     We use a percentile cut (top 25% by default) on this distribution.
     Plus a mega-root exclusion (top 1% by direct children count) to
     prevent SNOMED roots from absorbing the whole ontology.

  2. A small explicit set of known SNOMED admin CUIs is excluded
     (CANONICAL_EXCLUDE). Currently just C2720507.

  3. Each CUI's topics = NEAREST canonical ancestors via multi-source
     downward BFS from all canonicals at once.

EMPIRICAL VALIDATION (374K CUIs):
  - 95.9% coverage
  - Pneumonia, MI, Diabetes, Stroke etc. get sensible clinical topics
  - Granular concepts (BP, HR, knee pain) get granular topics
  - Build runs in ~25 seconds

USAGE (GCP notebook): paste the contents of this file into a cell.
The call to main() at the bottom runs the build.
"""

import datetime
import hashlib
import pickle
import os
import time
from collections import defaultdict, Counter, deque


CACHE_PATH = "umls_cache.pkl"
OUTPUT_PATH = "topic_lookup.pkl"

# Percentile cuts on the graph's own distributions.
# These describe shape, not magnitude — they scale with whatever
# SNOMED looks like.
STY_LOWER_PERCENTILE = 75
STY_UPPER_PERCENTILE = 100   # no upper bound — let big organizers in
MEGA_ROOT_PERCENTILE = 99    # exclude top 1% by direct children count

# Explicit list of CUIs to exclude from the canonical set.
# Empirical: C2720507 is the SNOMED metadata pseudo-root that ends up
# as the topic for ~12K otherwise-unanchored CUIs.
CANONICAL_EXCLUDE = {
    "C2720507",  # SNOMED CT has been created by combining SNOMED RT...
}

# Maximum number of hops away a canonical can be from a CUI and still
# become one of that CUI's topics. Setting this higher than 1 enables
# cross-axis topics (e.g. Pneumonia at distance 1 via IS-A from DISEASE,
# at distance 2 via finding_site_of -> Lung -> IS-A from ANATOMY).
#
# Higher value = more topics per CUI = wider retrieval recall.
# Lower value = tighter topics, mostly single-axis.
MAX_TOPIC_HOPS = 3

# ============================================================================
# RELA inclusion for the TOPIC GRAPH
# ============================================================================
# We include ALL (REL, RELA) pairs from the cache, EXCEPT literal inverse
# duplicates. No clinical curation. The inverse-pair detection runs at
# build time over the actual cache contents.
#
# Two RELAs are inverse pairs if:
#   - Their edge counts match (allowing small UMLS quirks)
#   - For sampled edges in one, the reversed edge exists in the other
#
# For each inverse pair we keep ONE side (deterministically: the one
# whose RELA name sorts first). The other is dropped to avoid counting
# the same semantic edge twice.



# ============================================================================
# Helpers
# ============================================================================

def build_isa_graph(cache):
    """parents[child] -> set of direct IS-A parents
       children[parent] -> set of direct IS-A children

    USED FOR CANONICAL SELECTION ONLY.
    """
    parents = defaultdict(set)
    children = defaultdict(set)
    for cui1, cui2, rel, rela in cache["mrrel_rows"]:
        if rel == "CHD" and rela == "isa":
            parents[cui2].add(cui1)
            children[cui1].add(cui2)
    return parents, children


def detect_inverse_pairs(cache, sample_size=200, count_tol=0.02):
    """
    Detect inverse-pair (REL, RELA)s from the cache itself.

    Two (REL, RELA) keys A and B are inverse pairs if:
      - Their edge counts match within count_tol relative tolerance
      - For sampled edges (a, b) under A, the reversed edge (b, a) exists
        under B in the cache

    For each detected inverse pair, we keep one side and drop the other.
    Selection rule: keep the side whose RELA name sorts first
    alphabetically (deterministic, no semantic choice).

    Returns:
        included_relas: set of (REL, RELA) tuples to use
        dropped_relas:  set of (REL, RELA) tuples dropped (inverse duplicates)
        pair_map:       dict[(REL, RELA)] -> (REL', RELA') showing which pair
                        each dropped key was matched against
    """
    # Bucket all edges by (REL, RELA)
    edges_by_key = defaultdict(list)
    edge_set_by_key = defaultdict(set)
    for cui1, cui2, rel, rela in cache["mrrel_rows"]:
        key = (rel, rela)
        edges_by_key[key].append((cui1, cui2))
        edge_set_by_key[key].add((cui1, cui2))

    counts = {k: len(v) for k, v in edges_by_key.items()}
    keys = list(counts.keys())

    # Build candidate inverse pairs by count similarity
    candidate_pairs = []
    for i, ka in enumerate(keys):
        for kb in keys[i+1:]:
            ca, cb = counts[ka], counts[kb]
            if ca == 0 or cb == 0:
                continue
            ratio = abs(ca - cb) / max(ca, cb)
            if ratio <= count_tol:
                candidate_pairs.append((ka, kb))

    # Verify each candidate by sampling
    verified_pairs = []
    for (ka, kb) in candidate_pairs:
        edges_a = edges_by_key[ka]
        edges_b_set = edge_set_by_key[kb]
        # Sample up to sample_size edges from A; check if reversed is in B
        sample = edges_a[:sample_size]
        n_reversed = sum(
            1 for (a, b) in sample if (b, a) in edges_b_set
        )
        # Threshold: >=90% of samples must have reversed counterpart
        if n_reversed >= 0.9 * len(sample):
            verified_pairs.append((ka, kb))

    # Build pair_map and decide which to drop
    dropped = set()
    pair_map = {}

    # Special rule: when one side of a pair is CHD/isa, ALWAYS keep CHD/isa
    # (downstream canonical-selection code reads the IS-A direction).
    # This is the only hardcoded choice; all other pairs use alphabetic order.
    ISA_KEY = ("CHD", "isa")

    for (ka, kb) in verified_pairs:
        ra, rb = ka[1], kb[1]
        if ka == ISA_KEY:
            kept, dropped_one = ka, kb
        elif kb == ISA_KEY:
            kept, dropped_one = kb, ka
        elif ra <= rb:
            kept, dropped_one = ka, kb
        else:
            kept, dropped_one = kb, ka
        if dropped_one in dropped:
            continue
        dropped.add(dropped_one)
        pair_map[dropped_one] = kept

    included = set(keys) - dropped
    return included, dropped, pair_map



def build_topic_graph(cache, included_relas):
    """Build the UNDIRECTED multi-RELA topic graph used for topic assignment.

    Returns:
        topic_neighbors[cui] -> set of CUIs connected via any included RELA
        rela_edge_counts -> dict[(rel, rela)] -> int

    Every included RELA contributes BIDIRECTIONAL edges. The K-hop closure
    BFS walks all neighbors, so a CUI can reach a canonical via any path on
    this combined graph.

    Each MRREL row is counted once even though we add edges both ways.
    """
    topic_neighbors = defaultdict(set)
    rela_edge_counts = Counter()

    for cui1, cui2, rel, rela in cache["mrrel_rows"]:
        key = (rel, rela)
        if key not in included_relas:
            continue
        if cui1 == cui2:
            continue  # skip self-loops
        topic_neighbors[cui1].add(cui2)
        topic_neighbors[cui2].add(cui1)
        rela_edge_counts[key] += 1

    return topic_neighbors, rela_edge_counts


def percentile_value(sorted_values, p):
    """Get the value at percentile p (0-100) from a sorted list."""
    if not sorted_values:
        return 0
    idx = min(int(len(sorted_values) * p / 100), len(sorted_values) - 1)
    return sorted_values[idx]


def hash_topic(cui):
    """Stable hash for a canonical CUI -> topic ID."""
    return "tp_" + hashlib.sha1(cui.encode()).hexdigest()[:12]


def compute_depth_from_roots(cuis, parents, children):
    """Returns dict[cui] -> minimum BFS depth from any IS-A root."""
    roots = {c for c in cuis if not parents.get(c)}
    depth = {}
    dq = deque((r, 0) for r in roots)
    while dq:
        cui, d = dq.popleft()
        if cui in depth and depth[cui] <= d:
            continue
        depth[cui] = d
        for ch in children.get(cui, ()):
            dq.append((ch, d + 1))
    return depth


# ============================================================================
# Canonical detection (STY-coverage based)
# ============================================================================

def find_subhierarchy_parents(cuis, children, tags):
    """
    A CUI qualifies as canonical if BOTH:
      (1) STY-bearing-descendant count is in [STY_LOWER_PERCENTILE,
          STY_UPPER_PERCENTILE] of the graph's distribution. Measures
          how much typed content the node organizes — a better proxy
          for clinical centrality than raw children-count.
      (2) Direct children-count is NOT in the top MEGA_ROOT_PERCENTILE
          (excludes mega-roots that would absorb most of the ontology).
    """
    # Compute STY-descendant-count for every non-leaf node
    sty_desc_count = {}
    desc_cache = {}

    def descendants(c):
        if c in desc_cache:
            return desc_cache[c]
        visited = {c}
        frontier = {c}
        while frontier:
            nxt = set()
            for n in frontier:
                for ch in children.get(n, ()):
                    if ch not in visited:
                        visited.add(ch)
                        nxt.add(ch)
            frontier = nxt
        desc_cache[c] = visited
        return visited

    non_leaf = [c for c in cuis if children.get(c)]
    for cui in non_leaf:
        desc = descendants(cui)
        n_sty_desc = sum(1 for d in desc if tags.get(d))
        sty_desc_count[cui] = n_sty_desc

    cc = {c: len(children.get(c, ())) for c in non_leaf}

    sorted_sty = sorted(sty_desc_count.values())
    sty_lower = percentile_value(sorted_sty, STY_LOWER_PERCENTILE)
    sty_upper = percentile_value(sorted_sty, STY_UPPER_PERCENTILE)

    sorted_cc = sorted(cc.values())
    mega_root_threshold = percentile_value(sorted_cc, MEGA_ROOT_PERCENTILE)

    found = {}
    for cui in non_leaf:
        n_sty_desc = sty_desc_count[cui]
        n_children = cc[cui]
        if not (sty_lower <= n_sty_desc <= sty_upper):
            continue
        if n_children > mega_root_threshold:
            continue
        found[cui] = {
            "n_children": n_children,
            "sty_descendant_count": n_sty_desc,
        }
    return found, sty_lower, sty_upper, mega_root_threshold


def extract_canonicals(subhier_parents):
    """Canonicals = the subhierarchy parents themselves."""
    canonicals = set(subhier_parents.keys())
    canonical_info = {
        c: {
            "n_children": subhier_parents[c]["n_children"],
            "sty_descendant_count": subhier_parents[c]["sty_descendant_count"],
        }
        for c in canonicals
    }
    return canonicals, canonical_info


# ============================================================================
# Topic assignment (multi-source downward BFS)
# ============================================================================

def compute_topics_per_cui(all_cuis, canonicals, neighbors, max_hops):
    """
    Topics-within-K-hops on UNDIRECTED multi-RELA graph.

    For each non-canonical CUI v: topics(v) = { c in canonicals :
        shortest_path(c, v) on the topic graph <= max_hops }

    For each canonical c: topics(c) = { c } union any canonicals reachable
    within max_hops via the graph.

    Algorithm (level-synchronous multi-source BFS with explicit per-node
    minimum distance):

        Initialize: distance[c] = 0, topics[c] = {c} for each canonical
        For hop d in 1..max_hops:
            For each node n with distance[n] == d-1:
                For each neighbor nb of n:
                    If nb not yet visited:
                        distance[nb] = d
                        topics[nb] = topics[n].copy()
                        mark nb as frontier_next
                    Else if distance[nb] >= d-1 (within range to absorb):
                        # nb is reachable at distance <= d-1 from at least one
                        # canonical; merging n's canonicals adds any canonicals
                        # that are at distance d from nb via this path.
                        topics[nb] |= topics[n]

    This formulation makes the K-hop bound explicit per node.

    Returns cui_topics: dict[cui] -> set of canonical CUIs within max_hops.
    """
    # distance[v] = shortest distance from any canonical to v
    distance = {c: 0 for c in canonicals}
    # topics[v] = set of canonicals c with shortest_path(c, v) <= distance[v]
    topics = {c: {c} for c in canonicals}

    # Frontier at hop d-1 = nodes whose canonicals must be propagated outward
    frontier = set(canonicals)

    t0 = time.time()
    for d in range(1, max_hops + 1):
        next_frontier = set()
        for node in frontier:
            node_topics = topics[node]
            for nb in neighbors.get(node, ()):
                if nb not in distance:
                    # First reach: shortest distance from any canonical is d
                    distance[nb] = d
                    topics[nb] = set(node_topics)
                    next_frontier.add(nb)
                elif distance[nb] == d:
                    # Already reached at distance d; tie path — union additions
                    if not node_topics <= topics[nb]:
                        topics[nb] |= node_topics
                        next_frontier.add(nb)
                # else: distance[nb] < d, already closer via another canonical;
                #       still merge so that canonicals at hop d via this path
                #       are also included (this is what makes it K-hop closure,
                #       not nearest-canonical-only)
                else:  # distance[nb] < d
                    if not node_topics <= topics[nb]:
                        topics[nb] |= node_topics
                        next_frontier.add(nb)
        print(f"    Hop {d}: total={len(topics):,} reached, "
              f"frontier_next={len(next_frontier):,} "
              f"({time.time()-t0:.1f}s elapsed)")
        if not next_frontier:
            break
        frontier = next_frontier

    cui_topics = {}
    for cui in all_cuis:
        t = topics.get(cui)
        if t:
            cui_topics[cui] = t
    return cui_topics


# ============================================================================
# Main
# ============================================================================

def main():
    print("=" * 60)
    print("Topic builder (multi-RELA, K-hop closure)")
    print("=" * 60)
    print(f"  cache         : {CACHE_PATH}")
    print(f"  output        : {OUTPUT_PATH}")
    print(f"  STY band      : [{STY_LOWER_PERCENTILE}, {STY_UPPER_PERCENTILE}] of "
          f"STY-descendant counts")
    print(f"  mega filter   : exclude top {100-MEGA_ROOT_PERCENTILE}% by direct children")
    print(f"  excluded CUIs : {len(CANONICAL_EXCLUDE)} "
          f"({', '.join(sorted(CANONICAL_EXCLUDE))})")
    print(f"  RELAs        : auto-detect (all non-inverse-duplicate)")
    print(f"  max topic hops       : {MAX_TOPIC_HOPS}")

    print("\n[1/6] Loading cache ...")
    t0 = time.time()
    with open(CACHE_PATH, "rb") as f:
        cache = pickle.load(f)
    print(f"  {len(cache['cuis']):,} CUIs in {time.time()-t0:.1f}s")
    labels = cache["labels"]

    print("\n[2/6] Building IS-A graph (used for canonical selection) ...")
    t0 = time.time()
    parents, children = build_isa_graph(cache)
    n_edges = sum(len(ps) for ps in parents.values())
    print(f"  {n_edges:,} IS-A edges in {time.time()-t0:.1f}s")

    print(f"\n[3a/6] Detecting inverse-pair RELAs (dedup) ...")
    t0 = time.time()
    included_relas, dropped_relas, pair_map = detect_inverse_pairs(cache)
    print(f"  Total distinct (REL, RELA) pairs in cache: "
          f"{len(included_relas) + len(dropped_relas)}")
    print(f"  Detected as inverse duplicates (dropped): {len(dropped_relas)}")
    print(f"  -> Using {len(included_relas)} RELAs for topic graph")
    print(f"  Detection took {time.time()-t0:.1f}s")
    if dropped_relas:
        print(f"\n  Sample of dropped inverse-pair RELAs (showing first 10):")
        for dropped in sorted(dropped_relas)[:10]:
            kept = pair_map[dropped]
            print(f"    DROP {dropped[0]}/{dropped[1]:<35s} "
                  f"(inverse of {kept[0]}/{kept[1]})")
        if len(dropped_relas) > 10:
            print(f"    ... plus {len(dropped_relas) - 10} more dropped")

    print(f"\n[3b/6] Building UNDIRECTED multi-RELA topic graph "
          f"({len(included_relas)} RELA types) ...")
    t0 = time.time()
    topic_neighbors, rela_edge_counts = build_topic_graph(
        cache, included_relas,
    )
    n_input_rows = sum(c for c in rela_edge_counts.values())
    n_undirected_edges = sum(len(s) for s in topic_neighbors.values()) // 2
    n_cuis = len(topic_neighbors)
    print(f"  {n_input_rows:,} MRREL rows across {len(rela_edge_counts)} RELAs "
          f"in {time.time()-t0:.1f}s")
    print(f"  -> {n_undirected_edges:,} undirected edges in topic graph")
    print(f"  {n_cuis:,} CUIs have at least one topic-graph neighbor")
    avg_degree = (2 * n_undirected_edges) / max(n_cuis, 1)
    print(f"  Average degree: {avg_degree:.1f} neighbors per CUI")
    print(f"\n  Top 15 RELAs by edge count:")
    for (rel, rela), n in sorted(rela_edge_counts.items(), key=lambda kv: -kv[1])[:15]:
        print(f"    {n:>8,d}  {rel:<4} {rela}")

    print(f"\n[4/6] Finding subhierarchy parents (STY-coverage on IS-A graph) ...")
    t0 = time.time()
    subhier_parents, sty_lower, sty_upper, mega_thresh = find_subhierarchy_parents(
        cache["cuis"], children, cache["tags"],
    )
    print(f"  STY-descendant count cutoffs:")
    print(f"    {STY_LOWER_PERCENTILE}th percentile = {sty_lower:,} STY descendants")
    print(f"    {STY_UPPER_PERCENTILE}th percentile = {sty_upper:,} STY descendants")
    print(f"  Mega-root threshold (children-count): {mega_thresh}")
    print(f"  Found {len(subhier_parents):,} subhierarchy parents "
          f"in {time.time()-t0:.1f}s")
    print(f"\n  Top 30 subhierarchy parents (by STY-descendant count):")
    sorted_sp = sorted(
        subhier_parents.items(),
        key=lambda kv: -kv[1]["sty_descendant_count"],
    )
    for cui, info in sorted_sp[:30]:
        label = labels.get(cui, "?")
        print(f"    sty_desc={info['sty_descendant_count']:>6,d}  "
              f"children={info['n_children']:>4d}  "
              f"{cui}  {label[:50]}")
    if len(sorted_sp) > 30:
        print(f"    ... plus {len(sorted_sp) - 30} more subhier parents")

    print("\n[5/6] Extracting canonical CUIs ...")
    t0 = time.time()
    canonicals, canonical_info = extract_canonicals(subhier_parents)
    print(f"  Found {len(canonicals):,} canonical CUIs in "
          f"{time.time()-t0:.1f}s")

    # Compute depth from roots (for both exclude reporting and diagnostics)
    print(f"\n  Computing depth from IS-A roots ...")
    t0 = time.time()
    depth_from_root = compute_depth_from_roots(cache["cuis"], parents, children)
    print(f"  Computed in {time.time()-t0:.1f}s")

    # Drop explicitly excluded canonicals (known SNOMED admin/metadata)
    excluded_present = canonicals & CANONICAL_EXCLUDE
    if excluded_present:
        print(f"\n  Excluding {len(excluded_present)} CUI(s) from "
              f"CANONICAL_EXCLUDE:")
        for c in sorted(excluded_present):
            d = depth_from_root.get(c, "?")
            lbl = labels.get(c, "?")[:55]
            print(f"    depth={d}  {c}  {lbl}")
        canonicals -= excluded_present
        canonical_info = {c: v for c, v in canonical_info.items() if c in canonicals}
    print(f"  Final canonicals: {len(canonicals):,}")

    print(f"\n  Top 30 canonicals (by STY-descendant count):")
    sorted_canon = sorted(
        canonical_info.items(),
        key=lambda kv: -kv[1]["sty_descendant_count"],
    )
    for cui, info in sorted_canon[:30]:
        cui_label = labels.get(cui, "?")
        print(f"    sty_desc={info['sty_descendant_count']:>6,d}  "
              f"children={info['n_children']:>4d}  "
              f"{cui}  {cui_label[:50]}")

    print(f"\n[6/6] Computing topics via multi-RELA BFS (max_hops={MAX_TOPIC_HOPS}) ...")
    t0 = time.time()
    cui_topics = compute_topics_per_cui(
        sorted(cache["cuis"]), canonicals, topic_neighbors, MAX_TOPIC_HOPS,
    )
    print(f"  {len(cui_topics):,} CUIs have at least one topic "
          f"in {time.time()-t0:.1f}s")

    topic_to_cuis = defaultdict(set)
    cui_topic_ids = {}
    for cui, canon_set in cui_topics.items():
        tids = {hash_topic(c) for c in canon_set}
        cui_topic_ids[cui] = tids
        for tid in tids:
            topic_to_cuis[tid].add(cui)

    topic_to_canonical = {hash_topic(c): c for c in canonicals}

    # ---------------- RESULTS ----------------

    print("\n" + "=" * 60)
    print("RESULTS")
    print("=" * 60)
    n_topics_per_cui = [len(ts) for ts in cui_topic_ids.values()]
    n_topics_distribution = Counter(n_topics_per_cui)
    avg_topics = sum(n_topics_per_cui) / len(n_topics_per_cui) if n_topics_per_cui else 0
    print(f"  Total CUIs                  : {len(cache['cuis']):,}")
    print(f"  CUIs with at least 1 topic  : {len(cui_topic_ids):,} "
          f"({100*len(cui_topic_ids)/len(cache['cuis']):.1f}%)")
    print(f"  Total canonical CUIs        : {len(canonicals):,}")
    print(f"  Average topics per CUI      : {avg_topics:.2f}")
    print(f"\n  Distribution: topics per CUI:")
    for n_topics in sorted(n_topics_distribution.keys()):
        n_cuis = n_topics_distribution[n_topics]
        pct = 100 * n_cuis / len(cui_topic_ids)
        if n_topics <= 10 or n_topics % 5 == 0:
            print(f"    {n_topics:>3d} topics : {n_cuis:>7,d} CUIs ({pct:5.1f}%)")

    print(f"\n  Top 30 topics by CUI membership:")
    sorted_topics = sorted(
        topic_to_cuis.items(),
        key=lambda kv: -len(kv[1]),
    )
    for tid, cuis_in_topic in sorted_topics[:30]:
        canon_cui = topic_to_canonical[tid]
        canon_label = labels.get(canon_cui, "?")
        print(f"    {len(cuis_in_topic):>7,d} CUIs  {tid}  -> {canon_cui}  "
              f"({canon_label[:50]})")

    # ---------------- DIAGNOSTICS ----------------

    # 1. Canonical depth from roots
    print(f"\n  Diagnostic: canonical depth from roots")
    canon_depths = [depth_from_root.get(c, -1) for c in canonicals]
    depth_counter = Counter(canon_depths)
    for d in sorted(depth_counter.keys()):
        if d == -1:
            print(f"    depth=unknown : {depth_counter[d]:>5,d}")
        else:
            print(f"    depth={d:>3d}     : {depth_counter[d]:>5,d}")

    # 2. Multi-parent multiplicity (CUIs with multiple IS-A parents)
    multi_parent_cuis = [c for c in cache["cuis"] if len(parents.get(c, ())) > 1]
    multi_parent_topic_counts = Counter()
    for c in multi_parent_cuis:
        n = len(cui_topic_ids.get(c, set()))
        multi_parent_topic_counts[n] += 1
    print(f"\n  Diagnostic: multi-parent CUIs (DAG nodes)")
    print(f"    total multi-parent CUIs   : {len(multi_parent_cuis):,}")
    print(f"    topic-count distribution among them:")
    for n in sorted(multi_parent_topic_counts.keys()):
        pct = 100 * multi_parent_topic_counts[n] / max(len(multi_parent_cuis), 1)
        print(f"      {n:>3d} topics : {multi_parent_topic_counts[n]:>6,d} "
              f"CUIs ({pct:5.1f}%)")

    # 3. Orphan coverage by STY
    cuis_without_topic = set(cache["cuis"]) - set(cui_topic_ids.keys())
    print(f"\n  Diagnostic: orphan coverage by semantic type")
    print(f"    total orphans (no topic) : {len(cuis_without_topic):,}")
    sty_orphan_counts = Counter()
    sty_total_counts = Counter()
    for c in cache["cuis"]:
        for sty in cache["tags"].get(c, frozenset()):
            sty_total_counts[sty] += 1
            if c in cuis_without_topic:
                sty_orphan_counts[sty] += 1
    print(f"    top 20 STYs by orphan count:")
    for sty, n_orphan in sty_orphan_counts.most_common(20):
        n_total = sty_total_counts[sty]
        pct = 100 * n_orphan / n_total if n_total else 0
        print(f"      {n_orphan:>6,d} / {n_total:>7,d}  "
              f"({pct:5.1f}%)  {sty}")

    # ---------------- SAVE ----------------

    print("\n[Saving]")
    t0 = time.time()
    payload = {
        "built_at": datetime.datetime.now().isoformat(),
        "cache_fetched_at": cache.get("fetched_at"),
        "config": {
            "detection": "STY-descendant percentile + mega-root filter (IS-A only)",
            "sty_lower_percentile": STY_LOWER_PERCENTILE,
            "sty_upper_percentile": STY_UPPER_PERCENTILE,
            "mega_root_percentile": MEGA_ROOT_PERCENTILE,
            "actual_sty_lower": sty_lower,
            "actual_sty_upper": sty_upper,
            "actual_mega_root_threshold": mega_thresh,
            "canonical_exclude": sorted(CANONICAL_EXCLUDE),
            "topic_assignment": "all-canonicals-within-K-hops via multi-RELA undirected BFS",
            "max_topic_hops": MAX_TOPIC_HOPS,
            "rela_inclusion": "auto-detect: all RELAs in cache minus inverse-pair duplicates",
            "included_relas": sorted(
                f"{rel}/{rela}" for (rel, rela) in included_relas
            ),
            "n_included_relas": len(included_relas),
            "dropped_inverse_relas": sorted(
                f"{rel}/{rela}" for (rel, rela) in dropped_relas
            ),
            "rela_edge_counts": {
                f"{rel}/{rela}": c
                for (rel, rela), c in rela_edge_counts.items()
            },
        },
        "subhierarchy_parents": subhier_parents,
        "canonicals":          canonicals,
        "canonical_info":      canonical_info,
        "cui_topic_ids":       cui_topic_ids,
        "topic_to_canonical":  topic_to_canonical,
        "topic_to_cuis":       dict(topic_to_cuis),
        "labels":              cache["labels"],
        "tags":                cache["tags"],
    }
    with open(OUTPUT_PATH, "wb") as f:
        pickle.dump(payload, f, protocol=pickle.HIGHEST_PROTOCOL)
    size_mb = os.path.getsize(OUTPUT_PATH) / 1024 / 1024
    print(f"  wrote {size_mb:.1f} MB in {time.time()-t0:.1f}s")
    print("\n" + "=" * 60)
    print(f"DONE — {OUTPUT_PATH}")
    print("=" * 60)


main()

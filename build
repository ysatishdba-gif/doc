"""
compare_graph_vs_mrrel.py
-------------------------
Side-by-side comparison of:
  - Graph-based CUI neighbors (1-hop from the suffix-bridge graph)
  - MRREL-based topics (from existing topic_lookup.pkl)

For each focal CUI, prints:
  - Its graph neighbors (with labels)
  - Its MRREL IS-A topics (with labels)
  - Its MRREL RELA topics (with labels)
  - Overlap analysis: which graph neighbors are also MRREL topics?

Run in notebook AFTER:
  - `data` is loaded (the network graph)
  - umls_cache.pkl is available
  - topic_lookup.pkl is available (the dual MRREL build)
"""

import pickle
from collections import defaultdict


# ============================================================================
# Config
# ============================================================================

CACHE_PATH = "umls_cache.pkl"
MRREL_PICKLE_PATH = "topic_lookup.pkl"  # the dual IS-A + RELA build

FOCAL_CUIS = [
    "C0032285",  # Pneumonia
    "C0021368",  # Inflammation
    "C0024109",  # Lung
    "C0011849",  # Diabetes
    "C1527304",  # Allergic reaction
    "C0559470",  # Peanut allergy  -- the key test case
    "C0002792",  # Anaphylaxis
    "C0013182",  # Drug allergy
    "C0020517",  # Hypersensitivity
]


# ============================================================================
# Helpers
# ============================================================================

def is_pure_cui(node):
    return isinstance(node, str) and node.startswith("C") and "-" not in node and node != "CUI"


def cui_of(suffix_node):
    if "-" not in suffix_node:
        return suffix_node
    return suffix_node.rsplit("-", 1)[0]


def graph_neighbors(g, cui, snomed_cuis):
    """1-hop conservative neighbors (SNOMED-only)."""
    if cui not in g:
        return set()
    nbrs = set()
    for suffix in g.successors(cui):
        if "-" not in suffix:
            continue
        for pred in g.predecessors(suffix):
            if pred == cui or pred == "CUI" or "-" not in pred:
                continue
            other_cui = cui_of(pred)
            if other_cui != cui and other_cui in snomed_cuis:
                nbrs.add(other_cui)
    return nbrs


# ============================================================================
# Main
# ============================================================================

# Load MRREL-based pickle
print(f"Loading {MRREL_PICKLE_PATH} ...")
with open(MRREL_PICKLE_PATH, "rb") as f:
    payload = pickle.load(f)
labels = payload["labels"]
tags = payload["tags"]
isa_map = payload["isa_cui_topic_ids"]
rela_map = payload["rela_cui_topic_ids"]
topic_to_canon = payload["topic_to_canonical"]
canonicals_set = payload["canonicals"]

# Load cache for SNOMED CUI set
print(f"Loading {CACHE_PATH} ...")
with open(CACHE_PATH, "rb") as f:
    cache = pickle.load(f)
SNOMED_CUIS = cache["cuis"]


def lbl(c):
    return labels.get(c, "?")[:40]


for cui in FOCAL_CUIS:
    print("\n" + "=" * 100)
    print(f"  {cui}  '{lbl(cui)}'")
    print("=" * 100)

    # GRAPH neighbors
    g_nbrs = graph_neighbors(data, cui, SNOMED_CUIS)
    print(f"\n  GRAPH neighbors ({len(g_nbrs)} CUIs, 1-hop conservative):")
    for n in sorted(g_nbrs)[:20]:
        is_canon = " [CANONICAL]" if n in canonicals_set else ""
        print(f"    {n}  {lbl(n)}{is_canon}")
    if len(g_nbrs) > 20:
        print(f"    ... +{len(g_nbrs) - 20} more")

    # MRREL IS-A topics
    isa_tids = isa_map.get(cui, set())
    isa_canons = {topic_to_canon[t] for t in isa_tids}
    print(f"\n  MRREL IS-A topics ({len(isa_canons)}):")
    for c in sorted(isa_canons):
        print(f"    {c}  {lbl(c)}")

    # MRREL RELA topics
    rela_tids = rela_map.get(cui, set())
    rela_canons = {topic_to_canon[t] for t in rela_tids}
    print(f"\n  MRREL RELA topics ({len(rela_canons)}):")
    if len(rela_canons) <= 25:
        for c in sorted(rela_canons):
            print(f"    {c}  {lbl(c)}")
    else:
        for c in sorted(rela_canons)[:25]:
            print(f"    {c}  {lbl(c)}")
        print(f"    ... +{len(rela_canons) - 25} more")

    # Overlap analysis
    print(f"\n  OVERLAP:")
    g_in_isa = g_nbrs & isa_canons
    g_in_rela = g_nbrs & rela_canons
    g_in_either = g_nbrs & (isa_canons | rela_canons)
    g_canon = g_nbrs & canonicals_set
    print(f"    Graph neighbors that are canonicals: {len(g_canon)}")
    print(f"    Graph neighbors in MRREL IS-A topics: {len(g_in_isa)}")
    print(f"    Graph neighbors in MRREL RELA topics: {len(g_in_rela)}")
    print(f"    Graph neighbors in EITHER MRREL topic set: {len(g_in_either)}")
    if g_in_either:
        print(f"    Overlapping (graph ∩ MRREL):")
        for c in sorted(g_in_either)[:10]:
            print(f"      {c}  {lbl(c)}")

# Summary line
print("\n\n" + "=" * 100)
print("  ONE-LINE SUMMARY PER CUI")
print("=" * 100)
print(f"  {'CUI':<12s}  {'Label':<35s}  {'GRAPH':>6s}  {'IS-A':>6s}  {'RELA':>6s}  {'G∩MRREL':>8s}")
for cui in FOCAL_CUIS:
    g_nbrs = graph_neighbors(data, cui, SNOMED_CUIS)
    isa_canons = {topic_to_canon[t] for t in isa_map.get(cui, set())}
    rela_canons = {topic_to_canon[t] for t in rela_map.get(cui, set())}
    overlap = g_nbrs & (isa_canons | rela_canons)
    print(f"  {cui:<12s}  {lbl(cui):<35s}  {len(g_nbrs):>6,d}  "
          f"{len(isa_canons):>6,d}  {len(rela_canons):>6,d}  {len(overlap):>8,d}")

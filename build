"""
build_facets.py
---------------
Build a CUI -> facet-signature pickle from UMLS data.

Each CUI becomes a structured signature: a dict mapping UMLS RELA names
to sets of value CUIs. This preserves the full attribute structure that
SNOMED encodes about each concept — not just the IS-A hierarchy, but
ALL of the defining relationships:

    'C0032285' (Pneumonia) -> {
        'has_finding_site':          {'C0024109'},  # Lung
        'has_associated_morphology': {'C0009450'},  # Inflammation
        'has_causative_agent':       {'C0004611'},  # Bacterium (if present)
        ...
    }

This is "Multi-Facet Topics": instead of compressing a concept into a
single ancestor anchor, we keep the multi-dimensional structure.

At query time, two CUI signatures are compared facet-by-facet:
- Exact equality counts as a match
- Hierarchical (one value IS-A descends from the other) counts as a match
  for that facet (Lung matches Right upper lobe)

This is closer to how SNOMED CT actually models clinical concepts.

The build also precomputes IS-A ancestor sets for every CUI that appears
as a facet value. Stored in the pickle so match-time hierarchical
comparison is O(1) per pair.

Usage:
    Define PROJECT and DATASET in a cell above this one.
    Then run:
        python build_facets.py
    On first run, fetches UMLS data from BigQuery into umls_cache.pkl.
    On subsequent runs, uses the cache.
"""

import datetime
import os
import pickle
import time
from collections import defaultdict


# ============================================================================
# CONFIG
# ============================================================================

# PROJECT and DATASET must be defined in a cell above this one (or in the
# enclosing module). They are referenced directly — no defaults here.

CACHE_PATH  = "umls_cache.pkl"
OUTPUT_PATH = "facets.pkl"

# Table names
TABLE_MRCONSO = "MRCONSO"
TABLE_MRREL   = "MRREL"
TABLE_MRSTY   = "MRSTY"

# Source filters
SAB      = "SNOMEDCT_US"
LANGUAGE = "ENG"

# Cache schema version. Reusing the v2 cache from build_topics.py.
CACHE_SCHEMA_VERSION = 2

# How many IS-A ancestor levels to precompute. None = full transitive closure.
# Setting to a small number (say 5) caps memory at the cost of recall on
# very deep IS-A chains. None is recommended for clinical use.
MAX_ANCESTOR_DEPTH = None


# ============================================================================
# Step 1: Cache management
# ============================================================================

def get_or_fetch_cache():
    """
    Load existing umls_cache.pkl if it's compatible, else fetch from BQ.
    Reuses the same cache as build_topics.py.
    """
    current_config = {
        "project":  PROJECT,
        "dataset":  DATASET,
        "sab":      SAB,
        "language": LANGUAGE,
    }

    if os.path.exists(CACHE_PATH):
        print(f"Found existing cache: {CACHE_PATH}")
        t0 = time.time()
        with open(CACHE_PATH, "rb") as f:
            cache = pickle.load(f)
        print(f"  loaded in {time.time()-t0:.1f}s")

        cached_config = cache.get("config", {})
        cache_schema = cache.get("schema_version", 0)
        if cache_schema != CACHE_SCHEMA_VERSION:
            print(f"\n  Cache schema version is {cache_schema}, "
                  f"current code expects {CACHE_SCHEMA_VERSION}.")
            print(f"  Re-fetching from BigQuery ...\n")
        elif cached_config != current_config:
            print(f"\n  WARNING: cache config differs from current config:")
            for key in current_config:
                if cached_config.get(key) != current_config[key]:
                    print(f"    {key}: cache={cached_config.get(key)!r}  "
                          f"current={current_config[key]!r}")
            print(f"  Re-fetching from BigQuery ...\n")
        else:
            print(f"  fetched_at  : {cache['fetched_at']}")
            print(f"  cuis        : {len(cache['cuis']):,}")
            print(f"  mrrel_rows  : {len(cache['mrrel_rows']):,}")
            print(f"  config OK — using cached data")
            return cache

    print(f"\nFetching UMLS data from BigQuery ...")
    cache = fetch_from_bigquery(current_config)
    print(f"\nSaving cache to {CACHE_PATH} ...")
    t0 = time.time()
    with open(CACHE_PATH, "wb") as f:
        pickle.dump(cache, f, protocol=pickle.HIGHEST_PROTOCOL)
    size_mb = os.path.getsize(CACHE_PATH) / 1024 / 1024
    print(f"  wrote {size_mb:.1f} MB in {time.time()-t0:.1f}s")
    return cache


def fetch_from_bigquery(config):
    """Fetch the four data sources needed: CUIs, MRREL, MRSTY, labels."""
    from google.cloud import bigquery

    client = bigquery.Client(project=config["project"])
    sab = config["sab"]
    lat = config["language"]

    # ---- 1. Active CUIs ----
    print("  [1/4] Loading SNOMED CUIs from MRCONSO ...")
    t0 = time.time()
    sql = f"""
    SELECT DISTINCT CUI
    FROM `{config['project']}.{config['dataset']}.{TABLE_MRCONSO}`
    WHERE SAB = @sab AND LAT = @lat AND SUPPRESS = 'N'
    """
    job_config = bigquery.QueryJobConfig(query_parameters=[
        bigquery.ScalarQueryParameter("sab", "STRING", sab),
        bigquery.ScalarQueryParameter("lat", "STRING", lat),
    ])
    cuis = set()
    for row in client.query(sql, job_config=job_config).result():
        cuis.add(row.CUI)
    print(f"        {len(cuis):,} CUIs in {time.time()-t0:.1f}s")

    # ---- 2. MRREL rows ----
    print("  [2/4] Loading MRREL rows ...")
    t0 = time.time()
    sql = f"""
    SELECT CUI1, CUI2, REL, RELA
    FROM `{config['project']}.{config['dataset']}.{TABLE_MRREL}`
    WHERE SAB = @sab AND SUPPRESS = 'N'
      AND (
            (REL = 'CHD' AND RELA = 'isa')
         OR (REL = 'RO' AND RELA IS NOT NULL
                         AND RELA != 'isa'
                         AND NOT STARTS_WITH(RELA, 'inverse_'))
      )
    """
    job_config = bigquery.QueryJobConfig(query_parameters=[
        bigquery.ScalarQueryParameter("sab", "STRING", sab),
    ])
    mrrel_rows = []
    for row in client.query(sql, job_config=job_config).result():
        if row.CUI1 in cuis and row.CUI2 in cuis:
            mrrel_rows.append((row.CUI1, row.CUI2, row.REL, row.RELA))
    print(f"        {len(mrrel_rows):,} rows in {time.time()-t0:.1f}s")

    # ---- 3. Semantic types ----
    print("  [3/4] Loading semantic types from MRSTY ...")
    t0 = time.time()
    sql = f"""
    SELECT CUI, STY
    FROM `{config['project']}.{config['dataset']}.{TABLE_MRSTY}`
    """
    tags_accum = defaultdict(set)
    for row in client.query(sql).result():
        if row.CUI in cuis:
            tags_accum[row.CUI].add(row.STY)
    tags = {cui: frozenset(stys) for cui, stys in tags_accum.items()}
    print(f"        {len(tags):,} CUIs tagged in {time.time()-t0:.1f}s")

    # ---- 4. Preferred labels ----
    print("  [4/4] Loading preferred labels from MRCONSO ...")
    t0 = time.time()
    cui_list = sorted(cuis)
    BATCH = 50000
    labels = {}
    for i in range(0, len(cui_list), BATCH):
        batch = cui_list[i:i+BATCH]
        sql = f"""
        SELECT CUI, STR
        FROM `{config['project']}.{config['dataset']}.{TABLE_MRCONSO}`
        WHERE SAB = @sab AND LAT = @lat AND TS = 'P' AND ISPREF = 'Y'
              AND STT = 'PF' AND SUPPRESS = 'N'
              AND CUI IN UNNEST(@cuis)
        """
        job_config = bigquery.QueryJobConfig(query_parameters=[
            bigquery.ScalarQueryParameter("sab", "STRING", sab),
            bigquery.ScalarQueryParameter("lat", "STRING", lat),
            bigquery.ArrayQueryParameter("cuis", "STRING", batch),
        ])
        for row in client.query(sql, job_config=job_config).result():
            if row.CUI not in labels:
                labels[row.CUI] = row.STR
    print(f"        {len(labels):,} labels in {time.time()-t0:.1f}s")

    return {
        "schema_version": CACHE_SCHEMA_VERSION,
        "fetched_at": datetime.datetime.now().isoformat(),
        "config":     config,
        "cuis":       cuis,
        "mrrel_rows": mrrel_rows,
        "tags":       tags,
        "labels":     labels,
    }


# ============================================================================
# Step 2: Extract facet signatures from MRREL
# ============================================================================

def extract_facets(cache):
    """
    For each CUI, collect all of its non-IS-A attribute relationships
    into a facet signature.

    Returns:
        cui_facets: dict[cui] -> dict[rela] -> frozenset of value CUIs

    Multi-value RELAs are preserved as sets (a single CUI may have
    multiple values for the same RELA, e.g., Fracture of tibia and fibula).

    Only RELAs that point to other CUIs in our universe are kept.
    """
    cui_facets = defaultdict(lambda: defaultdict(set))
    for cui1, cui2, rel, rela in cache["mrrel_rows"]:
        # IS-A rows are handled separately (used for ancestor closure).
        # We only collect RO (Related Other) rows as facets.
        if rel == "RO" and rela and rela != "isa":
            # cui1 is the value, cui2 is the concept being described
            cui_facets[cui2][rela].add(cui1)

    # Convert to frozensets for hashability/predictability
    return {
        cui: {rela: frozenset(vals) for rela, vals in rela_map.items()}
        for cui, rela_map in cui_facets.items()
    }


# ============================================================================
# Step 3: Build IS-A ancestor closure
# ============================================================================

def build_isa_parents(cache):
    """
    Return parents[cui] = set of direct IS-A parent CUIs.

    UMLS encoding: REL='CHD' RELA='isa' means CUI2 is a child of CUI1.
    So CUI1 is a parent of CUI2.
    """
    parents = defaultdict(set)
    for cui1, cui2, rel, rela in cache["mrrel_rows"]:
        if rel == "CHD" and rela == "isa":
            parents[cui2].add(cui1)
    return parents


def compute_ancestors(parents, target_cuis, max_depth=None):
    """
    For each CUI in target_cuis, compute the set of ALL ancestors via IS-A
    (including itself). This is the transitive closure of parent links.

    Used at query time for hierarchical facet matching: when comparing
    facet values, we want to know if one is an ancestor of the other.

    max_depth=None means full closure (recommended for clinical use).
    max_depth=N caps walking at N levels above (saves memory).

    Returns: dict[cui] -> frozenset(ancestor_cuis_including_self)
    """
    ancestors_cache = {}

    def get_ancestors(cui):
        if cui in ancestors_cache:
            return ancestors_cache[cui]
        result = {cui}
        # BFS up the parent tree
        frontier = {cui}
        depth = 0
        while frontier:
            if max_depth is not None and depth >= max_depth:
                break
            next_frontier = set()
            for c in frontier:
                for p in parents.get(c, ()):
                    if p not in result:
                        next_frontier.add(p)
                        result.add(p)
            frontier = next_frontier
            depth += 1
        ancestors_cache[cui] = frozenset(result)
        return ancestors_cache[cui]

    ancestors = {}
    for i, cui in enumerate(target_cuis):
        ancestors[cui] = get_ancestors(cui)
        if (i + 1) % 50000 == 0:
            print(f"      {i+1:,} / {len(target_cuis):,} ancestor sets computed")
    return ancestors


# ============================================================================
# Step 4: Main
# ============================================================================

def main():
    print("=" * 60)
    print("UMLS facet-signature builder")
    print("=" * 60)
    print(f"  project       : {PROJECT}")
    print(f"  dataset       : {DATASET}")
    print(f"  cache         : {CACHE_PATH}")
    print(f"  output        : {OUTPUT_PATH}")
    print(f"  max_depth     : {MAX_ANCESTOR_DEPTH if MAX_ANCESTOR_DEPTH else 'full closure'}")

    print("\n[1/4] Getting UMLS data (cache or BigQuery) ...")
    cache = get_or_fetch_cache()

    print("\n[2/4] Extracting facet signatures from MRREL ...")
    t0 = time.time()
    cui_facets = extract_facets(cache)
    n_cuis_with_facets = len(cui_facets)
    n_total_facets = sum(len(f) for f in cui_facets.values())
    n_total_values = sum(
        len(vals)
        for f in cui_facets.values()
        for vals in f.values()
    )
    facet_counts = defaultdict(int)
    for f in cui_facets.values():
        for rela in f:
            facet_counts[rela] += 1
    print(f"      {n_cuis_with_facets:,} CUIs have facets")
    print(f"      {n_total_facets:,} facet entries ({n_total_values:,} total values)")
    print(f"      in {time.time()-t0:.1f}s")
    print(f"      Top 10 most common facet types:")
    for rela, n in sorted(facet_counts.items(), key=lambda kv: -kv[1])[:10]:
        print(f"        {n:>7,d}  {rela}")

    print("\n[3/4] Computing IS-A ancestor closure ...")
    t0 = time.time()
    parents = build_isa_parents(cache)
    # We only need ancestor sets for CUIs that appear as facet values,
    # PLUS all CUIs in our universe (for query matching).
    target_cuis = set(cache["cuis"])
    for f in cui_facets.values():
        for vals in f.values():
            target_cuis.update(vals)
    print(f"      Computing ancestors for {len(target_cuis):,} CUIs ...")
    ancestors = compute_ancestors(parents, target_cuis, MAX_ANCESTOR_DEPTH)
    avg_anc = sum(len(a) for a in ancestors.values()) / max(len(ancestors), 1)
    print(f"      {len(ancestors):,} ancestor sets, avg {avg_anc:.1f} ancestors each")
    print(f"      in {time.time()-t0:.1f}s")

    print("\n[4/4] Saving pickle ...")
    t0 = time.time()
    payload = {
        "built_at": datetime.datetime.now().isoformat(),
        "cache_fetched_at": cache.get("fetched_at"),
        "config": {
            "max_ancestor_depth": MAX_ANCESTOR_DEPTH,
        },
        "cui_facets":    cui_facets,
        "isa_ancestors": ancestors,
        "labels":        cache["labels"],
        "tags":          cache["tags"],
        "stats": {
            "total_cuis":             len(cache["cuis"]),
            "cuis_with_facets":       n_cuis_with_facets,
            "total_facet_entries":    n_total_facets,
            "total_facet_values":     n_total_values,
            "facet_type_counts":      dict(facet_counts),
        },
    }
    with open(OUTPUT_PATH, "wb") as f:
        pickle.dump(payload, f, protocol=pickle.HIGHEST_PROTOCOL)
    size_mb = os.path.getsize(OUTPUT_PATH) / 1024 / 1024
    print(f"      wrote {size_mb:.1f} MB in {time.time()-t0:.1f}s")

    print("\n" + "=" * 60)
    print("DONE")
    print(f"  Total CUIs              : {len(cache['cuis']):,}")
    print(f"  CUIs with facets        : {n_cuis_with_facets:,} "
          f"({100*n_cuis_with_facets/max(len(cache['cuis']),1):.1f}%)")
    print(f"  Distinct facet types    : {len(facet_counts):,}")
    print(f"  Avg facets per CUI      : {n_total_facets/max(n_cuis_with_facets,1):.2f}")
    print(f"  IS-A ancestor sets      : {len(ancestors):,}")
    print(f"  Pickle                  : {OUTPUT_PATH} ({size_mb:.1f} MB)")
    print("=" * 60)


if __name__ == "__main__":
    main()

"""
evaluate_topic_methods.py
-------------------------
Rigorous evaluation of multiple topic-detection methods on the implication
graph. No more picking from 3 examples.

Inputs (must be loaded in notebook):
  data            : NetworkX DiGraph (the suffix-bridge graph)
  SNOMED_CUIS     : set of SNOMED CUIs
  TAGS            : dict cui -> frozenset of STY codes  (REQUIRED for STY purity)
  LABELS          : dict cui -> name                    (optional, for inspection)

Methods evaluated:
  - Method 1: multi-source nearest-canonical BFS (current Method 1)
  - Method 2a: Louvain resolution=1.0 (default)
  - Method 2b: Louvain resolution=0.5
  - Method 2c: Louvain resolution=0.3
  - Method 2d: Louvain resolution=2.0

Metrics per method:
  - Total topics
  - Size distribution (min/median/mean/p90/p99/max)
  - Singleton rate (% topics of size 1)
  - Mass concentration (% of CUIs in top-10 largest topics)
  - STY purity: per-topic, what fraction of members share the dominant STY?
    Report mean and median across topics with >= 5 members.
  - On 100 "should-match" pairs (IS-A siblings): what % share a topic?
  - On 100 "should-not-match" pairs (random across STY families): what %
    share a topic? (lower is better — measures false positives)
"""

import statistics
import random
import time
import os
from collections import defaultdict, Counter


# ============================================================================
# Helpers
# ============================================================================

def cui_of(suffix_node):
    return suffix_node.rsplit("-", 1)[0] if "-" in suffix_node else suffix_node


def percentile_value(sorted_values, p):
    if not sorted_values:
        return 0
    idx = min(int(len(sorted_values) * p / 100), len(sorted_values) - 1)
    return sorted_values[idx]


# ============================================================================
# Step 1: Flatten graph (we've done this before, repeat for self-containment)
# ============================================================================

def flatten_graph(g, snomed_cuis):
    print(f"  flattening for {len(snomed_cuis):,} SNOMED CUIs ...")
    neighbors = defaultdict(set)
    t0 = time.time()
    n_proc = 0
    for cui in snomed_cuis:
        if cui not in g:
            n_proc += 1
            continue
        for suffix in g.successors(cui):
            if "-" not in suffix:
                continue
            for pred in g.predecessors(suffix):
                if pred == cui or pred == "CUI" or "-" not in pred:
                    continue
                other_cui = cui_of(pred)
                if other_cui != cui and other_cui in snomed_cuis:
                    neighbors[cui].add(other_cui)
                    neighbors[other_cui].add(cui)
        n_proc += 1
        if n_proc % 100000 == 0:
            print(f"    {n_proc:,} ({time.time()-t0:.0f}s)")
    n_edges = sum(len(s) for s in neighbors.values()) // 2
    print(f"  -> {n_edges:,} edges in {time.time()-t0:.0f}s")
    return dict(neighbors)


# ============================================================================
# Method 1: Multi-source nearest-canonical BFS
# ============================================================================

def build_method1(neighbors, snomed_cuis):
    """
    Pick canonicals from 75-99 degree percentile. Multi-source BFS.
    Returns: dict[cui] -> set of canonical CUIs (the topic-set).
    """
    print(f"  selecting canonicals ...")
    degrees = sorted(len(s) for s in neighbors.values())
    min_deg = percentile_value(degrees, 75)
    max_deg = percentile_value(degrees, 99)
    canonicals = {cui for cui, nbrs in neighbors.items()
                  if min_deg <= len(nbrs) <= max_deg}
    canonicals.discard("C2720507")
    print(f"  {len(canonicals):,} canonicals (degree band [{min_deg}, {max_deg}])")

    print(f"  multi-source BFS ...")
    distance = {c: 0 for c in canonicals}
    nearest = {c: {c} for c in canonicals}
    frontier = set(canonicals)
    t0 = time.time()
    while frontier:
        next_frontier = set()
        for node in frontier:
            cand_d = distance[node] + 1
            for nb in neighbors.get(node, ()):
                if nb not in distance:
                    distance[nb] = cand_d
                    nearest[nb] = set(nearest[node])
                    next_frontier.add(nb)
                elif distance[nb] == cand_d:
                    if not nearest[node] <= nearest[nb]:
                        nearest[nb] |= nearest[node]
        frontier = next_frontier
    print(f"  BFS done in {time.time()-t0:.0f}s")

    cui_topics = {cui: nearest.get(cui, set()) for cui in snomed_cuis if cui in nearest}
    return cui_topics, canonicals


# ============================================================================
# Method 2: Louvain at multiple resolutions
# ============================================================================

def build_louvain(neighbors, snomed_cuis, resolution):
    """Returns: dict[cui] -> community_id (int), and list of communities."""
    import networkx as nx
    G = nx.Graph()
    G.add_nodes_from(snomed_cuis)
    for u, nbrs in neighbors.items():
        for v in nbrs:
            if u < v:
                G.add_edge(u, v)

    print(f"  Louvain (resolution={resolution}) ...")
    t0 = time.time()
    try:
        from networkx.algorithms.community import louvain_communities
        comms = louvain_communities(G, resolution=resolution, seed=42)
    except ImportError:
        import community as community_louvain
        partition = community_louvain.best_partition(
            G, resolution=resolution, random_state=42,
        )
        cd = defaultdict(set)
        for c, ci in partition.items():
            cd[ci].add(c)
        comms = list(cd.values())
    print(f"  done in {time.time()-t0:.0f}s, {len(comms):,} communities")

    cui_to_community = {}
    for i, comm in enumerate(comms):
        for cui in comm:
            cui_to_community[cui] = i
    return cui_to_community, comms


# ============================================================================
# Convert each method's output to a uniform "cui -> topic_ids" representation
# ============================================================================

def m1_to_topics(cui_to_canonical_set):
    """Method 1: each CUI's topics = its set of nearest canonicals."""
    # topic_id == canonical CUI string
    return cui_to_canonical_set  # already in the format dict[cui] -> set


def m2_to_topics(cui_to_community):
    """Method 2: each CUI's topics = {its community_id} (set of size 1)."""
    return {cui: {f"comm_{cid}"} for cui, cid in cui_to_community.items()}


# ============================================================================
# Generate evaluation pairs from the implication graph itself
# ============================================================================

def generate_eval_pairs(neighbors, snomed_cuis, n_pairs=100, seed=42):
    """
    Generate "should-match" and "should-not-match" pairs.

    Should-match: pairs of CUIs that are 2 hops apart via the implication
    graph (immediate neighbors of neighbors but not direct neighbors). The
    idea: if A and B both link to a common neighbor C, they're related.

    Should-not-match: random pairs of CUIs that are mutually unreachable
    in the implication graph (no path between them).

    We use this graph (not a separate IS-A) because it's our actual
    relation source. Self-consistent ground truth.
    """
    print(f"  generating {n_pairs} should-match + {n_pairs} should-not-match pairs ...")
    rng = random.Random(seed)
    cui_list = list(snomed_cuis & set(neighbors.keys()))
    rng.shuffle(cui_list)

    should_match = []
    should_not_match = []

    # Should-match: 2-hop sibling pairs (share a common neighbor)
    for cui in cui_list:
        if len(should_match) >= n_pairs:
            break
        # Find 2-hop neighbors via shared neighbor
        for shared in neighbors.get(cui, ()):
            for sibling in neighbors.get(shared, ()):
                if sibling == cui or sibling in neighbors.get(cui, set()):
                    continue
                # sibling shares a common direct neighbor with cui
                should_match.append((cui, sibling))
                if len(should_match) >= n_pairs:
                    break
            if len(should_match) >= n_pairs:
                break

    # Should-not-match: random pairs that are NOT in each other's neighborhood
    # (within 2 hops) — i.e., truly distant in the graph
    cui_neighbors_2hop = {}
    for cui in rng.sample(cui_list, min(2000, len(cui_list))):
        n1 = neighbors.get(cui, set())
        n2 = set()
        for nb in n1:
            n2 |= neighbors.get(nb, set())
        cui_neighbors_2hop[cui] = n1 | n2 | {cui}

    distant_candidates = list(cui_neighbors_2hop.keys())
    while len(should_not_match) < n_pairs and distant_candidates:
        a = rng.choice(distant_candidates)
        b = rng.choice(cui_list)
        if b == a:
            continue
        if b in cui_neighbors_2hop[a]:
            continue
        should_not_match.append((a, b))

    print(f"  -> {len(should_match)} should-match, "
          f"{len(should_not_match)} should-not-match")
    return should_match, should_not_match


# ============================================================================
# Metrics
# ============================================================================

def evaluate(name, cui_to_topics, should_match, should_not_match, tags):
    """Compute all metrics for one method."""
    print(f"\n{'='*78}")
    print(f"  EVALUATING: {name}")
    print(f"{'='*78}")
    metrics = {"name": name}

    # Topic sizes
    topic_to_cuis = defaultdict(set)
    for cui, tids in cui_to_topics.items():
        for tid in tids:
            topic_to_cuis[tid].add(cui)

    sizes = sorted(len(s) for s in topic_to_cuis.values())
    metrics["n_topics"]      = len(topic_to_cuis)
    metrics["n_cuis_topicd"] = len(cui_to_topics)
    metrics["size_min"]      = sizes[0]
    metrics["size_median"]   = sizes[len(sizes)//2]
    metrics["size_mean"]     = statistics.mean(sizes)
    metrics["size_p90"]      = percentile_value(sizes, 90)
    metrics["size_p99"]      = percentile_value(sizes, 99)
    metrics["size_max"]      = sizes[-1]
    metrics["singleton_rate"] = sum(1 for s in sizes if s == 1) / max(len(sizes), 1)

    # Mass concentration in top-10 largest topics
    top10_sizes = sorted(sizes, reverse=True)[:10]
    total_membership = sum(sizes)
    metrics["top10_mass_frac"] = sum(top10_sizes) / max(total_membership, 1)

    # STY purity (only for topics of size >= 5)
    pure_topics = []
    for tid, cuis_in_topic in topic_to_cuis.items():
        if len(cuis_in_topic) < 5:
            continue
        sty_counter = Counter()
        for c in cuis_in_topic:
            for sty in tags.get(c, ()):
                sty_counter[sty] += 1
        if not sty_counter:
            continue
        top_sty_count = sty_counter.most_common(1)[0][1]
        purity = top_sty_count / len(cuis_in_topic)
        pure_topics.append(purity)
    metrics["sty_purity_mean"]   = statistics.mean(pure_topics) if pure_topics else 0.0
    metrics["sty_purity_median"] = statistics.median(pure_topics) if pure_topics else 0.0
    metrics["topics_evaluated_purity"] = len(pure_topics)

    # Pair recall / precision
    def pair_shares_topic(a, b):
        ta = cui_to_topics.get(a, set())
        tb = cui_to_topics.get(b, set())
        return bool(ta & tb)

    if should_match:
        n_match_hits = sum(1 for a, b in should_match if pair_shares_topic(a, b))
        metrics["recall_on_should_match"] = n_match_hits / len(should_match)
    else:
        metrics["recall_on_should_match"] = None

    if should_not_match:
        n_nonmatch_hits = sum(1 for a, b in should_not_match if pair_shares_topic(a, b))
        metrics["false_positive_rate"] = n_nonmatch_hits / len(should_not_match)
    else:
        metrics["false_positive_rate"] = None

    # Print
    print(f"  topics                       : {metrics['n_topics']:,}")
    print(f"  CUIs with topics             : {metrics['n_cuis_topicd']:,}")
    print(f"  size distribution:")
    print(f"    min                        : {metrics['size_min']}")
    print(f"    median                     : {metrics['size_median']}")
    print(f"    mean                       : {metrics['size_mean']:.1f}")
    print(f"    p90                        : {metrics['size_p90']}")
    print(f"    p99                        : {metrics['size_p99']:,}")
    print(f"    max                        : {metrics['size_max']:,}")
    print(f"  singleton rate (size=1)      : {100*metrics['singleton_rate']:.1f}%")
    print(f"  mass in top-10 topics        : {100*metrics['top10_mass_frac']:.1f}%")
    print(f"  STY purity mean              : {metrics['sty_purity_mean']:.2f}")
    print(f"  STY purity median            : {metrics['sty_purity_median']:.2f}")
    print(f"    (evaluated on {metrics['topics_evaluated_purity']:,} topics with >=5 members)")
    rec = metrics['recall_on_should_match']
    fpr = metrics['false_positive_rate']
    print(f"  recall on should-match pairs  : {100*rec:.1f}%" if rec is not None else "  recall: n/a")
    print(f"  false-positive rate (should-not-match): {100*fpr:.1f}%" if fpr is not None else "  fpr: n/a")

    return metrics


# ============================================================================
# Main
# ============================================================================

def main():
    print("=" * 60)
    print("Topic method evaluation (data-driven, multi-method)")
    print("=" * 60)

    # Sanity check globals
    for g in ["data", "SNOMED_CUIS", "TAGS"]:
        if g not in globals():
            raise RuntimeError(f"Required variable '{g}' not set in notebook")

    print(f"\n[1] Flattening graph ...")
    neighbors = flatten_graph(data, SNOMED_CUIS)

    print(f"\n[2] Generating evaluation pairs ...")
    should_match, should_not_match = generate_eval_pairs(
        neighbors, SNOMED_CUIS, n_pairs=100,
    )

    print(f"\n[3] Building topic methods ...")
    print(f"\n  Method 1 (nearest-canonical BFS)")
    m1_topics, m1_canonicals = build_method1(neighbors, SNOMED_CUIS)
    m1_eval_topics = m1_to_topics(m1_topics)

    louvain_results = {}
    for res in [0.3, 0.5, 1.0, 2.0]:
        print(f"\n  Method 2 (Louvain, res={res})")
        cui_to_comm, comms = build_louvain(neighbors, SNOMED_CUIS, res)
        louvain_results[res] = m2_to_topics(cui_to_comm)

    print(f"\n[4] Computing metrics ...")
    all_metrics = []
    all_metrics.append(evaluate("Method 1 (BFS)", m1_eval_topics,
                                should_match, should_not_match, TAGS))
    for res in sorted(louvain_results.keys()):
        all_metrics.append(evaluate(f"Louvain res={res}", louvain_results[res],
                                    should_match, should_not_match, TAGS))

    # Summary table
    print("\n" + "=" * 100)
    print("  SUMMARY TABLE")
    print("=" * 100)
    headers = ["Method", "Topics", "Median sz", "p99 sz", "Single%",
               "Top10%", "Purity", "Recall", "FPR"]
    print(f"  {headers[0]:<22s} {headers[1]:>8s} {headers[2]:>10s} "
          f"{headers[3]:>8s} {headers[4]:>8s} {headers[5]:>8s} "
          f"{headers[6]:>8s} {headers[7]:>8s} {headers[8]:>6s}")
    for m in all_metrics:
        rec = m['recall_on_should_match'] or 0
        fpr = m['false_positive_rate'] or 0
        print(f"  {m['name']:<22s} {m['n_topics']:>8,d} "
              f"{m['size_median']:>10d} {m['size_p99']:>8,d} "
              f"{100*m['singleton_rate']:>7.1f}% "
              f"{100*m['top10_mass_frac']:>7.1f}% "
              f"{m['sty_purity_mean']:>7.2f} "
              f"{100*rec:>6.1f}% {100*fpr:>5.1f}%")

    print("\nDecision criteria suggestions:")
    print("  - Higher RECALL on should-match = better at finding related concepts")
    print("  - Lower FPR on should-not-match = fewer spurious matches")
    print("  - Higher PURITY = topics have semantic coherence")
    print("  - Lower Top10% = no mega-cluster problem")
    print("  - Reasonable median size = useful granularity (not all size-1, not all huge)")


main()

"""
build_topics.py
---------------
Unified end-to-end build with SY-cluster pre-merging.

PIPELINE (all stages internal, intermediate state not saved):

  STAGE 0: Extract SY clusters from MRREL (REL=SY rows).
           Build canonical_map: every CUI -> its cluster's canonical CUI.
           This makes synonymous CUIs (e.g. C0007113 Rectal cancer and
           C0949022 Malignant tumour of rectum) into one concept.

  STAGE A: Flatten the suffix-bridge network graph, applying canonical_map.
           Each canonical CUI's main topic = canonical CUIs of its
           network neighbors.

  STAGE B: Extract IS-A from MRREL (PAR/CHD/RB/RN), applying canonical_map.
           Compute Seco IC on canonical-CUI level.

  STAGE C: For each canonical CUI's main topic, find anchor per member
           (highest-IC IS-A ancestor in topic, with IC >= MIN_ANCHOR_IC).

  STAGE D: Dedup by anchor — one final topic per anchor canonical.

  STAGE E: Expand back to all original CUIs.
           Each original CUI inherits its canonical's topic memberships.
           Each topic's members expand to include all SY-cluster members.

Inputs (notebook globals):
  data, cache (with mrrel_rows), SNOMED_CUIS, LABELS, TAGS (optional)

Output:
  topics.pkl + topics_debug.pkl (sidecar)
"""

import pickle
import datetime
import hashlib
import math
import os
import time
from collections import defaultdict, Counter


OUTPUT_PATH = "topics.pkl"

# IS-A relation types from MRREL (hierarchical only)
HIERARCHY_RELS = {"PAR", "CHD", "RB", "RN"}

# Synonym relation type — used for clustering
SY_REL = "SY"

# Minimum IC for an ancestor to qualify as an anchor.
MIN_ANCHOR_IC = 0.15


# ============================================================================
# STAGE 0: Build SY clusters via union-find
# ============================================================================

class UnionFind:
    def __init__(self):
        self.parent = {}

    def find(self, x):
        if x not in self.parent:
            self.parent[x] = x
            return x
        # Path compression
        root = x
        while self.parent[root] != root:
            root = self.parent[root]
        while self.parent[x] != root:
            self.parent[x], x = root, self.parent[x]
        return root

    def union(self, a, b):
        ra, rb = self.find(a), self.find(b)
        if ra != rb:
            self.parent[ra] = rb


def build_sy_canonical_map(mrrel_rows, snomed_cuis):
    """Find SY clusters, return canonical_map: CUI -> canonical CUI."""
    print("  [0] Building SY clusters from MRREL...")
    t0 = time.time()

    uf = UnionFind()
    sy_pairs = 0
    for row in mrrel_rows:
        if len(row) < 3:
            continue
        c1, c2, rel = row[0], row[1], row[2]
        if rel != SY_REL:
            continue
        if c1 not in snomed_cuis or c2 not in snomed_cuis:
            continue
        if c1 == c2:
            continue
        uf.union(c1, c2)
        sy_pairs += 1

    # Build canonical_map: for each CUI in any cluster, map to root
    # Then pick deterministic canonical per cluster (lex-min CUI)
    cluster_members = defaultdict(set)
    for c in uf.parent:
        cluster_members[uf.find(c)].add(c)

    canonical_map = {}
    cluster_sizes = []
    for root, members in cluster_members.items():
        # Canonical = lex-min CUI in cluster
        canonical = min(members)
        for m in members:
            canonical_map[m] = canonical
        cluster_sizes.append(len(members))

    # CUIs not in any cluster map to themselves (singleton)
    for c in snomed_cuis:
        if c not in canonical_map:
            canonical_map[c] = c

    n_clustered = sum(1 for c in snomed_cuis if c != canonical_map[c])
    n_clusters_multi = sum(1 for s in cluster_sizes if s > 1)

    print(f"      SY pairs scanned          : {sy_pairs:,}")
    print(f"      Multi-member clusters     : {n_clusters_multi:,}")
    print(f"      CUIs merged into a synonym: {n_clustered:,}")
    if cluster_sizes:
        cluster_sizes.sort()
        print(f"      Cluster size min/med/p99/max: "
              f"{cluster_sizes[0]} / {cluster_sizes[len(cluster_sizes)//2]} / "
              f"{cluster_sizes[int(0.99*len(cluster_sizes))]} / "
              f"{cluster_sizes[-1]}")
    print(f"      Done in {time.time()-t0:.0f}s")

    # Reverse map: canonical -> all CUIs in its cluster
    canonical_to_cluster = defaultdict(set)
    for c, can in canonical_map.items():
        canonical_to_cluster[can].add(c)

    return canonical_map, dict(canonical_to_cluster)


# ============================================================================
# STAGE A: Flatten network graph (with canonical mapping)
# ============================================================================

def flatten_graph(graph, snomed_cuis, canonical_map):
    """Same as before, but maps neighbors through canonical_map.
    Result: per-canonical-CUI neighbor sets."""
    print("  [A] Flattening suffix-bridge graph (with SY canonicalization)...")
    t0 = time.time()

    neighbors = defaultdict(set)
    n_processed = 0
    for cui in snomed_cuis:
        n_processed += 1
        if n_processed % 50000 == 0:
            print(f"      {n_processed:,}/{len(snomed_cuis):,} "
                  f"({time.time()-t0:.0f}s)")

        if cui not in graph:
            continue
        can_cui = canonical_map.get(cui, cui)

        for suffix_child in graph.successors(cui):
            if "-" not in suffix_child:
                continue
            try:
                base, _ = suffix_child.rsplit("-", 1)
            except ValueError:
                continue
            if base != cui:
                continue

            for pred in graph.predecessors(suffix_child):
                if pred == cui or "-" not in pred:
                    continue
                try:
                    other, _ = pred.rsplit("-", 1)
                except ValueError:
                    continue
                if other == cui or other not in snomed_cuis:
                    continue
                can_other = canonical_map.get(other, other)
                if can_cui == can_other:
                    continue  # don't add self-loop within cluster
                neighbors[can_cui].add(can_other)
                neighbors[can_other].add(can_cui)

    n_with_edges = len(neighbors)
    total_edges = sum(len(n) for n in neighbors.values()) // 2
    print(f"      Done in {time.time()-t0:.0f}s")
    print(f"      Canonical CUIs with edges : {n_with_edges:,}")
    print(f"      Total undirected edges    : {total_edges:,}")
    return neighbors


# ============================================================================
# STAGE B: Extract IS-A from MRREL (with canonical mapping) + compute IC
# ============================================================================

def extract_isa_dag(mrrel_rows, snomed_cuis, canonical_map):
    """Same as before, but maps both endpoints through canonical_map.
    Edges within same SY cluster get dropped (self-loop on canonical)."""
    print("  [B] Extracting IS-A edges from MRREL (with SY canonicalization)...")
    t0 = time.time()

    edges = set()
    n_match = 0
    n_dropped_cluster_internal = 0

    for row in mrrel_rows:
        if len(row) < 3:
            continue
        c1, c2, rel = row[0], row[1], row[2]
        if rel not in HIERARCHY_RELS:
            continue
        if c1 not in snomed_cuis or c2 not in snomed_cuis:
            continue
        if c1 == c2:
            continue

        can_c1 = canonical_map.get(c1, c1)
        can_c2 = canonical_map.get(c2, c2)
        if can_c1 == can_c2:
            n_dropped_cluster_internal += 1
            continue  # within-cluster relation, ignore

        if rel in ("PAR", "RB"):
            edges.add((can_c1, can_c2))
        else:  # CHD, RN
            edges.add((can_c2, can_c1))
        n_match += 1

    isa_parents  = defaultdict(set)
    isa_children = defaultdict(set)
    for child, parent in edges:
        isa_parents[child].add(parent)
        isa_children[parent].add(child)

    print(f"      MRREL rows scanned        : {len(mrrel_rows):,}")
    print(f"      IS-A matches              : {n_match:,}")
    print(f"      Dropped (within cluster)  : {n_dropped_cluster_internal:,}")
    print(f"      Unique IS-A edges (post)  : {len(edges):,}")
    print(f"      Canonical CUIs with parents: {len(isa_parents):,}")
    print(f"      Done in {time.time()-t0:.0f}s")
    return dict(isa_parents), dict(isa_children)


def compute_ic(isa_children, all_nodes, total_universe):
    """Seco IC."""
    print("  [B] Computing IC scores...")
    t0 = time.time()
    descendant_sets = {}

    def descendants(node, stack):
        if node in descendant_sets:
            return descendant_sets[node]
        if node in stack:
            return set()
        stack = stack | {node}
        result = set()
        for child in isa_children.get(node, ()):
            result.add(child)
            result |= descendants(child, stack)
        descendant_sets[node] = result
        return result

    for node in all_nodes:
        descendants(node, set())

    log_total = math.log(total_universe + 1)
    ic = {n: 1.0 - math.log(len(d) + 1) / log_total
          for n, d in descendant_sets.items()}

    print(f"      IC computed for {len(ic):,} canonical nodes "
          f"in {time.time()-t0:.0f}s")
    return ic


def ancestor_closure(cui, isa_parents, cache):
    if cui in cache:
        return cache[cui]
    ancestors = set()
    stack = [cui]
    visited = set()
    while stack:
        node = stack.pop()
        if node in visited:
            continue
        visited.add(node)
        for p in isa_parents.get(node, set()):
            if p not in ancestors:
                ancestors.add(p)
                stack.append(p)
    cache[cui] = frozenset(ancestors)
    return cache[cui]


# ============================================================================
# STAGE C+D: Build topics on canonical CUIs
# ============================================================================

def topic_id_for(canonical):
    h = hashlib.sha1(canonical.encode()).hexdigest()[:12]
    return f"tp_{h}"


def build_canonical_topics(canonical_cuis, neighbors, isa_parents, ic_scores):
    """Form granular subgroups on canonical CUIs, dedup by anchor."""
    print("  [C] Forming granular subgroups per canonical main topic...")
    print(f"      Anchor rule: highest-IC IS-A ancestor in topic with "
          f"IC >= {MIN_ANCHOR_IC}")
    t0 = time.time()

    closure_cache = {}
    canonical_to_members = defaultdict(set)

    n_processed = 0
    for focal in canonical_cuis:
        n_processed += 1
        if n_processed % 50000 == 0:
            print(f"      {n_processed:,}/{len(canonical_cuis):,} "
                  f"({time.time()-t0:.0f}s)")

        members = {focal} | neighbors.get(focal, frozenset())
        if len(members) < 2:
            continue

        for m in members:
            closure = ancestor_closure(m, isa_parents, closure_cache)
            in_topic = closure & members
            if not in_topic:
                continue
            qualified = {a for a in in_topic
                         if ic_scores.get(a, 0.0) >= MIN_ANCHOR_IC}
            if not qualified:
                continue
            anchor = max(qualified, key=lambda a: ic_scores.get(a, 0.0))
            canonical_to_members[anchor].add(anchor)
            canonical_to_members[anchor].add(m)

    print(f"      Done in {time.time()-t0:.0f}s")
    print(f"      Closure cache size        : {len(closure_cache):,}")
    print(f"      Unique anchors            : {len(canonical_to_members):,}")
    return dict(canonical_to_members)


# ============================================================================
# STAGE E: Expand back to original CUIs
# ============================================================================

def expand_to_original_cuis(canonical_to_members, canonical_to_cluster,
                             canonical_map, labels, ic_scores):
    """Expand topic members and lookups to include all SY-cluster members."""
    print("  [E] Expanding back to original (non-canonical) CUIs...")
    t0 = time.time()

    topic_id_to_topic     = {}
    canonical_to_topic_id = {}
    cui_to_topic_ids      = defaultdict(set)

    for canonical, mems in canonical_to_members.items():
        tp_id = topic_id_for(canonical)

        # Expand member list: each canonical member -> include all its cluster
        expanded_members = set()
        for m in mems:
            expanded_members |= canonical_to_cluster.get(m, {m})

        expanded_members_fs = frozenset(expanded_members)
        topic_id_to_topic[tp_id] = {
            "canonical":  canonical,
            "members":    expanded_members_fs,
            "size":       len(expanded_members_fs),
            "anchor_ic":  ic_scores.get(canonical, 0.0),
        }
        canonical_to_topic_id[canonical] = tp_id

        # Every expanded member's lookup gets this topic
        for m in expanded_members_fs:
            cui_to_topic_ids[m].add(tp_id)

    print(f"      Done in {time.time()-t0:.0f}s")
    print(f"      Final topics              : {len(topic_id_to_topic):,}")
    print(f"      CUIs participating        : {len(cui_to_topic_ids):,}")

    sizes = sorted(t["size"] for t in topic_id_to_topic.values())
    topics_per_cui = sorted(len(s) for s in cui_to_topic_ids.values())
    if sizes:
        print(f"      Topic size min/med/p90/p99/max : "
              f"{sizes[0]} / {sizes[len(sizes)//2]} / "
              f"{sizes[int(0.9*len(sizes))]} / {sizes[int(0.99*len(sizes))]} / "
              f"{sizes[-1]}")
    if topics_per_cui:
        print(f"      Topics-per-CUI min/med/p90/p99/max : "
              f"{topics_per_cui[0]} / {topics_per_cui[len(topics_per_cui)//2]} / "
              f"{topics_per_cui[int(0.9*len(topics_per_cui))]} / "
              f"{topics_per_cui[int(0.99*len(topics_per_cui))]} / "
              f"{topics_per_cui[-1]}")

    return topic_id_to_topic, canonical_to_topic_id, cui_to_topic_ids


# ============================================================================
# Main
# ============================================================================

def main():
    print(f"BUILD START — {datetime.datetime.now().isoformat()}")
    t_total = time.time()

    print(f"\nInputs:")
    print(f"  data (graph) : {type(data).__name__} with "
          f"{data.number_of_nodes():,} nodes, {data.number_of_edges():,} edges")
    print(f"  SNOMED_CUIS  : {len(SNOMED_CUIS):,}")
    print(f"  LABELS       : {len(LABELS):,}")
    print(f"  cache keys   : {list(cache.keys())}")

    print(f"\n[0] Build SY clusters")
    canonical_map, canonical_to_cluster = build_sy_canonical_map(
        cache["mrrel_rows"], SNOMED_CUIS)

    print(f"\n[A] Flatten graph (on canonicals)")
    neighbors = flatten_graph(data, SNOMED_CUIS, canonical_map)

    print(f"\n[B] Extract IS-A DAG + IC (on canonicals)")
    isa_parents, isa_children = extract_isa_dag(
        cache["mrrel_rows"], SNOMED_CUIS, canonical_map)
    canonical_cuis = {canonical_map[c] for c in SNOMED_CUIS}
    all_nodes = set(isa_parents.keys()) | set(isa_children.keys())
    ic_scores = compute_ic(isa_children, all_nodes, len(canonical_cuis))

    print(f"\n[C+D] Build topics on canonical CUIs")
    canonical_to_members = build_canonical_topics(
        canonical_cuis, neighbors, isa_parents, ic_scores)

    print(f"\n[E] Expand back to original CUIs")
    topic_id_to_topic, canonical_to_topic_id, cui_to_topic_ids = \
        expand_to_original_cuis(canonical_to_members, canonical_to_cluster,
                                 canonical_map, LABELS, ic_scores)

    print(f"\n[Save] Writing to {OUTPUT_PATH}")
    payload = {
        "topic_id_to_topic":       topic_id_to_topic,
        "canonical_to_topic_id":   canonical_to_topic_id,
        "cui_to_topic_ids":        {c: sorted(s) for c, s
                                    in cui_to_topic_ids.items()},
        "labels":                  LABELS,
        "tags":                    globals().get("TAGS", {}),
        "canonical_map":           canonical_map,
        "config": {
            "anchor_rule":     "highest-IC IS-A ancestor in topic, "
                               f"with IC >= {MIN_ANCHOR_IC}",
            "min_anchor_ic":   MIN_ANCHOR_IC,
            "ic_formula":      "Seco: 1 - log(desc+1) / log(total)",
            "hierarchy_rels":  sorted(HIERARCHY_RELS),
            "sy_merging":      True,
            "topic_dedup":     "one topic per unique canonical anchor; "
                               "synonyms expanded in members and lookups",
        },
        "built_at": datetime.datetime.now().isoformat(),
    }
    with open(OUTPUT_PATH, "wb") as f:
        pickle.dump(payload, f, protocol=pickle.HIGHEST_PROTOCOL)
    size_mb = os.path.getsize(OUTPUT_PATH) / 1024 / 1024
    print(f"        Wrote {size_mb:.1f} MB")

    debug_path = OUTPUT_PATH.replace(".pkl", "_debug.pkl")
    print(f"\n[Save] Writing debug sidecar to {debug_path}")
    debug_payload = {
        "neighbors":            {c: frozenset(n) for c, n in neighbors.items()},
        "isa_parents":          isa_parents,
        "ic_scores":            ic_scores,
        "labels":               LABELS,
        "canonical_map":        canonical_map,
        "canonical_to_cluster": canonical_to_cluster,
        "built_at":             datetime.datetime.now().isoformat(),
    }
    with open(debug_path, "wb") as f:
        pickle.dump(debug_payload, f, protocol=pickle.HIGHEST_PROTOCOL)
    size_mb = os.path.getsize(debug_path) / 1024 / 1024
    print(f"        Wrote {size_mb:.1f} MB")

    print(f"\nTOTAL: {time.time()-t_total:.0f}s")
    print(f"DONE — {datetime.datetime.now().isoformat()}")


main()

class TemporalMatch(BaseModel):
    """One generated temporal phrase plus the concept the model matched it to
    (inline, from the injected TEMPORAL CONCEPTS list). selected_id/selected_name
    are None when the model finds no good match; selected_reasoning is its short
    justification (kept to improve selection quality, not surfaced in output)."""
    signal: str
    selected_id: Optional[str] = None
    selected_name: Optional[str] = None
    selected_reasoning: Optional[str] = None


class CandidateTemporal(BaseModel):
    candidate: str
    temporal_signal: List[TemporalMatch] = Field(default_factory=list)

    @field_validator("temporal_signal", mode="before")
    @classmethod
    def _coerce(cls, v: Any) -> Any:
        # Accept either bare strings (no-vocab / resolver mode) or objects
        # {signal, selected_id, selected_name} (folded mode). Strip the
        # STATE:/RELATIVE: type prefixes the model sometimes adds to the phrase.
        if not isinstance(v, list):
            return v
        prefix_re = re.compile(
            r"^\s*(?:state|status|relative|absolute|rank)\s*[:\-–]\s*",
            re.IGNORECASE,
        )
        out: List[Dict[str, Any]] = []
        for item in v:
            if isinstance(item, str):
                s = prefix_re.sub("", item).strip()
                if s:
                    out.append({"signal": s})
            elif isinstance(item, dict):
                sig = prefix_re.sub("", str(item.get("signal", "")).strip()).strip()
                if sig:
                    out.append({
                        "signal": sig,
                        "selected_id": item.get("selected_id"),
                        "selected_name": item.get("selected_name"),
                        "selected_reasoning": item.get("selected_reasoning"),
                    })
        return out



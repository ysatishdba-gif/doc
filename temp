# --------------------------------------------------------------------------- #
# Retrieval-signal coding contracts.
#
# Temporal matching is done inline: the pipeline injects the temporal concept
# names into the build_context prompt, the model picks the match there, and the
# code resolves that pick to a cui + formula deterministically (see TemporalVocab
# and _get_temporal_map). The TemporalResolver protocol below is only the
# fallback for when no vocabulary is supplied — it returns no matches. Record
# types are plain strings.
# --------------------------------------------------------------------------- #
class CodeEntry(BaseModel):
    cui: str
    formula: Optional[str] = None   # from the file, e.g. "REF_POINT - 3Y"; None if none


class TemporalMapping(BaseModel):
    # The time-window concept a phrase matched (or None) and that concept's
    # cui + formula. Keyed by the phrase in the match map, but the phrase
    # itself is not emitted.
    time_window: Optional[str] = None  # concept name picked from the file, e.g. "3 Years"; None if no match
    codes: Optional[str] = None        # the cui, e.g. "C0003"; None if no match
    formula: Optional[str] = None      # e.g. "REF_POINT - 3Y"; None if none


@runtime_checkable
class TemporalResolver(Protocol):
    """Fallback interface, used ONLY when the pipeline has no temporal vocabulary.
    Given the raw phrases, return one TemporalMapping per phrase."""
    def resolve(self, signals: List[Union[str, int]]) -> List[TemporalMapping]: ...


class NullTemporalResolver:
    """Default fallback (no vocabulary supplied): returns each phrase with no
    match and no codes. In normal operation a TemporalVocab is set and matching
    happens inline in build_context, so this is not exercised."""

    def resolve(self, signals: List[Union[str, int]]) -> List[TemporalMapping]:
        return [TemporalMapping(time_window=None, codes=None, formula=None)
                for _ in signals]



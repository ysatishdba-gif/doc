"""
temporal_formula_builder.py

Offline batch job that turns a curated vocabulary of temporal concepts
(LOINC + UMLS) into a normalized retrieval-formula lookup table.

For each concept name it asks Gemini whether the *entire* name expresses a
concrete, measurable duration ("3 years", "past 30 days") as opposed to an
abstract temporal idea ("adolescence", "age", "anniversary"). Concrete ones
get a standardized formula such as "ref_point - 3Y"; everything else is
recorded with formula = None.

Output written to GCS:
    {
      "has_formula": [{code, name, formula, reasoning, code_system}, ...],
      "no_formula":  [{code, name, formula=None, reasoning, code_system}, ...],
    }

This is intentionally SEPARATE from the request-time ContextualIntentPipeline:
it runs over the whole vocabulary on a periodic cadence, not per query, so the
pipeline pays zero extra latency. The pipeline (or a terminology service) is
meant to CONSUME the table this job produces via a cheap dict lookup.

Usage (programmatic):
    cfg = TemporalFormulaConfig(project_id="my-proj", bucket="my-bucket")
    final = run(cfg)

Usage (CLI):
    python temporal_formula_builder.py \
        --project my-proj --bucket my-bucket \
        [--input-blob ...] [--output-blob ...] [--batch-size 100] \
        [--auth-gcloud /path/to/gcloud]
"""

from __future__ import annotations

import argparse
import json
import logging
import re
import subprocess
from dataclasses import dataclass
from typing import Any, Dict, List, Optional, Tuple

from google import genai
from google.cloud import storage

logger = logging.getLogger("temporal_formula_builder")


# --------------------------------------------------------------------------- #
# Config
# --------------------------------------------------------------------------- #
@dataclass
class TemporalFormulaConfig:
    project_id: str
    bucket: str
    input_blob: str = (
        "Normalized_loinc_classes/temporal_norm_code_to_loinc_codes_dict.json"
    )
    output_blob: str = "Normalized_loinc_classes/temporal_norm_code_to_formula.json"
    location: str = "us-central1"
    model: str = "gemini-2.5-flash"
    batch_size: int = 100
    max_output_tokens: int = 8192


# Structured-output schema enforced on the model (unchanged contract).
RESPONSE_SCHEMA: Dict[str, Any] = {
    "type": "array",
    "description": "A list of processed temporal concepts.",
    "items": {
        "type": "object",
        "description": "The processed output for a single temporal concept.",
        "required": ["selected_id", "formula", "reasoning"],
        "properties": {
            "selected_id": {
                "type": "string",
                "description": "unique id of temporal concept",
            },
            "formula": {
                "type": "string",
                "description": "a string of formula generated for temporal concept",
            },
            "reasoning": {
                "type": "string",
                "description": "Brief explanation for selecting the concept and formula",
            },
        },
    },
}


# --------------------------------------------------------------------------- #
# Prompt
# --------------------------------------------------------------------------- #
def build_payload(temp_transactions: List[List[Any]]) -> str:
    """Build the batch prompt.

    `temp_transactions` is a list of [id, name] pairs. NOTE: the few-shot
    example below uses the SAME integer-id format the real data uses, so the
    model returns ids that map straight back to `transaction_dict`.
    """
    return f""" I have a list of transactions mentioned between <transactions> and <transactions> where each transaction has two elements. The first element is the id of the temporal concept
            and the second element is the temporal concept name. For each temporal concept, you need to perform the two steps mentioned between <steps> and </steps>.
            The output must be a dictionary with the selected temporal concept id, its generated formula, and the reason
            for selecting temporal concept and its generated formula. Return empty list if no temporal concept passes step 1.
            <transactions> {temp_transactions} <transactions>

            <steps>
            1) Identify and select the temporal concept whose ENTIRE NAME description and not just part of the name indicates a quantifiable, discrete, and measurable duration of time such as 3 years, 2 days etc., instead of abstract temporal concepts such as adolescence, age, anniversary etc. Example: For temporal concepts: 3 years, 2 years, past 3 years, less than 1 year, I felt good in past 30 days, worse in 3 months. 3 years, 2 years, past 3 years, less than 1 year should be selected and not others.
            2) Only if the temporal concept is selected in step 1 then follow this step and next steps. In this step, check if the temporal concept is a range. If it is, then take the maximum time of that concept such as for '2 to 3 days', '6 to 9 months', use it has '3 days', and '9 months' respectively. If it is not a range then ignore this step.
            3) Next, convert temporal concept to standard temporal concept such as 3 years to 3Y, 2 years to 2Y, 2 month to 2M etc. It is critical that a standardized component such as years to Y should be applied the same way to all selected temporal concepts that has year related terms in their name. Example: 2 years, 3 year, 3y should be 2Y, 3Y, 3Y.
            4) Finally, create a formula string using standardized temporal concept name as "ref_point - standard temporal concept". Example: ref_point - 3Y
            </steps>

            * Examples *
            ** input **

            transactions = [[0, "age"], [1, "adolescence"], [2, "3 years"], [3, "anniversaries"], [4, "1 year"],
                            [5, "Rejection of care - presence and frequency in last 7D"], [6, "less than one year"]]

            ** output **
            [{{"selected_id": "2",
                "formula": "ref_point - 3Y",
                "reasoning": "this temporal concept indicates a concrete measurement of time and the formula maps years to the standard term Y."
            }},
            {{"selected_id": "4",
                "formula": "ref_point - 1Y",
                "reasoning": "this temporal concept indicates a concrete measurement of time and the formula maps year to the standard term Y."
            }},
            {{"selected_id": "6",
                "formula": "ref_point - 1Y",
                "reasoning": "this temporal concept indicates a concrete measurement of time and the formula maps year to the standard term Y."
            }}]


            """


# --------------------------------------------------------------------------- #
# GCS helpers (client is passed in so it is created once and reused)
# --------------------------------------------------------------------------- #
def read_json_from_gcs(client: storage.Client, bucket: str, blob_name: str) -> Any:
    blob = client.bucket(bucket).blob(blob_name)
    return json.loads(blob.download_as_text())


def save_json_to_gcs(
    client: storage.Client, bucket: str, blob_name: str, data: Any
) -> None:
    blob = client.bucket(bucket).blob(blob_name)
    blob.upload_from_string(
        data=json.dumps(data, indent=4),
        content_type="application/json",
    )


# --------------------------------------------------------------------------- #
# Model call (with one retry + safe fallback, mirroring the pipeline)
# --------------------------------------------------------------------------- #
def _strip_fences(text: str) -> str:
    text = re.sub(r"^```(?:json)?\s*", "", text.strip())
    return re.sub(r"\s*```$", "", text)


def call_gemini(
    client: genai.Client, payload: str, cfg: TemporalFormulaConfig
) -> List[Dict[str, Any]]:
    """Return the model's list for one batch; [] on failure (logged), so a
    single bad batch never aborts the whole job."""
    last_exc: Optional[Exception] = None
    for _ in range(2):
        try:
            response = client.models.generate_content(
                model=cfg.model,
                contents=payload,
                config={
                    "response_mime_type": "application/json",
                    "response_schema": RESPONSE_SCHEMA,
                    "max_output_tokens": cfg.max_output_tokens,
                },
            )
            text = _strip_fences(response.text or "")
            if not text.strip():
                raise ValueError("empty response text")
            data = json.loads(text)
            return data if isinstance(data, list) else []
        except Exception as e:  # noqa: BLE001 - intermittent LLM/JSON errors
            last_exc = e
    logger.warning(
        "batch failed after retry (%s); skipping batch: %s",
        type(last_exc).__name__,
        str(last_exc)[:200],
    )
    return []


# --------------------------------------------------------------------------- #
# Pure transforms (no I/O — unit-testable)
# --------------------------------------------------------------------------- #
def build_transactions(
    all_temporal_codes: Dict[str, str]
) -> Tuple[Dict[int, Dict[str, str]], List[List[Any]]]:
    transaction_dict = {
        i: {"code": code, "name": name}
        for i, (code, name) in enumerate(all_temporal_codes.items())
    }
    transactions = [[i, c["name"]] for i, c in transaction_dict.items()]
    return transaction_dict, transactions


def _coerce_id(raw: Any) -> Optional[int]:
    """Tolerate "2", "id_2", or 2; return None if no digits present."""
    digits = re.sub(r"\D", "", str(raw if raw is not None else ""))
    return int(digits) if digits else None


def assemble_results(
    all_results: List[List[Dict[str, Any]]],
    transaction_dict: Dict[int, Dict[str, str]],
    loinc_keys: set,
    umls_keys: set,
) -> Dict[str, List[Dict[str, Any]]]:
    """Split the vocabulary into has_formula / no_formula. Unknown or
    duplicate ids returned by the model are skipped rather than crashing."""

    def code_system(code: str) -> str:
        return "loinc" if code in loinc_keys else "umls"

    has_formula: List[Dict[str, Any]] = []
    has_ids: set = set()
    for batch in all_results:
        for item in batch:
            t_id = _coerce_id(item.get("selected_id"))
            if t_id is None or t_id not in transaction_dict or t_id in has_ids:
                continue
            has_ids.add(t_id)
            code = transaction_dict[t_id]["code"]
            formula = (item.get("formula") or "").upper() or None
            has_formula.append(
                {
                    "code": code,
                    "name": transaction_dict[t_id]["name"],
                    "formula": formula,
                    "reasoning": item.get("reasoning", ""),
                    "code_system": code_system(code),
                }
            )

    no_formula: List[Dict[str, Any]] = []
    for t_id, concept in transaction_dict.items():
        if t_id in has_ids:
            continue
        code = concept["code"]
        no_formula.append(
            {
                "code": code,
                "name": concept["name"],
                "formula": None,
                "reasoning": "llm did not provide formula for this concept",
                "code_system": code_system(code),
            }
        )

    return {"has_formula": has_formula, "no_formula": no_formula}


# --------------------------------------------------------------------------- #
# Orchestration
# --------------------------------------------------------------------------- #
def run(cfg: TemporalFormulaConfig) -> Dict[str, List[Dict[str, Any]]]:
    storage_client = storage.Client(project=cfg.project_id)
    genai_client = genai.Client(
        vertexai=True, project=cfg.project_id, location=cfg.location
    )

    # Single read; derive both the merged vocabulary and the per-system key
    # sets from it (the original re-read GCS just to get these keys).
    vocab = read_json_from_gcs(storage_client, cfg.bucket, cfg.input_blob)
    loinc = vocab["loinc_related_temporal_codes"]
    umls = vocab["umls_related_temporal_concept_codes"]
    all_temporal_codes: Dict[str, str] = {**loinc, **umls}
    loinc_keys, umls_keys = set(loinc.keys()), set(umls.keys())

    transaction_dict, transactions = build_transactions(all_temporal_codes)
    logger.info("processing %d temporal concepts", len(transactions))

    all_results: List[List[Dict[str, Any]]] = []
    for start in range(0, len(transactions), cfg.batch_size):
        batch = transactions[start : start + cfg.batch_size]
        logger.info("batch %d-%d", start, start + len(batch))
        all_results.append(call_gemini(genai_client, build_payload(batch), cfg))

    final = assemble_results(all_results, transaction_dict, loinc_keys, umls_keys)
    save_json_to_gcs(storage_client, cfg.bucket, cfg.output_blob, final)
    logger.info(
        "done: %d with formula, %d without",
        len(final["has_formula"]),
        len(final["no_formula"]),
    )
    return final


def ensure_adc(gcloud_path: str) -> None:
    """Optional, interactive. Prefer a service account for automated runs."""
    proc = subprocess.run([gcloud_path, "auth", "application-default", "login"])
    if proc.returncode != 0:
        raise RuntimeError("gcloud application-default login failed")


def main() -> None:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--project", required=True)
    parser.add_argument("--bucket", required=True)
    parser.add_argument("--input-blob", default=TemporalFormulaConfig.input_blob)
    parser.add_argument("--output-blob", default=TemporalFormulaConfig.output_blob)
    parser.add_argument("--location", default=TemporalFormulaConfig.location)
    parser.add_argument("--model", default=TemporalFormulaConfig.model)
    parser.add_argument("--batch-size", type=int, default=TemporalFormulaConfig.batch_size)
    parser.add_argument(
        "--max-output-tokens", type=int, default=TemporalFormulaConfig.max_output_tokens
    )
    parser.add_argument(
        "--auth-gcloud",
        metavar="GCLOUD_PATH",
        help="Run interactive `gcloud auth application-default login` first.",
    )
    args = parser.parse_args()

    logging.basicConfig(level=logging.INFO, format="%(levelname)s %(message)s")

    if args.auth_gcloud:
        ensure_adc(args.auth_gcloud)

    cfg = TemporalFormulaConfig(
        project_id=args.project,
        bucket=args.bucket,
        input_blob=args.input_blob,
        output_blob=args.output_blob,
        location=args.location,
        model=args.model,
        batch_size=args.batch_size,
        max_output_tokens=args.max_output_tokens,
    )
    run(cfg)


if __name__ == "__main__":
    main()

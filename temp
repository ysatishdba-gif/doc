from google.cloud import storage
from google import genai
import json
import subprocess

def auth_gcp(gcloud_loc: str):
    '''
    # Authenticate with GCP environment within the program

    :param gcloud_loc: location of gcloud credentials.json file
    '''

    tmp = subprocess.run([gcloud_loc, 'auth', 'application-default', 'login'], stdout=subprocess.PIPE)
    if tmp.returncode == 1:
        raise Exception("GCloud login failed")


def get_token(GCLOUD_LOC):
    '''
    Get GCP token within the program
    '''
    # Get the identity token
    tmp = subprocess.run([GCLOUD_LOC, 'auth', 'print-identity-token'], stdout=subprocess.PIPE, universal_newlines=True)
    token = str(tmp.stdout).strip()

    # Set the headers including the Authorization and Content-Type
    headers = {
        "Authorization": f"Bearer {token}",
    }
    return headers

def read_json_from_gcs(project_id, source_blob_name, bucket):
    # Initialize the client
    client = storage.Client(project=project_id)

    # Get the bucket and the specific blob (file)
    bucket = client.bucket(bucket)
    blob = bucket.blob(source_blob_name)

    # Download the content as a string
    json_data = blob.download_as_text()

    # Parse the JSON string into a Python dictionary
    return json.loads(json_data)


def save_json_to_gcs(project_id, source_blob_name, bucket, results):
    # Initialize the client
    client = storage.Client(project=project_id)

    # Get the bucket and the specific blob (file)
    bucket = client.bucket(bucket)
    blob = bucket.blob(source_blob_name)

    # Download the content as a string
    json_data = json.dumps(results, indent=4)

    # Parse the JSON string into a Python dictionary
    blob.upload_from_string(
        data=json_data,
        content_type='application/json'
    )

def get_genai_payload(temp_transactions):
    temp_payload = f""" I have a list of transactions mentioned between <transactions> and <transactions> where each transaction has two elements. The first element is the id of the temporal concept
            and the second element is the temporal concept name. For each temporal concept, you need to perform the two steps mentioned between <steps> and </steps>.
            The output must be a dictionary with the selected temporal concept id, its generated formula, and the reason
            for selecting temporal concept and its generated formula. Return empty list if no temporal concept passes step 1. 
            <transactions> {temp_transactions} <transactions>
            
            <steps>
            1) Identify and select the temporal concept whose ENTIRE NAME description and not just part of the name indicates a quantifiable, discrete, and measurable duration of time such as 3 years, 2 days etc., instead of abstract temporal concepts such as adolescence, age, anniversary etc. Example: For temporal concepts: 3 years, 2 years, past 3 years, less than 1 year, I felt good in past 30 days, worse in 3 months. 3 years, 2 years, past 3 years, less than 1 year should be selected and not others.
            2) Only if the temporal concept is selected in step 1 then follow this step and next steps. In this step, check if the temporal concept is a range. If it is, then take the maximum time of that concept such as for '2 to 3 days', '6 to 9 months', use it has '3 days', and '9 months' respectively. If it is not a range then ignore this step.
            3) Next, convert temporal concept to standard temporal concept such as 3 years to 3Y, 2 years to 2Y, 2 month to 2M etc. It is critical that a standardized component such as years to Y should be applied the same way to all selected temporal concepts that has year related terms in their name. Example: 2 years, 3 year, 3y should be 2Y, 3Y, 3Y.
            4) Finally, create a formula string using standardized temporal concept name as "ref_point - standard temporal concept". Example: ref_point - 3Y
            </steps>

            * Examples *
            ** input **
            
            transactions = [[id_1, 'age'], [id_2, 'adolesence'], ['id_3', '3 years'], ['id_4', 'anniverseries'], ['id_5', '1 year'],
                            ['id_6', 'Rejection of care - presence and frequency in last 7D'], ['id_7', 'less than one year']]

            ** output **
            [{{"selected_id": 'id_3',
                "formula": 'ref_point - 3Y',
                "reasoning": this is temporal concept indicates concrete measurement of time and formula is provided as mentioned in prompt name with years mapped to a standard term Y.
            }},
            {{"selected_id": 'id_5',
                "formula": 'ref_point - 1Y',
                "reasoning": this is temporal concept indicates concrete measurement of time and formula is provided as mentioned in prompt name with year mapped to a standard term Y.
            }},
            {{"selected_id": 'id_7',
                "formula": 'ref_point - 1Y',
                "reasoning": this is temporal concept indicates concrete measurement of time and formula is provided as mentioned in prompt name with year mapped to a standard term Y.
            }}]

            
            """

    return temp_payload


def get_genai_resp(temp_payload, project_id, location):
    client = genai.Client(vertexai=True, project=project_id, location=location)
    response_schema = {
        "type": "array",
        "description": "A list of processed temporal concepts.",
        "items":{
        "type": "object",
        "description": "The processed output for a single record type name.",
        "required": [
            "selected_id",
            "formula",
            "reasoning"
        ],
        "properties": {
            "selected_id": {
                "type": "string",
                "description": "unique id of temporal concept"
            },
            "formula": {
                "type": "string",
                "description": "a string of formula generated for temporal concept"
            },
            "reasoning": {
                "type": "string",
                "description": "Brief explanation for selecting the temporal concept and the formula"
            }
        }
    }
    }
    response = client.models.generate_content(
        model="gemini-2.5-flash",
        contents=temp_payload,
        config={
            "response_mime_type": "application/json",
            "response_schema": response_schema,
        },
    )

    resp_dict = json.loads(response.text)

    return resp_dict


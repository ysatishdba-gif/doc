"""
api.py — request payload + validation for the Intent Finder endpoint.

Framework-agnostic on purpose:
  * IntentRequest validates/sanitizes the incoming payload.
  * handle_intent_request() validates, runs the pipeline, and returns
    (body, http_status).
Wire it to FastAPI / Flask with a thin endpoint (see the bottom of this file).
"""

from typing import Any, Dict, Tuple

from pydantic import BaseModel, Field, ValidationError, field_validator

# NOTE: ContextualIntentPipeline and minimal_pipeline come from the intent cell above


# Accepted spellings for the on/off switch in the client payload.
_TRUTHY = {"yes", "y", "true", "1", "on"}
_FALSY = {"no", "n", "false", "0", "off", ""}


class IntentRequest(BaseModel):
    """Incoming request payload.

    retrieval_signals is the on/off switch the client sends. It accepts
    "Yes"/"No" (case-insensitive) or true/false. If omitted it defaults to
    False, so existing clients keep the pre-signals response unchanged
    (backward compatible).
    """

    query: str = Field(..., min_length=1, max_length=4000)
    retrieval_signals: bool = False

    @field_validator("query")
    @classmethod
    def _clean_query(cls, v: str) -> str:
        # trim and collapse internal whitespace; reject empty/whitespace-only
        v = " ".join(v.split())
        if not v:
            raise ValueError("query must not be empty")
        return v

    @field_validator("retrieval_signals", mode="before")
    @classmethod
    def _coerce_yes_no(cls, v: Any) -> bool:
        if isinstance(v, bool):
            return v
        if v is None:
            return False
        if isinstance(v, int):
            return bool(v)
        if isinstance(v, str):
            s = v.strip().lower()
            if s in _TRUTHY:
                return True
            if s in _FALSY:
                return False
        raise ValueError('retrieval_signals must be "Yes" or "No" (or true/false)')


def _error(code: str, message: str, details: Any = None) -> Dict[str, Any]:
    """The one error shape used everywhere."""
    return {"error": {"code": code, "message": message, "details": details}}


def handle_intent_request(
    pipeline: ContextualIntentPipeline, payload: Dict[str, Any]
) -> Tuple[Dict[str, Any], int]:
    """Validate the payload and run the pipeline.

    On success the body is the pipeline output and status is 200. The
    retrieval_signals block is present ONLY when the client said Yes — and the
    4th LLM call only runs in that case (No -> it neither runs nor returns).

    On failure the body is the error envelope and status is 4xx/5xx.
    """
    try:
        req = IntentRequest.model_validate(payload)
    except ValidationError as e:
        return _error("invalid_request", "Request validation failed", e.errors()), 422

    try:
        result = minimal_pipeline(
            pipeline, req.query, include_retrieval_signals=req.retrieval_signals
        )
    except ValueError as e:
        return _error("invalid_query", str(e)), 400
    except Exception:  # pragma: no cover - log server-side, don't leak internals
        return _error("internal_error", "Intent extraction failed"), 500

    return result, 200



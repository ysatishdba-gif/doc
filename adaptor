"""
topic_adaptor.py
----------------
Loads topics (from topics.pkl, built by build_topics.py) and matches
topic-ID sets between a query and documents.

Matching uses TOP-K-BY-IC at scoring time: among the topics shared between
query and document, only the K most-specific (highest anchor IC) are scored.
This keeps broad/low-IC "blob" topics out of the score without filtering
anything at formation time. K defaults to 3.

  cuis_to_topics(cuis)             : CUI list -> set of topic IDs
  match(query_tp_ids, doc_tp_ids)  : score on top-K-by-IC shared topics
  search(query_tp_ids, doc_index)  : rank many docs

Scoring metrics (computed on the top-K-by-IC shared topics):
  count          - number of shared topics SCORED (<= K)
  shared_total   - total shared topics before top-K cut
  min_inv_size   - 1 / min(size) over scored topics
  sum_inv_size   - sum(1/size) over scored topics
  max_anchor_ic  - max anchor IC among scored topics
  sum_anchor_ic  - sum of anchor ICs among scored topics
"""

import pickle

_SHARED = {}   # process-level cache for explicit-path loads


class TopicAdaptor:
    def __init__(self, topics_pkl=None, top_k=3):
        """
        topics_pkl=None  -> use config.topics (shared, loaded once)
        topics_pkl="..." -> load that pickle directly (cached per path)
        top_k            -> how many shared topics to score (top-K by IC)
        """
        self.top_k = top_k

        if topics_pkl is None:
            from config import topics, TOPICS_PATH
            if topics is None:
                raise FileNotFoundError(
                    f"{TOPICS_PATH} not found — run build_topics.py first")
            p = topics
        else:
            if topics_pkl not in _SHARED:
                with open(topics_pkl, "rb") as f:
                    _SHARED[topics_pkl] = pickle.load(f)
            p = _SHARED[topics_pkl]

        self.cui_to_topic_ids  = p["cui_to_topic_ids"]
        self.topic_id_to_topic = p["topic_id_to_topic"]
        self.labels            = p.get("labels", {})
        self.config            = p.get("config", {})
        print(f"TopicAdaptor: {len(self.topic_id_to_topic):,} topics, "
              f"{len(self.cui_to_topic_ids):,} CUIs with topics, top_k={top_k}")

    # ---- CUI set -> topic IDs ----
    def cuis_to_topics(self, cuis):
        out = set()
        for c in cuis:
            out.update(self.cui_to_topic_ids.get(c, ()))
        return out

    # ---- topic lookups ----
    def topic_size(self, tp_id):
        t = self.topic_id_to_topic.get(tp_id)
        return t["size"] if t else 0

    def topic_anchor(self, tp_id):
        t = self.topic_id_to_topic.get(tp_id)
        return t["canonical"] if t else None

    def topic_anchor_ic(self, tp_id):
        t = self.topic_id_to_topic.get(tp_id)
        return t["anchor_ic"] if t else 0.0

    def topic_members(self, tp_id):
        t = self.topic_id_to_topic.get(tp_id)
        return t["members"] if t else frozenset()

    def topic_label(self, tp_id):
        anchor = self.topic_anchor(tp_id)
        return self.labels.get(anchor, anchor) if anchor else tp_id

    # ---- scoring: one query vs one doc ----
    def match(self, query_tp_ids, doc_tp_ids, top_k=None):
        """Score on the top-K-by-IC shared topics (K = top_k or self.top_k)."""
        k = self.top_k if top_k is None else top_k
        q = set(query_tp_ids)
        d = set(doc_tp_ids)
        shared_all = q & d
        if not shared_all:
            return {"count": 0, "shared_total": 0, "min_inv_size": 0.0,
                    "sum_inv_size": 0.0, "max_anchor_ic": 0.0,
                    "sum_anchor_ic": 0.0, "shared": []}

        # rank shared topics by anchor IC (most specific first), keep top-K
        ranked = sorted(shared_all,
                        key=lambda tp: self.topic_anchor_ic(tp),
                        reverse=True)
        scored = ranked[:k]

        details, sizes, ics = [], [], []
        for tp in scored:
            sz = self.topic_size(tp)
            ic = self.topic_anchor_ic(tp)
            sizes.append(sz)
            ics.append(ic)
            details.append({"tp_id": tp, "size": sz,
                            "anchor_ic": round(ic, 4),
                            "label": self.topic_label(tp)})
        details.sort(key=lambda r: r["size"])  # show most specific (smallest) first

        valid = [s for s in sizes if s > 0]
        min_size = min(valid) if valid else 0
        return {
            "count":         len(scored),
            "shared_total":  len(shared_all),
            "min_inv_size":  round(1.0 / min_size, 4) if min_size else 0.0,
            "sum_inv_size":  round(sum(1.0 / s for s in valid), 4),
            "max_anchor_ic": round(max(ics), 4) if ics else 0.0,
            "sum_anchor_ic": round(sum(ics), 4),
            "shared":        details,
        }

    # ---- search over many docs ----
    def search(self, query_tp_ids, doc_index, top_n=10,
               rank_by="sum_inv_size", top_k=None):
        """
        doc_index : {doc_id: set/list of tp_ids}
        top_n     : how many docs to return
        rank_by   : metric to sort docs on
        top_k     : top-K-by-IC shared topics to score (default self.top_k)
        """
        q = set(query_tp_ids)
        results = []
        for doc_id, doc_tps in doc_index.items():
            m = self.match(q, doc_tps, top_k=top_k)
            if m["count"] == 0:
                continue
            m["doc_id"] = doc_id
            results.append(m)
        results.sort(key=lambda r: -r.get(rank_by, 0))
        return results[:top_n]

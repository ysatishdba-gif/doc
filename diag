"""
diagnose_cui.py
---------------
Diagnose WHY specific CUIs anchored where they did (or didn't).

Reads umls_cache.pkl + topics.pkl. For each CUI in DIAGNOSE_CUIS, shows:
  - The seed's defining attributes
  - The seed's direct parents and each parent's attributes
  - Why each parent did or didn't preserve the seed's attributes
  - The resulting anchor(s)

This is the tool to use when you see a self-anchored CUI in
inspect_pickle.py and want to know why it didn't walk up further.
"""

import pickle

CACHE_PATH = "umls_cache.pkl"
TOPICS_PATH = "topics.pkl"

DIAGNOSE_CUIS = [
    "C4517381",   # Discharge specimen from penis
    "C1275033",   # PUVA therapy-associated SCC
    "C4302701",   # Wedge pressure technique
    "C2960444",   # Mixed serous and mucinous cystadenoma
]

STRICT_SLOTS = {"has_finding_site", "has_laterality"}


def main():
    print(f"Loading {CACHE_PATH} ...")
    with open(CACHE_PATH, "rb") as f:
        cache = pickle.load(f)
    print(f"Loading {TOPICS_PATH} ...")
    with open(TOPICS_PATH, "rb") as f:
        topics = pickle.load(f)

    # Parse MRREL the same way build_topics.py does, but keep ALL hierarchy
    # edges so we can see what parents exist even if our policy excluded them.
    from collections import defaultdict
    parents_all = defaultdict(dict)  # child -> { parent: (REL, RELA) }
    attrs = defaultdict(dict)
    for cui1, cui2, rel, rela in cache["mrrel_rows"]:
        # Hierarchy-shaped rows: any REL that has CUI1 as parent of CUI2
        if rel in ("CHD", "RB", "SY", "SIB") or (rel == "PAR" and rela == "inverse_isa"):
            # CHD/isa, RB, SY: CUI1 is parent
            # PAR/inverse_isa: CUI1 is parent (since PAR says CUI2 is parent of CUI1, inverse)
            # Actually PAR/inverse_isa means CUI1 is the parent — same direction as CHD
            parents_all[cui2][cui1] = (rel, rela)
        elif rel == "RO" and rela and not rela.startswith("inverse_") and rela != "isa":
            attrs[cui2].setdefault(rela, cui1)

    labels = cache["labels"]

    def lbl(cui):
        return labels.get(cui, "?")

    for seed_cui in DIAGNOSE_CUIS:
        print("\n" + "=" * 72)
        print(f"SEED: {seed_cui}  ({lbl(seed_cui)})")
        print("=" * 72)

        seed_attrs = attrs.get(seed_cui, {})
        print(f"\nSeed attributes ({len(seed_attrs)}):")
        if not seed_attrs:
            print("  (none — seed will anchor to itself automatically)")
        for rela, val in sorted(seed_attrs.items()):
            strict = "  [STRICT]" if rela in STRICT_SLOTS else ""
            print(f"  {rela:35s} -> {val}  ({lbl(val)}){strict}")

        # Show what the topic pickle says happened
        topic_entries = topics["anchors"].get(seed_cui, [])
        print(f"\nAnchors from topics.pkl ({len(topic_entries)}):")
        for e in topic_entries:
            print(f"  {e['anchor']}  ({lbl(e['anchor'])})  lost={e['lost']}")

        # Show ALL parents of the seed (any REL)
        all_parents = parents_all.get(seed_cui, {})
        print(f"\nAll parents in MRREL ({len(all_parents)}):")
        if not all_parents:
            print("  (none — seed has no parents in any REL type)")

        for parent_cui, (rel, rela) in sorted(all_parents.items()):
            parent_attrs = attrs.get(parent_cui, {})
            print(f"\n  Parent: {parent_cui}  ({lbl(parent_cui)})")
            print(f"    edge type      : REL={rel} RELA={rela}")
            print(f"    parent attrs   : {len(parent_attrs)} total")

            # Check what would break under our current matching rule
            broken = []
            for rela_name, seed_value in seed_attrs.items():
                if rela_name in STRICT_SLOTS:
                    if parent_attrs.get(rela_name) != seed_value:
                        broken.append(f"STRICT {rela_name}: "
                                      f"seed={seed_value}({lbl(seed_value)}) "
                                      f"vs parent={parent_attrs.get(rela_name)}"
                                      f"({lbl(parent_attrs.get(rela_name)) if parent_attrs.get(rela_name) else 'missing'})")
                else:
                    if rela_name not in parent_attrs:
                        broken.append(f"MISSING {rela_name}: "
                                      f"seed has it, parent doesn't")

            if broken:
                print(f"    boundary fires : YES, because:")
                for reason in broken:
                    print(f"      - {reason}")
            else:
                print(f"    boundary fires : NO — would walk up to this parent")


if __name__ == "__main__":
    main()

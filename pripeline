"""
Stage 2 of 2: form topics using TWO approaches in parallel for comparison.

Reads:  cui_expansion_lookup.pkl   (built by run_builder.py)
Writes: cui_topic_lookup.pkl       (same data + topic_id_hac + topic_id_components)

Both approaches assign topics within each semantic type independently.

APPROACH 1: HAC + silhouette-maximizing auto-cut (topic_id_hac)
  - Build sparse Jaccard distance matrix between same-type CUIs
  - Run HAC with average linkage
  - Evaluate silhouette at every merge height; pick the cut with highest silhouette
  - Higher quality clusters but expensive (hours on large types)
  - Adaptive per semantic type

APPROACH 2: Connected components on relation graph (topic_id_components)
  - Build a graph: edge between two CUIs iff they have a direct MRREL relation
    (PAR, CHD, RB, RN, SY, SIB) AND share the same semantic type.
  - Each connected component becomes a topic.
  - Fast (seconds), no thresholds, no parameters.
  - Risk: dense relation graphs can produce mega-components.

Storing both lets you compare on real data and pick the one that works.

Topic IDs are scoped per semantic type:
    "<semantic_type>::hac::<int>"           or "<semantic_type>::hac::singleton::<cui>"
    "<semantic_type>::components::<int>"    or "<semantic_type>::components::singleton::<cui>"

Design choices that are NOT tunable knobs:
  - LINKAGE_METHOD = "average" (standard for arbitrary distance metrics)
  - Silhouette requires 2 <= k <= n-1 to be defined (mathematical, not a threshold)
  - Memory cap is auto-derived from system RAM at runtime
"""

import os
import pickle
import sys
import time
from collections import defaultdict

import numpy as np
import psutil
from scipy.cluster.hierarchy import linkage, fcluster
from scipy.spatial.distance import squareform
from sklearn.metrics import silhouette_score

try:
    sys.stdout.reconfigure(line_buffering=True)
except AttributeError:
    pass


INPUT  = "cui_expansion_lookup.pkl"
OUTPUT = "cui_topic_lookup.pkl"

# Linkage method is a fixed algorithmic choice, not a tunable threshold.
# "average" is the standard default for arbitrary distance metrics.
LINKAGE_METHOD = "average"


def auto_max_safe_cuis():
    """Derive the largest CUI count we can safely build a float32 N x N
    distance matrix for, based on currently-available system memory.

    We reserve half of available memory for the matrix and overhead;
    the other half stays free for HAC linkage, silhouette computation,
    and Python overhead.
    """
    available_bytes = psutil.virtual_memory().available
    matrix_budget = available_bytes // 2          # leave half for everything else
    bytes_per_cell = 4                            # float32
    max_cells = matrix_budget // bytes_per_cell
    # max N where N*N <= max_cells
    max_n = int(np.sqrt(max_cells))
    return max_n


def assign_topics_components(lookup):
    """Connected-components topic assignment.

    For each semantic type, build a graph where each CUI's expansion list
    defines its edges. Connected components of this graph are topics.

    Notes:
      - Edges come from same-type, allowed-relation expansion (already
        filtered in Stage 1). No additional thresholds applied here.
      - Components are computed per semantic type independently (CUIs of
        different types never share a topic, even if they appear in
        each other's expansions — this is enforced by Stage 1's design).
      - Risk: dense relation graphs can produce mega-components covering
        most of a semantic type. The output stats show component sizes
        so this is visible.
    """
    print("  Forming topics via connected components...")
    t = time.time()

    # Build edges per semantic type
    edges_by_type = defaultdict(list)
    cuis_by_type  = defaultdict(set)
    for cui, entry in lookup.items():
        sem_type = entry["semantic_type"]
        cuis_by_type[sem_type].add(cui)
        for e in entry["expansion"]:
            other = e["cui"]
            # Stage 1 already filtered expansion to same semantic type, so
            # all entries are same-type by construction. We add the edge.
            edges_by_type[sem_type].append((cui, other))

    assignments = {}
    component_sizes = []
    n_types = len(cuis_by_type)

    for type_idx, (sem_type, cuis_in_type) in enumerate(cuis_by_type.items(), 1):
        if type_idx % 20 == 0 or type_idx == 1 or type_idx == n_types:
            print(f"    [{type_idx}/{n_types}] semantic_type={sem_type!r}  "
                  f"CUIs={len(cuis_in_type):,}", flush=True)

        # Union-Find for connected components (faster than DFS for large graphs)
        parent = {c: c for c in cuis_in_type}

        def find(x):
            # Path compression
            root = x
            while parent[root] != root:
                root = parent[root]
            while parent[x] != root:
                parent[x], x = root, parent[x]
            return root

        def union(a, b):
            ra, rb = find(a), find(b)
            if ra != rb:
                parent[ra] = rb

        for a, b in edges_by_type[sem_type]:
            if a in parent and b in parent:
                union(a, b)

        # Group by root
        components = defaultdict(list)
        for cui in cuis_in_type:
            components[find(cui)].append(cui)

        for comp_idx, (root, members) in enumerate(components.items()):
            component_sizes.append(len(members))
            if len(members) == 1:
                assignments[members[0]] = (
                    f"{sem_type}::components::singleton::{members[0]}"
                )
            else:
                tid = f"{sem_type}::components::{comp_idx}"
                for cui in members:
                    assignments[cui] = tid

    # Write topic_id_components into lookup
    for cui, entry in lookup.items():
        entry["topic_id_components"] = assignments.get(
            cui, f"{entry['semantic_type']}::components::unassigned"
        )

    distinct = set(assignments.values())
    singletons = sum(1 for x in distinct if "::singleton::" in x)
    multi = len(distinct) - singletons

    print(f"  -> done ({time.time()-t:.1f}s)")
    print(f"    Topics: {len(distinct):,} distinct")
    print(f"      multi-CUI:  {multi:,}")
    print(f"      singletons: {singletons:,}")

    if component_sizes:
        sizes = sorted(component_sizes)
        print(f"    Component size distribution:")
        print(f"      min:    {sizes[0]:,}")
        print(f"      median: {sizes[len(sizes)//2]:,}")
        print(f"      mean:   {sum(sizes)/len(sizes):.0f}")
        print(f"      p95:    {sizes[int(len(sizes)*0.95)]:,}")
        print(f"      max:    {sizes[-1]:,}")

    return lookup


def find_best_cut_silhouette(Z, dist_matrix):
    """For a dendrogram Z and full distance matrix, evaluate silhouette
    at EVERY merge height in the dendrogram and return cluster_ids from
    the highest-silhouette cut.

    Silhouette is undefined for k=1 (one cluster) and k=n (every CUI
    alone). These are mathematical boundaries, not tunable parameters —
    cuts producing those k values are skipped.
    """
    n_samples = dist_matrix.shape[0]
    if n_samples < 3:
        # Silhouette needs at least 3 points to be defined.
        return np.arange(1, n_samples + 1, dtype=np.int64), -1.0, None

    merge_heights = Z[:, 2]
    if merge_heights.min() == merge_heights.max():
        # Degenerate dendrogram (all merges at same height).
        return np.arange(1, n_samples + 1, dtype=np.int64), -1.0, None

    # Evaluate at every merge height. We cut just below each merge, which
    # gives us the cluster state right before that merge happened. This
    # covers all distinct k values from k=n down to k=1 as we sweep up.
    sorted_heights = np.unique(merge_heights)
    eps = (sorted_heights[-1] - sorted_heights[0]) * 1e-9

    best_score = -np.inf
    best_ids = None
    best_height = None
    for h in sorted_heights:
        # Cut just below this merge height
        cut_at = float(h) - eps
        ids = fcluster(Z, t=cut_at, criterion="distance")
        k = len(set(ids))
        # Mathematical requirement, not a tunable: silhouette undefined
        # for k=1 or k=n.
        if k < 2 or k >= n_samples:
            continue
        try:
            score = silhouette_score(dist_matrix, ids, metric="precomputed")
        except Exception:
            continue
        if score > best_score:
            best_score = score
            best_ids = ids
            best_height = cut_at

    if best_ids is None:
        return np.arange(1, n_samples + 1, dtype=np.int64), -1.0, None

    return best_ids, best_score, best_height


def assign_topics_hac(lookup, linkage_method, max_safe_cuis):
    """Run HAC per semantic type with silhouette-maximizing auto-cut.

    Each semantic type's dendrogram is cut at the height that maximizes
    silhouette on its own distance matrix. No manual thresholds.
    """
    print(f"  Forming topics (HAC, linkage={linkage_method}, "
          f"silhouette over every merge height)...")
    print(f"  Memory-derived max-safe CUIs per type: {max_safe_cuis:,}")
    t = time.time()

    by_type = defaultdict(list)
    for cui, entry in lookup.items():
        by_type[entry["semantic_type"]].append(cui)

    expansion_set = {
        cui: {e["cui"] for e in lookup[cui]["expansion"]}
        for cui in lookup
    }

    assignments = {}
    n_types = len(by_type)
    skipped_large = []
    cut_summary = []

    for type_idx, (sem_type, cuis_in_type) in enumerate(by_type.items(), 1):
        n_cuis = len(cuis_in_type)
        if type_idx % 20 == 0 or type_idx == 1 or type_idx == n_types:
            print(f"    [{type_idx}/{n_types}] semantic_type={sem_type!r}  "
                  f"CUIs={n_cuis:,}", flush=True)

        if n_cuis < 2:
            for cui in cuis_in_type:
                assignments[cui] = f"{sem_type}::hac::singleton::{cui}"
            continue

        if n_cuis > max_safe_cuis:
            skipped_large.append((sem_type, n_cuis))
            for cui in cuis_in_type:
                assignments[cui] = f"{sem_type}::hac::oversized::{cui}"
            continue

        cui_to_idx = {c: i for i, c in enumerate(cuis_in_type)}

        member_index = defaultdict(list)
        for cui in cuis_in_type:
            for m in expansion_set[cui]:
                member_index[m].append(cui)

        dist = np.ones((n_cuis, n_cuis), dtype=np.float32)
        np.fill_diagonal(dist, 0.0)

        seen_pairs = set()
        for member, sharers in member_index.items():
            if len(sharers) < 2:
                continue
            for i in range(len(sharers)):
                for j in range(i + 1, len(sharers)):
                    a, b = sharers[i], sharers[j]
                    pair = (a, b) if a < b else (b, a)
                    if pair in seen_pairs:
                        continue
                    seen_pairs.add(pair)
                    sa = expansion_set[a]
                    sb = expansion_set[b]
                    union = len(sa | sb)
                    if union == 0:
                        continue
                    inter = len(sa & sb)
                    distance = 1.0 - (inter / union)
                    ia, ib = cui_to_idx[a], cui_to_idx[b]
                    dist[ia, ib] = distance
                    dist[ib, ia] = distance

        try:
            condensed = squareform(dist, checks=False)
            Z = linkage(condensed, method=linkage_method)
            cluster_ids, best_score, best_height = find_best_cut_silhouette(
                Z, dist,
            )
        except Exception as e:
            print(f"      HAC failed for {sem_type}: {e}")
            for cui in cuis_in_type:
                assignments[cui] = f"{sem_type}::hac::failed::{cui}"
            continue

        clusters = defaultdict(list)
        for cui, cid in zip(cuis_in_type, cluster_ids):
            clusters[int(cid)].append(cui)

        cut_summary.append((sem_type, n_cuis, len(clusters),
                            best_score, best_height))

        for cid, members in clusters.items():
            if len(members) == 1:
                assignments[members[0]] = f"{sem_type}::hac::singleton::{members[0]}"
            else:
                tid = f"{sem_type}::hac::{cid - 1}"
                for cui in members:
                    assignments[cui] = tid

    for cui, entry in lookup.items():
        entry["topic_id_hac"] = assignments.get(
            cui, f"{entry['semantic_type']}::hac::unassigned"
        )

    distinct_topics = set(assignments.values())
    singletons = sum(1 for t in distinct_topics if "::singleton::" in t)
    oversized = sum(1 for t in distinct_topics if "::oversized::" in t)
    multi = len(distinct_topics) - singletons - oversized

    print(f"  -> done ({time.time()-t:.1f}s)")
    print(f"    Topics: {len(distinct_topics):,} distinct")
    print(f"      multi-CUI:  {multi:,}")
    print(f"      singletons: {singletons:,}")
    if oversized:
        print(f"      oversized:  {oversized:,} (semantic types skipped)")
        for st, n in skipped_large:
            print(f"        {st}: {n:,} CUIs")

    if cut_summary:
        cut_summary.sort(key=lambda x: -x[1])
        print(f"\n    Per-type cuts (top 10 by CUI count):")
        print(f"      {'sem_type':30s}  {'CUIs':>8s}  {'topics':>8s}  "
              f"{'silhouette':>11s}  {'cut_h':>7s}")
        for sem_type, n_cuis, n_clusters, score, height in cut_summary[:10]:
            score_str = f"{score:.4f}" if score is not None else "n/a"
            height_str = f"{height:.4f}" if height is not None else "n/a"
            print(f"      {sem_type:30s}  {n_cuis:>8,}  {n_clusters:>8,}  "
                  f"{score_str:>11s}  {height_str:>7s}")

    return lookup


def load_pickle(path):
    if not os.path.exists(path):
        raise FileNotFoundError(
            f"{path} not found. Run run_builder.py first to produce the "
            f"expansion pickle."
        )
    with open(path, "rb") as f:
        return pickle.load(f)


def save_pickle(obj, path):
    with open(path, "wb") as f:
        pickle.dump(obj, f, protocol=pickle.HIGHEST_PROTOCOL)
    size_mb = round(os.path.getsize(path) / 1e6, 1)
    print(f"  Saved {len(obj):,} entries -> {path}  ({size_mb} MB)")


if __name__ == "__main__":
    start = time.time()

    max_safe_cuis = auto_max_safe_cuis()

    print(f"\n{'='*60}")
    print(f"  Topic clustering (HAC + components, both stored)")
    print(f"  Input             : {INPUT}")
    print(f"  Output            : {OUTPUT}")
    print(f"  Linkage           : {LINKAGE_METHOD}")
    print(f"  Available memory  : {psutil.virtual_memory().available / 1e9:.1f} GB")
    print(f"  Auto max-safe CUIs: {max_safe_cuis:,}  (per semantic type, HAC only)")
    print(f"{'='*60}\n")

    print("[1/4] Loading expansion pickle...")
    t = time.time()
    lookup = load_pickle(INPUT)
    print(f"  -> {len(lookup):,} entries  ({time.time()-t:.1f}s)")
    print()

    print("[2/4] Forming topics via HAC + silhouette auto-cut...")
    lookup = assign_topics_hac(lookup, LINKAGE_METHOD, max_safe_cuis)
    print()

    print("[3/4] Forming topics via connected components...")
    lookup = assign_topics_components(lookup)
    print()

    print("[4/4] Saving pickle...")
    save_pickle(lookup, OUTPUT)
    print(f"\nTotal time: {(time.time()-start)/60:.1f} min")

"""
lookup_facets.py
----------------
Given a CUI, print its facet signature with human-readable labels.

Edit CUIS_TO_LOOKUP below and run:
    python lookup_facets.py
"""

import pickle

PICKLE_PATH = "facets.pkl"

CUIS_TO_LOOKUP = [
    "C0032285",   # Pneumonia (example — replace with your CUIs)
]


def show_facets(cui, payload):
    cui_facets    = payload["cui_facets"]
    labels        = payload["labels"]
    tags          = payload["tags"]

    label = labels.get(cui, "?")
    sty   = sorted(tags.get(cui, frozenset()))
    print(f"\n{cui}  {label}")
    if sty:
        print(f"  semantic type(s): {', '.join(sty)}")

    facets = cui_facets.get(cui)
    if not facets:
        print(f"  (no facets — CUI has no defining RELA attributes in this build)")
        return

    print(f"  facets:")
    # Sort by facet name for stable output
    for rela in sorted(facets):
        values = facets[rela]
        # Render each value with its label
        rendered = []
        for v in sorted(values):
            v_label = labels.get(v, "?")
            rendered.append(f"{v} ({v_label})")
        print(f"    {rela}:")
        for r in rendered:
            print(f"      {r}")


def main():
    with open(PICKLE_PATH, "rb") as f:
        payload = pickle.load(f)
    print(f"Loaded {PICKLE_PATH}")
    print(f"  built_at        : {payload['built_at']}")
    print(f"  cuis with facets: {payload['stats']['cuis_with_facets']:,}")

    for cui in CUIS_TO_LOOKUP:
        show_facets(cui, payload)


if __name__ == "__main__":
    main()

"""
cuis_to_topics.py
-----------------
Look up the topic for one or more CUIs and show the details.

Use this to inspect what's in facet_index.pkl after the build:
  - which topic ID a CUI maps to
  - the normalized facets that produced that topic
  - the human-readable labels for each facet value

Edit CUIS_TO_LOOKUP below and run:
    python cuis_to_topics.py
"""

import pickle


PICKLE_PATH = "facet_index.pkl"

CUIS_TO_LOOKUP = [
    "C0032285",   # Pneumonia (example — replace with your CUIs)
]


def lookup(cui, payload):
    labels = payload["labels"]
    tags   = payload["tags"]

    cui_label = labels.get(cui, "?")
    cui_stys  = sorted(tags.get(cui, frozenset()))

    print(f"\n{'='*60}")
    print(f"{cui}  {cui_label}")
    print(f"{'='*60}")
    if cui_stys:
        print(f"  semantic type(s): {', '.join(cui_stys)}")

    topic_id   = payload["cui_topic_id"].get(cui)
    signature  = payload["cui_signature"].get(cui)
    normalized = payload["cui_normalized"].get(cui)

    if topic_id is None:
        print(f"\n  No topic ID — this CUI has no facets in the index.")
        return

    print(f"\n  topic ID  : {topic_id}")
    print(f"  signature : {signature}")
    print(f"\n  Normalized facets:")
    for facet in sorted(normalized):
        values = sorted(normalized[facet])
        print(f"    {facet}:")
        for v in values:
            v_label = labels.get(v, "?")
            print(f"      {v}  ({v_label})")

    # Also show other CUIs that map to this same topic ID
    members = payload["topic_members"].get(topic_id, [])
    if len(members) > 1:
        others = [m for m in members if m != cui][:10]
        print(f"\n  Other CUIs with this same topic ID ({len(members)-1} total"
              f"{', showing 10' if len(members) > 11 else ''}):")
        for m in others:
            print(f"    {m}  ({labels.get(m, '?')})")


def main():
    with open(PICKLE_PATH, "rb") as f:
        payload = pickle.load(f)
    print(f"Loaded {PICKLE_PATH}")
    print(f"  built_at        : {payload['built_at']}")
    print(f"  total CUIs      : {len(payload['cui_topic_id']):,}")
    print(f"  distinct topics : {len(payload['topic_metadata']):,}")

    for cui in CUIS_TO_LOOKUP:
        lookup(cui, payload)


if __name__ == "__main__":
    main()

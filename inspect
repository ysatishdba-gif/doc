"""
inspect_pickle.py
-----------------
Look at the pickle and print interesting CUIs to test the lookup with.

Use this when your pickle is a smoke build (e.g. MAX_CONCEPTS=1000) and
you don't know which specific CUIs are in it. This script samples the
pickle and shows you:
  - A few CUIs with a SINGLE topic
  - A few CUIs with MULTIPLE topics
  - The 10 largest topic groups

Then you can copy any of those CUIs into lookup_topics.py to test.

Just edit PICKLE_PATH below and run:
    python inspect_pickle.py
"""

import pickle
from collections import defaultdict


PICKLE_PATH = "topics.pkl"


def main():
    with open(PICKLE_PATH, "rb") as f:
        data = pickle.load(f)

    anchors = data["anchors"]
    labels = data["labels"]
    stats = data["stats"]

    print("=" * 70)
    print(f"Pickle: {PICKLE_PATH}")
    print(f"  built_at         : {data['built_at']}")
    print(f"  total CUIs       : {stats['total_cuis']:,}")
    print(f"  unique anchors   : {stats['unique_anchors']:,}")
    print(f"  self-only        : {stats.get('self_only', '?'):,}")
    print(f"  multi-topic CUIs : {stats.get('multi_anchor', '?'):,}")
    print("=" * 70)

    # --- REL breakdown: which relationship types are contributing anchors? ---
    # An anchor's rels_used set tells us which REL types appeared on the
    # path that reached it. We count how many anchor entries used each REL.
    rel_anchor_counts = defaultdict(int)
    anchors_with_only_isa = 0
    anchors_with_any_rb = 0
    anchors_with_only_rb = 0
    total_non_self_anchors = 0
    for cui, entries in anchors.items():
        for e in entries:
            if e["anchor"] == cui:
                continue
            total_non_self_anchors += 1
            rels = set(tuple(r) for r in e.get("rels_used", []))
            for r in rels:
                rel_anchor_counts[r] += 1
            isa_only = rels == {("CHD", "isa")}
            has_rb = any(r[0] == "RB" for r in rels)
            only_rb = rels and all(r[0] == "RB" for r in rels)
            if isa_only:
                anchors_with_only_isa += 1
            if has_rb:
                anchors_with_any_rb += 1
            if only_rb:
                anchors_with_only_rb += 1

    if total_non_self_anchors > 0:
        print(f"\nRelationship-type contribution to non-self anchors "
              f"({total_non_self_anchors:,} total):")
        for (rel, rela), n in sorted(rel_anchor_counts.items(), key=lambda kv: -kv[1]):
            pct = 100 * n / total_non_self_anchors
            print(f"  {rel:6s} {str(rela):20s}  {n:>8,d}  ({pct:5.1f}%)")
        print(f"\n  Anchors reached using ONLY CHD/isa : {anchors_with_only_isa:,}")
        print(f"  Anchors that used RB at any point  : {anchors_with_any_rb:,}")
        print(f"  Anchors reached using ONLY RB      : {anchors_with_only_rb:,}")
        print(f"    (these would not exist without RB traversal)")

    # --- Separate the CUIs into buckets ---
    single_topic = []
    multi_topic = []
    self_only = []
    for cui, entries in anchors.items():
        if len(entries) == 1:
            if entries[0]["anchor"] == cui:
                self_only.append(cui)
            else:
                single_topic.append(cui)
        else:
            multi_topic.append(cui)

    # --- Show 5 single-topic samples (where the topic differs from the CUI) ---
    print(f"\n--- Sample CUIs with ONE topic (different from self) "
          f"[{len(single_topic)} total in pickle] ---")
    if not single_topic:
        print("  (none — every non-multi CUI is its own topic; expected if smoke build is small)")
    else:
        for cui in single_topic[:5]:
            anchor = anchors[cui][0]["anchor"]
            print(f"  {cui}  ({labels.get(cui, '?'):40s}) -> {anchor}  ({labels.get(anchor, '?')})")

    # --- Show 5 multi-topic samples ---
    print(f"\n--- Sample CUIs with MULTIPLE topics [{len(multi_topic)} total in pickle] ---")
    if not multi_topic:
        print("  (none in this pickle)")
    else:
        for cui in multi_topic[:5]:
            print(f"  {cui}  ({labels.get(cui, '?')})")
            for e in anchors[cui]:
                a = e["anchor"]
                print(f"      -> {a}  ({labels.get(a, '?')})")

    # --- Show 5 self-only samples (just so you can confirm the lookup works
    #     for them too — they'll just return themselves as the topic) ---
    print(f"\n--- Sample CUIs that anchor to themselves [{len(self_only)} total in pickle] ---")
    for cui in self_only[:5]:
        print(f"  {cui}  ({labels.get(cui, '?')})")

    # --- Diagnostic: are self-only CUIs orphans, or do they have parents
    #     that the algorithm rejected? This is the question that decides
    #     whether further algorithm improvements would help.
    print(f"\n--- Self-only CUI diagnostic ---")
    print(f"  Loading umls_cache.pkl to check parent structure of self-only CUIs ...")
    try:
        with open("umls_cache.pkl", "rb") as f:
            cache = pickle.load(f)
        # Build parents map from cache (CHD/isa only, matching the algorithm)
        parents_map = defaultdict(set)
        for cui1, cui2, rel, rela in cache["mrrel_rows"]:
            if rel == "CHD" and rela == "isa":
                parents_map[cui2].add(cui1)

        orphans = 0
        with_parents = 0
        for cui in self_only:
            if parents_map.get(cui):
                with_parents += 1
            else:
                orphans += 1
        total = orphans + with_parents
        if total > 0:
            print(f"  Self-only CUIs that are TRUE ORPHANS (no IS-A parent): "
                  f"{orphans:,} ({100*orphans/total:.1f}%)")
            print(f"  Self-only CUIs that HAVE parents but algorithm rejected them: "
                  f"{with_parents:,} ({100*with_parents/total:.1f}%)")
            if with_parents > orphans:
                print(f"  --> The majority have parents — Fix B (per-attribute "
                      f"anchoring) would likely help reduce self-only count")
            else:
                print(f"  --> The majority are orphans — algorithm changes won't "
                      f"help much; these CUIs are genuinely terminal")
    except FileNotFoundError:
        print(f"  (umls_cache.pkl not found; skipping diagnostic)")

    # --- Top 10 largest topic groups (which anchors gather the most members) ---
    groups = defaultdict(list)
    for cui, entries in anchors.items():
        for e in entries:
            groups[e["anchor"]].append(cui)

    big_groups = sorted(groups.items(), key=lambda kv: -len(kv[1]))[:10]
    print(f"\n--- Top 10 largest topic groups ---")
    for anchor, members in big_groups:
        print(f"  {len(members):>4d} members  {anchor}  ({labels.get(anchor, '?')})")

    # --- Ready-to-paste list for lookup_topics.py ---
    print("\n" + "=" * 70)
    print("Copy/paste any of these into CUIS_TO_LOOKUP in lookup_topics.py")
    print("=" * 70)
    sample = []
    if single_topic:
        sample.extend(single_topic[:2])
    if multi_topic:
        sample.extend(multi_topic[:2])
    if self_only:
        sample.append(self_only[0])
    print("\nCUIS_TO_LOOKUP = [")
    for cui in sample:
        comment = labels.get(cui, "")
        print(f'    "{cui}",   # {comment}')
    print("]")


if __name__ == "__main__":
    main()

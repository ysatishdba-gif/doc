"""
config.py — single source of configuration for the service and its tools.

All values come from environment variables, prefixed INTENT_ (see .env.example).
Import the shared instance:

    from config import settings

Both the API (intent_api.py) and the local runner (run_local.py) read from here,
so there is exactly one place that defines names, defaults, and types.
"""
from pydantic_settings import BaseSettings, SettingsConfigDict


class Settings(BaseSettings):
    model_config = SettingsConfigDict(env_prefix="INTENT_", env_file=".env", extra="ignore")

    # --- GCP / Vertex ---
    gcp_project: str = ""                            # INTENT_GCP_PROJECT (required in prod)
    gcp_location: str = "us-central1"                # INTENT_GCP_LOCATION
    model_name: str = "gemini-2.5-flash"             # INTENT_MODEL_NAME

    # --- Pipeline ---
    temporal_file: str = "temporal_name_to_cui.json"    # INTENT_TEMPORAL_FILE (local path)
    default_include_retrieval_signals: bool = True      # INTENT_DEFAULT_INCLUDE_RETRIEVAL_SIGNALS

    # --- Service ---
    api_key: str = ""                                # INTENT_API_KEY ("" disables auth — dev only)
    request_timeout_seconds: float = 60.0            # INTENT_REQUEST_TIMEOUT_SECONDS
    max_query_chars: int = 4000                      # INTENT_MAX_QUERY_CHARS


# Import this everywhere; do not construct Settings() elsewhere.
settings = Settings()

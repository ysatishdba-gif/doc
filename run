"""
run.py — quick end-to-end test of the Intent Finder pipeline.

Place this file in the same folder as intent.py.

Prereqs:
    pip install google-genai google-cloud-storage pydantic pandas
    # Application Default Credentials set up ONCE in your environment:
    #   gcloud auth application-default login
    # (or GOOGLE_APPLICATION_CREDENTIALS) — used for the Vertex (Gemini) calls.

Run:
    python run.py
"""

import json

from intent import ContextualIntentPipeline, minimal_pipeline


# ── config ───────────────────────────────────────────────────────────────
PROJECT_ID = ""          # e.g. "my-gcp-project"
LOCATION   = "us-central1"
MODEL      = "gemini-2.5-flash"

# Retrieval-signals toggle. True  -> include the retrieval_signals block
# (runs the 4th LLM call). False -> omit it and skip that call (3 calls).
INCLUDE_RETRIEVAL_SIGNALS = True

QUERY = "elevated psa in last 3 years"


def main() -> None:
    # When your teammate hands you the temporal module (and, later, the
    # record-type coder), import and inject them here. They only need to match
    # the TemporalResolver / ConceptCoder interfaces defined in intent.py:
    #     TemporalResolver.resolve(signals)        -> [{signal, code, formula}]
    #     ConceptCoder.code_record_types(names)    -> [{name,  code, system}]
    # Until then, the built-in Null* stand-ins are used: record types stay
    # strings and temporal stays the raw phrase, both with null code slots
    # (structurally code-ready).
    #
    #   from teammate_temporal import TemporalModule
    #   pipeline = ContextualIntentPipeline(
    #       project=PROJECT_ID, location=LOCATION, model=MODEL,
    #       temporal_resolver=TemporalModule(),
    #       # concept_coder=RecordTypeCoder(),   # when available
    #   )
    pipeline = ContextualIntentPipeline(
        project=PROJECT_ID, location=LOCATION, model=MODEL,
    )

    out = minimal_pipeline(
        pipeline, QUERY, include_retrieval_signals=INCLUDE_RETRIEVAL_SIGNALS
    )
    print(json.dumps(out, indent=2))


if __name__ == "__main__":
    main()

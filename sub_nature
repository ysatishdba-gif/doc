"""
Demo script for the contextual pipeline -> CUI extraction -> summarization
-> topics flow.

PRINT STRUCTURE (two passes):

  PASS 1: Pipeline structure
    For each intent:
      - intent title, nature, description
      - for each sub_nature:
          category_path
          atomic_concepts
      - retrieval_signals (per intent, deduped)

  PASS 2: CUI extraction + per-intent summarization
    For each intent:
      For each sub_nature:
        For each path segment: text -> CUIs
        For each atomic concept: text -> CUIs
      Retrieval-signal CUIs (separate, NOT summarized into the intent)
      Intent summary (path+atomic CUIs only)

  PASS 3: Topics
    Union of all per-intent surviving CUIs -> one topic run
    (hierarchy, embedding, siblingreach)
    No adaptor search.
"""

import time
from typing import Any, Dict, List

from config import (
    API_URL, TOP_K, TOP_P, CLUSTER_SET, COMBINED,
    PROJECT_ID, LOCATION, MODEL_VERSION,
)
from intents import ContextualIntentPipeline
from cui_core import CUIExtractor
from cui_summarizer import CUISummarizer
from cui_topics import CUITopics
from topic_labeler import TopicLabeler
from siblingreach_compare import SiblingReachGrouper


# ---------------------------------------------------------------------------
# Build clients
# ---------------------------------------------------------------------------
pipeline   = ContextualIntentPipeline(project=PROJECT_ID, location=LOCATION, model=MODEL_VERSION)
extractor  = CUIExtractor(API_URL, top_k=TOP_K, top_p=TOP_P, cluster_set=CLUSTER_SET, combined=COMBINED)
summarizer = CUISummarizer()
topics_mod = CUITopics()
labeler    = TopicLabeler()
grouper    = SiblingReachGrouper("cui_topic_lookup.pkl")


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

SIGNAL_FIELDS = (
    "document_types",
    "author_roles",
    "temporal_signals",
    "content_signals",
    "clinical_setting",
)


def split_path(path: str) -> List[str]:
    return [seg.strip() for seg in path.split(">>") if seg.strip()]


def cuis_from_raw(raw: Dict[str, Any]) -> List[Any]:
    out = []
    seen = set()
    for d in raw.values():
        for c in d.get("cuis", []):
            key = c if isinstance(c, str) else c.get("cui", c)
            if key and key not in seen:
                seen.add(key)
                out.append(c)
    return out


def cui_id(c: Any) -> str:
    return c if isinstance(c, str) else c.get("cui", "")


def cui_term(c: Any) -> str:
    return c.get("preferred_term", "") if isinstance(c, dict) else ""


def union_signals_from_candidates(intent: Dict[str, Any]) -> Dict[str, List[str]]:
    """Union retrieval signals across all final_candidates of an intent.

    The intent-level retrieval_signals field is sometimes empty even when
    per-candidate signals are populated (depends on pipeline aggregation).
    Reading directly from candidates is more reliable.
    """
    out: Dict[str, List[str]] = {f: [] for f in SIGNAL_FIELDS}
    seen: Dict[str, set] = {f: set() for f in SIGNAL_FIELDS}
    for fc in intent.get("final_candidates", []) or []:
        sigs = fc.get("retrieval_signals") or {}
        for field in SIGNAL_FIELDS:
            for term in sigs.get(field, []) or []:
                term = term.strip() if isinstance(term, str) else term
                if not term:
                    continue
                key = term.lower()
                if key not in seen[field]:
                    seen[field].add(key)
                    out[field].append(term)
    return out


def fmt_cuis_comma(cuis: List[Any]) -> str:
    """Format a CUI list as compact comma-separated codes only."""
    ids = [cui_id(c) for c in cuis if cui_id(c)]
    return ", ".join(ids) if ids else "(none)"


def hr(char="=", n=70):
    print(char * n)


# ---------------------------------------------------------------------------
# PASS 1: Pipeline structure
# ---------------------------------------------------------------------------

def print_pipeline_structure(full_output: Dict[str, Any]) -> None:
    print()
    hr("=")
    print("  PASS 1 — PIPELINE STRUCTURE")
    hr("=")
    print(f"\nQuery:    {full_output.get('original_query', '')!r}")
    print(f"Expanded: {full_output.get('expanded_query', '')!r}")
    print(f"Total intents: {full_output.get('total_intents_detected', 0)}")

    for i, intent in enumerate(full_output.get("intents", []), 1):
        print()
        hr("-")
        print(f"  INTENT {i}: {intent.get('intent_title', '')}")
        hr("-")
        print(f"    Nature:      {intent.get('nature', '')}")
        print(f"    Description: {intent.get('description', '')}")

        sub_natures = intent.get("sub_natures", []) or []
        print(f"\n    Sub-natures ({len(sub_natures)}):")
        for sn in sub_natures:
            print(f"      - {sn.get('category_path', '')}")
            for atom in sn.get("atomic_concepts", []) or []:
                print(f"          atomic: {atom}")

        # Per-candidate signals unioned at intent level (more reliable than
        # reading the intent-level retrieval_signals field, which may be empty).
        signals = union_signals_from_candidates(intent)
        print(f"\n    Retrieval signals (deduped from candidates):")
        for field in SIGNAL_FIELDS:
            vals = signals.get(field, []) or []
            if vals:
                preview = vals[:5]
                more = "" if len(vals) <= 5 else f"  (+{len(vals)-5} more)"
                print(f"      {field:18s}: {preview}{more}")
            else:
                print(f"      {field:18s}: []")


# ---------------------------------------------------------------------------
# PASS 2: CUI extraction + per-intent summarization
# ---------------------------------------------------------------------------

def extract_for_intent(intent: Dict[str, Any]) -> Dict[str, Any]:
    """For one intent:
      - extract CUIs per sub-nature (path segments + atomic concepts)
      - extract CUIs from retrieval signals (kept separate)
      - summarize the path+atomic CUIs at intent level
    Print everything as it happens.
    """
    intent_title = intent.get("intent_title", "")
    sub_natures = intent.get("sub_natures", []) or []

    print()
    hr("-")
    print(f"  INTENT: {intent_title}")
    hr("-")

    # CUIs from path segments + atomic concepts (these go into summarization)
    intent_cuis = []
    seen_intent = set()
    provenance: Dict[str, List[Dict[str, str]]] = {}

    for sn in sub_natures:
        path = sn.get("category_path", "")
        atoms = sn.get("atomic_concepts", []) or []
        print(f"\n    sub_nature: {path}")

        for seg in split_path(path):
            raw = extractor.extract([seg], [seg])
            cuis = cuis_from_raw(raw)
            print(f"      [path]   {seg!r:30s} -> {len(cuis)} CUIs: "
                  f"{fmt_cuis_comma(cuis)}")
            for c in cuis:
                cid = cui_id(c)
                if not cid:
                    continue
                provenance.setdefault(cid, []).append({
                    "text":   seg,
                    "source": "path_segment",
                    "sub_nature": path,
                })
                if cid not in seen_intent:
                    seen_intent.add(cid)
                    intent_cuis.append(c)

        for concept in atoms:
            concept = (concept or "").strip()
            if not concept:
                continue
            raw = extractor.extract([concept], [concept])
            cuis = cuis_from_raw(raw)
            print(f"      [atomic] {concept!r:30s} -> {len(cuis)} CUIs: "
                  f"{fmt_cuis_comma(cuis)}")
            for c in cuis:
                cid = cui_id(c)
                if not cid:
                    continue
                provenance.setdefault(cid, []).append({
                    "text":   concept,
                    "source": "atomic_concept",
                    "sub_nature": path,
                })
                if cid not in seen_intent:
                    seen_intent.add(cid)
                    intent_cuis.append(c)

    # Retrieval signal CUIs (kept SEPARATE — not added to intent_cuis)
    print(f"\n    --- RETRIEVAL SIGNAL CUIs -for filter) ---")
    signals = union_signals_from_candidates(intent)
    signal_cuis_by_field: Dict[str, List[Any]] = {f: [] for f in SIGNAL_FIELDS}
    any_signals = False
    for field in SIGNAL_FIELDS:
        terms = signals.get(field, []) or []
        if not terms:
            print(f"      {field}: (no terms)")
            continue
        any_signals = True
        # extract once per field with all terms in that field
        raw = extractor.extract(terms, terms)
        cuis = cuis_from_raw(raw)
        signal_cuis_by_field[field] = cuis
        print(f"      {field}: {len(terms)} terms -> {len(cuis)} CUIs: "
              f"{fmt_cuis_comma(cuis)}")
    if not any_signals:
        print(f"      (no retrieval signals available for this intent)")

    # Per-intent summarize (path + atomic CUIs only)
    print(f"\n    --- INTENT SUMMARIZATION ---")
    print(f"    input CUIs (path + atomic): {len(intent_cuis)}")

    if not intent_cuis:
        print(f"    no CUIs to summarize.")
        return {
            "intent_title":      intent_title,
            "surviving_cuis":    [],
            "removed_cuis":      [],
            "signal_cuis":       signal_cuis_by_field,
            "provenance":        provenance,
        }

    t = time.time()
    s = summarizer.summarize(intent_cuis, sources=["SNOMEDCT_US"])
    print(f"    summarize: {time.time()-t:.1f}s")

    m = s["metrics"]
    print(f"    {m['input_code_count']} in -> {m['output_code_count']} out "
          f"(reduction {(1 - m['output_code_count']/max(m['input_code_count'],1))*100:.0f}%)")

    print(f"\n    Surviving CUIs for {intent_title!r}:")
    for c in s["surviving_cuis"]:
        prov = provenance.get(c["cui"], [])
        prov_str = ", ".join(f"{p['source']}={p['text']!r}" for p in prov[:2])
        if len(prov) > 2:
            prov_str += f" (+{len(prov)-2} more)"
        print(f"      {c['cui']}  {c['preferred_term']}  IC={c['ic']}")
        if prov_str:
            print(f"        from: {prov_str}")

    if s["removed_cuis"]:
        print(f"\n    Removed CUIs (collapsed during summarization):")
        for c in s["removed_cuis"]:
            print(f"      {c['cui']}  {c['preferred_term']}  "
                  f"<- by {c['retained_by']} ({c['reason']})")

    return {
        "intent_title":   intent_title,
        "surviving_cuis": s["surviving_cuis"],
        "removed_cuis":   s["removed_cuis"],
        "signal_cuis":    signal_cuis_by_field,
        "provenance":     provenance,
    }



# PASS 3: Topics on union of all surviving CUIs


def run_topics(intent_results: List[Dict[str, Any]]) -> None:
    print()
    hr("-")
    print("  Topics-union of all per-intent surviving CUIs")
    hr("-")

    # Union surviving CUIs across intents (deduped)
    all_surviving: List[Dict[str, Any]] = []
    seen = set()
    for ir in intent_results:
        for c in ir["surviving_cuis"]:
            if c["cui"] not in seen:
                seen.add(c["cui"])
                all_surviving.append(c)

    if not all_surviving:
        print("\n  no surviving CUIs across intents; skipping topics.")
        return

    cui_ids  = [c["cui"] for c in all_surviving]
    ic_map   = {c["cui"]: c["ic"] for c in all_surviving}
    term_map = {c["cui"]: c["preferred_term"] for c in all_surviving}

    print(f"\n  combined surviving CUIs: {len(cui_ids)}")

    # hierarchy + embedding via existing pipeline
    for strategy in ["hierarchy", "embedding"]:
        try:
            t = time.time()
            t_result = topics_mod.build_topics(cui_ids, strategy=strategy)
            relabeled = labeler.relabel(t_result, ic_map=ic_map)
            print(f"\n  [{strategy}] {time.time()-t:.1f}s  "
                  f"-> {relabeled['metrics']['topic_count']} topics, "
                  f"{relabeled['metrics']['singleton_count']} singletons")
            for topic in relabeled["topics"]:
                print(f"    [{topic['topic_id']}] {topic['topic_label']}  "
                      f"({topic['label_source']})")
                for mem in topic["members"]:
                    print(f"      {mem['cui']}  {mem['preferred_term']}  "
                          f"IC={mem['ic']}")
        except Exception as e:
            print(f"\n  [{strategy}] FAILED: {e}")

    # siblingreach
    try:
        sr = grouper.group(cui_ids, ic_map=ic_map, term_map=term_map, min_members=1)
        n_singletons = sum(1 for t in sr["topics"] if len(t["members"]) == 1)
        print(f"\n  [siblingreach] {sr['metrics']['topic_count']} topics, "
              f"{n_singletons} singletons "
              f"(missing: {sr['metrics']['missing_cui_count']})")
        for topic in sr["topics"]:
            print(f"    [{topic['topic_id']}] {topic['topic_label']}  "
                  f"score={topic['score']}")
            for mem in topic["members"]:
                print(f"      {mem['cui']}  {mem['preferred_term']}  "
                      f"IC={mem['ic']}")
    except Exception as e:
        print(f"\n  [siblingreach] FAILED: {e}")



# MAIN


if __name__ == "__main__":
    query = "Do you have constipation or diarrhea?"
    # query = "Is your primary concern related to colon or rectal cancer or mass?"
    # query = Which best describes your primary concern?"

    print(f"\n{'-' * 70}")
    print(f"#  Query: {query!r}")
    print(f"{'-' * 70}")

    t = time.time()
    full_output = pipeline.run(query=query, output_format="full_pipeline")
    print(f"\nContextual pipeline: {time.time()-t:.1f}s")

    if not full_output.get("is_clinical", False):
        print(f"Non-clinical query: {full_output.get('reason')}")
        raise SystemExit(0)

    # PASS 1
    print_pipeline_structure(full_output)

    # PASS 2
    print()
    hr("-")
    print("  CUI EXTRACTION + PER-INTENT SUMMARIZATION")
    hr("-")

    intent_results = []
    for intent in full_output.get("intents", []):
        intent_results.append(extract_for_intent(intent))

    # PASS 3
    run_topics(intent_results)

    # Cleanup
    print()
    hr("-")
    print("  Cleanup")
    hr("-")
    summarizer.close()
    topics_mod.close()
    print("Done.")

    print(f"\nInputs:")
    print(f"  mrrel_rows  : {len(mrrel_rows):,}")
    print(f"  SNOMED_CUIS : {len(SNOMED_CUIS):,}")

    print(f"\n[1] Extract IS-A edges")
    isa_edges, rel_counts = extract_isa_edges(mrrel_rows, SNOMED_CUIS)
    print(f"    IS-A edges: {len(isa_edges):,}")
    print(f"    REL counts: {dict(rel_counts.most_common(8))}")

    print(f"\n[2] Build IS-A DAG and IC")
    isa_parents, isa_children = build_isa_dag(isa_edges)
    all_isa_nodes = set(isa_parents) | set(isa_children)
    descendant_counts = compute_descendant_counts(isa_children, all_isa_nodes)
    ic = compute_ic(descendant_counts, len(SNOMED_CUIS))
    print(f"    Nodes with parents: {len(isa_parents):,}")
    print(f"    Nodes with children: {len(isa_children):,}")

    print(f"\n[3] Extract RO neighbors")
    ro_neighbors = extract_ro_neighbors(mrrel_rows, SNOMED_CUIS)

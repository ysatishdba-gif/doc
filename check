"""
build_rollup_compare.py
-----------------------
Build TWO rollup indexes for side-by-side comparison:
  - rollup_isa_only.pkl     : IS-A relations only (current build)
  - rollup_isa_ro.pkl       : IS-A + direct RO neighbors of focal CUI

The IS-A walk is unchanged between builds. The RO version ALSO adds the
direct RO neighbors of each CUI as additional rollup ancestors.

No transitive RO walking, no IS-A walks from RO neighbors. Each CUI
contributes its own first-hop RO neighbors only — bounded and predictable.
"""

import pickle
import datetime
import math
import time
import os
from collections import defaultdict, Counter


ISA_OUTPUT_PATH = "rollup_isa_only.pkl"
RO_OUTPUT_PATH  = "rollup_isa_ro.pkl"

ISA_RELATIONS   = {"PAR", "CHD", "RB", "RN"}
RO_RELATION     = "RO"
MIN_CHILDREN    = 3


# ============================================================================
# Common: extract edges and build adjacency
# ============================================================================

def extract_isa_edges(mrrel_rows, snomed_cuis):
    """Return set of (child, parent) tuples from MRREL IS-A relations.
    Row format: (CUI1, CUI2, REL, RELA)
    """
    edges = set()
    rel_counts = Counter()
    for row in mrrel_rows:
        if len(row) < 3:
            continue
        cui1, cui2, rel = row[0], row[1], row[2]
        rel_counts[rel] += 1
        if rel not in ISA_RELATIONS:
            continue
        if cui1 not in snomed_cuis or cui2 not in snomed_cuis:
            continue
        if cui1 == cui2:
            continue
        if rel == "PAR" or rel == "RB":
            edges.add((cui1, cui2))
        elif rel == "CHD" or rel == "RN":
            edges.add((cui2, cui1))
    return edges, rel_counts


def extract_ro_neighbors(mrrel_rows, snomed_cuis):
    """For each CUI, return its set of direct RO neighbors (any direction).
    
    Returns: dict[cui] -> set[(neighbor_cui, RELA)]
    """
    neighbors = defaultdict(set)
    for row in mrrel_rows:
        if len(row) < 4:
            continue
        cui1, cui2, rel, rela = row[0], row[1], row[2], row[3]
        if rel != RO_RELATION:
            continue
        if cui1 not in snomed_cuis or cui2 not in snomed_cuis:
            continue
        if cui1 == cui2:
            continue
        neighbors[cui1].add((cui2, rela))
        neighbors[cui2].add((cui1, rela))
    return dict(neighbors)


def build_isa_dag(edges):
    isa_parents  = defaultdict(set)
    isa_children = defaultdict(set)
    for child, parent in edges:
        isa_parents[child].add(parent)
        isa_children[parent].add(child)
    return dict(isa_parents), dict(isa_children)


def compute_descendant_counts(isa_children, all_nodes):
    descendant_sets = {}
    def descendants(node, stack):
        if node in descendant_sets:
            return descendant_sets[node]
        if node in stack:
            return set()
        stack = stack | {node}
        result = set()
        for child in isa_children.get(node, ()):
            result.add(child)
            result |= descendants(child, stack)
        descendant_sets[node] = result
        return result
    for node in all_nodes:
        descendants(node, set())
    return {n: len(d) for n, d in descendant_sets.items()}


def compute_ic(descendant_counts, total_nodes):
    log_total = math.log(total_nodes + 1)
    return {cui: 1.0 - math.log(n + 1) / log_total
            for cui, n in descendant_counts.items()}


# ============================================================================
# Path walking and rollup finding (unchanged from before)
# ============================================================================

def all_paths_to_root(cui, isa_parents, max_paths=200, max_depth=30):
    paths = []
    def walk(current_path, visited):
        if len(paths) >= max_paths:
            return
        if len(current_path) >= max_depth:
            paths.append(list(current_path))
            return
        current = current_path[-1]
        parents = isa_parents.get(current, set()) - visited
        if not parents:
            paths.append(list(current_path))
            return
        for p in parents:
            current_path.append(p)
            visited.add(p)
            walk(current_path, visited)
            current_path.pop()
            visited.remove(p)
    walk([cui], {cui})
    return paths


def find_rollup_ancestor(path, ic, isa_children, min_children):
    if len(path) == 1:
        return path[0]
    if len(path) == 2:
        return path[1]
    ics = [ic.get(node, 0.0) for node in path]
    deltas = [ics[i] - ics[i+1] for i in range(len(ics) - 1)]
    ic_stop_idx = None
    for i in range(1, len(deltas)):
        if deltas[i] > deltas[i-1]:
            ic_stop_idx = i
            break
    if ic_stop_idx is None:
        ic_stop_idx = min(2, len(path) - 1)
    candidate_idx = ic_stop_idx
    while candidate_idx < len(path) - 1:
        candidate = path[candidate_idx]
        if len(isa_children.get(candidate, set())) >= min_children:
            return candidate
        candidate_idx += 1
    return path[-1]


# ============================================================================
# Ancestor closure cache + dedup
# ============================================================================

_ancestor_closure_cache = {}

def compute_ancestor_closure(cui, isa_parents):
    if cui in _ancestor_closure_cache:
        return _ancestor_closure_cache[cui]
    ancestors = set()
    stack = [cui]
    visited = set()
    while stack:
        node = stack.pop()
        if node in visited:
            continue
        visited.add(node)
        for p in isa_parents.get(node, set()):
            if p not in ancestors:
                ancestors.add(p)
                stack.append(p)
    _ancestor_closure_cache[cui] = frozenset(ancestors)
    return _ancestor_closure_cache[cui]


def dedup_ancestors(ancestors, isa_parents):
    ancestors = list(ancestors)
    if len(ancestors) <= 1:
        return frozenset(ancestors)
    closures = {a: compute_ancestor_closure(a, isa_parents) for a in ancestors}
    redundant = set()
    for a in ancestors:
        for b in ancestors:
            if a == b:
                continue
            if a in closures[b]:
                redundant.add(a)
                break
    return frozenset(a for a in ancestors if a not in redundant)


# ============================================================================
# Build rollups (both flavors)
# ============================================================================

def build_isa_only_rollups(snomed_cuis, isa_parents, isa_children, ic,
                            min_children):
    """Rollup set = {self} U deduped(IS-A ancestors via path walk)."""
    cui_to_rollup = {}
    paths_count = {}
    n_orphan = 0
    t0 = time.time()
    for i, cui in enumerate(snomed_cuis):
        if i % 50000 == 0 and i > 0:
            print(f"    {i:,}/{len(snomed_cuis):,} ({time.time()-t0:.0f}s)")
        if cui not in isa_parents:
            cui_to_rollup[cui] = frozenset({cui})
            paths_count[cui] = 0
            n_orphan += 1
            continue
        paths = all_paths_to_root(cui, isa_parents)
        paths_count[cui] = len(paths)
        ancestors = set()
        for path in paths:
            ancestors.add(find_rollup_ancestor(path, ic, isa_children, min_children))
        deduped = dedup_ancestors(ancestors, isa_parents)
        cui_to_rollup[cui] = frozenset({cui} | deduped)
    print(f"    Done in {time.time()-t0:.0f}s, {n_orphan:,} orphans")
    return cui_to_rollup, paths_count


def build_isa_ro_rollups(snomed_cuis, isa_parents, isa_children, ic,
                          ro_neighbors, min_children):
    """Rollup set = {self} U deduped(IS-A ancestors) U RO neighbors."""
    cui_to_rollup = {}
    paths_count = {}
    cui_to_ro_neighbors_used = {}  # for diagnostic — which RO neighbors added
    n_orphan = 0
    n_ro_only = 0
    t0 = time.time()
    for i, cui in enumerate(snomed_cuis):
        if i % 50000 == 0 and i > 0:
            print(f"    {i:,}/{len(snomed_cuis):,} ({time.time()-t0:.0f}s)")
        
        # IS-A part
        if cui not in isa_parents:
            isa_part = frozenset()
            paths_count[cui] = 0
            n_orphan += 1
        else:
            paths = all_paths_to_root(cui, isa_parents)
            paths_count[cui] = len(paths)
            ancestors = set()
            for path in paths:
                ancestors.add(find_rollup_ancestor(path, ic, isa_children, min_children))
            isa_part = dedup_ancestors(ancestors, isa_parents)
        
        # RO part: direct neighbors of focal CUI only
        ro_part = set()
        for neighbor, rela in ro_neighbors.get(cui, set()):
            ro_part.add(neighbor)
        
        cui_to_rollup[cui] = frozenset({cui} | isa_part | ro_part)
        if ro_part:
            cui_to_ro_neighbors_used[cui] = frozenset(ro_part)
            if not isa_part:
                n_ro_only += 1
    
    print(f"    Done in {time.time()-t0:.0f}s, {n_orphan:,} IS-A orphans, "
          f"{n_ro_only:,} CUIs got RO ancestors only")
    return cui_to_rollup, paths_count, cui_to_ro_neighbors_used


def build_reverse_index(cui_to_rollup):
    rollup_to_cuis = defaultdict(set)
    for cui, ancestors in cui_to_rollup.items():
        for anc in ancestors:
            rollup_to_cuis[anc].add(cui)
    return dict(rollup_to_cuis)



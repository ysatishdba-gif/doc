    extra_per_cui = []
    for cui in SNOMED_CUIS:
        s_isa = rollup_isa.get(cui, frozenset())
        s_ro = rollup_ro.get(cui, frozenset())
        extra_per_cui.append(len(s_ro) - len(s_isa))
    print(f"\n    Extra rollups per CUI from RO:")
    print(f"      median: {sorted(extra_per_cui)[len(extra_per_cui)//2]}")
    print(f"      mean:   {sum(extra_per_cui)/len(extra_per_cui):.1f}")
    print(f"      max:    {max(extra_per_cui)}")


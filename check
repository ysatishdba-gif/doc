    with open(RO_OUTPUT_PATH, "wb") as f:
        pickle.dump({
            **common_meta,
            "cui_to_rollup_ancestors":   rollup_ro,
            "rollup_to_descendants":     reverse_ro,
            "paths_count":               paths_ro,
            "cui_to_ro_neighbors_used":  ro_used,
            "ro_neighbors_all":          ro_neighbors,
            "config": {
                "relations_used":   sorted(ISA_RELATIONS) + ["RO"],
                "min_children":     MIN_CHILDREN,
                "ro_added":         True,
                "ro_mode":          "direct neighbors of focal CUI",
            },
        }, f, protocol=pickle.HIGHEST_PROTOCOL)
    sz2 = os.path.getsize(RO_OUTPUT_PATH) / 1024 / 1024
    print(f"    Wrote {RO_OUTPUT_PATH} ({sz2:.1f} MB)")

    print(f"\nTOTAL: {time.time()-t_total:.0f}s")
    print(f"DONE — {datetime.datetime.now().isoformat()}")


main()

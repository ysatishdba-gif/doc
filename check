    print(f"    Avg RO neighbors per CUI: {avg_ro:.1f}")

    # ─── Build 1: IS-A only ───
    print(f"\n[4] Build IS-A-only rollups")
    rollup_isa, paths_isa = build_isa_only_rollups(
        SNOMED_CUIS, isa_parents, isa_children, ic, MIN_CHILDREN
    )
    reverse_isa = build_reverse_index(rollup_isa)
    print(f"    Unique rollup ancestors (IS-A only): "
          f"{len(reverse_isa):,}")
    print(f"    Compression: "
          f"{len(rollup_isa)/max(len(reverse_isa),1):.1f}x")

    # ─── Build 2: IS-A + RO ───
    print(f"\n[5] Build IS-A+RO rollups")
    rollup_ro, paths_ro, ro_used = build_isa_ro_rollups(
        SNOMED_CUIS, isa_parents, isa_children, ic, ro_neighbors, MIN_CHILDREN
    )
    reverse_ro = build_reverse_index(rollup_ro)
    print(f"    Unique rollup ancestors (IS-A+RO):   "
          f"{len(reverse_ro):,}")
    print(f"    Compression: "
          f"{len(rollup_ro)/max(len(reverse_ro),1):.1f}x")


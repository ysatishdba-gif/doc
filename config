import networkx as nx
import math

# netw = your network DiGraph (already loaded)
ROOT = 'SNOMEDCT_US.isa'

def clean(nodes):
    """strip the -suffix, keep base CUIs, drop the root itself."""
    out = set()
    for n in nodes:
        if isinstance(n, str) and '-' in n:
            out.add(n.split('-')[0])
    return out

def cui_isa_nodes(cui):
    """the suffix-bridge nodes of `cui` that sit under the isa root."""
    nodes = []
    for s in netw.successors(cui):
        if nx.has_path(netw, ROOT, s):
            nodes.append(s)
    return nodes

def ancestors_of(cui):
    """is-a ancestors (more general concepts above cui)."""
    anc = set()
    for node in cui_isa_nodes(cui):
        anc |= set(nx.ancestors(netw, node))
    return clean(anc)

def descendants_of(cui):
    """is-a descendants (more specific concepts below cui)."""
    desc = set()
    for node in cui_isa_nodes(cui):
        desc |= set(nx.descendants(netw, node))
    return clean(desc)


# ---- TEST on a few known concepts ----
TESTS = {
    "C0032285": "Pneumonia",
    "C0011849": "Diabetes mellitus",

import os, sys, pickle
import networkx

PROJECT_ID      = ""
DATASET_ID      = ""
EMBEDDING_TABLE = ""

API_URL         = "" 
TOP_K           = 5 #Number of clusters to select (must be ≥ 1)
TOP_P           = 30 #Number of members to retrieve per cluster (must be ≥ 1)
CLUSTER_SET     = "umls"
COMBINED        = True
source_system = "SNOMED_CT"

OUTPUT_DIR      = "output/"
HIERARCHY_PATH  = "networkx_cui_context_v1_3_0.pkl" 
IC_PATH         = "ic_precomputed.pkl"
MEDLINEPLUS_PATH = "medlineplus.pkl"

ALLOWED_SABS    = {"SNOMEDCT_US"}

LLM_PROJECT_ID  = PROJECT_ID
LLM_LOCATION    = "us-central1"
LOCATION    = "us-central1"
MODEL_VERSION       = "gemini-2.0-flash"
LLM_MAX_TOKENS  = 1500

os.makedirs(OUTPUT_DIR, exist_ok=True)

if not os.path.exists(HIERARCHY_PATH):
    print(f"ERROR: {HIERARCHY_PATH} not found"); sys.exit(1)
with open(HIERARCHY_PATH, "rb") as f:
    hierarchy = pickle.load(f)
assert isinstance(hierarchy, networkx.DiGraph)

if not os.path.exists(IC_PATH):
    print(f"ERROR: {IC_PATH} not found. Run ic_precompute.py first."); sys.exit(1)
with open(IC_PATH, "rb") as f:
    ic_precomputed = pickle.load(f)
assert isinstance(ic_precomputed, dict) and len(ic_precomputed) > 0

medlineplus = {}
if os.path.exists(MEDLINEPLUS_PATH):
    with open(MEDLINEPLUS_PATH, "rb") as f:
        medlineplus = pickle.load(f)
    print(f"Config: {hierarchy.number_of_nodes()} nodes, {len(ic_precomputed)} IC scores, {len(medlineplus)} MedlinePlus topics")
else:
    print(f"Config: {hierarchy.number_of_nodes()} nodes, {len(ic_precomputed)} IC scores (no MedlinePlus)")

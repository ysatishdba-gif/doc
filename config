import pickle
P = pickle.load(open("topics.pkl", "rb"))

CUI = "C0032285"      # <-- change

tids = P["cui_to_topic_ids"].get(CUI, [])
print(f"{CUI}  '{P['labels'].get(CUI, CUI)}'  -> {len(tids)} topic(s)")
for tp in sorted(tids, key=lambda t: P["topic_id_to_topic"][t]["size"]):
    t = P["topic_id_to_topic"][t] if False else P["topic_id_to_topic"][tp]
    print(f"  {tp}  size={t['size']:>4}  IC={t['anchor_ic']:.3f}  "
          f"anchor '{P['labels'].get(t['canonical'], t['canonical'])}'")

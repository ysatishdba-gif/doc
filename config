import requests, subprocess

GCLOUD_LOC = r"C:\path\to\gcloud.cmd"   # your gcloud path
API_URL = "https://your-custom-url"     # your endpoint

def headers():
    token = subprocess.run(
        [GCLOUD_LOC, "auth", "print-identity-token"],
        capture_output=True, text=True,
    ).stdout.strip()
    return {"Authorization": f"Bearer {token}", "Content-Type": "application/json"}

payload = {
    "text": "Patient has fever, headache and is in Newname hospital with Dr. John Doe.",
    "pipeline_steps": {
        "run_general_extraction": True, "run_ner_extraction": False,
        "run_semantic_linking_v1": False, "run_semantic_linking_v2": False,
        "run_intent_filter": False, "run_deep_search": False,
    },
    "intents": {
        1: {"metadata": "Entities", "definition": "Identify and return ALL medical entities (diseases, medications, symptoms, etc.) exactly as they appear in the text."},
    },
    "cluster_selection_params": {
        "cluster_set": "umls", "top_k": 150, "top_p": 10, "top_q": 20,
        "source_system": ["ICD10CM"],
    },
    "reasoning": ["both"],
}

resp = requests.post(API_URL, json=payload, headers=headers(), timeout=600)
resp.raise_for_status()

cuis = list(resp.json()["output"]["concepts"].keys())
print(cuis)

import networkx as nx
import time

ROOT = 'SNOMEDCT_US.isa'

t0 = time.time()

# all nodes under the isa root (the hierarchy universe)
isa_nodes = nx.descendants(netw, ROOT)
print(f"nodes under isa root: {len(isa_nodes):,}  ({time.time()-t0:.0f}s)")

# Build a clean CUI-level isa DiGraph: parent_cui -> child_cui
# Edges in netw under the isa root go root -> ... -> general -> specific.
# We collapse suffix-bridge nodes to base CUIs.
t0 = time.time()
G = nx.DiGraph()
for u, v in netw.subgraph(isa_nodes | {ROOT}).edges():
    cu = u.split('-')[0] if isinstance(u, str) and '-' in u else u
    cv = v.split('-')[0] if isinstance(v, str) and '-' in v else v
    if cu == ROOT or cv == ROOT:
        continue
    if cu != cv:
        G.add_edge(cu, cv)        # cu (more general) -> cv (more specific)

print(f"isa CUI graph: {G.number_of_nodes():,} nodes, "
      f"{G.number_of_edges():,} edges  ({time.time()-t0:.0f}s)")

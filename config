4. How many CUIs were left out (no topic)
"Left out" = CUIs that exist in the isa hierarchy but ended up in no topic. Compare the full CUI universe against the ones that got topics:
pythonimport pickle
P = pickle.load(open("topics.pkl", "rb"))

# all CUIs we tried to place = those in the isa hierarchy
d = pickle.load(open("isa_precomputed.pkl", "rb"))
all_cuis = set(d["isa_ancestors"].keys()) | set(d["ic"].keys())

in_topics = set(P["cui_to_topic_ids"].keys())
left_out  = all_cuis - in_topics

print(f"total CUIs (isa universe) : {len(all_cuis):,}")
print(f"CUIs in >=1 topic         : {len(in_topics):,}  "
      f"({len(in_topics)/len(all_cuis)*100:.1f}%)")
print(f"CUIs left out (no topic)  : {len(left_out):,}  "
      f"({len(left_out)/len(all_cuis)*100:.1f}%)")

# sample some left-out CUIs to see what they are
print("\nsample left-out CUIs:")
for c in list(left_out)[:20]:
    print(f"  {c}  '{P['labels'].get(c, c)}'  ic={d['ic'].get(c, '?')}")

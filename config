def _trace_doc(doc):
    """DOC side: NO LLM. Per-chunk CUI extract -> union -> summarize -> topics.
    `doc` is the dict from document.get_document()."""
    tr = {"text": f"{doc['label']}  ({doc['category']})",
          "doc_id": doc["doc_id"],
          "is_clinical": True,
          "chunks": []}

    cuis, seen = [], set()
    for ci, chunk in enumerate(doc["chunks"]):
        got = flat(extractor.extract([chunk], [chunk]))
        tr["chunks"].append({
            "i": ci,
            "preview": chunk[:80].replace("\n", " "),
            "cuis": got,
        })
        for c in got:
            if c not in seen:
                seen.add(c); cuis.append(c)

    tr["extracted_cuis"] = list(cuis)
    _summarize_and_topics(tr, cuis)
    return tr

1. Give a CUI → get its topics
pythonimport pickle
P = pickle.load(open("topics.pkl", "rb"))

CUI = "C0032285"      # <-- change

tids = P["cui_to_topic_ids"].get(CUI, [])
print(f"{CUI}  '{P['labels'].get(CUI, CUI)}'  -> {len(tids)} topic(s)")
for tp in sorted(tids, key=lambda t: P["topic_id_to_topic"][t]["size"]):
    t = P["topic_id_to_topic"][t] if False else P["topic_id_to_topic"][tp]
    print(f"  {tp}  size={t['size']:>4}  IC={t['anchor_ic']:.3f}  "
          f"anchor '{P['labels'].get(t['canonical'], t['canonical'])}'")
2. Give a topic ID → get the CUIs in it
pythonimport pickle
P = pickle.load(open("topics.pkl", "rb"))

TOPIC_ID = "tp_4385b55dfcd9"     # <-- change

t = P["topic_id_to_topic"].get(TOPIC_ID)
if not t:
    print("no such topic:", TOPIC_ID)
else:
    anchor = t["canonical"]
    print(f"{TOPIC_ID}  anchor {anchor} '{P['labels'].get(anchor, anchor)}'  "
          f"size {t['size']}  IC {t['anchor_ic']:.3f}\n")
    for cui in sorted(t["members"]):
        mark = "  <-- anchor" if cui == anchor else ""
        print(f"  {cui}  '{P['labels'].get(cui, cui)}'{mark}")

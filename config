for cui, name in TESTS.items():
    if cui not in netw:
        print(f"\n{cui} {name}: NOT in network"); continue
    anc = ancestors_of(cui)
    desc = descendants_of(cui)
    print(f"\n{cui}  {name}")
    print(f"  ancestors  : {len(anc)}")
    print(f"  descendants: {len(desc)}")

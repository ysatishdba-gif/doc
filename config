import requests

URL = "https://your-host/concept-coding/v1/analyze"

def analyze(text, internal_timeout=300):
    r = requests.post(
        URL,
        json={"text": text, "internal_timeout": internal_timeout},
        timeout=internal_timeout + 20,   # keep HTTP timeout above the server's
    )
    r.raise_for_status()
    return r.json()

resp = analyze("Patient has fever, headache and diabetes.")

if resp["status"] == 1:
    out = resp["output"]
    print("text:", out["text"])
    for entity, cui in out["cuis"].items():
        print(f"  {entity} -> {cui}")
else:
    print("failed:", resp.get("code"), resp.get("error"))   # 500 = crash, 230 = partial/timeout

"""
artifacts.py
------------
Run ONCE at the start of the day (one cell). Loads all pickles and builds
all clients, holding them as module globals. test_manual.py then reuses
them — no reloading, no rebuilding.

Start-of-day cell:
    import artifacts
    artifacts.init()
"""

import os
import pickle
import time
import networkx

# ---- paths ----
HIERARCHY_PATH   = "networkx_cui_context_v1_3_0.pkl"
IC_PATH          = "ic_precomputed.pkl"
MEDLINEPLUS_PATH = "medlineplus.pkl"
TOPICS_PATH      = "topics.pkl"

# ---- loaded pickles (filled by init) ----
hierarchy        = None
ic_precomputed   = None
medlineplus      = {}
topics           = None
TOPICS_AVAILABLE = False

# ---- built clients (filled by init) ----
pipeline   = None
extractor  = None
summarizer = None
adaptor    = None

_INITED = False


def _load(path, required=True, validate=None):
    if not os.path.exists(path):
        if required:
            raise FileNotFoundError(f"{path} not found")
        print(f"[artifacts] {path} not found — skipping (optional)")
        return None
    t0 = time.time()
    with open(path, "rb") as f:
        obj = pickle.load(f)
    if validate:
        validate(obj)
    print(f"[artifacts] loaded {path} ({time.time()-t0:.1f}s)")
    return obj


def init():
    """Load all pickles + build all clients ONCE. Safe to call repeatedly."""
    global hierarchy, ic_precomputed, medlineplus, topics, TOPICS_AVAILABLE
    global pipeline, extractor, summarizer, adaptor, _INITED

    if _INITED:
        print("[artifacts] already initialized — reusing.")
        return

    print("[artifacts] initializing (once)...")

    # ---- pickles ----
    hierarchy = _load(HIERARCHY_PATH,
                      validate=lambda o: isinstance(o, networkx.DiGraph) or
                      (_ for _ in ()).throw(AssertionError("hierarchy not DiGraph")))
    ic_precomputed = _load(IC_PATH,
                           validate=lambda o: (isinstance(o, dict) and len(o) > 0) or
                           (_ for _ in ()).throw(AssertionError("ic empty")))
    medlineplus = _load(MEDLINEPLUS_PATH, required=False) or {}
    topics = _load(TOPICS_PATH, required=False)
    TOPICS_AVAILABLE = topics is not None

    # ---- clients (import here so config sees loaded pickles) ----
    from config import (
        PROJECT_ID, LOCATION, MODEL_VERSION,
        API_URL, TOP_K, TOP_P, CLUSTER_SET, COMBINED,
    )
    from intents import ContextualIntentPipeline
    from cui_core import CUIExtractor
    from cui_summarizer import CUISummarizer
    from topic_adaptor import TopicAdaptor

    pipeline   = ContextualIntentPipeline(project=PROJECT_ID, location=LOCATION,
                                          model=MODEL_VERSION)
    extractor  = CUIExtractor(API_URL, top_k=TOP_K, top_p=TOP_P,
                              cluster_set=CLUSTER_SET, combined=COMBINED)
    summarizer = CUISummarizer()
    adaptor    = TopicAdaptor()

    _INITED = True
    print(f"[artifacts] ready: "
          f"hierarchy={hierarchy.number_of_nodes():,} nodes | "
          f"ic={len(ic_precomputed):,} | "
          f"topics={len(topics['topic_id_to_topic']) if topics else 0} | "
          f"clients built.")

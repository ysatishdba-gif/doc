"""
artifacts.py
------------
Loads ALL heavy pickles once, at import time, into module globals.
Import this once per kernel; everything is then available as attributes:

    import artifacts
    artifacts.hierarchy        # networkx.DiGraph
    artifacts.ic_precomputed   # dict
    artifacts.medlineplus      # dict (or {})
    artifacts.topics           # dict (or None)

Re-importing in the same kernel is free — Python caches the module, so the
pickles load only once and are reused for the entire session.
"""

import os
import pickle
import time
import networkx

# ---- paths ----
HIERARCHY_PATH   = "networkx_cui_context_v1_3_0.pkl"
IC_PATH          = "ic_precomputed.pkl"
MEDLINEPLUS_PATH = "medlineplus.pkl"
TOPICS_PATH      = "topics.pkl"


def _load(path, required=True, validate=None):
    if not os.path.exists(path):
        if required:
            raise FileNotFoundError(f"{path} not found")
        print(f"[artifacts] {path} not found — skipping (optional)")
        return None
    t0 = time.time()
    with open(path, "rb") as f:
        obj = pickle.load(f)
    if validate:
        validate(obj)
    print(f"[artifacts] loaded {path} ({time.time()-t0:.1f}s)")
    return obj


print("[artifacts] loading all pickles (once per kernel)...")

hierarchy = _load(
    HIERARCHY_PATH,
    validate=lambda o: (_ for _ in ()).throw(
        AssertionError("hierarchy must be a DiGraph"))
    if not isinstance(o, networkx.DiGraph) else None,
)

ic_precomputed = _load(
    IC_PATH,
    validate=lambda o: (_ for _ in ()).throw(
        AssertionError("ic must be a non-empty dict"))
    if not (isinstance(o, dict) and len(o) > 0) else None,
)

medlineplus = _load(MEDLINEPLUS_PATH, required=False) or {}

topics = _load(TOPICS_PATH, required=False)

TOPICS_AVAILABLE = topics is not None

print(f"[artifacts] ready: "
      f"hierarchy={hierarchy.number_of_nodes():,} nodes | "
      f"ic={len(ic_precomputed):,} | "
      f"medlineplus={len(medlineplus)} | "
      f"topics={len(topics['topic_id_to_topic']) if topics else 0}")

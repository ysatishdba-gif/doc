import requests, google.auth.transport.requests
from google.oauth2 import id_token

URL = "https://your-host/concept-coding/v1/analyze"

def analyze(text):
    token = id_token.fetch_id_token(google.auth.transport.requests.Request(), URL)
    r = requests.post(URL, json={"text": text},
                      headers={"Authorization": f"Bearer {token}"}, timeout=320)
    r.raise_for_status()
    return r.json()

resp = analyze("Patient has fever.")
print(resp["status"])          # 1 = success
print(resp["output"]["cuis"])  # the CUIs
print(resp["output"]["entities"])

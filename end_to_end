"""
retry_errors.py — gather the errored blobs from a finished run and retry ONLY those.

Workflow:
  Phase 1 :  python extract_concepts.py        # bulk pass (e.g. MAX_WORKERS=8)
  Phase 2 :  python retry_errors.py            # collect every errored blob (with
                                               # its address), re-call the API for
                                               # just those, patch results back.

This does NOT re-scan or re-run completed docs — it touches only blobs whose
saved record carries an "error". Each errored blob is addressed by
(recon key, blob_index); the full text is read from reconstructed_obj.pk at that
address. Identical texts are deduped into one call. Successful retries overwrite
the errored slot in codes_by_blob.pkl and the doc is re-finalized
(extracted_cuis / n_errors / complete recomputed). Blobs that fail again keep
their error and will be picked up by the next retry pass.

Reuses extract_concepts.py's own functions so the payload, parsing, and
finalization are identical to the main run.
"""
import pickle
from concurrent.futures import ThreadPoolExecutor, as_completed

import extract_concepts as E

OUTPUT_PATH = E.OUTPUT_PATH          # codes_by_blob.pkl  (read + written back)
INPUT_PATH  = E.INPUT_PATH           # reconstructed_obj.pk   (full blob text by address)
MAX_WORKERS = 8                      # calls in flight for the retry pass
SAVE_EVERY  = 50                     # checkpoint results after this many calls


def gather_errored(results):
    """Every blob that has a real error -> (key, blob_index).
    A successful blob (even one with 0 CUIs) is stored with error=None and is
    NOT included. Skipped blobs (skipped=True) are not errors and are excluded."""
    out = []
    for key, rec in results.items():
        for c in rec.get("chunks", []) or []:
            if not c:
                continue
            err = c.get("error")
            if err in (None, "", False) or c.get("skipped"):
                continue                                  # success / empty / skipped -> leave alone
            out.append((key, c.get("blob_index", c.get("i"))))
    return out


def _resolve_text(recon, key, blob_index):
    """Full blob text from reconstructed_obj.pk at (key, blob_index)."""
    rec = recon.get(key) if isinstance(recon, dict) else None
    if not rec:
        return None
    blobs = (rec.get("reconstructed") or {}).get("blobs")
    if blobs is None or not (0 <= blob_index < len(blobs)):
        return None
    return blobs[blob_index]


def main():
    results = pickle.load(open(OUTPUT_PATH, "rb"))
    recon   = pickle.load(open(INPUT_PATH, "rb"))

    errored = gather_errored(results)
    total_blobs = sum(len(r.get("chunks", []) or []) for r in results.values())
    err_docs = {k for k, _ in errored}
    print(f"blobs in file        : {total_blobs}")
    print(f"errored (will retry) : {len(errored)} across {len(err_docs)} docs")
    print(f"clean / 0-error      : {total_blobs - len(errored)}  (skipped — no API call)")
    if not errored:
        print("nothing to retry.")
        return

    # resolve each errored blob's full text by address, dedup identical texts
    by_hash, unresolved = {}, 0
    for (key, bi) in errored:
        text = _resolve_text(recon, key, bi)
        if not text or not str(text).strip():
            unresolved += 1
            continue
        h = E._blob_hash(text)
        by_hash.setdefault(h, {"text": text, "units": []})["units"].append((key, bi))
    if unresolved:
        print(f"  ({unresolved} could not be addressed in {INPUT_PATH} — left as-is)")

    uniq = list(by_hash.items())
    print(f"{len(uniq)} unique texts to retry ({MAX_WORKERS} in flight)\n")
    if not uniq:
        return

    # optional: keep the blob cache consistent on success
    cache = {}
    if E.USE_BLOB_CACHE:
        try:
            with open(E.BLOB_CACHE_PATH, "rb") as f:
                cache = pickle.load(f)
        except Exception:
            cache = {}

    touched, done, fixed, still_err = set(), 0, 0, 0
    def _checkpoint():
        for k in touched:
            E._finalize_blob_doc(results[k])
        E._save(results, OUTPUT_PATH)              # atomic (temp + os.replace)
        if E.USE_BLOB_CACHE:
            E._save(cache, E.BLOB_CACHE_PATH)      # atomic

    ex = ThreadPoolExecutor(max_workers=MAX_WORKERS)
    try:
        futs = {ex.submit(E.call_api, info["text"]): h for h, info in uniq}
        for fut in as_completed(futs):
            h = futs[fut]; info = by_hash[h]
            concepts, err, secs, _sm = fut.result()
            cuis = [] if err else list(concepts.keys())
            if not err and E.USE_BLOB_CACHE:
                cache[h] = cuis
            for (key, bi) in info["units"]:
                results[key]["chunks"][bi] = E._chunk_rec(bi, info["text"], list(cuis), err, secs)
                touched.add(key)
            done += 1
            if err:
                still_err += 1
                print(f"  [{done}/{len(uniq)}] ERR  {info['text'][:50]!r}  {str(err)[:80]}")
            else:
                fixed += 1
                print(f"  [{done}/{len(uniq)}] {len(cuis):>3} cuis  {info['text'][:50]!r}")
            if done % SAVE_EVERY == 0:
                _checkpoint()
    except KeyboardInterrupt:
        print("\ninterrupted — saving progress so far, then stopping...")
        ex.shutdown(wait=False, cancel_futures=True)
        _checkpoint()
        remaining = len(gather_errored(results))
        print(f"saved {OUTPUT_PATH}. errored blobs remaining: {remaining} "
              f"(re-run to continue).")
        return
    finally:
        ex.shutdown(wait=False)

    _checkpoint()

    remaining = len(gather_errored(results))
    print(f"\nsaved {OUTPUT_PATH}")
    print(f"unique texts: fixed={fixed}  still erroring={still_err}  "
          f"|  errored blobs remaining in file: {remaining}")
    if remaining:
        print("run again to retry the remaining (those that fail repeatedly are "
              "likely deterministic server-side failures).")


if __name__ == "__main__":
    main()

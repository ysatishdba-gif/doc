def _run_blob_mode(docs, results):
    """One API call per UNIQUE blob text (deduped), fanned to every occurrence.
    MAX_WORKERS calls in flight across the whole corpus; per-blob resume + cache."""
    cache = {}
    if USE_BLOB_CACHE and os.path.exists(BLOB_CACHE_PATH):
        try:
            with open(BLOB_CACHE_PATH, "rb") as f:
                cache = pickle.load(f)
            print(f"Loaded blob cache: {len(cache)} unique blobs known")
        except Exception:
            cache = {}

    units, touched = [], []
    for d in docs:
        key = d["key"]; blobs = d["chunks"]
        rec = results.get(key)
        if not rec or "chunks" not in rec or len(rec["chunks"]) != len(blobs):
            rec = {**_doc_base(d), "chunks": [None] * len(blobs),
                   "extracted_cuis": [], "doc_secs": 0.0, "n_errors": 0,
                   "complete": False}
            results[key] = rec
        if rec.get("complete"):
            continue
        touched.append(d)
        for i, b in enumerate(blobs):
            ex = rec["chunks"][i]
            if ex is not None and not ex.get("error"):
                continue
            if MIN_BLOB_CHARS and len((b or "").strip()) < MIN_BLOB_CHARS:
                rec["chunks"][i] = _chunk_rec(i, b, [], None, 0.0, skipped=True)
                continue
            is_retry = ex is not None and bool(ex.get("error"))   # errored before -> force fresh
            units.append((key, i, b, is_retry))

    by_hash, cached_hits = {}, 0
    for (key, i, b, is_retry) in units:
        h = _blob_hash(b)
        if USE_BLOB_CACHE and not is_retry and h in cache:    # never serve a retry from cache
            results[key]["chunks"][i] = _chunk_rec(i, b, list(cache[h]), None, 0.0,
                                                   cached=True)
            cached_hits += 1
        else:
            by_hash.setdefault(h, {"text": b, "units": []})["units"].append((key, i))

    uniq = list(by_hash.items())
    total = len(uniq)
    print(f"{len(units)} blobs pending across {len(touched)} docs: "
          f"{cached_hits} from cache, {total} unique calls ({MAX_WORKERS} in flight)")
    if total == 0:
        for d in touched:
            _finalize_blob_doc(results[d["key"]])
        _save(results, OUTPUT_PATH)
        return

    done = [0]; t0 = time.perf_counter(); stop = threading.Event()

    def _beat():
        while not stop.wait(HEARTBEAT_SECS):
            el = time.perf_counter() - t0
            rate = done[0] / max(1, el)
            eta = (total - done[0]) / rate if rate > 0 else 0
            print(f"   ... {done[0]}/{total} unique calls done, "
                  f"elapsed {el:.0f}s, eta ~{_hms(eta)} (workers={MAX_WORKERS})")
    hb = threading.Thread(target=_beat, daemon=True); hb.start()

    def _save_cache():
        if USE_BLOB_CACHE:
            try:
                tmp = BLOB_CACHE_PATH + ".tmp"
                with open(tmp, "wb") as f:
                    pickle.dump(cache, f)
                os.replace(tmp, BLOB_CACHE_PATH)
            except Exception:
                pass

    try:
        with ThreadPoolExecutor(max_workers=MAX_WORKERS) as ex:
            futs = {ex.submit(call_api, info["text"]): h for h, info in uniq}
            for fut in as_completed(futs):
                h = futs[fut]; info = by_hash[h]
                concepts, err, secs, _sm = fut.result()
                cuis = [] if err else list(concepts.keys())
                if not err and USE_BLOB_CACHE:
                    cache[h] = cuis
                for (key, i) in info["units"]:
                    results[key]["chunks"][i] = _chunk_rec(i, info["text"], list(cuis),
                                                           err, secs)
                done[0] += 1
                if done[0] % CHECKPOINT_BLOBS == 0:
                    for d in touched:
                        _finalize_blob_doc(results[d["key"]])
                    _save(results, OUTPUT_PATH); _save_cache()
    finally:
        stop.set()
    for d in touched:
        _finalize_blob_doc(results[d["key"]])
    _save_cache()


def _run_doc_mode(docs, results):
    pending = [d for d in docs if not results.get(d["key"], {}).get("complete")]
    print(f"{len(pending)} docs to process ({len(docs) - len(pending)} already done), "
          f"{MAX_WORKERS} in parallel")
    if not pending:
        return
    done = [0]
    t0 = time.perf_counter()
    stop = threading.Event()

    def _beat():
        while not stop.wait(HEARTBEAT_SECS):
            print(f"   ... {done[0]}/{len(pending)} docs done, "
                  f"elapsed {time.perf_counter()-t0:.0f}s (workers={MAX_WORKERS})")
    hb = threading.Thread(target=_beat, daemon=True); hb.start()
    try:
        with ThreadPoolExecutor(max_workers=MAX_WORKERS) as ex:
            futs = {ex.submit(process_doc, d): d["key"] for d in pending}
            for fut in as_completed(futs):
                key, rec = fut.result()
                results[key] = rec
                done[0] += 1
                sm = rec.get("server_ms", {}) or {}
                extra = (f" match={sm['matching_ms']/1000:.0f}s"
                         if isinstance(sm.get("matching_ms"), (int, float)) else "")
                state = (f"ERROR: {str(rec.get('error'))[:140]}" if rec.get("n_errors")
                         else f"{len(rec['extracted_cuis'])} cuis / {rec['n_chunks']} blobs")
                print(f"   [{done[0]}/{len(pending)}] {rec['doc_id']}: {state}  "
                      f"({rec['doc_secs']:.0f}s{extra})")
                if done[0] % CHECKPOINT_DOCS == 0:
                    _save(results, OUTPUT_PATH)
    finally:
        stop.set()


def main():
    if not API_URL.strip():
        raise SystemExit("Set API_URL first.")
    get_token()   # fail fast if gcloud auth isn't set up

    all_docs = load_documents(INPUT_PATH)
    total = len(load_documents(INPUT_PATH, only_sampled=False)) if ONLY_SAMPLED else len(all_docs)
    print(f"Loaded {len(all_docs)} sampled docs from {INPUT_PATH} (of {total} total; "
          f"ONLY_SAMPLED={ONLY_SAMPLED})  MODE={MODE!r}  ONLY_DOC={ONLY_DOC!r}")
    docs = all_docs
    if ONLY_DOC:
        docs = [d for d in all_docs if _doc_matches(d, ONLY_DOC)]
        if not docs:
            print(f"No document matched ONLY_DOC={ONLY_DOC!r}. Available:")
            for d in all_docs[:60]:
                print(f"   key={str(d['key']):>6}  {d.get('file_name')}  {d['raw_document']}")
            raise SystemExit(1)
        print(f"ONLY_DOC={ONLY_DOC!r} -> {[(d['key'], d.get('file_name')) for d in docs]}")

    results = {}
    if os.path.exists(OUTPUT_PATH):
        with open(OUTPUT_PATH, "rb") as f:
            results = pickle.load(f)
        print(f"Resuming: {len(results)} docs already in {OUTPUT_PATH}")

    if MODE == "blob":
        _run_blob_mode(docs, results)
    else:
        _run_doc_mode(docs, results)

    _save(results, OUTPUT_PATH)
    errs = sum(1 for r in results.values() if r.get("n_errors"))
    incomplete = sum(1 for r in results.values() if not r.get("complete"))
    print(f"\nDONE. docs={len(results)}  with-errors={errs}  "
          f"incomplete={incomplete}  saved -> {OUTPUT_PATH}")

    if ONLY_DOC:
        # no CUI dump -- validate later with check_output.py. just project full-run time.
        if MODE == "blob":
            cs = [c.get("secs", 0) for d in docs
                  for c in results.get(d["key"], {}).get("chunks", []) or []
                  if c and not c.get("skipped") and c.get("secs")]
        else:
            cs = [results[d["key"]]["doc_secs"] for d in docs
                  if results.get(d["key"], {}).get("doc_secs")]
        if cs:
            estimate(sum(cs) / len(cs))


def inspect(key=None, path=OUTPUT_PATH, max_chunks=None, show_cuis=None):
    if show_cuis is None:
        show_cuis = SHOW_CUIS
    with open(path, "rb") as f:
        r = pickle.load(f)
    if key is None:
        key = next(iter(r))
    d = r[key]
    print("=" * 70)
    print(d["doc_id"])
    print(f"ADDRESS: key={d.get('key')}  file_name={d.get('file_name')}  "
          f"sampling_id={d.get('sampling_id')}  sample_index={d.get('sample_index')}")
    sm = d.get("server_ms", {}) or {}
    print(f"pages={d.get('pages')}  blobs={d['n_chunks']}  "
          f"union_cuis={len(d['extracted_cuis'])}  doc_secs={d.get('doc_secs')}  "
          f"server_ms={sm}")
    ms = d.get("mapping_stats")
    if ms:
        print(f"blob mapping: by_offset={ms.get('by_offset')}  "
              f"by_surface={ms.get('by_surface')}  unmapped={ms.get('unmapped')}  "
              f"(want most by_offset, unmapped~0)")
    print("=" * 70)
    chunks = d["chunks"] if max_chunks is None else d["chunks"][:max_chunks]
    for c in chunks:
        print(f"[blob {c.get('blob_index', c.get('i')):>2}] {len(c['cuis'])} cuis  "
              f"{c['preview']!r}")
        if show_cuis and c["cuis"]:
            print(f"           {c['cuis']}")
    if show_cuis:
        print(f"\nUNION ({len(d['extracted_cuis'])}): {d['extracted_cuis']}")
    else:
        print(f"\nunion_cuis={len(d['extracted_cuis'])}  "
              f"(set SHOW_CUIS=True to print the actual CUI lists)")


if __name__ == "__main__":
    main()

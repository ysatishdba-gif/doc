def parse_concepts(data):
    """{cui: [occurrence, ...]} from data['output']['concepts']."""
    out = data.get("output", data) if isinstance(data, dict) else {}
    c = out.get("concepts", {}) if isinstance(out, dict) else {}
    return c if isinstance(c, dict) else {}


def parse_timings(data):
    if not isinstance(data, dict):
        return {}
    tm = (data.get("details", {}) or {}).get("timings_ms", {}) or {}
    return {"extraction_ms": tm.get("step_1_extraction_ms"),
            "matching_ms": tm.get("step_2_matching_ms")}


# ============================================================================
# AUTH + HTTP  (same shape as the reference: fetch token, one POST per call)
# ============================================================================
def get_token():
    """Google Cloud identity-token auth headers."""
    p = subprocess.run([GCLOUD_LOC, "auth", "print-identity-token"],
                       stdout=subprocess.PIPE, universal_newlines=True)
    if p.returncode != 0:
        raise RuntimeError("gcloud returned non-zero exit code")
    return {"Authorization": f"Bearer {p.stdout.strip()}",
            "Content-Type": "application/json"}


RETRY_ON_5XX = 3          # transient server errors: retry this many times
RETRY_BACKOFF = 2.0       # seconds * attempt between retries


def call_api(text):
    """One API call -> (concepts, error, secs, server_ms).
    Retries only on 5xx / network errors (transient); 4xx fails immediately."""
    t0 = time.perf_counter()
    last = None
    for attempt in range(1, RETRY_ON_5XX + 1):
        try:
            resp = requests.post(API_URL, json=build_payload(text),
                                 headers=get_token(), timeout=REQUEST_TIMEOUT)
            if resp.status_code >= 500:
                last = f"HTTP {resp.status_code}: {resp.text[:200]}"
                if attempt < RETRY_ON_5XX:
                    time.sleep(RETRY_BACKOFF * attempt)
                    continue
                return {}, last, time.perf_counter() - t0, {}
            if resp.status_code >= 400:                       # client error: don't retry
                return {}, f"HTTP {resp.status_code}: {resp.text[:300]}", time.perf_counter() - t0, {}
            data = resp.json()
            return parse_concepts(data), None, time.perf_counter() - t0, parse_timings(data)
        except requests.exceptions.RequestException as e:     # network/timeout: transient
            last = str(e)
            if attempt < RETRY_ON_5XX:
                time.sleep(RETRY_BACKOFF * attempt)
                continue
            return {}, last, time.perf_counter() - t0, {}
    return {}, last or "failed", time.perf_counter() - t0, {}



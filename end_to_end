"""
end_to_end.py
-------------
End-to-end run (no socket server):

  DOCUMENT side: read pre-extracted per-blob CUIs from codes_by_blob.pkl
                 (NO extraction API calls) -> summarize per blob -> topics per
                 blob -> doc topic set. Cached to a pickle so it's built once.
  QUERY side:    LLM breakdown -> concepts -> CUIs via the LATEST API (the only
                 live API call) -> summarize -> topics.
  MATCH:         query topics vs document topics, with per-blob provenance.

Pick the document by recon key or file name in DOC_SELECT.

Edit DOC_SELECT and QUERY, then:
    python end_to_end.py

Needs: codes_by_blob.pkl (per-blob CUIs), the summarizer's services
(BigQuery + network graph), topics.pkl, gcloud auth + config.API_URL (query side).
"""

import os
import pickle

import config  # loads hierarchy / ic / topics once
from intents import ContextualIntentPipeline
from cui_core import CUIExtractor
from cui_summarizer import CUISummarizer
from topic_adaptor import TopicAdaptor
from config import PROJECT_ID, LOCATION, MODEL_VERSION, API_URL, QUERY_CLUSTER_SELECTION_PARAMS

CONCEPTS_PATH = "codes_by_blob.pkl"   # per-blob CUIs (from extract_concepts.py)
DOC_SELECT    = 101                        # recon key (int) or file name ("sample_101.pdf")
QUERY         = "medical history, physical examination, performance status"
SOURCES       = ["SNOMEDCT_US"]
DOC_CACHE     = "doc_side_cache.pkl"       # summarized document side, keyed by recon key
REBUILD_DOC   = False                      # True to re-summarize the document side

pipeline   = ContextualIntentPipeline(project=PROJECT_ID, location=LOCATION, model=MODEL_VERSION)
extractor  = CUIExtractor(API_URL, cluster_params=QUERY_CLUSTER_SELECTION_PARAMS)  # query side only
summarizer = CUISummarizer()
adaptor    = TopicAdaptor()


def _flat(raw):
    out, seen = [], set()
    for d in raw.values():
        for c in d.get("cuis", {}):
            if c and c not in seen:
                seen.add(c); out.append(c)
    return out


def _split_path(p):
    return [s.strip() for s in p.split(">>") if s.strip()]


def _topics(cuis):
    """cuis -> (surviving_cuis, [topic dicts], topic_id set)."""
    if not cuis:
        return [], [], set()
    summ = summarizer.summarize(cuis, sources=SOURCES)
    surviving = [c["cui"] for c in summ["surviving_cuis"]]
    tps = sorted(adaptor.cuis_to_topics(surviving), key=adaptor.topic_size)
    topics = [{"tp": tp, "size": adaptor.topic_size(tp),
               "ic": round(adaptor.topic_anchor_ic(tp), 3),
               "label": adaptor.topic_label(tp)} for tp in tps]
    return surviving, topics, set(t["tp"] for t in topics)


# ── DOCUMENT side: read pre-extracted CUIs -> summarize -> topics (cached) ────
def _find_doc_record(concepts, select):
    """Find a doc in codes_by_blob.pkl by recon key (int) or file name (str)."""
    if select in concepts:                      # direct recon-key hit
        return select, concepts[select]
    sel = str(select).strip().casefold()
    sel_stem = sel[:-4] if sel.endswith(".pdf") else sel
    for k, rec in concepts.items():
        fn = str(rec.get("file_name") or "").casefold()
        if fn == sel or fn[:-4] == sel_stem or str(k).casefold() == sel:
            return k, rec
    raise KeyError(f"{select!r} not found in {CONCEPTS_PATH} "
                   f"(keys look like {list(concepts)[:5]} ...)")


def load_or_build_document(select):
    """Document side for `select`, summarized once and cached to DOC_CACHE.
    Reused across runs/queries. No extraction API calls — CUIs come from
    codes_by_blob.pkl."""
    concepts = pickle.load(open(CONCEPTS_PATH, "rb"))
    key, rec = _find_doc_record(concepts, select)

    cache = {}
    if os.path.exists(DOC_CACHE):
        try:
            with open(DOC_CACHE, "rb") as f:
                cache = pickle.load(f)
        except Exception:
            cache = {}
    if not REBUILD_DOC and key in cache:
        d = cache[key]
        print(f"[doc cache] reusing {DOC_CACHE} for {d['doc_id']} "
              f"({len(d['blobs'])} blobs, {len(d['topic_ids'])} topics)")
        d = dict(d); d["topic_ids"] = set(d["topic_ids"])
        return d

    d = run_document(key, rec)
    to_store = dict(d); to_store["topic_ids"] = sorted(d["topic_ids"])
    cache[key] = to_store
    with open(DOC_CACHE, "wb") as f:
        pickle.dump(cache, f)
    print(f"[doc cache] saved {d['doc_id']} to {DOC_CACHE}")
    return d


def run_document(key, rec):
    """Summarize each blob's pre-extracted CUIs -> topics. No extraction calls."""
    doc_id = rec.get("doc_id", f"doc_{key}")
    chunks = rec.get("chunks", [])
    print("#" * 70)
    print(f"# DOCUMENT  {doc_id}   ({len(chunks)} blobs)   [CUIs from {CONCEPTS_PATH}]")
    print("#" * 70)

    blobs, doc_topic_ids, tp_to_blobs = [], set(), {}
    for ch in chunks:
        i = ch.get("blob_index", ch.get("i"))
        cuis = ch.get("cuis", []) or []
        surviving, topics, tp_ids = _topics(cuis)
        for tp in tp_ids:
            doc_topic_ids.add(tp)
            tp_to_blobs.setdefault(tp, []).append(i)
        blobs.append({"i": i, "preview": ch.get("preview", ""),
                      "cuis": cuis, "surviving": surviving, "topics": topics})
        print(f"  [blob {i:>2}] {len(cuis):>3} cuis -> {len(surviving):>3} surviving "
              f"-> {len(topics):>3} topics   {ch.get('preview','')[:50]!r}")

    print(f"\n  DOC topic set: {len(doc_topic_ids)} distinct topics")
    return {"doc_id": doc_id, "key": key, "blobs": blobs,
            "topic_ids": doc_topic_ids, "tp_to_blobs": tp_to_blobs}


# ── QUERY side: LLM breakdown -> extract -> summarize -> topics ───────────────
def run_query(text):
    print("\n" + "#" * 70)
    print(f"# QUERY  {text!r}")
    print("#" * 70)
    full = pipeline.run(query=text, output_format="full_pipeline")
    if not full.get("is_clinical", False):
        print(f"  NON-CLINICAL: {full.get('reason')}")
        return {"topic_ids": set(), "topics": []}

    # ---- NATURE BREAKDOWN (LLM decomposition) — printed first ----
    print(f"\n  Expanded: {full.get('expanded_query','')!r}")
    print(f"  Total intents: {full.get('total_intents_detected', len(full.get('intents', [])))}")
    for i, it in enumerate(full.get("intents", []), 1):
        print(f"\n  {'-'*60}")
        print(f"  INTENT {i}: {it.get('intent_title','')}")
        print(f"    Nature:      {it.get('nature','')}")
        print(f"    Description: {it.get('description','')}")
        subs = it.get("sub_natures", [])
        print(f"    Sub-natures ({len(subs)}):")
        for sn in subs:
            print(f"      - {sn.get('category_path','')}")
            for a in (sn.get("atomic_concepts") or []):
                print(f"          atomic: {a}")

    # Extract ATOMIC CONCEPTS only (the real clinical terms). category_path
    # segments are navigation labels ("Administration", "Dosage"), not concepts,
    # so we skip them — unless a sub-nature has no atomic_concepts, in which case
    # the path segments are the only signal available.
    phrases, pseen = [], set()
    for it in full.get("intents", []):
        for sn in it.get("sub_natures", []):
            atoms = [a for a in (sn.get("atomic_concepts") or []) if a and a.strip()]
            src = atoms if atoms else _split_path(sn.get("category_path", ""))
            for ph in src:
                ph = (ph or "").strip()
                k = ph.casefold()
                if ph and k not in pseen:
                    pseen.add(k); phrases.append(ph)

    # ---- CUI EXTRACTION (after the breakdown) ----
    print(f"\n  {'-'*60}")
    print(f"  CUI EXTRACTION — {len(phrases)} unique phrases")
    cuis, seen = [], set()
    for n, ph in enumerate(phrases, 1):
        got = _flat(extractor.extract([ph], [ph]))
        print(f"    [{n}/{len(phrases)}] {ph!r:40s} -> {len(got)} cuis")
        for c in got:
            if c not in seen:
                seen.add(c); cuis.append(c)

    surviving, topics, tp_ids = _topics(cuis)
    print(f"  {len(cuis)} cuis -> {len(surviving)} surviving -> {len(topics)} topics")
    for t in topics:
        print(f"    {t['tp']}  size={t['size']:>4}  IC={t['ic']}  '{t['label']}'")
    return {"topic_ids": tp_ids, "topics": topics}


def main():
    doc = load_or_build_document(DOC_SELECT)
    qry = run_query(QUERY)

    print("\n" + "#" * 70)
    print("# MATCH  (query topics vs document topics)")
    print("#" * 70)
    m = adaptor.match(qry["topic_ids"], doc["topic_ids"])
    shared = qry["topic_ids"] & doc["topic_ids"]
    print(f"  shared topics: {len(shared)}   "
          f"scored(top-{adaptor.top_k}-by-IC)={m['count']}   "
          f"sum_inv_size={m['sum_inv_size']}   max_anchor_ic={m['max_anchor_ic']}")
    if not shared:
        print("  no shared topics — query and document do not overlap.")
    else:
        for tp in sorted(shared, key=adaptor.topic_size):
            blobs = doc["tp_to_blobs"].get(tp, [])
            print(f"\n  >>> {tp}  size={adaptor.topic_size(tp)}  "
                  f"IC={round(adaptor.topic_anchor_ic(tp),3)}  "
                  f"'{adaptor.topic_label(tp)}'")
            print(f"      from blob(s): {sorted(set(blobs))}")
    try:
        summarizer.close()
    except Exception:
        pass


if __name__ == "__main__":
    main()

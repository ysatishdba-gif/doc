"""
slim_temporal.py — read the big temporal formula JSON from GCS and keep ONLY
{name: cui}.  name = the match target;  cui = the output (the file's 'code' field).
Drops formula, reasoning, code_system so the file you load at runtime is small.

Fill in CONFIG, then:  python slim_temporal.py
Requires google-cloud-storage + ADC creds.
"""

import json
from google.cloud import storage

# ───────────────────────── CONFIG (fill in) ─────────────────────────
PROJECT_ID = ""        # e.g. "my-gcp-project"
BUCKET     = ""        # your GCS bucket
SRC_PATH   = "Normalized_loinc_classes/temporal_norm_code_to_formula.json"
OUT_LOCAL  = "temporal_name_to_cui.json"
OUT_GCS    = ""        # e.g. "Normalized_loinc_classes/temporal_name_to_cui.json"
                       # leave "" to skip the GCS upload
# ─────────────────────────────────────────────────────────────────────


def read_json_from_gcs(project_id, blob_path, bucket):
    blob = storage.Client(project=project_id).bucket(bucket).blob(blob_path)
    return json.loads(blob.download_as_text())


def write_json_to_gcs(project_id, blob_path, bucket, obj):
    blob = storage.Client(project=project_id).bucket(bucket).blob(blob_path)
    blob.upload_from_string(json.dumps(obj), content_type="application/json")


def slim(vocab):
    """Return ({name: cui}, total_rows, dup_names, skipped)."""
    rows = (vocab.get("has_formula") or []) + (vocab.get("no_formula") or [])
    name_to_cui = {}
    dups = skipped = 0
    for r in rows:
        name, cui = r.get("name"), r.get("code")
        if not name or not cui:
            skipped += 1
            continue
        if name in name_to_cui:          # same name, seen already -> keep first
            dups += 1
            continue
        name_to_cui[name] = cui
    return name_to_cui, len(rows), dups, skipped


def main():
    vocab = read_json_from_gcs(PROJECT_ID, SRC_PATH, BUCKET)
    name_to_cui, total, dups, skipped = slim(vocab)

    print(f"rows read             : {total:,}")
    print(f"unique name -> cui    : {len(name_to_cui):,}")
    print(f"duplicate names       : {dups:,} (kept first)")
    print(f"skipped (no name/cui) : {skipped:,}")
    print("sample:")
    for name, cui in list(name_to_cui.items())[:10]:
        print(f"   {name!r}: {cui!r}")

    with open(OUT_LOCAL, "w") as f:
        json.dump(name_to_cui, f)
    print(f"\nsaved -> {OUT_LOCAL}")

    if OUT_GCS:
        write_json_to_gcs(PROJECT_ID, OUT_GCS, BUCKET, name_to_cui)
        print(f"uploaded -> gs://{BUCKET}/{OUT_GCS}")


if __name__ == "__main__":
    main()

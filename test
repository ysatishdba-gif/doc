"""
analyze_duplicates.py
---------------------
For each CUI's rollup set, detect "duplicate" ancestors:
  1. Literal duplicates (shouldn't exist but verify)
  2. Hierarchical duplicates: rollup A is an IS-A ancestor of rollup B
     -> B is more specific; A is redundant
  3. Descendant-overlap duplicates: two rollups cover ~same descendants

Edit CUIS list, run.
"""

import pickle
from itertools import combinations

ROLLUP_PATH       = "rollup_index.pkl"
TOPIC_LOOKUP_PATH = "topic_lookup.pkl"

CUIS = [
    "C2142181",  # Pain of left knee joint
    "C0571275",  # Allergy to ketoconazole
    "C0571398",  # Cinoxacin allergy
    "C0276253",  # Cytomegaloviral pneumonia
    "C0021368",  # Inflammation
    "C0024109",  # Lung
]


# ============================================================================
# Load with explicit label diagnostics
# ============================================================================

print(f"Loading {ROLLUP_PATH} ...")
with open(ROLLUP_PATH, "rb") as f:
    r = pickle.load(f)

cui_to_rollup     = r["cui_to_rollup_ancestors"]
ic_scores         = r["ic_scores"]
descendant_counts = r["descendant_counts"]
isa_parents       = r["isa_parents"]
isa_children      = r["isa_children"]

# Reconstruct descendant SETS (not just counts) for overlap analysis
print("Computing descendant sets for overlap analysis...")
descendant_sets = {}
def get_descendants(node, stack):
    if node in descendant_sets:
        return descendant_sets[node]
    if node in stack:
        return set()
    stack = stack | {node}
    result = set()
    for child in isa_children.get(node, ()):
        result.add(child)
        result |= get_descendants(child, stack)
    descendant_sets[node] = result
    return result

# Only compute for nodes we'll need (rollup ancestors + their context)
rollup_universe = set()
for cui in CUIS:
    rollup_universe |= cui_to_rollup.get(cui, set())
for r_cui in list(rollup_universe):
    rollup_universe |= cui_to_rollup.get(r_cui, set())  # transitive a bit

for node in rollup_universe:
    get_descendants(node, set())
print(f"  Computed {len(descendant_sets):,} descendant sets")

# Load labels — with explicit reporting
labels = {}
import os
if os.path.exists(TOPIC_LOOKUP_PATH):
    print(f"Loading labels from {TOPIC_LOOKUP_PATH} ...")
    with open(TOPIC_LOOKUP_PATH, "rb") as f:
        t = pickle.load(f)
    labels = t.get("labels", {})
    print(f"  Loaded {len(labels):,} labels")
else:
    print(f"  WARNING: {TOPIC_LOOKUP_PATH} not found in cwd. "
          f"Run: {os.getcwd()}")


def lbl(c):
    return labels.get(c, "?")


# ============================================================================
# Duplicate detection helpers
# ============================================================================

def is_ancestor_of(a, b, parents_dict, max_depth=20):
    """Is `a` a transitive IS-A ancestor of `b`?"""
    visited = set()
    stack = [(b, 0)]
    while stack:
        node, depth = stack.pop()
        if depth > max_depth:
            continue
        if node in visited:
            continue
        visited.add(node)
        for p in parents_dict.get(node, set()):
            if p == a:
                return True
            stack.append((p, depth + 1))
    return False


def descendant_jaccard(a, b):
    """Jaccard similarity of descendant sets."""
    da = descendant_sets.get(a, set())
    db = descendant_sets.get(b, set())
    union = da | db
    if not union:
        return 0.0
    return len(da & db) / len(union)


# ============================================================================
# Per-CUI analysis
# ============================================================================

for cui in CUIS:
    print(f"\n{'='*100}")
    print(f"  {cui}  '{lbl(cui)}'")
    print(f"{'='*100}")
    
    rollups = sorted(cui_to_rollup.get(cui, []))
    if not rollups:
        print(f"  No rollups")
        continue
    
    print(f"  {len(rollups)} rollup ancestors:\n")
    for r_cui in sorted(rollups, key=lambda c: -ic_scores.get(c, 0.0)):
        r_ic = ic_scores.get(r_cui, 0.0)
        r_descs = descendant_counts.get(r_cui, 0)
        print(f"    {r_cui}  IC={r_ic:.3f}  descs={r_descs:>5d}  "
              f"'{lbl(r_cui)}'")
    
    # 1. Literal duplicate check
    if len(rollups) != len(set(rollups)):
        print(f"\n  ⚠ LITERAL DUPLICATES FOUND in set!")
    else:
        print(f"\n  ✓ No literal duplicates (set has {len(set(rollups))} unique)")
    
    # 2. Hierarchical duplicates: pairs where one is ancestor of the other
    print(f"\n  Hierarchical-duplicate pairs (one is IS-A ancestor of the other):")
    hier_dups = []
    for a, b in combinations(rollups, 2):
        if is_ancestor_of(a, b, isa_parents):
            hier_dups.append((a, b, "a is ancestor of b"))
        elif is_ancestor_of(b, a, isa_parents):
            hier_dups.append((b, a, "b is ancestor of a"))
    
    if hier_dups:
        for anc, desc, _ in hier_dups:
            print(f"    {anc} (anc, IC={ic_scores.get(anc, 0):.3f}) "
                  f"'{lbl(anc)[:35]}'")
            print(f"      ↑ contains ↑")
            print(f"    {desc} (desc, IC={ic_scores.get(desc, 0):.3f}) "
                  f"'{lbl(desc)[:35]}'")
            print(f"    -> '{lbl(anc)[:25]}' is REDUNDANT, drop it\n")
    else:
        print(f"    (none — all rollups are siblings in IS-A, not ancestors)")
    
    # 3. Descendant overlap: pairs with high Jaccard
    print(f"  Descendant-overlap pairs (Jaccard > 0.5):")
    overlap_dups = []
    for a, b in combinations(rollups, 2):
        j = descendant_jaccard(a, b)
        if j > 0.5:
            overlap_dups.append((a, b, j))
    
    overlap_dups.sort(key=lambda x: -x[2])
    if overlap_dups:
        for a, b, j in overlap_dups:
            print(f"    J={j:.3f}  {a} ({lbl(a)[:30]}) <-> {b} ({lbl(b)[:30]})")
    else:
        print(f"    (none — rollups cover distinct concept regions)")
    
    # 4. Suggested dedup: keep only most-specific (highest IC), drop ancestors
    redundant = {anc for anc, desc, _ in hier_dups}
    kept = [r for r in rollups if r not in redundant]
    print(f"\n  After dropping hierarchical redundancy: {len(kept)} kept "
          f"(was {len(rollups)})")
    for r_cui in sorted(kept, key=lambda c: -ic_scores.get(c, 0.0)):
        r_ic = ic_scores.get(r_cui, 0.0)
        print(f"    {r_cui}  IC={r_ic:.3f}  '{lbl(r_cui)}'")


print("\n\nDONE")

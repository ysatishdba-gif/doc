# Run this to see what's actually available
for n in dir():
    if not n.startswith('_'):
        try:
            v = eval(n)
            if hasattr(v, '__len__'):
                print(f"  {n}: type={type(v).__name__}, len={len(v)}")
            else:
                print(f"  {n}: type={type(v).__name__}")
        except Exception:
            pass

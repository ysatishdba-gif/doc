"""
build_rollup.py
---------------
Build IS-A hierarchical rollup using MRREL.

Pipeline:
  1. Extract IS-A edges from MRREL (PAR/CHD/RB/RN), filtered to our SNOMED universe
  2. Build IS-A DAG (child -> parent direction, normalized)
  3. Compute structural IC per concept (Seco)
  4. For each CUI, walk all paths to root; find rollup ancestor per path
     (stop at first IC delta acceleration); union across paths
  5. Write rollup_index.pkl

Inputs (notebook globals expected):
  mrrel_rows       : list of MRREL rows from umls_cache.pkl
                     (each row should have CUI1, CUI2, REL, RELA columns
                      or equivalent dict keys)
  SNOMED_CUIS      : set of 374K SNOMED CUIs
  LABELS           : cui -> label (for diagnostics)

Output:
  rollup_index.pkl with:
    cui_to_rollup_ancestors : cui -> frozenset(ancestor_cuis)
    rollup_to_descendants   : ancestor -> set(cuis_that_roll_up_to_it)
    ic_scores               : cui -> float (Seco IC)
    descendant_counts       : cui -> int
    paths_count             : cui -> int (number of paths to root)
    isa_parents             : cui -> set of immediate IS-A parents
    isa_children            : cui -> set of immediate IS-A children
    config, built_at
"""

import pickle
import datetime
import math
import time
import os
from collections import defaultdict, Counter


OUTPUT_PATH       = "rollup_index.pkl"
RELATIONS_TO_USE  = {"PAR", "CHD", "RB", "RN"}  # hierarchical only, NO RO


# ============================================================================
# Step 1: Extract IS-A edges from MRREL
# ============================================================================

def extract_isa_edges(mrrel_rows, snomed_cuis, relations):
    """Return set of (child, parent) tuples representing IS-A relationships.

    Handles MRREL rows whether they're tuples or dicts. Adjust the field
    extraction below if your row format differs.
    """
    print("  Extracting IS-A edges from MRREL...")
    print(f"    Total MRREL rows                : {len(mrrel_rows):,}")
    print(f"    Filtering to REL in             : {sorted(relations)}")

    edges = set()
    n_skipped_rel = 0
    n_skipped_scope = 0
    n_kept = 0

    for row in mrrel_rows:
        # Handle both dict and tuple shapes
        if isinstance(row, dict):
            cui1 = row.get("CUI1") or row.get("cui1")
            cui2 = row.get("CUI2") or row.get("cui2")
            rel  = row.get("REL")  or row.get("rel")
        else:
            # Assume tuple/sequence: (CUI1, AUI1, STYPE1, REL, CUI2, AUI2, ...)
            try:
                cui1, _, _, rel, cui2 = row[0], row[1], row[2], row[3], row[4]
            except (IndexError, TypeError, ValueError):
                continue

        if rel not in relations:
            n_skipped_rel += 1
            continue
        if cui1 not in snomed_cuis or cui2 not in snomed_cuis:
            n_skipped_scope += 1
            continue
        if cui1 == cui2:
            continue

        # Normalize direction to child -> parent
        if rel == "PAR" or rel == "RB":
            # cui1 is narrower/child; cui2 is broader/parent
            edges.add((cui1, cui2))
        elif rel == "CHD" or rel == "RN":
            # cui1 is broader/parent; cui2 is narrower/child
            edges.add((cui2, cui1))
        n_kept += 1

    print(f"    Skipped (wrong relation)        : {n_skipped_rel:,}")
    print(f"    Skipped (out of scope)          : {n_skipped_scope:,}")
    print(f"    Kept (relation x scope match)   : {n_kept:,}")
    print(f"    Unique IS-A edges               : {len(edges):,}")
    return edges


# ============================================================================
# Step 2: Build IS-A DAG
# ============================================================================

def build_isa_dag(edges):
    """Build child -> parents and parent -> children indexes."""
    isa_parents  = defaultdict(set)  # child -> set of parents
    isa_children = defaultdict(set)  # parent -> set of children

    for child, parent in edges:
        isa_parents[child].add(parent)
        isa_children[parent].add(child)

    return dict(isa_parents), dict(isa_children)


# ============================================================================
# Step 3: Structural IC (Seco)
# ============================================================================

def compute_descendant_counts(isa_children, all_nodes):
    """For each node, count its descendants (transitive, in IS-A DAG)."""
    print("  Computing descendant counts...")
    t0 = time.time()

    # Memoized DFS
    descendant_counts = {}

    def descendants(node, stack):
        if node in descendant_counts:
            return descendant_counts[node]
        if node in stack:
            return set()  # cycle guard
        stack = stack | {node}
        result = set()
        for child in isa_children.get(node, ()):
            result.add(child)
            result |= descendants(child, stack)
        descendant_counts[node] = result
        return result

    for node in all_nodes:
        descendants(node, set())

    counts = {n: len(d) for n, d in descendant_counts.items()}
    print(f"    Computed for {len(counts):,} nodes in {time.time()-t0:.1f}s")
    return counts


def compute_ic(descendant_counts, total_nodes):
    """Seco IC: 1 - log(descendants+1) / log(total)."""
    print("  Computing Seco IC scores...")
    log_total = math.log(total_nodes + 1)
    ic = {}
    for cui, n_desc in descendant_counts.items():
        ic[cui] = 1.0 - math.log(n_desc + 1) / log_total
    return ic


# ============================================================================
# Step 4: Walk paths and find rollup ancestors
# ============================================================================

def all_paths_to_root(cui, isa_parents, max_paths=200, max_depth=30):
    """Return list of paths (each a list of CUIs from cui up to a root).

    Caps paths and depth as safety nets — UMLS DAG is large.
    """
    paths = []

    def walk(current_path, visited):
        if len(paths) >= max_paths:
            return
        if len(current_path) >= max_depth:
            paths.append(list(current_path))
            return
        current = current_path[-1]
        parents = isa_parents.get(current, set()) - visited
        if not parents:
            paths.append(list(current_path))
            return
        for p in parents:
            current_path.append(p)
            visited.add(p)
            walk(current_path, visited)
            current_path.pop()
            visited.remove(p)

    walk([cui], {cui})
    return paths


def find_rollup_ancestor(path, ic):
    """Given a path [cui, parent, grandparent, ..., root], find the rollup
    ancestor using the first-IC-acceleration rule.

    Returns the CUI in the path where we stop.
    """
    if len(path) == 1:
        # CUI is a root or has no parents at all
        return path[0]
    if len(path) == 2:
        # Just CUI and parent — rollup to parent
        return path[1]

    ics = [ic.get(node, 0.0) for node in path]
    deltas = [ics[i] - ics[i+1] for i in range(len(ics) - 1)]

    # Walk deltas; find first delta that exceeds the previous delta
    # (rate of IC drop accelerates)
    for i in range(1, len(deltas)):
        if deltas[i] > deltas[i-1]:
            return path[i]  # ancestor just before the accelerated drop

    # No acceleration found — IC drops uniformly all the way to root
    # Fall back to one step beyond immediate parent (= path[2])
    return path[min(2, len(path) - 1)]


def build_rollups(snomed_cuis, isa_parents, ic):
    """For each CUI, find rollup ancestors via path-wise stop rule."""
    print("  Computing rollup ancestors for all CUIs...")
    t0 = time.time()

    cui_to_rollup_ancestors = {}
    paths_count = {}
    n_orphan = 0
    n_with_rollup = 0

    for i, cui in enumerate(snomed_cuis):
        if i % 50000 == 0 and i > 0:
            print(f"    Processed {i:,}/{len(snomed_cuis):,} ({time.time()-t0:.0f}s)")

        if cui not in isa_parents:
            # No IS-A parent — orphan; roll up to self
            cui_to_rollup_ancestors[cui] = frozenset({cui})
            paths_count[cui] = 0
            n_orphan += 1
            continue

        paths = all_paths_to_root(cui, isa_parents)
        paths_count[cui] = len(paths)

        rollup_ancestors = set()
        for path in paths:
            rollup_ancestors.add(find_rollup_ancestor(path, ic))

        cui_to_rollup_ancestors[cui] = frozenset(rollup_ancestors)
        n_with_rollup += 1

    print(f"  Done in {time.time()-t0:.0f}s")
    print(f"    CUIs with IS-A parent           : {n_with_rollup:,}")
    print(f"    Orphans (rolled up to self)     : {n_orphan:,}")
    return cui_to_rollup_ancestors, paths_count


# ============================================================================
# Step 5: Build reverse index and stats
# ============================================================================

def build_reverse_and_stats(cui_to_rollup_ancestors):
    """rollup -> set of CUIs that map to it."""
    print("  Building reverse index...")
    rollup_to_descendants = defaultdict(set)
    for cui, ancestors in cui_to_rollup_ancestors.items():
        for anc in ancestors:
            rollup_to_descendants[anc].add(cui)

    n_unique = len(rollup_to_descendants)
    compression_ratio = (
        len(cui_to_rollup_ancestors) / n_unique
        if n_unique else 0.0
    )

    print(f"    Unique rollup ancestors         : {n_unique:,}")
    print(f"    Avg CUIs per rollup             : {compression_ratio:.1f}")
    print(f"    Compression ratio (CUIs/rollup) : {compression_ratio:.1f}x")

    # Size distribution
    sizes = Counter()
    for desc in rollup_to_descendants.values():
        sizes[len(desc)] += 1
    print(f"    Rollup-cluster size distribution (top 10):")
    for size, count in sorted(sizes.items())[:10]:
        print(f"      size {size:>5d}: {count:>7,d} rollups")
    print(f"    Biggest rollup clusters:")
    biggest = sorted(rollup_to_descendants.items(), key=lambda kv: -len(kv[1]))[:5]
    for r, descs in biggest:
        print(f"      {r}: {len(descs):,} descendants")

    return dict(rollup_to_descendants)


# ============================================================================
# Main
# ============================================================================

def main():
    print(f"BUILD START — {datetime.datetime.now().isoformat()}")
    t_total = time.time()

    print(f"\nInputs (from notebook globals):")
    print(f"  mrrel_rows        : {len(mrrel_rows):,}")
    print(f"  SNOMED_CUIS       : {len(SNOMED_CUIS):,}")

    print(f"\n[1] Extract IS-A edges")
    edges = extract_isa_edges(mrrel_rows, SNOMED_CUIS, RELATIONS_TO_USE)
    if not edges:
        print("  ERROR: no IS-A edges extracted. Check MRREL row format.")
        return

    print(f"\n[2] Build IS-A DAG")
    isa_parents, isa_children = build_isa_dag(edges)
    print(f"    CUIs with parents               : {len(isa_parents):,}")
    print(f"    CUIs with children              : {len(isa_children):,}")

    print(f"\n[3] Compute descendant counts and IC")
    all_nodes = set(isa_parents.keys()) | set(isa_children.keys())
    descendant_counts = compute_descendant_counts(isa_children, all_nodes)
    ic = compute_ic(descendant_counts, len(SNOMED_CUIS))

    # IC sanity check
    ic_vals = sorted(ic.values())
    if ic_vals:
        print(f"    IC range                        : "
              f"{ic_vals[0]:.3f} to {ic_vals[-1]:.3f}")
        print(f"    IC median                       : "
              f"{ic_vals[len(ic_vals)//2]:.3f}")

    print(f"\n[4] Walk paths and find rollup ancestors")
    cui_to_rollup_ancestors, paths_count = build_rollups(
        SNOMED_CUIS, isa_parents, ic
    )

    print(f"\n[5] Build reverse index")
    rollup_to_descendants = build_reverse_and_stats(cui_to_rollup_ancestors)

    print(f"\n[6] Assemble pickle")
    payload = {
        "cui_to_rollup_ancestors": cui_to_rollup_ancestors,
        "rollup_to_descendants":   rollup_to_descendants,
        "ic_scores":               ic,
        "descendant_counts":       descendant_counts,
        "paths_count":             paths_count,
        "isa_parents":             isa_parents,
        "isa_children":            isa_children,
        "config": {
            "relations_used":  sorted(RELATIONS_TO_USE),
            "ic_formula":      "Seco structural: 1 - log(descendants+1)/log(total)",
            "stop_rule":       "first IC delta acceleration along path",
            "snomed_universe_size": len(SNOMED_CUIS),
        },
        "built_at": datetime.datetime.now().isoformat(),
    }

    print(f"\n[7] Saving to {OUTPUT_PATH}")
    with open(OUTPUT_PATH, "wb") as f:
        pickle.dump(payload, f, protocol=pickle.HIGHEST_PROTOCOL)
    size_mb = os.path.getsize(OUTPUT_PATH) / 1024 / 1024
    print(f"    Wrote {size_mb:.1f} MB")

    print(f"\nTOTAL: {time.time()-t_total:.0f}s")
    print(f"DONE — {datetime.datetime.now().isoformat()}")


main()

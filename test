"""
diagnose_relations.py
---------------------
Inspect what (REL, RELA) pairs exist in the UMLS cache and how many
edges of each type. Use this BEFORE deciding whether to include more
relations in topic building.

For each (REL, RELA) pair, prints:
  - edge count
  - 3 sample edges (with labels) to show what kind of relation it is

Run this as a standalone script in your GCP notebook.
"""

import pickle
from collections import Counter, defaultdict


CACHE_PATH = "umls_cache.pkl"


def main():
    print(f"Loading {CACHE_PATH} ...")
    with open(CACHE_PATH, "rb") as f:
        cache = pickle.load(f)
    print(f"  {len(cache['cuis']):,} CUIs")
    print(f"  {len(cache['mrrel_rows']):,} MRREL rows")
    labels = cache["labels"]

    # Count by (rel, rela)
    counts = Counter()
    examples = defaultdict(list)
    for cui1, cui2, rel, rela in cache["mrrel_rows"]:
        key = (rel, rela)
        counts[key] += 1
        if len(examples[key]) < 3:
            l1 = labels.get(cui1, "?")[:40]
            l2 = labels.get(cui2, "?")[:40]
            examples[key].append(f"{cui1} '{l1}' --[{rel}/{rela}]--> {cui2} '{l2}'")

    print(f"\n{len(counts)} distinct (REL, RELA) pairs:\n")
    print(f"{'EDGES':>10}  {'REL':<6} {'RELA'}")
    print("-" * 60)
    for (rel, rela), n in counts.most_common():
        print(f"{n:>10,}  {rel:<6} {rela}")

    print("\n\nExamples per (REL, RELA):")
    for (rel, rela), n in counts.most_common():
        print(f"\n  [{rel} / {rela}]  ({n:,} edges)")
        for ex in examples[(rel, rela)]:
            print(f"    {ex}")

    # Identify likely inverse pairs (RELAs paired by 'has_X' vs 'X_of' convention)
    print("\n\nLikely inverse-pair RELAs:")
    relas = {rela for (_, rela), _ in counts.items() if rela}
    paired = set()
    for r in sorted(relas):
        if r in paired:
            continue
        inverse_candidates = [
            f"has_{r}",
            f"{r}_of",
            f"inverse_{r}",
            r.replace("_of", "") if r.endswith("_of") else None,
            r.replace("has_", "") if r.startswith("has_") else None,
            f"has_{r[:-3]}" if r.endswith("_of") else None,
        ]
        for inv in inverse_candidates:
            if inv and inv in relas and inv != r:
                count_r = sum(c for (_, rl), c in counts.items() if rl == r)
                count_inv = sum(c for (_, rl), c in counts.items() if rl == inv)
                print(f"  {r} ({count_r:,}) <-> {inv} ({count_inv:,})")
                paired.add(r)
                paired.add(inv)
                break


main()

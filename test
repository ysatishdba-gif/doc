"""
test_subtopics_v2.py
--------------------
Test the bidirectional sub-topic build.

Demonstrates both directions:
  - Forward: given a main topic CUI, list its sub-topics
  - Reverse: given a sub-topic, list which main topics it belongs to
  - Per CUI: which sub-topics does this CUI appear in?
"""

import pickle
from collections import Counter


PICKLE_PATH = "topic_lookup_subtopics_v2.pkl"

CUIS_TO_TEST = [
    "C0032285",  # Pneumonia
    "C0021368",  # Inflammation
    "C0024109",  # Lung
    "C0011849",  # Diabetes
    "C1527304",  # Allergic reaction
    "C0559470",  # Allergy to peanut
    "C0002792",  # Anaphylaxis
    "C0013182",  # Allergy to drug
    "C2142181",  # Pain of left knee joint
    "C1621958",  # Glioblastoma multiforme
]


print(f"Loading {PICKLE_PATH} ...")
with open(PICKLE_PATH, "rb") as f:
    p = pickle.load(f)

topic_to_cuis              = p["topic_to_cuis"]
main_topic_to_subtopic_ids = p["main_topic_to_subtopic_ids"]
subtopic_id_to_cuis        = p["subtopic_id_to_cuis"]
subtopic_id_to_main_topics = p["subtopic_id_to_main_topics"]
cui_to_subtopic_ids        = p["cui_to_subtopic_ids"]
subtopic_metadata          = p["subtopic_metadata"]
labels                     = p.get("labels", {})


def lbl(c):
    return labels.get(c, "?")[:40] if labels else "?"


print(f"  Main topics             : {len(topic_to_cuis):,}")
print(f"  Unique sub-topics       : {len(subtopic_id_to_cuis):,}")


# ============================================================================
# Per-CUI inspection
# ============================================================================

for cui in CUIS_TO_TEST:
    print(f"\n\n{'='*80}")
    print(f"  {cui}  '{lbl(cui)}'")
    print(f"{'='*80}")

    main_members = topic_to_cuis.get(cui, set())
    print(f"\n  MAIN TOPIC (size {len(main_members)})")

    # All sub-topics this CUI belongs to
    sids = cui_to_subtopic_ids.get(cui, set())
    print(f"\n  This CUI appears in {len(sids)} sub-topics total")

    # Group by size for readability
    by_size = Counter()
    for sid in sids:
        size = subtopic_metadata.get(sid, {}).get("size", 0)
        by_size[size] += 1
    print(f"  By size:")
    for size in sorted(by_size):
        print(f"    size {size:>3}: {by_size[size]} sub-topics")

    # Forward: sub-topics within THIS CUI's main topic
    own_subtopics = main_topic_to_subtopic_ids.get(cui, [])
    # Deduplicate (same subtopic_id can appear multiple times in list)
    unique_own_subtopics = list(dict.fromkeys(own_subtopics))
    print(f"\n  SUB-TOPICS within this main topic ({len(unique_own_subtopics)}):")

    # Sort by size descending, show interesting ones
    sorted_subs = sorted(
        unique_own_subtopics,
        key=lambda s: -subtopic_metadata.get(s, {}).get("size", 0),
    )
    for sid in sorted_subs[:10]:
        meta = subtopic_metadata.get(sid, {})
        members = subtopic_id_to_cuis.get(sid, frozenset())
        n_main_topics = len(subtopic_id_to_main_topics.get(sid, set()))
        print(f"    {sid}  size={meta.get('size')} "
              f"method={meta.get('method')} "
              f"appears_in_main_topics={n_main_topics}")
        for m in sorted(members):
            marker = " <-- self" if m == cui else ""
            print(f"      {m}  '{lbl(m)}'{marker}")
    if len(sorted_subs) > 10:
        print(f"    ... +{len(sorted_subs)-10} more sub-topics")


# ============================================================================
# Reverse lookup demo: pick a few sub-topics, show which main topics they're in
# ============================================================================

print(f"\n\n{'#'*80}")
print(f"#  REVERSE LOOKUP DEMO")
print(f"#  (For a few sub-topics, show which main topics they appear in)")
print(f"{'#'*80}")

# Find some sub-topics of size >= 3 to demonstrate
demo_sids = [
    sid for sid, meta in subtopic_metadata.items()
    if meta.get("size", 0) >= 3 and meta.get("method") == "clique"
][:5]

for sid in demo_sids:
    members = subtopic_id_to_cuis[sid]
    main_topics = subtopic_id_to_main_topics[sid]
    print(f"\n  Sub-topic {sid} (size {len(members)}):")
    print(f"    Members:")
    for m in sorted(members):
        print(f"      {m}  '{lbl(m)}'")
    print(f"    Appears in {len(main_topics)} main topic(s):")
    for mt in sorted(main_topics):
        print(f"      {mt}  '{lbl(mt)}'")


print("\n\nDONE")

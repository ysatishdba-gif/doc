"""
lookup.py
---------
Pass a CUI, get back its topics with the CUIs in each topic.

    exec(open("lookup.py").read())
    lookup("C0032285")
    lookup("C0032285", "C0011849")
"""

import pickle


_PKL_PATH = "topics.pkl"
_state = {}


def _load():
    if _state:
        return
    with open(_PKL_PATH, "rb") as f:
        p = pickle.load(f)
    _state["topic_id_to_topic"] = p["topic_id_to_topic"]
    _state["cui_to_topic_ids"]  = p["cui_to_topic_ids"]
    _state["labels"]            = p["labels"]


def lookup(*cuis):
    _load()
    labels   = _state["labels"]
    cui_to_t = _state["cui_to_topic_ids"]
    topics   = _state["topic_id_to_topic"]

    for cui in cuis:
        tids = cui_to_t.get(cui, [])
        print(f"\n{'='*78}")
        print(f"{cui}  '{labels.get(cui, '?')}'  -> {len(tids)} topic(s)")
        print('='*78)
        # Show smallest topic first (tightest match)
        rows = [(tid, topics[tid]) for tid in tids]
        rows.sort(key=lambda r: r[1]["size"])
        for tid, t in rows:
            anchor = t["canonical"]
            print(f"\n  {tid}  size={t['size']}  IC={t['anchor_ic']:.3f}")
            print(f"    Anchor: {anchor} '{labels.get(anchor, '?')}'")
            for m in sorted(t["members"], key=lambda c: labels.get(c, "")):
                mark = "  <-- self" if m == cui else ""
                print(f"      {m}  '{labels.get(m, '?')}'{mark}")


_load()
print(f"Loaded topics.pkl ({len(_state['cui_to_topic_ids']):,} CUIs)\n")
print("Try:  lookup('C0032285')")
print("      lookup('C0032285', 'C0011849')")

"""

Per-CUI inspector for topics.pkl.

For each test CUI:
  - Its STY tags
  - All topics it belongs to (one per IS-A ancestor anchor)
  - Per topic: ID, canonical, label, size, member CUIs
"""

import pickle

PKL_PATH = "topics.pkl"

CUIS = [
    # "C0032285",  # Pneumonia
    # "C0011849",  # Diabetes mellitus
    "C0041296",  # Inflammation
    # "C0043481",  # Lung
    "C2142181",  # Pain of left knee joint
    # "C0559470",  # Allergy to peanut
    # "C0205082",  # Allergy to drug
    # "C0006826",  # Anaphylaxis
]

MAX_MEMBERS_TO_SHOW = 25


with open(PKL_PATH, "rb") as f:
    p = pickle.load(f)

topic_id_to_topic = p["topic_id_to_topic"]
cui_to_topic_ids  = p["cui_to_topic_ids"]
labels            = p.get("labels", {})
tags              = p.get("tags", {})


def lbl(c):
    return labels.get(c, "?")


def sty(c):
    t = tags.get(c)
    if not t:
        return "(no STY)"
    if isinstance(t, (set, frozenset, list)):
        return ", ".join(sorted(t))
    return str(t)


for cui in CUIS:
    print(f"\n{'='*80}")
    print(f"{cui}  |  {lbl(cui)}")
    print(f"STY: {sty(cui)}")

    topic_ids = cui_to_topic_ids.get(cui, [])
    print(f"-> {len(topic_ids)} TOPIC(S)")

    if not topic_ids:
        print("  (no topics — this CUI has no IS-A ancestor in any of its main topics)")
        continue

    # Show topics, smallest first (most specific tighter matches)
    sorted_topic_ids = sorted(
        topic_ids,
        key=lambda tid: topic_id_to_topic[tid]["size"]
    )

    for tid in sorted_topic_ids:
        topic = topic_id_to_topic[tid]
        print()
        print(f"  Topic ID : {tid}")
        print(f"  Canonical: {topic['canonical']}")
        print(f"  Label    : {lbl(topic['canonical'])}")
        print(f"  Size     : {topic['size']} CUIs")
        print(f"  IC       : {topic['anchor_ic']:.3f}")
        print(f"  Members  :")
        for m in sorted(topic["members"])[:MAX_MEMBERS_TO_SHOW]:
            print(f"    {m}  '{lbl(m)}'")
        if topic["size"] > MAX_MEMBERS_TO_SHOW:
            print(f"    ... and {topic['size'] - MAX_MEMBERS_TO_SHOW} more")

print("\n" + "="*80)
print("DONE")

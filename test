# cui_topics.py
# Forms topics from surviving CUIs.
#
# Strategies:
#   "hierarchy" — UMLS ancestor convergence (default, deterministic, interpretable)
#   "embedding" — Louvain on cosine k-NN graph of CUI embeddings (semantic clustering)

import time, logging
from collections import defaultdict
import numpy as np
from google.cloud import bigquery
from config import PROJECT_ID, DATASET_ID, EMBEDDING_TABLE, hierarchy, ic_precomputed, medlineplus

from cui_core import (
    MetadataFetcher, ICComputer, EmbeddingFetcher,
    HierarchicalTopicBuilder, TopicBuilder, fetch_preferred_terms,
)

log = logging.getLogger(__name__)


class CUITopics:

    def __init__(self):
        self._graph = hierarchy
        self._ic_pre = ic_precomputed
        self._bq = bigquery.Client(project=PROJECT_ID)
        self._pid, self._did = PROJECT_ID, DATASET_ID
        self._meta = MetadataFetcher(self._bq, PROJECT_ID, DATASET_ID)
        self._ic = ICComputer(self._graph, self._ic_pre)
        self._emb = EmbeddingFetcher(self._bq, PROJECT_ID, DATASET_ID, EMBEDDING_TABLE)

    def build_topics(self, cuis, strategy="hierarchy"):
        """
        strategy = "hierarchy"  -> UMLS ancestor convergence (HierarchicalTopicBuilder)
        strategy = "embedding"  -> Louvain on cosine k-NN of embeddings (TopicBuilder)
        """
        t0 = time.perf_counter()

        if not cuis:
            return self._empty(t0)

        cuis = list(dict.fromkeys(cuis))
        n_in = len(cuis)

        meta = self._meta.fetch(cuis)
        ic = self._ic.compute(cuis, meta)
        embs = self._emb.fetch(cuis)
        terms = fetch_preferred_terms(self._bq, self._pid, self._did, cuis)

        if strategy == "embedding":
            h = self._form_embedding(cuis, embs, ic, meta)
        elif strategy == "hierarchy":
            h = self._form_hierarchy(cuis, ic)
        else:
            raise ValueError(f"unknown strategy: {strategy}")

        if not h:
            ms = (time.perf_counter() - t0) * 1000
            return {"topics": [], "metrics": {"input_cui_count": n_in, "topic_count": 0,
                                               "singleton_count": 0, "strategy": strategy,
                                               "processing_time_ms": round(ms, 1)}}

        # ensure each topic has a topic_cui (highest IC member)
        for t in h.values():
            if not t.get("topic_cui"):
                t["topic_cui"] = max(t.get("members", [""]), key=lambda c: ic.get(c, 0.0))

        # collect all label CUIs (topic + subtopic)
        label_cuis = set()
        for t in h.values():
            if t.get("topic_cui"):
                label_cuis.add(t["topic_cui"])
            for st in t.get("subtopics", {}).values():
                if st.get("subtopic_cui"):
                    label_cuis.add(st["subtopic_cui"])

        missing = label_cuis - set(terms)
        if missing:
            terms.update(fetch_preferred_terms(self._bq, self._pid, self._did, missing))

        centroids = {}
        for tid, t in h.items():
            vecs = [embs[c] for c in t.get("members", []) if c in embs]
            if vecs:
                mu = np.mean(vecs, axis=0, dtype=np.float32)
                n = np.linalg.norm(mu)
                centroids[tid] = (mu / n).tolist() if n > 0 else None
            else:
                centroids[tid] = None

        topics_out = []
        for tid in sorted(h):
            t = h[tid]
            tc = t.get("topic_cui", "")
            members_list = t.get("members", [])

            members = []
            for c in members_list:
                m = meta.get(c)
                members.append({"cui": c, "preferred_term": terms.get(c, c),
                                "ic": round(ic.get(c, 0.0), 4),
                                "semantic_types": list(m.semantic_types) if m and m.semantic_types else []})

            topic_label, topic_label_source = self._pick_label(tc, terms)

            subtopics = []
            for sid in sorted(t.get("subtopics", {})):
                st = t["subtopics"][sid]
                sc = st.get("subtopic_cui", "")
                st_members = st.get("members", [])
                st_mem = [{"cui": c, "preferred_term": terms.get(c, c),
                           "ic": round(ic.get(c, 0.0), 4)} for c in st_members]
                st_label, st_source = self._pick_label(sc, terms)
                subtopics.append({"subtopic_id": sid,
                                  "subtopic_cui": sc,
                                  "subtopic_label": st_label,
                                  "label_source": st_source,
                                  "members": st_mem})

            topics_out.append({"topic_id": tid,
                               "topic_cui": tc,
                               "topic_label": topic_label,
                               "label_source": topic_label_source,
                               "members": members, "subtopics": subtopics,
                               "centroid": centroids.get(tid)})

        ms = (time.perf_counter() - t0) * 1000
        n_topics = len(topics_out)
        n_sing = sum(1 for t in topics_out if len(t["members"]) == 1)
        n_mtp = sum(1 for t in topics_out if t["label_source"] == "medlineplus")
        n_hier = n_topics - n_mtp

        # sanity check: every input CUI ends up in exactly one topic
        total_members = sum(len(t["members"]) for t in topics_out)
        if total_members != n_in:
            log.warning(f"CUI count mismatch: {n_in} in, {total_members} in topics")

        log.info(f"[{strategy}] {n_in} CUIs -> {n_topics} topics ({n_sing} singletons) "
                 f"labels: {n_mtp} medlineplus, {n_hier} hierarchy "
                 f"{ms:.0f}ms")

        return {"topics": topics_out,
                "metrics": {"input_cui_count": n_in, "topic_count": n_topics,
                            "singleton_count": n_sing, "strategy": strategy,
                            "processing_time_ms": round(ms, 1)}}

    # ── Strategies ───────────────────────────────────────────────────────────

    def _form_hierarchy(self, cuis, ic):
        """UMLS ancestor convergence via HierarchicalTopicBuilder."""
        return HierarchicalTopicBuilder.build(cuis, self._graph, ic)

    def _form_embedding(self, cuis, embs, ic, metadata):
        """Phase 1: stratify by dominant semantic type, then cluster within each group.

        Each CUI is assigned to its first (primary) semantic type. CUIs with no
        type form their own group. Within each type group, TopicBuilder runs
        independently, so Disease CUIs never cluster with Procedure CUIs etc.
        """
        cuis_with_emb = [c for c in cuis if c in embs]
        if not cuis_with_emb:
            return {}

        # Group CUIs by primary semantic type
        by_type = defaultdict(list)
        for cui in cuis_with_emb:
            m = metadata.get(cui)
            types = m.semantic_types if (m and m.semantic_types) else []
            primary = types[0] if types else "__untyped__"
            by_type[primary].append(cui)

        # Cluster within each type group independently
        h = {}
        next_tid = 0
        for sem_type, group_cuis in sorted(by_type.items()):
            if len(group_cuis) < 2:
                # singleton CUI in its own topic
                cui = group_cuis[0]
                h[next_tid] = {
                    "topic_cui": cui,
                    "members": [cui],
                    "subtopics": {},
                    "ungrouped": [cui],
                    "_grouping_cui": cui,
                    "_semantic_type": sem_type,
                }
                next_tid += 1
                continue

            groups = TopicBuilder.build(group_cuis, embs)
            if not groups:
                continue

            for _, members in groups.items():
                if not members:
                    continue
                members_sorted = sorted(members)
                topic_cui = max(members_sorted, key=lambda c: ic.get(c, 0.0))
                h[next_tid] = {
                    "topic_cui": topic_cui,
                    "members": members_sorted,
                    "subtopics": {},
                    "ungrouped": members_sorted,
                    "_grouping_cui": topic_cui,
                    "_semantic_type": sem_type,
                }
                next_tid += 1
        return h

    # ── Helpers ──────────────────────────────────────────────────────────────

    @staticmethod
    def _pick_label(cui, terms):
        """MedlinePlus if available, else MRCONSO preferred term."""
        if not cui:
            return "", "hierarchy"
        if cui in medlineplus:
            return medlineplus[cui], "medlineplus"
        return terms.get(cui, cui), "hierarchy"

    @staticmethod
    def _empty(t0):
        ms = (time.perf_counter() - t0) * 1000
        return {"topics": [], "metrics": {"input_cui_count": 0, "topic_count": 0,
                                           "singleton_count": 0, "strategy": None,
                                           "processing_time_ms": round(ms, 1)}}

    def close(self):
        self._emb.close()

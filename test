"""
test_neighborhood_topics.py
---------------------------
Load topic_lookup_neighborhoods.pkl and run lookups + retrieval tests.

Paste in a notebook cell after the neighborhood build has finished.
No globals required — pickle is self-contained.
"""

import pickle


PICKLE_PATH = "topic_lookup_neighborhoods.pkl"


# ============================================================================
# Load
# ============================================================================

print(f"Loading {PICKLE_PATH} ...")
with open(PICKLE_PATH, "rb") as f:
    payload = pickle.load(f)

cui_topic_id        = payload["cui_topic_id"]        # cui -> topic_id (= cui itself)
topic_to_cuis       = payload["topic_to_cuis"]       # cui -> set of members (self + neighbors)
flattened_neighbors = payload["flattened_neighbors"]  # cui -> set of direct neighbors only
labels              = payload.get("labels", {})
tags                = payload.get("tags", {})

print(f"  Total CUIs with topic     : {len(cui_topic_id):,}")
print(f"  Total topics (= CUI count): {len(topic_to_cuis):,}")
print(f"  CUIs in flattened graph   : {len(flattened_neighbors):,}")
print(f"  Labels available          : {len(labels):,}")


def lbl(c):
    return labels.get(c, "?")[:35] if labels else "?"


# ============================================================================
# Lookup 1: print a CUI's topic
# ============================================================================

def lookup(cui):
    print(f"\n{'='*80}")
    print(f"  CUI: {cui}  '{lbl(cui)}'")
    print(f"{'='*80}")

    members = topic_to_cuis.get(cui, set())
    if not members:
        print(f"  CUI not in any topic")
        return

    print(f"  Topic ID     : {cui}  (each CUI is its own topic)")
    print(f"  Topic size   : {len(members)}")
    print(f"  Members:")
    for m in sorted(members):
        mlbl = lbl(m)
        marker = " <-- self" if m == cui else ""
        print(f"    {m}  '{mlbl}'{marker}")


# ============================================================================
# Lookup 2: retrieval test (topic overlap == 2-hop reachability)
# ============================================================================

def retrieval_test(cui_a, cui_b):
    ta = topic_to_cuis.get(cui_a, set())
    tb = topic_to_cuis.get(cui_b, set())
    overlap = ta & tb

    print(f"\n  '{lbl(cui_a)}' ({cui_a}) <-> '{lbl(cui_b)}' ({cui_b})")
    if overlap:
        print(f"    MATCH via {len(overlap)} shared CUI(s):")
        for c in sorted(overlap)[:5]:
            print(f"      {c}  '{lbl(c)}'")
    else:
        print(f"    no match")
        # Diagnostic — how close are they?
        if cui_a in tb:
            print(f"    (Note: {cui_a} is in {cui_b}'s neighborhood — shouldn't happen)")
        if cui_b in ta:
            print(f"    (Note: {cui_b} is in {cui_a}'s neighborhood — shouldn't happen)")


# ============================================================================
# Run tests
# ============================================================================

FOCAL_CUIS = [
    ("C0032285", "Pneumonia"),
    ("C0021368", "Inflammation"),
    ("C0024109", "Lung"),
    ("C0011849", "Diabetes mellitus"),
    ("C1527304", "Allergic reaction"),
    ("C0559470", "Allergy to peanut"),
    ("C0002792", "Anaphylaxis"),
    ("C0013182", "Allergy to drug"),
    ("C2142181", "Pain of left knee joint"),
    ("C1621958", "Glioblastoma multiforme"),
]

print("\n" + "#"*80)
print("# SECTION 1: Focal CUI lookups (each CUI's full topic)")
print("#"*80)
for cui, _ in FOCAL_CUIS:
    lookup(cui)


print("\n\n" + "#"*80)
print("# SECTION 2: Pair retrieval tests")
print("#"*80)
PAIRS = [
    # Allergy
    ("C1527304", "C0559470"),  # Allergic reaction <-> Peanut allergy
    ("C1527304", "C0002792"),  # Allergic reaction <-> Anaphylaxis
    ("C1527304", "C0013182"),  # Allergic reaction <-> Drug allergy
    ("C0559470", "C0002792"),  # Peanut allergy <-> Anaphylaxis
    ("C0559470", "C0013182"),  # Peanut allergy <-> Drug allergy
    # Anatomy / Disease
    ("C0032285", "C0024109"),  # Pneumonia <-> Lung
    ("C0032285", "C0035243"),  # Pneumonia <-> Respiratory tract infection
    # Knee
    ("C2142181", "C0231749"),  # Pain left knee joint <-> Pain of knee region
    ("C2142181", "C5442019"),  # Pain left knee joint <-> Pain of left knee
    # Cross-domain (should NOT match)
    ("C0032285", "C0011849"),  # Pneumonia <-> Diabetes
    ("C0559470", "C0024109"),  # Peanut allergy <-> Lung
    ("C0021368", "C0011849"),  # Inflammation <-> Diabetes
]
for a, b in PAIRS:
    retrieval_test(a, b)


# ============================================================================
# Section 3: distribution sanity
# ============================================================================

print("\n\n" + "#"*80)
print("# SECTION 3: Size distribution + outliers")
print("#"*80)

sizes = sorted(len(c) for c in topic_to_cuis.values())
print(f"  Topic sizes: min={sizes[0]}, median={sizes[len(sizes)//2]}, "
      f"mean={sum(sizes)/len(sizes):.1f}, max={sizes[-1]}")
print(f"  Size buckets:")
bucket_counts = {1: 0, 2: 0, "3-5": 0, "6-10": 0, "11-50": 0, "51-100": 0, ">100": 0}
for s in sizes:
    if s == 1: bucket_counts[1] += 1
    elif s == 2: bucket_counts[2] += 1
    elif s <= 5: bucket_counts["3-5"] += 1
    elif s <= 10: bucket_counts["6-10"] += 1
    elif s <= 50: bucket_counts["11-50"] += 1
    elif s <= 100: bucket_counts["51-100"] += 1
    else: bucket_counts[">100"] += 1
for k, v in bucket_counts.items():
    pct = 100 * v / len(sizes)
    print(f"    size {k:>10}: {v:>7,d}  ({pct:.1f}%)")

# Top 10 largest topics
print(f"\n  Top 10 largest topics (likely hubs):")
top10 = sorted(topic_to_cuis.items(), key=lambda kv: -len(kv[1]))[:10]
for cui, members in top10:
    print(f"    {cui} '{lbl(cui)}': {len(members)} members")
    for m in sorted(members)[:3]:
        if m != cui:
            print(f"      {m}  '{lbl(m)}'")


print("\n\nDONE")

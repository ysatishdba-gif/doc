"""
spot_check_cuis.py
------------------
Stratified spot-check across clinical domains and semantic types.

This is the same lookup as test_final.py, but with a broader CUI list
covering many different clinical areas. Useful for validating that
sub-topic quality holds across the universe, not just on the few
CUIs we've been using.

Paste in a notebook. Loads topic_lookup_final.pkl.
"""

import pickle

PICKLE_PATH = "topic_lookup_final.pkl"

# Stratified across semantic types + clinical domains
CUIS_TO_TEST = [
    # ---- CARDIOLOGY ----
    ("C0027051", "Myocardial infarction"),
    ("C0020538", "Hypertensive disease"),
    ("C0018802", "Congestive heart failure"),
    ("C0004238", "Atrial fibrillation"),
    ("C0010068", "Coronary heart disease"),
    ("C0042373", "Vascular disease"),

    # ---- INFECTIONS ----
    ("C0021400", "Influenza"),
    ("C0036690", "Septicemia"),
    ("C0042029", "Urinary tract infection"),
    ("C0009450", "Communicable disease"),
    ("C0036572", "Seizure"),  # neurologic, included to mix it up

    # ---- ONCOLOGY ----
    ("C0006142", "Malignant neoplasm of breast"),
    ("C0007131", "Non-small cell lung cancer"),
    ("C0024623", "Malignant neoplasm of stomach"),
    ("C0007621", "Neoplastic cell"),
    ("C0007112", "Malignant tumor of prostate"),
    ("C0023893", "Liver cirrhosis"),

    # ---- NEUROLOGY ----
    ("C0038454", "Cerebrovascular accident (stroke)"),
    ("C0002395", "Alzheimer's disease"),
    ("C0026769", "Multiple sclerosis"),
    ("C0030567", "Parkinson disease"),
    ("C0014544", "Epilepsy"),
    ("C0149931", "Migraine"),

    # ---- GASTROENTEROLOGY ----
    ("C0010346", "Crohn disease"),
    ("C0009324", "Ulcerative colitis"),
    ("C0011991", "Diarrhea"),
    ("C0011860", "Type 2 diabetes mellitus"),  # endocrine cross-check
    ("C0020443", "Hypercholesterolemia"),

    # ---- MUSCULOSKELETAL ----
    ("C0003864", "Arthritis"),
    ("C0029408", "Degenerative polyarthritis"),
    ("C0003873", "Rheumatoid arthritis"),
    ("C0024031", "Low back pain"),
    ("C0029443", "Osteoporosis"),

    # ---- PEDIATRIC / OBSTETRIC ----
    ("C0007222", "Cardiovascular disease"),
    ("C0009806", "Constipation"),
    ("C0042961", "Vomiting"),
    ("C0032797", "Postpartum disorder"),
    ("C0085207", "Gestational diabetes"),

    # ---- ANATOMY ----
    ("C0018787", "Heart"),
    ("C0023884", "Liver"),
    ("C0022646", "Kidney"),
    ("C0006104", "Brain"),
    ("C0006141", "Breast structure"),

    # ---- PROCEDURES ----
    ("C0021107", "Operative surgical procedures"),
    ("C0028778", "Obstruction (procedure)"),
    ("C0034102", "Pulmonary lobectomy"),
    ("C0010055", "Coronary artery bypass surgery"),
    ("C0009378", "Colonoscopy"),

    # ---- LAB / DIAGNOSTIC ----
    ("C0202223", "Complete blood count"),
    ("C0202117", "Standard chemistry panel"),
    ("C0392201", "Glucose measurement, blood"),
    ("C0474680", "Haemoglobin A1c measurement"),

    # ---- DRUGS ----
    ("C0004057", "Aspirin"),
    ("C0021641", "Insulin"),
    ("C0025859", "Metformin"),
    ("C0006675", "Caffeine"),

    # ---- SYMPTOMS / FINDINGS ----
    ("C0030193", "Pain"),
    ("C0015967", "Fever"),
    ("C0008031", "Chest pain"),
    ("C0013404", "Dyspnea"),
    ("C0027497", "Nausea"),
]


print(f"Loading {PICKLE_PATH} ...")
with open(PICKLE_PATH, "rb") as f:
    p = pickle.load(f)

topic_to_cuis              = p["topic_to_cuis"]
main_topic_to_subtopic_ids = p["main_topic_to_subtopic_ids"]
subtopic_id_to_cuis        = p["subtopic_id_to_cuis"]
subtopic_id_to_main_topics = p["subtopic_id_to_main_topics"]
cui_to_subtopic_ids        = p["cui_to_subtopic_ids"]
subtopic_metadata          = p["subtopic_metadata"]
labels                     = p.get("labels", {})


def lbl(c):
    return labels.get(c, "?")[:45] if labels else "?"


# Aggregate summary first
print(f"\n{'='*100}")
print(f"  SUMMARY TABLE")
print(f"{'='*100}")
print(f"  {'CUI':<12s}  {'Expected label':<35s}  {'Real label':<35s}  {'Main':>5s}  {'Subs':>5s}")

for cui, expected in CUIS_TO_TEST:
    actual = lbl(cui)
    main_sz = len(topic_to_cuis.get(cui, set()))
    sub_count = len(dict.fromkeys(main_topic_to_subtopic_ids.get(cui, [])))
    in_universe = "?" if cui not in topic_to_cuis else ""
    print(f"  {cui:<12s}  {expected[:35]:<35s}  {actual[:35]:<35s}  "
          f"{main_sz:>5d}  {sub_count:>5d}  {in_universe}")


# Now detailed for each
for cui, expected in CUIS_TO_TEST:
    print(f"\n\n{'='*80}")
    print(f"  {cui}  expected: '{expected}'  actual: '{lbl(cui)}'")
    print(f"{'='*80}")

    main_members = topic_to_cuis.get(cui, set())
    print(f"  Main topic size: {len(main_members)}")

    if not main_members:
        print(f"  ⚠️ NOT IN SNOMED UNIVERSE")
        continue

    # Show first 8 main topic members
    print(f"  Main topic members (first 8):")
    for m in sorted(main_members)[:8]:
        marker = " <-- self" if m == cui else ""
        print(f"    {m}  '{lbl(m)}'{marker}")
    if len(main_members) > 8:
        print(f"    ... +{len(main_members)-8} more")

    # Sub-topics
    own = list(dict.fromkeys(main_topic_to_subtopic_ids.get(cui, [])))
    print(f"\n  Sub-topics (size-3+ cliques) within this main topic: {len(own)}")
    if not own:
        print(f"    (none — graph is star-shaped or topic too small)")
        continue

    own_sorted = sorted(own, key=lambda s: -subtopic_metadata[s]["size"])
    # Show up to 5 sub-topics, largest first
    for sid in own_sorted[:5]:
        meta = subtopic_metadata[sid]
        members = subtopic_id_to_cuis[sid]
        print(f"\n    {sid} (size {meta['size']}):")
        for m in sorted(members):
            marker = " <-- self" if m == cui else ""
            print(f"      {m}  '{lbl(m)}'{marker}")
    if len(own_sorted) > 5:
        print(f"\n    ... +{len(own_sorted)-5} more sub-topics")


print("\n\nDONE")

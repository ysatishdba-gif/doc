"""
inspect_topics.py
-----------------
Give CUIs, get their topic and sub-topic data. That's it.

Edit CUIS list, run in notebook.
"""

import pickle

PICKLE_PATH = "topic_lookup.pkl"

CUIS = [
    "C0032285",  # Pneumonia
    "C0013182",  # Allergy to drug
    "C0011849",  # Diabetes
    "C0002792",  # Anaphylaxis
    "C2142181",  # Pain of left knee joint
]


# Load
with open(PICKLE_PATH, "rb") as f:
    p = pickle.load(f)

topic_to_cuis              = p["topic_to_cuis"]
main_topic_to_subtopic_ids = p["main_topic_to_subtopic_ids"]
subtopic_id_to_cuis        = p["subtopic_id_to_cuis"]
subtopic_metadata          = p["subtopic_metadata"]
labels                     = p.get("labels", {})
tags                       = p.get("tags", {})


def lbl(c):
    return labels.get(c, "?")


for cui in CUIS:
    print(f"\n{'='*80}")
    print(f"  {cui}  '{lbl(cui)}'")
    print(f"{'='*80}")

    sty = sorted(tags.get(cui, frozenset()))
    print(f"  STY              : {sty}")

    main_members = topic_to_cuis.get(cui, set())
    print(f"  Main topic size  : {len(main_members)}")
    print(f"  Main topic members:")
    for m in sorted(main_members):
        marker = " <-- self" if m == cui else ""
        print(f"    {m}  '{lbl(m)}'{marker}")

    own = list(dict.fromkeys(main_topic_to_subtopic_ids.get(cui, [])))
    print(f"\n  Sub-topics: {len(own)}")
    own_sorted = sorted(own, key=lambda s: -subtopic_metadata[s]["size"])
    for sid in own_sorted:
        meta = subtopic_metadata[sid]
        members = subtopic_id_to_cuis[sid]
        print(f"\n    {sid} (size {meta['size']}):")
        for m in sorted(members):
            marker = " <-- self" if m == cui else ""
            print(f"      {m}  '{lbl(m)}'{marker}")

print("\n\nDONE")

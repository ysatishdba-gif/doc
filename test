"""
build_topics_final.py
---------------------
Final topic build from the team-provided network graph.

Design (committed):
  1. Flatten the suffix-bridge graph to direct undirected CUI-CUI edges,
     SNOMED-only.
  2. Run Louvain at resolution=1.0 (chosen empirically: 91% recall, 9% FPR
     on Disease pairs from our evaluation).
  3. Each community is one topic. Each CUI belongs to exactly one topic.
  4. Label each community by its dominant STY for interpretability.
  5. Save self-contained pickle.

Inputs (notebook globals):
  data        : the network graph
  SNOMED_CUIS : set of SNOMED CUIs
  TAGS        : dict cui -> frozenset of STY codes
  LABELS      : dict cui -> human-readable name (optional)
"""

import pickle
import datetime
import time
import os
import statistics
from collections import defaultdict, Counter


OUTPUT_PATH = "topic_lookup_graph_final.pkl"
LOUVAIN_RESOLUTION = 1.0   # empirically chosen


# ============================================================================
# Helpers
# ============================================================================

def cui_of(s):
    return s.rsplit("-", 1)[0] if "-" in s else s


def normalize_tags(tags):
    return {cui: frozenset(stys) if not isinstance(stys, frozenset) else stys
            for cui, stys in tags.items()}


# ============================================================================
# Step 1: Flatten suffix-bridge graph to CUI-CUI
# ============================================================================

def flatten_graph(g, snomed_cuis):
    print(f"[1/4] Flattening suffix-bridge -> CUI-CUI edges ...")
    neighbors = defaultdict(set)
    t0 = time.time()
    n_proc = 0
    for cui in snomed_cuis:
        if cui not in g:
            n_proc += 1
            continue
        for suffix in g.successors(cui):
            if "-" not in suffix:
                continue
            for pred in g.predecessors(suffix):
                if pred == cui or pred == "CUI" or "-" not in pred:
                    continue
                oc = cui_of(pred)
                if oc != cui and oc in snomed_cuis:
                    neighbors[cui].add(oc)
                    neighbors[oc].add(cui)
        n_proc += 1
        if n_proc % 100000 == 0:
            print(f"  {n_proc:,}/{len(snomed_cuis):,} ({time.time()-t0:.0f}s)")
    n_edges = sum(len(s) for s in neighbors.values()) // 2
    print(f"  -> {n_edges:,} undirected CUI-CUI edges in {time.time()-t0:.0f}s")
    return dict(neighbors)


# ============================================================================
# Step 2: Louvain
# ============================================================================

def louvain_communities(neighbors, snomed_cuis, resolution):
    import networkx as nx
    print(f"[2/4] Louvain (resolution={resolution}) ...")
    print(f"  building undirected nx graph ...")
    G = nx.Graph()
    G.add_nodes_from(snomed_cuis)
    for u, nbrs in neighbors.items():
        for v in nbrs:
            if u < v:
                G.add_edge(u, v)
    print(f"  nodes={G.number_of_nodes():,}, edges={G.number_of_edges():,}")

    from networkx.algorithms.community import louvain_communities as nx_louvain
    t0 = time.time()
    communities = nx_louvain(G, resolution=resolution, seed=42)
    print(f"  -> {len(communities):,} communities in {time.time()-t0:.0f}s")

    cui_to_community = {}
    for i, comm in enumerate(communities):
        for cui in comm:
            cui_to_community[cui] = i
    return cui_to_community, communities


# ============================================================================
# Step 3: Label communities by dominant STY + size
# ============================================================================

def label_communities(communities, tags):
    """
    For each community, find the most common STY among its members.
    This gives each topic a human-meaningful label.
    """
    print(f"[3/4] Labeling communities by dominant STY ...")
    community_info = {}
    for i, comm in enumerate(communities):
        sty_counts = Counter()
        for cui in comm:
            for sty in tags.get(cui, frozenset()):
                sty_counts[sty] += 1
        if sty_counts:
            top_sty, top_n = sty_counts.most_common(1)[0]
            purity = top_n / len(comm)
        else:
            top_sty = None
            purity = 0.0
        community_info[i] = {
            "size": len(comm),
            "dominant_sty": top_sty,
            "sty_purity": purity,
            "sty_distribution": dict(sty_counts.most_common(5)),
        }
    return community_info


# ============================================================================
# Step 4: Build topic-id mapping (stable hash on community_id)
# ============================================================================

def make_topic_id(community_id):
    """Generate a stable topic_id for a community."""
    return f"tp_{community_id:06d}"


def build_topic_mappings(cui_to_community, communities, community_info):
    print(f"[4/4] Building topic mappings ...")
    cui_topic_id = {cui: make_topic_id(cid) for cui, cid in cui_to_community.items()}
    topic_to_cuis = {make_topic_id(i): set(comm) for i, comm in enumerate(communities)}
    topic_info = {make_topic_id(i): info for i, info in community_info.items()}
    return cui_topic_id, topic_to_cuis, topic_info


# ============================================================================
# Report
# ============================================================================

def report(cui_topic_id, topic_to_cuis, topic_info, snomed_cuis, labels=None):
    print(f"\n{'='*78}")
    print(f"  RESULTS")
    print(f"{'='*78}")
    n_total = len(snomed_cuis)
    n_with_topic = len(cui_topic_id)
    n_topics = len(topic_to_cuis)
    print(f"  Total SNOMED CUIs       : {n_total:,}")
    print(f"  CUIs with topic         : {n_with_topic:,} ({100*n_with_topic/n_total:.1f}%)")
    print(f"  Total topics            : {n_topics:,}")

    sizes = [info["size"] for info in topic_info.values()]
    sizes.sort()
    print(f"\n  Topic size distribution:")
    print(f"    min     : {sizes[0]}")
    print(f"    median  : {sizes[len(sizes)//2]}")
    print(f"    mean    : {statistics.mean(sizes):.0f}")
    print(f"    p90     : {sizes[int(0.9*len(sizes))]}")
    print(f"    p99     : {sizes[int(0.99*len(sizes))]}")
    print(f"    max     : {sizes[-1]:,}")

    # Top 20 largest topics with their dominant STY
    print(f"\n  Top 20 largest topics:")
    top = sorted(topic_info.items(), key=lambda kv: -kv[1]["size"])[:20]
    for tid, info in top:
        sty = info["dominant_sty"] or "?"
        print(f"    {tid}  size={info['size']:>6,d}  "
              f"sty={sty}  purity={info['sty_purity']:.0%}")

    # Spot-check: a few focal CUIs
    focal = [
        "C0032285", "C0021368", "C0024109", "C1527304", "C0559470",
        "C0002792", "C2142181", "C0011849",
    ]
    print(f"\n  Focal CUI lookups:")
    for cui in focal:
        tid = cui_topic_id.get(cui)
        if tid is None:
            print(f"    {cui}: not in any topic")
            continue
        info = topic_info[tid]
        sty = info["dominant_sty"] or "?"
        lbl = labels.get(cui, "?") if labels else "?"
        print(f"    {cui} '{lbl[:30]}': {tid} "
              f"(size={info['size']}, dom_sty={sty}, purity={info['sty_purity']:.0%})")


# ============================================================================
# Main
# ============================================================================

def main():
    for v in ["data", "SNOMED_CUIS", "TAGS"]:
        if v not in globals():
            raise RuntimeError(f"Set '{v}' in notebook before running this")
    tags = normalize_tags(TAGS)
    labels = LABELS if "LABELS" in globals() else None

    print("=" * 60)
    print("Final topic build from network graph")
    print("=" * 60)
    print(f"  Graph       : {data.number_of_nodes():,} nodes, {data.number_of_edges():,} edges")
    print(f"  SNOMED CUIs : {len(SNOMED_CUIS):,}")
    print(f"  Resolution  : {LOUVAIN_RESOLUTION}")

    neighbors = flatten_graph(data, SNOMED_CUIS)
    cui_to_community, communities = louvain_communities(
        neighbors, SNOMED_CUIS, LOUVAIN_RESOLUTION,
    )
    community_info = label_communities(communities, tags)
    cui_topic_id, topic_to_cuis, topic_info = build_topic_mappings(
        cui_to_community, communities, community_info,
    )
    report(cui_topic_id, topic_to_cuis, topic_info, SNOMED_CUIS, labels)

    print(f"\n[Saving] {OUTPUT_PATH}")
    payload = {
        "built_at":            datetime.datetime.now().isoformat(),
        "source":              "network graph (team-provided)",
        "louvain_resolution":  LOUVAIN_RESOLUTION,
        # Core: CUI -> topic_id, topic_id -> set of CUIs
        "cui_topic_id":        cui_topic_id,
        "topic_to_cuis":       topic_to_cuis,
        "topic_info":          topic_info,   # size, dominant_sty, purity per topic
        # Auxiliary
        "snomed_cuis":         SNOMED_CUIS,
        "flattened_neighbors": neighbors,   # for graph-based lookups at retrieval time
        "tags":                tags,
    }
    if labels:
        payload["labels"] = labels

    with open(OUTPUT_PATH, "wb") as f:
        pickle.dump(payload, f, protocol=pickle.HIGHEST_PROTOCOL)
    size_mb = os.path.getsize(OUTPUT_PATH) / 1024 / 1024
    print(f"  wrote {size_mb:.1f} MB")
    print("\nDONE")


main()

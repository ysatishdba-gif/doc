"""
test_subtopics.py
-----------------
Test sub-topics. Just change CUIS_TO_TEST below.

Paste in a notebook cell after build_subtopics.py has finished.
"""

import pickle


PICKLE_PATH = "topic_lookup_subtopics.pkl"

# Add or remove CUIs here — that's all you need to change
CUIS_TO_TEST = [
    "C0032285",  # Pneumonia
    "C0021368",  # Inflammation
    "C0024109",  # Lung
    "C0011849",  # Diabetes mellitus
    "C1527304",  # Allergic reaction
    "C0559470",  # Allergy to peanut
    "C0002792",  # Anaphylaxis
    "C0013182",  # Allergy to drug
    "C2142181",  # Pain of left knee joint
    "C1621958",  # Glioblastoma multiforme
]


# ============================================================================
# Load
# ============================================================================

print(f"Loading {PICKLE_PATH} ...")
with open(PICKLE_PATH, "rb") as f:
    payload = pickle.load(f)

topic_to_cuis = payload["topic_to_cuis"]
sub_components = payload["cui_subtopics_components"]
sub_cliques    = payload["cui_subtopics_cliques"]
labels         = payload.get("labels", {})


def lbl(c):
    return labels.get(c, "?")[:40] if labels else "?"


# ============================================================================
# Print
# ============================================================================

for cui in CUIS_TO_TEST:
    main_members = topic_to_cuis.get(cui, set())
    comps        = sub_components.get(cui, [])
    cliques      = sub_cliques.get(cui, [])

    print(f"\n{'='*80}")
    print(f"  {cui}  '{lbl(cui)}'")
    print(f"{'='*80}")
    print(f"  Main topic size : {len(main_members)}")
    print(f"  # components    : {len(comps)}")
    print(f"  # cliques       : {len(cliques)}")

    # Components (Method A — exclusive partition)
    print(f"\n  COMPONENTS (Method A):")
    if not comps:
        print(f"    (none)")
    for i, c in enumerate(comps):
        print(f"    Component {i+1} (size {len(c)}):")
        for m in sorted(c):
            marker = " <-- self" if m == cui else ""
            print(f"      {m}  '{lbl(m)}'{marker}")

    # Cliques (Method B — overlapping)
    print(f"\n  CLIQUES (Method B):")
    if not cliques:
        print(f"    (none)")
    # Sort cliques by size descending
    sorted_cliques = sorted(cliques, key=lambda s: -len(s))
    for i, c in enumerate(sorted_cliques):
        contains_self = " (contains self)" if cui in c else ""
        print(f"    Clique {i+1} (size {len(c)}){contains_self}:")
        for m in sorted(c):
            marker = " <-- self" if m == cui else ""
            print(f"      {m}  '{lbl(m)}'{marker}")

print("\n\nDONE")

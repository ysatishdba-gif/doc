"""
inspect_isa_subgroups.py
------------------------
Show IS-A subgroups for sample CUIs.

For each CUI:
  - Its main topic members (from network graph)
  - The IS-A subgroups within the topic (anchored by topic members)
  - Members ungrouped (no IS-A relation to other members)
"""

import pickle

PKL_PATH = "topic_with_isa_subgroups.pkl"

CUIS = [
    "C0032285",  # Pneumonia
    "C0011849",  # Diabetes mellitus
    "C0021368",  # Inflammation
    "C0024109",  # Lung
    "C2142181",  # Pain of left knee joint
    "C0559470",  # Allergy to peanut
    "C0013182",  # Allergy to drug
    "C0002792",  # Anaphylaxis
]


with open(PKL_PATH, "rb") as f:
    p = pickle.load(f)

topic_to_cuis     = p["topic_to_cuis"]
isa_subgroups     = p["isa_subgroups"]
ungrouped_members = p["ungrouped_members"]
labels            = p.get("labels", {})


def lbl(c):
    return labels.get(c, "?")


for cui in CUIS:
    print(f"\n{'='*90}")
    print(f"  {cui}  '{lbl(cui)}'")
    print(f"{'='*90}")

    members = topic_to_cuis.get(cui, frozenset())
    print(f"  Main topic size: {len(members)}")

    subgroups = isa_subgroups.get(cui, {})
    ungrouped = ungrouped_members.get(cui, frozenset())

    print(f"  IS-A subgroups : {len(subgroups)}")
    print(f"  Ungrouped      : {len(ungrouped)} members\n")

    # Larger subgroups first
    sorted_groups = sorted(subgroups.items(), key=lambda kv: -len(kv[1]))
    for anchor, mems in sorted_groups:
        anchor_mark = " <-- topic anchor (self)" if anchor == cui else ""
        print(f"  SUBGROUP anchored by: {anchor}  '{lbl(anchor)}'{anchor_mark}")
        for m in sorted(mems):
            if m == anchor:
                role = " (anchor)"
            elif m == cui:
                role = " (focal CUI of topic)"
            else:
                role = ""
            print(f"    {m}  '{lbl(m)}'{role}")
        print()

    if ungrouped:
        print(f"  UNGROUPED (no IS-A relation to other topic members):")
        for m in sorted(ungrouped):
            role = " (focal CUI of topic)" if m == cui else ""
            print(f"    {m}  '{lbl(m)}'{role}")

print("\nDONE")

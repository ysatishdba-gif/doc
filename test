"""
test_all_cliques.py
-------------------
Test the all-cliques sub-topic build. Loads topic_lookup_all_cliques.pkl.
Edit CUIS_TO_TEST as needed.

Shows size breakdown (size-2 vs size-3+) per CUI so you can see how
much leaf-CUI precision was added back.
"""

import pickle
from collections import Counter


PICKLE_PATH = "topic_lookup_all_cliques.pkl"

CUIS_TO_TEST = [
    "C0032285",  # Pneumonia
    "C0021368",  # Inflammation
    "C0024109",  # Lung
    "C0011849",  # Diabetes
    "C1527304",  # Allergic reaction
    "C0559470",  # Allergy to peanut
    "C0002792",  # Anaphylaxis
    "C0013182",  # Allergy to drug    <-- the big test, was only 3 size-3+ subs
    "C2142181",  # Pain of left knee joint
    "C1621958",  # Glioblastoma multiforme
    "C0016470",  # Food allergy
]


print(f"Loading {PICKLE_PATH} ...")
with open(PICKLE_PATH, "rb") as f:
    p = pickle.load(f)

topic_to_cuis              = p["topic_to_cuis"]
main_topic_to_subtopic_ids = p["main_topic_to_subtopic_ids"]
subtopic_id_to_cuis        = p["subtopic_id_to_cuis"]
subtopic_id_to_main_topics = p["subtopic_id_to_main_topics"]
cui_to_subtopic_ids        = p["cui_to_subtopic_ids"]
subtopic_metadata          = p["subtopic_metadata"]
labels                     = p.get("labels", {})


def lbl(c):
    return labels.get(c, "?")[:42] if labels else "?"


print(f"  Main topics                     : {len(topic_to_cuis):,}")
print(f"  Unique sub-topics (size>=2)     : {len(subtopic_id_to_cuis):,}")
print(f"  Ratio                           : "
      f"{len(subtopic_id_to_cuis)/max(len(topic_to_cuis),1):.2f} "
      f"sub-topics per main topic")

# Summary table
print(f"\n\n{'='*90}")
print(f"  SUMMARY TABLE")
print(f"{'='*90}")
print(f"  {'CUI':<12s}  {'Label':<28s}  {'Main':>5s}  {'Subs':>5s}  "
      f"{'sz2':>5s}  {'sz3+':>5s}")

for cui in CUIS_TO_TEST:
    main_sz = len(topic_to_cuis.get(cui, set()))
    own = list(dict.fromkeys(main_topic_to_subtopic_ids.get(cui, [])))
    sz2 = sum(1 for s in own if subtopic_metadata[s]["size"] == 2)
    sz3plus = sum(1 for s in own if subtopic_metadata[s]["size"] >= 3)
    print(f"  {cui:<12s}  {lbl(cui)[:28]:<28s}  "
          f"{main_sz:>5d}  {len(own):>5d}  {sz2:>5d}  {sz3plus:>5d}")


# Detailed per CUI
for cui in CUIS_TO_TEST:
    print(f"\n\n{'='*80}")
    print(f"  {cui}  '{lbl(cui)}'")
    print(f"{'='*80}")

    main_members = topic_to_cuis.get(cui, set())
    print(f"  Main topic size: {len(main_members)}")

    own = list(dict.fromkeys(main_topic_to_subtopic_ids.get(cui, [])))
    print(f"  Sub-topics in this main topic: {len(own)}")

    if not own:
        print(f"    (none — main topic < 2 members or no edges)")
        continue

    # Size distribution
    by_size = Counter(subtopic_metadata[s]["size"] for s in own)
    print(f"  Size breakdown:")
    for size in sorted(by_size):
        print(f"    size {size:>3d}: {by_size[size]} sub-topics")

    # Show the largest 4 sub-topics
    own_sorted = sorted(own, key=lambda s: -subtopic_metadata[s]["size"])
    print(f"\n  Largest 4 sub-topics:")
    for sid in own_sorted[:4]:
        meta = subtopic_metadata[sid]
        members = subtopic_id_to_cuis[sid]
        print(f"\n    {sid} (size {meta['size']}):")
        for m in sorted(members):
            marker = " <-- self" if m == cui else ""
            print(f"      {m}  '{lbl(m)}'{marker}")

    # If there are size-2 sub-topics, show a few examples
    sz2_subs = [s for s in own_sorted if subtopic_metadata[s]["size"] == 2]
    if sz2_subs:
        print(f"\n  Sample size-2 sub-topics (showing first 3):")
        for sid in sz2_subs[:3]:
            members = subtopic_id_to_cuis[sid]
            other = [m for m in members if m != cui]
            other_str = ", ".join(f"'{lbl(o)}'" for o in other)
            print(f"    {sid}: self + {other_str}")


print("\n\nDONE")

"""
build_isa_subgroups.py
----------------------
For each main topic from the network graph, find IS-A subgroups WITHIN
the topic's own members.

Each subgroup is anchored by a TOPIC MEMBER that has other topic members
as its IS-A descendants (within the topic). No external ancestor CUIs are
introduced — every subgroup label is a CUI already in the topic.

Inputs:
  topic_lookup.pkl   : has topic_to_cuis (main topics from network graph)
  rollup_index.pkl   : has isa_parents (IS-A DAG from MRREL)

Output:
  topic_with_isa_subgroups.pkl

Rules:

  For each main topic T with members M (|M| >= 2):
    1. For each member m in M, compute m's transitive IS-A ancestor closure
       (set of all ancestors of m anywhere in the IS-A DAG).
    2. For each member a in M, define a's subgroup as:
         {x in M : a in ancestor_closure(x)}
       i.e., all topic members that have `a` as a transitive IS-A ancestor.
    3. Keep a's subgroup only if it contains >= 2 members (including a).
       Otherwise a is not an "anchor."
    4. Members not appearing as a descendant of any anchor in M go in the
       "ungrouped" bucket for this topic.

  Members can appear in multiple subgroups (one per anchor they descend
  from within the topic). Allowed by design.

Output structure:
  topic_to_cuis                   : carried through
  isa_subgroups                   : main_topic_cui -> {anchor_cui: frozenset(members)}
  isa_subgroup_index              : (main_topic_cui, anchor_cui) -> frozenset
  ungrouped_members               : main_topic_cui -> frozenset(members)
  cui_to_subgroup_anchors         : cui -> set of (main_topic, anchor) pairs
  config                          : build settings
"""

import pickle
import datetime
import time
import os
from collections import defaultdict


TOPIC_PATH  = "topic_lookup.pkl"
ROLLUP_PATH = "rollup_index.pkl"
OUTPUT_PATH = "topic_with_isa_subgroups.pkl"


# ============================================================================
# Ancestor closure (memoized)
# ============================================================================

def compute_ancestor_closure(cui, isa_parents, cache):
    """All transitive IS-A ancestors of `cui` (memoized).
    Pure graph walk on the IS-A DAG.
    """
    if cui in cache:
        return cache[cui]
    ancestors = set()
    stack = [cui]
    visited = set()
    while stack:
        node = stack.pop()
        if node in visited:
            continue
        visited.add(node)
        for p in isa_parents.get(node, set()):
            if p not in ancestors:
                ancestors.add(p)
                stack.append(p)
    cache[cui] = frozenset(ancestors)
    return cache[cui]


# ============================================================================
# Main
# ============================================================================

def main():
    print(f"BUILD START — {datetime.datetime.now().isoformat()}")
    t_total = time.time()

    print(f"\n[1] Load inputs")
    print(f"  Loading {TOPIC_PATH} ...")
    with open(TOPIC_PATH, "rb") as f:
        topic_pkl = pickle.load(f)
    topic_to_cuis = topic_pkl["topic_to_cuis"]
    labels        = topic_pkl.get("labels", {})
    print(f"    main topics: {len(topic_to_cuis):,}")

    print(f"  Loading {ROLLUP_PATH} ...")
    with open(ROLLUP_PATH, "rb") as f:
        rollup_pkl = pickle.load(f)
    isa_parents = rollup_pkl["isa_parents"]
    print(f"    CUIs with IS-A parents: {len(isa_parents):,}")

    # ========================================================================
    # [2] For each main topic, build subgroups using only its own members
    # ========================================================================

    print(f"\n[2] Build IS-A subgroups within each main topic")
    print(f"    Rule: each subgroup is anchored by a TOPIC MEMBER whose")
    print(f"    IS-A descendants (also in topic) form the subgroup.")
    t0 = time.time()

    closure_cache = {}
    isa_subgroups            = {}
    ungrouped_members        = {}
    cui_to_subgroup_anchors  = defaultdict(set)
    n_topics_with_subgroups  = 0
    total_subgroups          = 0
    total_members_grouped    = 0
    total_members_ungrouped  = 0

    for i, (main_topic, members) in enumerate(topic_to_cuis.items()):
        if i % 50000 == 0 and i > 0:
            print(f"    {i:,}/{len(topic_to_cuis):,} ({time.time()-t0:.0f}s)")

        if len(members) < 2:
            ungrouped_members[main_topic] = frozenset(members)
            continue

        # Closure of each member, restricted to the topic
        # (we only care about ancestors that ARE topic members)
        member_set = set(members)
        descendants_per_anchor = defaultdict(set)  # anchor -> set of descendants in topic

        for m in members:
            closure = compute_ancestor_closure(m, isa_parents, closure_cache)
            # Anchors in this topic = closure ∩ topic members (excluding m itself)
            for anc in closure & member_set:
                if anc != m:
                    descendants_per_anchor[anc].add(m)

        # An anchor's subgroup = {anchor} ∪ descendants (within topic)
        # Keep only if size >= 2 (anchor + at least 1 descendant)
        valid_subgroups = {}
        for anchor, descendants in descendants_per_anchor.items():
            if not descendants:
                continue
            subgroup = frozenset({anchor} | descendants)
            valid_subgroups[anchor] = subgroup

        if valid_subgroups:
            isa_subgroups[main_topic] = valid_subgroups
            n_topics_with_subgroups += 1
            total_subgroups += len(valid_subgroups)

            grouped_in_topic = set()
            for anchor, sub in valid_subgroups.items():
                grouped_in_topic |= sub
                for m in sub:
                    cui_to_subgroup_anchors[m].add((main_topic, anchor))

            ungrouped = set(members) - grouped_in_topic
            if ungrouped:
                ungrouped_members[main_topic] = frozenset(ungrouped)
            total_members_grouped   += len(grouped_in_topic)
            total_members_ungrouped += len(ungrouped)
        else:
            ungrouped_members[main_topic] = frozenset(members)
            total_members_ungrouped += len(members)

    print(f"    Done in {time.time()-t0:.0f}s")
    print(f"\n  Stats:")
    print(f"    Main topics                       : {len(topic_to_cuis):,}")
    print(f"    Topics with >=1 IS-A subgroup     : {n_topics_with_subgroups:,}")
    print(f"    Total IS-A subgroups across topics: {total_subgroups:,}")
    print(f"    Members grouped (across topics)   : {total_members_grouped:,}")
    print(f"    Members ungrouped (across topics) : {total_members_ungrouped:,}")
    print(f"    Closure cache size                : {len(closure_cache):,}")

    if total_subgroups:
        sizes = []
        for subgroups in isa_subgroups.values():
            for mems in subgroups.values():
                sizes.append(len(mems))
        sizes.sort()
        print(f"\n    IS-A subgroup size distribution:")
        print(f"      min/median/p90/p99/max : "
              f"{sizes[0]} / {sizes[len(sizes)//2]} / "
              f"{sizes[int(0.9*len(sizes))]} / {sizes[int(0.99*len(sizes))]} / "
              f"{sizes[-1]}")

    # ========================================================================
    # [3] Flat lookup index
    # ========================================================================

    print(f"\n[3] Build flat lookup index")
    isa_subgroup_index = {}
    for main_topic, subgroups in isa_subgroups.items():
        for anchor, mems in subgroups.items():
            isa_subgroup_index[(main_topic, anchor)] = mems
    print(f"    Flat entries: {len(isa_subgroup_index):,}")

    # ========================================================================
    # [4] Save
    # ========================================================================

    print(f"\n[4] Save to {OUTPUT_PATH}")
    payload = {
        "topic_to_cuis":            topic_to_cuis,
        "labels":                   labels,
        "isa_subgroups":            isa_subgroups,
        "isa_subgroup_index":       isa_subgroup_index,
        "ungrouped_members":        ungrouped_members,
        "cui_to_subgroup_anchors":  dict(cui_to_subgroup_anchors),
        "config": {
            "subgroup_rule":            "anchored by topic members only",
            "min_subgroup_size":         2,
            "members_in_multiple_subgroups_allowed": True,
            "source_topic_lookup":       TOPIC_PATH,
            "source_rollup":             ROLLUP_PATH,
        },
        "built_at": datetime.datetime.now().isoformat(),
    }
    with open(OUTPUT_PATH, "wb") as f:
        pickle.dump(payload, f, protocol=pickle.HIGHEST_PROTOCOL)
    size_mb = os.path.getsize(OUTPUT_PATH) / 1024 / 1024
    print(f"    Wrote {size_mb:.1f} MB")

    print(f"\nTOTAL: {time.time()-t_total:.0f}s")
    print(f"DONE — {datetime.datetime.now().isoformat()}")


main()

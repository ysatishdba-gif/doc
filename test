"""
step2_sample.py — instrumented, runnable sample of map_temporal_to_norm_class_step2.

It shows EVERY intermediate stage with prints so you can see the temporal match flow:
  your NB temporal phrases
    -> candidate concept list (from the temporal vocab/formula file)
    -> not100_match_temporal   (phrase -> all candidates, the var you asked about)
    -> per-phrase LLM selection ("the new phrase")
    -> matched concept name -> CUI

It fixes the things that stop the repo version from running:
  * original `list(executor.map(..., total=...))` -> TypeError (total= is not valid here)
  * no utils.py in the repo, and config.py is missing project_id/location/bucket/
    gemini_model -> both are provided inline below
  * config now points temporal_norm_code_json at the FORMULA file
    ({has_formula, no_formula}); this reads that shape AND the old vocab shape
  * the `!= 'None'` string check (a real JSON null slipped through) and the
    `[...][0]` reverse-lookup IndexError

USAGE: fill in the CONFIG block, then `python step2_sample.py`
Requires google-genai + google-cloud-storage and ADC creds (gcloud auth ...).
"""

import json
import re
from google import genai
from google.cloud import storage

# ───────────────────────────── CONFIG (fill in) ─────────────────────────────
PROJECT_ID   = ""        # e.g. "my-gcp-project"   (was MISSING from config.py)
LOCATION     = "us-central1"
BUCKET       = ""        # your GCS bucket          (was MISSING from config.py)
GEMINI_MODEL = "gemini-2.5-flash"

CUI_DICT_PATH       = "cui_def_dict/cui_definitions.json"
TEMPORAL_VOCAB_PATH = "Normalized_loinc_classes/temporal_norm_code_to_formula.json"
NB_RESULTS_PATH     = "Nature_breakdown/DT-nature-breakdown/epic-cohort-analysis.json"

# ───────────────────────────── SAMPLE LIMITS ─────────────────────────────
# Keep the run small and cheap. Set to None to use everything (production-like).
MAX_PHRASES       = 5      # how many of YOUR temporal phrases to actually match
MAX_CANDIDATES    = 300    # cap candidate concepts per call (full list ~5.6k)
SHOW_FULL_PROMPT  = False   # True -> print the entire prompt for each call
RUN_UMLS_FALLBACK = False   # 2nd-tier UMLS pass (extra calls); off for the sample
# ──────────────────────────────────────────────────────────────────────────

STATE_WORDS = ['YYYY-MM-DD to YYYY-MM-DD', 'acute', 'established',
               'chronic', 'resolved', 'initial']


# ---- helpers the repo expects from utils.py (provided here) ----
def read_json_from_gcs(project_id, blob_path, bucket):
    client = storage.Client(project=project_id)
    blob = client.bucket(bucket).blob(blob_path)
    return json.loads(blob.download_as_text())


def get_cui_dict(project_id, bucket, cui_dict_path):
    cui_dict = read_json_from_gcs(project_id, cui_dict_path, bucket)   # {cui: name}
    name_to_cui = {name: cui for cui, name in cui_dict.items()}
    return cui_dict, name_to_cui


# ---- the matching prompt + response schema, lifted verbatim from step2 ----
def get_genai_temporal_payload(temporal_type_name, transactions):
    temp_payload = f""" I have a temporal type name mentioned between <temporal type name> and <temporal type name>. 
            I have a list of transactions mentioned between <transactions> and <transactions> where each transaction has two elements. The first element is the id of the temporal class
            and the second element is the temporal class name. Your task is to identify a single temporal class that is the most closely aligned and hence a best choice/match compared to all other temporal classes
            to the temporal type name. ** It is critical to select only one temporal class and if no temporal class is considered to be the best choice then return None ** The output must be a dictionary with the best choice temporal class id, its name, and the reason
            for choosing that temporal class.
            <temporal type name> {temporal_type_name} <temporal type name>
            <transactions> {transactions} <transactions>

            * Examples *
            ** input **
            temporal type name = 'historical'
            transactions = [[id_1, 'Historical'], [id_2, 'Histological type'], ['id_3', 'history']]

            ** output **
            {{"selected_temporal_class_id": 'id_1',
                "selected_temporal_class_name": 'Historical',
                "reasoning": this is the most closest alignment and a best choice with temporal type name amongst other choices
            }}

            ** input **
            temporal type name = 'full history'
            transactions = [[id_1, 'Occupation history'], [id_2, 'disease history'], ['id_3', 'full time history']]

            ** output **
            {{"selected_temporal_class_id": 'id_3',
                "selected_temporal_class_name": 'full time history',
                "reasoning":  this is the most closest alignment and a best choice with temporal type name amongst other choices
            }}

            ** input **
            temporal type name = 'most recent'
            transactions = [[id_1, 'Most recent treponemal test type'], [id_2, 'most recent pregnancy'], ['id_3', 'pre most recent time']]

            ** output **
            {{"selected_temporal_class_id": None,
                "selected_temporal_class_name": None,
                "reasoning":  None of the temporal classes are best choice. 'Most recent treponemal test type' is too specific whereas 'most recent' is general and hence it is also not a best choice.
            }}

            """
    return temp_payload


RESPONSE_SCHEMA = {
    "type": "object",
    "required": ["selected_temporal_class_id", "selected_temporal_class_name", "reasoning"],
    "properties": {
        "selected_temporal_class_id":   {"type": "string"},
        "selected_temporal_class_name": {"type": "string"},
        "reasoning":                    {"type": "string"},
    },
}


def make_gemini_call():
    """Returns a callable prompt -> dict, using real Vertex Gemini."""
    client = genai.Client(vertexai=True, project=PROJECT_ID, location=LOCATION)

    def _call(prompt):
        resp = client.models.generate_content(
            model=GEMINI_MODEL,
            contents=prompt,
            config={"response_mime_type": "application/json",
                    "response_schema": RESPONSE_SCHEMA},
        )
        return json.loads(resp.text)

    return _call


def extract_candidates(vocab):
    """Return (names, name_to_meta, shape_label), handling both file shapes."""
    if isinstance(vocab, dict) and ("has_formula" in vocab or "no_formula" in vocab):
        rows = (vocab.get("has_formula") or []) + (vocab.get("no_formula") or [])
        names, meta = [], {}
        for r in rows:
            n = r.get("name")
            if n:
                names.append(n)
                meta[n] = {"code": r.get("code"),
                           "code_system": r.get("code_system"),
                           "formula": r.get("formula")}
        return names, meta, "FORMULA file ({has_formula, no_formula})"
    if isinstance(vocab, dict) and "loinc_related_temporal_codes" in vocab:
        names = list(vocab["loinc_related_temporal_codes"].values())
        return names, {}, "VOCAB file (loinc_related_temporal_codes)"
    raise ValueError("Unrecognized temporal vocab shape; top keys: " + str(list(vocab)[:6]))


def _no_match(sel_id):
    return sel_id is None or str(sel_id).strip().lower() in ("none", "null", "")


def run_pipeline(cui_dict, name_to_cui, query_results, vocab, gemini_call):
    line = "=" * 74

    # ---- STEP A: inputs ----
    print(line); print("STEP A — INPUTS LOADED"); print(line)
    print(f"cui_dict entries (cui->name)     : {len(cui_dict):,}")
    print(f"name_to_cui entries (name->cui)  : {len(name_to_cui):,}")
    print(f"nature-breakdown records         : {len(query_results):,}")

    # ---- STEP B: candidate concept vocabulary ----
    cand_names, name_to_meta, shape = extract_candidates(vocab)
    cand_names = list(dict.fromkeys(cand_names))   # dedupe, keep order
    print(); print(line); print("STEP B — CANDIDATE TEMPORAL CONCEPTS (match target)"); print(line)
    print(f"vocab file shape detected        : {shape}")
    print(f"unique candidate concept names   : {len(cand_names):,}")
    print(f"sample candidates                : {cand_names[:12]}")

    # ---- STEP C: YOUR temporal phrases from nature breakdown ----
    all_temporal = [q.get("temporal_signals", []) for q in query_results
                    if q.get("is_processable") is True]
    phrases = [t for lst in all_temporal for t in lst]
    phrases = list(set(phrases))
    phrases = [p for p in phrases
               if not re.findall(r"(\d{4}-\d{2}-\d{2}) to (\d{4}-\d{2}-\d{2})", p)
               and p not in STATE_WORDS]
    print(); print(line); print("STEP C — YOUR NB TEMPORAL PHRASES (after filtering)"); print(line)
    print(f"is_processable records used      : {sum(1 for q in query_results if q.get('is_processable') is True):,}")
    print(f"distinct temporal phrases        : {len(phrases):,}")
    print(f"phrases                          : {phrases}")
    if not phrases:
        print("\n!! No temporal phrases found — check is_processable / temporal_signals fields. Stopping.")
        return

    # ---- STEP D: length filter on candidates (mirrors step2) ----
    max_temp_len = max(len(p) for p in phrases)
    before = len(cand_names)
    cand_names = [c for c in cand_names if len(str(c)) <= max_temp_len]
    print(); print(line); print("STEP D — LENGTH FILTER ON CANDIDATES"); print(line)
    print(f"max phrase length                : {max_temp_len}")
    print(f"candidates before -> after filter: {before:,} -> {len(cand_names):,}")

    # ---- STEP E: not100_match_temporal (the variable you wanted to see) ----
    not100 = {" ".join(p.split("_")): [(c, 0) for c in cand_names] for p in phrases}
    print(); print(line); print("STEP E — not100_match_temporal"); print(line)
    print(f"keys (phrases)                   : {len(not100)}")
    any_key = next(iter(not100))
    print(f"candidates per phrase            : {len(not100[any_key])}  (IDENTICAL list for every phrase)")
    print(f"  -> structure: {{phrase: [(concept_name, fuzzy_score=0), ...]}}")
    print(f"  -> for phrase {any_key!r}, first 8 candidates:")
    for c, score in not100[any_key][:8]:
        print(f"        ({c!r}, {score})")
    print("  NOTE: fuzzy score is always 0 (fuzzy disabled) -> the LLM does all the matching.")

    # ---- STEP F: per-phrase LLM selection (sampled + capped) ----
    sample_phrases = list(not100.keys())[:MAX_PHRASES] if MAX_PHRASES else list(not100.keys())
    print(); print(line)
    print(f"STEP F — LLM MATCH  (sampling {len(sample_phrases)} of {len(not100)} phrases, "
          f"candidates capped at {MAX_CANDIDATES})")
    print(line)

    temporal_map = {}   # phrase -> matched concept name
    for i, phrase in enumerate(sample_phrases, 1):
        full = [c for c, _ in not100[phrase]]
        cands = full[:MAX_CANDIDATES] if MAX_CANDIDATES else full
        id_to_name = {f"id_{j+1}": name for j, name in enumerate(cands)}
        transactions = [[f"id_{j+1}", name] for j, name in enumerate(cands)]
        prompt = get_genai_temporal_payload(phrase, transactions)

        print(f"\n--- MATCH {i}/{len(sample_phrases)}: phrase = {phrase!r} ---")
        print(f"    candidates in this call : {len(cands)} (of {len(full)} available)")
        if SHOW_FULL_PROMPT:
            print("    ---- PROMPT ----"); print(prompt); print("    ----------------")
        else:
            print(f"    prompt size (~tokens)   : {len(prompt)//4:,}")

        resp = gemini_call(prompt)
        sel_id   = resp.get("selected_temporal_class_id")
        sel_name = resp.get("selected_temporal_class_name")
        reason   = (resp.get("reasoning") or "")[:140]
        print(f"    LLM selected_id         : {sel_id!r}")
        print(f"    LLM selected_name       : {sel_name!r}")
        print(f"    LLM reasoning           : {reason}")

        if _no_match(sel_id):
            print("    => NO MATCH (None)")
            continue
        name = id_to_name.get(sel_id)
        if name is None:
            print(f"    => id {sel_id!r} not in candidate ids — skipped (guarded, no crash)")
            continue
        temporal_map[phrase] = name
        print(f"    => MATCHED concept name : {name!r}")

    # ---- STEP G: matched map ----
    print(); print(line); print("STEP G — PHRASE -> MATCHED CONCEPT NAME"); print(line)
    print(json.dumps(temporal_map, indent=2) if temporal_map else "(no matches in sample)")

    # ---- STEP H: name -> CUI lookup ----
    print(); print(line); print("STEP H — LOOKUP: concept name -> CUI (+ formula if present)"); print(line)
    use_meta = bool(name_to_meta)
    print(f"lookup source                    : {'formula file (name->code)' if use_meta else 'cui_definitions (name->cui)'}")
    for phrase, name in temporal_map.items():
        if use_meta:
            m = name_to_meta.get(name, {})
            print(f"  {phrase!r:>22}  ->  {name!r:>22}  ->  code={m.get('code')!r}  "
                  f"formula={m.get('formula')!r}  system={m.get('code_system')!r}")
        else:
            print(f"  {phrase!r:>22}  ->  {name!r:>22}  ->  CUI={name_to_cui.get(name)!r}")

    print(); print(line); print("DONE"); print(line)


def main():
    cui_dict, name_to_cui = get_cui_dict(PROJECT_ID, BUCKET, CUI_DICT_PATH)
    query_results = read_json_from_gcs(PROJECT_ID, NB_RESULTS_PATH, BUCKET)
    vocab = read_json_from_gcs(PROJECT_ID, TEMPORAL_VOCAB_PATH, BUCKET)
    run_pipeline(cui_dict, name_to_cui, query_results, vocab, make_gemini_call())


if __name__ == "__main__":
    main()

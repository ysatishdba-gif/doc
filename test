import json
d = json.load(open("temporal_name_to_cui.json"))
names = list(d)
low = {n.lower(): n for n in names}

targets = ["current","present","ongoing","future","planned","anticipated",
           "past","historical","prior","previous","recent","most recent",
           "onset","initial","first","new"]

for t in targets:
    exact = low.get(t)                                    # exact concept, e.g. "Current"
    cui   = d[exact][0]["cui"] if exact else None
    contains = [n for n in names if t in n.lower()][:6]   # concepts containing the word
    print(f"{t:11} exact={str(exact):20} cui={cui}")
    print(f"            competes-> {contains}")

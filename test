"""
trace_topic.py
--------------
Show the per-member anchor decision for one focal CUI's main topic.
Pure IS-A only (matches build_topics.py).

Reads topics_debug.pkl.
"""

import pickle


DEBUG_PATH = "topics_debug.pkl"
MIN_ANCHOR_IC = 0.15


FOCAL_CUIS = [
    "C0032285",  # Pneumonia
    "C0011849",  # Diabetes mellitus
    "C0024109",  # Lung
    "C2142181",  # Pain of left knee joint
    "C0559470",  # Allergy to peanut
    "C0013182",  # Allergy to drug
    "C0002792",  # Anaphylaxis
    "C0007113",  # Rectal cancer  (will be ungrouped — orphan)
    "C0007121",  # Bronchogenic carcinoma  (orphan)
]


with open(DEBUG_PATH, "rb") as f:
    d = pickle.load(f)

neighbors     = d["neighbors"]
isa_parents   = d["isa_parents"]
ic_scores     = d["ic_scores"]
labels        = d["labels"]
canonical_map = d.get("canonical_map", {})


def lbl(c, width=None):
    s = labels.get(c, "?")
    return s[:width].ljust(width) if width else s


_closure = {}
def ancestor_closure(cui):
    if cui in _closure:
        return _closure[cui]
    ancestors = set()
    stack = [cui]
    visited = set()
    while stack:
        node = stack.pop()
        if node in visited:
            continue
        visited.add(node)
        for p in isa_parents.get(node, set()):
            if p not in ancestors:
                ancestors.add(p)
                stack.append(p)
    _closure[cui] = frozenset(ancestors)
    return _closure[cui]


def canonical(c):
    return canonical_map.get(c, c)


def trace(focal):
    can_focal = canonical(focal)
    print(f"\n{'='*110}")
    print(f"FOCAL CUI: {focal}  '{labels.get(focal, '?')}'")
    if can_focal != focal:
        print(f"  Canonicalized to: {can_focal} '{labels.get(can_focal, '?')}'")
    print(f"{'='*110}\n")

    members = {can_focal} | neighbors.get(can_focal, frozenset())
    print(f"Main topic size: {len(members)} canonical members\n")

    if len(members) < 2:
        print("  (too small for anchor selection)")
        return

    n_anchored = 0
    n_no_candidate = 0
    n_ic_filtered = 0

    for m in sorted(members, key=lambda c: -ic_scores.get(c, 0.0)):
        m_ic = ic_scores.get(m, 0.0)
        m_text = f"{m} '{lbl(m,42)}' (IC={m_ic:.3f})"

        closure = ancestor_closure(m)
        in_topic = (closure & members) - {m}

        if not in_topic:
            print(f"  {m_text}")
            print(f"     -> UNGROUPED (no IS-A ancestor in topic)")
            n_no_candidate += 1
            continue

        qualified = {a for a in in_topic
                     if ic_scores.get(a, 0.0) >= MIN_ANCHOR_IC}
        if not qualified:
            best_ic = max(ic_scores.get(a, 0.0) for a in in_topic)
            print(f"  {m_text}")
            print(f"     -> UNGROUPED (all candidates below IC floor "
                  f"{MIN_ANCHOR_IC}; best={best_ic:.3f})")
            n_ic_filtered += 1
            continue

        anchor = max(qualified, key=lambda a: ic_scores.get(a, 0.0))
        anchor_ic = ic_scores.get(anchor, 0.0)
        print(f"  {m_text}")
        print(f"     -> {anchor} '{lbl(anchor,42)}' (IC={anchor_ic:.3f})")
        n_anchored += 1

    print(f"\n  Summary: anchored={n_anchored}, "
          f"ungrouped_no_ancestor={n_no_candidate}, "
          f"ungrouped_ic={n_ic_filtered}")


for cui in FOCAL_CUIS:
    trace(cui)

print(f"\n{'='*110}\nDONE")

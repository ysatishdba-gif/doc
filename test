"""
temporal_match.py — step2's temporal matching, moved in-process as a resolver.

For each generated temporal phrase, an LLM picks the single best normalized
concept NAME from the slim file (temporal_name_to_cui.json), or None — exactly
like map_temporal_to_norm_class_step2.py. The matched name is then looked up to
its codes. Plugs into the pipeline through the TemporalResolver interface:

    resolve(signals) -> [{"signal", "matched_name", "codes": [{"cui","system"}, ...]}]

The slim file is loaded ONCE (from_gcs / from_file); its names are the match
target and its values are the codes. LOINC-vs-UMLS priority is a match-time
concern handled in the prompt (see _build_match_prompt), not in the file.
"""

import json
from typing import Any, Callable, Dict, List, Optional

GeminiCall = Callable[[str], Dict[str, Any]]   # prompt -> parsed JSON dict


# ---- step2 matching prompt (ported verbatim) ----
def _build_match_prompt(temporal_type_name: str, transactions: List[List[str]]) -> str:
    return f""" I have a temporal type name mentioned between <temporal type name> and <temporal type name>. 
            I have a list of transactions mentioned between <transactions> and <transactions> where each transaction has two elements. The first element is the id of the temporal class
            and the second element is the temporal class name. Your task is to identify a single temporal class that is the most closely aligned and hence a best choice/match compared to all other temporal classes
            to the temporal type name. ** It is critical to select only one temporal class and if no temporal class is considered to be the best choice then return None ** The output must be a dictionary with the best choice temporal class id, its name, and the reason
            for choosing that temporal class.
            <temporal type name> {temporal_type_name} <temporal type name>
            <transactions> {transactions} <transactions>

            * Examples *
            ** input **
            temporal type name = 'historical'
            transactions = [[id_1, 'Historical'], [id_2, 'Histological type'], ['id_3', 'history']]

            ** output **
            {{"selected_temporal_class_id": 'id_1',
                "selected_temporal_class_name": 'Historical',
                "reasoning": this is the most closest alignment and a best choice with temporal type name amongst other choices
            }}

            ** input **
            temporal type name = 'full history'
            transactions = [[id_1, 'Occupation history'], [id_2, 'disease history'], ['id_3', 'full time history']]

            ** output **
            {{"selected_temporal_class_id": 'id_3',
                "selected_temporal_class_name": 'full time history',
                "reasoning":  this is the most closest alignment and a best choice with temporal type name amongst other choices
            }}

            ** input **
            temporal type name = 'most recent'
            transactions = [[id_1, 'Most recent treponemal test type'], [id_2, 'most recent pregnancy'], ['id_3', 'pre most recent time']]

            ** output **
            {{"selected_temporal_class_id": None,
                "selected_temporal_class_name": None,
                "reasoning":  None of the temporal classes are best choice. 'Most recent treponemal test type' is too specific whereas 'most recent' is general and hence it is also not a best choice.
            }}

            """


_MATCH_SCHEMA = {
    "type": "object",
    "required": ["selected_temporal_class_id", "selected_temporal_class_name", "reasoning"],
    "properties": {
        "selected_temporal_class_id":   {"type": "string"},
        "selected_temporal_class_name": {"type": "string"},
        "reasoning":                    {"type": "string"},
    },
}


def make_gemini_call(project: str, location: str, model: str) -> GeminiCall:
    """Build a prompt -> dict caller backed by Vertex Gemini (matches the
    pipeline's model settings)."""
    from google import genai

    client = genai.Client(vertexai=True, project=project, location=location)

    def _call(prompt: str) -> Dict[str, Any]:
        resp = client.models.generate_content(
            model=model,
            contents=prompt,
            config={"response_mime_type": "application/json",
                    "response_schema": _MATCH_SCHEMA},
        )
        return json.loads(resp.text)

    return _call


def _is_none(sel_id: Any) -> bool:
    return sel_id is None or str(sel_id).strip().lower() in ("none", "null", "")


class TemporalMatcher:
    """Matches temporal phrases -> normalized concept names + codes.

    name_to_codes is the slim file: { name: [ {"cui","system"}, ... ] }.
    gemini_call is prompt -> parsed-JSON dict (use make_gemini_call()).
    max_candidates optionally caps how many names go into each prompt.
    """

    def __init__(
        self,
        name_to_codes: Dict[str, List[Dict[str, str]]],
        gemini_call: GeminiCall,
        max_candidates: Optional[int] = None,
    ):
        self._map = name_to_codes
        self._names = list(name_to_codes.keys())
        self._call = gemini_call
        self._max = max_candidates

    @classmethod
    def from_file(cls, path: str, gemini_call: GeminiCall, **kw) -> "TemporalMatcher":
        with open(path) as f:
            return cls(json.load(f), gemini_call, **kw)

    @classmethod
    def from_gcs(cls, project: str, bucket: str, blob_path: str,
                 gemini_call: GeminiCall, **kw) -> "TemporalMatcher":
        from google.cloud import storage
        blob = storage.Client(project=project).bucket(bucket).blob(blob_path)
        return cls(json.loads(blob.download_as_text()), gemini_call, **kw)

    def _match_one(self, phrase: str) -> Optional[str]:
        names = self._names[: self._max] if self._max else self._names
        id_to_name = {f"id_{i+1}": n for i, n in enumerate(names)}
        transactions = [[f"id_{i+1}", n] for i, n in enumerate(names)]
        resp = self._call(_build_match_prompt(phrase, transactions))
        sel_id = (resp or {}).get("selected_temporal_class_id")
        if _is_none(sel_id):
            return None
        return id_to_name.get(sel_id)   # None if the model returns an unknown id

    def resolve(self, signals: List[Any]) -> List[Dict[str, Any]]:
        # Match each UNIQUE phrase once, then map results back over the input.
        uniq = list(dict.fromkeys(
            s for s in signals if isinstance(s, str) and s.strip()
        ))
        matched = {p: self._match_one(p) for p in uniq}

        out: List[Dict[str, Any]] = []
        for s in signals:
            name = matched.get(s)
            out.append({
                "signal": s,
                "matched_name": name,
                "codes": list(self._map.get(name, [])) if name else [],
            })
        return out

"""
build_isa_subgroups.py
----------------------
For each main topic from the network graph, form GRANULAR sub-topics
within the topic's own members, using IC-based hierarchy from Step 2.

For each member m in topic T:
  1. Use Step 2's rollup ancestor for m as the candidate anchor.
     (Step 2 already picked the optimal rollup using IC-acceleration
     + min_children rule on the full IS-A DAG.)
  2. If that rollup ancestor is a member of T → use it as m's anchor.
  3. Else fall back: find m's IS-A ancestor closure, pick the highest-IC
     ancestor that IS in T.
  4. If no IS-A ancestor of m is in T → m goes ungrouped.

Each member ends up in ONE primary granular subgroup (the most-specific
anchor available in the topic). A member can also BE the anchor of
another subgroup containing more specific members.

Inputs:
  topic_lookup.pkl   : has topic_to_cuis (main topics from network graph)
  rollup_index.pkl   : has cui_to_rollup_ancestors, ic_scores, isa_parents

Output:
  topic_with_isa_subgroups.pkl

Output structure:
  topic_to_cuis              : carried through
  isa_subgroups              : main_topic_cui -> {anchor_cui: frozenset(members)}
  isa_subgroup_index         : (main_topic_cui, anchor_cui) -> frozenset
  ungrouped_members          : main_topic_cui -> frozenset(members)
  cui_to_primary_anchor      : (main_topic_cui, cui) -> anchor_cui
                               tells what anchor each member uses in each topic
  config                     : build settings
"""

import pickle
import datetime
import time
import os
from collections import defaultdict


TOPIC_PATH  = "topic_lookup.pkl"
ROLLUP_PATH = "rollup_index.pkl"
OUTPUT_PATH = "topic_with_isa_subgroups.pkl"


# ============================================================================
# Ancestor closure (memoized) — used only when Step 2 rollup not in topic
# ============================================================================

def compute_ancestor_closure(cui, isa_parents, cache):
    """All transitive IS-A ancestors of `cui` (memoized).
    Pure graph walk."""
    if cui in cache:
        return cache[cui]
    ancestors = set()
    stack = [cui]
    visited = set()
    while stack:
        node = stack.pop()
        if node in visited:
            continue
        visited.add(node)
        for p in isa_parents.get(node, set()):
            if p not in ancestors:
                ancestors.add(p)
                stack.append(p)
    cache[cui] = frozenset(ancestors)
    return cache[cui]


# ============================================================================
# Main
# ============================================================================

def main():
    print(f"BUILD START — {datetime.datetime.now().isoformat()}")
    t_total = time.time()

    print(f"\n[1] Load inputs")
    with open(TOPIC_PATH, "rb") as f:
        topic_pkl = pickle.load(f)
    topic_to_cuis = topic_pkl["topic_to_cuis"]
    labels        = topic_pkl.get("labels", {})
    print(f"  topic_lookup.pkl: {len(topic_to_cuis):,} main topics")

    with open(ROLLUP_PATH, "rb") as f:
        rollup_pkl = pickle.load(f)
    cui_to_rollup = rollup_pkl["cui_to_rollup_ancestors"]
    ic_scores     = rollup_pkl["ic_scores"]
    isa_parents   = rollup_pkl["isa_parents"]
    print(f"  rollup_index.pkl: {len(cui_to_rollup):,} CUIs with rollup")
    print(f"    ic_scores      : {len(ic_scores):,}")
    print(f"    isa_parents    : {len(isa_parents):,}")

    # ========================================================================
    # [2] For each main topic, assign each member to its primary anchor
    # ========================================================================

    print(f"\n[2] Form granular subgroups per main topic")
    print(f"    Rule per member m in topic T:")
    print(f"      1. If Step 2's rollup ancestor of m is in T -> use it")
    print(f"         (pick highest-IC if multiple rollups in T)")
    print(f"      2. Else find m's IS-A ancestors in T,")
    print(f"         pick highest-IC one")
    print(f"      3. Else m goes ungrouped")
    t0 = time.time()

    closure_cache = {}
    isa_subgroups            = {}
    ungrouped_members        = {}
    cui_to_primary_anchor    = {}   # (main_topic_cui, cui) -> anchor_cui
    n_topics_with_subgroups  = 0
    total_subgroups          = 0
    total_members_grouped    = 0
    total_members_ungrouped  = 0
    n_via_rollup             = 0
    n_via_fallback           = 0

    for i, (main_topic, members) in enumerate(topic_to_cuis.items()):
        if i % 50000 == 0 and i > 0:
            print(f"    {i:,}/{len(topic_to_cuis):,} ({time.time()-t0:.0f}s)")

        if len(members) < 2:
            ungrouped_members[main_topic] = frozenset(members)
            continue

        member_set = set(members)

        # Find anchor per member
        member_to_anchor = {}
        for m in members:
            # Try Step 2's rollup ancestors first
            rollup_ancestors = cui_to_rollup.get(m, frozenset({m}))
            rollup_in_topic = (rollup_ancestors & member_set) - {m}

            if rollup_in_topic:
                # Pick highest-IC rollup ancestor that's in topic
                anchor = max(rollup_in_topic,
                             key=lambda a: ic_scores.get(a, 0.0))
                member_to_anchor[m] = anchor
                n_via_rollup += 1
                continue

            # Fallback: full IS-A ancestor closure
            closure = compute_ancestor_closure(m, isa_parents, closure_cache)
            closure_in_topic = closure & member_set
            if closure_in_topic:
                anchor = max(closure_in_topic,
                             key=lambda a: ic_scores.get(a, 0.0))
                member_to_anchor[m] = anchor
                n_via_fallback += 1

        # Form subgroups: anchor -> {anchor + members anchored here}
        subgroups = defaultdict(set)
        for m, anchor in member_to_anchor.items():
            subgroups[anchor].add(m)
            subgroups[anchor].add(anchor)  # include the anchor itself

        # Frozenset the subgroups
        subgroups = {a: frozenset(s) for a, s in subgroups.items()}

        if subgroups:
            isa_subgroups[main_topic] = subgroups
            n_topics_with_subgroups += 1
            total_subgroups += len(subgroups)

            grouped = set()
            for s in subgroups.values():
                grouped |= s
            for m, anchor in member_to_anchor.items():
                cui_to_primary_anchor[(main_topic, m)] = anchor

            ungrouped = member_set - grouped
            if ungrouped:
                ungrouped_members[main_topic] = frozenset(ungrouped)
            total_members_grouped   += len(grouped)
            total_members_ungrouped += len(ungrouped)
        else:
            ungrouped_members[main_topic] = frozenset(members)
            total_members_ungrouped += len(members)

    print(f"\n  Done in {time.time()-t0:.0f}s")
    print(f"\n  Stats:")
    print(f"    Main topics                            : {len(topic_to_cuis):,}")
    print(f"    Topics with >=1 IS-A subgroup          : "
          f"{n_topics_with_subgroups:,}")
    print(f"    Total subgroups across topics          : {total_subgroups:,}")
    print(f"    Members grouped (across topics)        : "
          f"{total_members_grouped:,}")
    print(f"    Members ungrouped (across topics)      : "
          f"{total_members_ungrouped:,}")
    print(f"    Anchors via Step-2 rollup directly     : {n_via_rollup:,}")
    print(f"    Anchors via fallback (closure search)  : {n_via_fallback:,}")
    print(f"    Closure cache size                     : {len(closure_cache):,}")

    if total_subgroups:
        sizes = []
        for sg in isa_subgroups.values():
            for mems in sg.values():
                sizes.append(len(mems))
        sizes.sort()
        print(f"\n    Subgroup size distribution:")
        print(f"      min/median/p90/p99/max : "
              f"{sizes[0]} / {sizes[len(sizes)//2]} / "
              f"{sizes[int(0.9*len(sizes))]} / {sizes[int(0.99*len(sizes))]} / "
              f"{sizes[-1]}")

    # ========================================================================
    # [3] Flat lookup index
    # ========================================================================

    print(f"\n[3] Build flat lookup index")
    isa_subgroup_index = {}
    for main_topic, sg in isa_subgroups.items():
        for anchor, mems in sg.items():
            isa_subgroup_index[(main_topic, anchor)] = mems
    print(f"    Flat entries: {len(isa_subgroup_index):,}")

    # ========================================================================
    # [4] Save
    # ========================================================================

    print(f"\n[4] Save to {OUTPUT_PATH}")
    payload = {
        "topic_to_cuis":           topic_to_cuis,
        "labels":                  labels,
        "isa_subgroups":           isa_subgroups,
        "isa_subgroup_index":      isa_subgroup_index,
        "ungrouped_members":       ungrouped_members,
        "cui_to_primary_anchor":   cui_to_primary_anchor,
        "config": {
            "anchor_rule":  "Step-2 rollup ancestor if in topic; "
                            "else highest-IC IS-A ancestor in topic",
            "one_anchor_per_member": True,
            "anchors_can_also_be_members_of_other_subgroups": True,
            "uses_ic_scores":         True,
            "uses_step2_rollup":      True,
            "source_topic_lookup":    TOPIC_PATH,
            "source_rollup":          ROLLUP_PATH,
        },
        "built_at": datetime.datetime.now().isoformat(),
    }
    with open(OUTPUT_PATH, "wb") as f:
        pickle.dump(payload, f, protocol=pickle.HIGHEST_PROTOCOL)
    size_mb = os.path.getsize(OUTPUT_PATH) / 1024 / 1024
    print(f"    Wrote {size_mb:.1f} MB")

    print(f"\nTOTAL: {time.time()-t_total:.0f}s")
    print(f"DONE — {datetime.datetime.now().isoformat()}")


main()

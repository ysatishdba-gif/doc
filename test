"""
analyze_duplicates.py
---------------------
For each CUI's rollup set, detect REDUNDANT ancestors using ONLY structural
IS-A traversal — no similarity metrics, no thresholds.

Rule: if rollup A is a transitive IS-A ancestor of rollup B (both in the
rollup set), A is redundant. Drop A. Keep only the most-specific rollups.

This is graph traversal only. No math.
"""

import os
import pickle
from itertools import combinations

ROLLUP_PATH       = "rollup_index.pkl"
TOPIC_LOOKUP_PATH = "topic_lookup.pkl"

CUIS = [
    "C2142181",  # Pain of left knee joint
    "C0571275",  # Allergy to ketoconazole
    "C0571398",  # Cinoxacin allergy
    "C0276253",  # Cytomegaloviral pneumonia
    "C0021368",  # Inflammation
    "C0024109",  # Lung
]


# ============================================================================
# Load
# ============================================================================

print(f"Loading {ROLLUP_PATH} ...")
with open(ROLLUP_PATH, "rb") as f:
    r = pickle.load(f)

cui_to_rollup     = r["cui_to_rollup_ancestors"]
ic_scores         = r["ic_scores"]
descendant_counts = r["descendant_counts"]
isa_parents       = r["isa_parents"]
isa_children      = r["isa_children"]

labels = {}
if os.path.exists(TOPIC_LOOKUP_PATH):
    print(f"Loading labels from {TOPIC_LOOKUP_PATH} ...")
    with open(TOPIC_LOOKUP_PATH, "rb") as f:
        t = pickle.load(f)
    labels = t.get("labels", {})
    print(f"  Loaded {len(labels):,} labels")
else:
    print(f"  WARNING: {TOPIC_LOOKUP_PATH} not in cwd ({os.getcwd()})")


def lbl(c):
    return labels.get(c, "?")


# ============================================================================
# Structural ancestor check (graph traversal only — no math)
# ============================================================================

def is_isa_ancestor_of(a, b, max_depth=20):
    """True iff `a` is a transitive IS-A ancestor of `b`.
    Pure graph traversal — walks parent edges from `b` upward looking for `a`.
    """
    if a == b:
        return False
    visited = set()
    stack = [(b, 0)]
    while stack:
        node, depth = stack.pop()
        if depth > max_depth:
            continue
        if node in visited:
            continue
        visited.add(node)
        for p in isa_parents.get(node, set()):
            if p == a:
                return True
            stack.append((p, depth + 1))
    return False


# ============================================================================
# Per-CUI analysis
# ============================================================================

for cui in CUIS:
    print(f"\n{'='*100}")
    print(f"  {cui}  '{lbl(cui)}'")
    print(f"{'='*100}")

    rollups = sorted(cui_to_rollup.get(cui, []))
    if not rollups:
        print(f"  No rollups")
        continue

    print(f"  {len(rollups)} rollup ancestors:\n")
    for r_cui in sorted(rollups, key=lambda c: -ic_scores.get(c, 0.0)):
        r_ic = ic_scores.get(r_cui, 0.0)
        r_descs = descendant_counts.get(r_cui, 0)
        print(f"    {r_cui}  IC={r_ic:.3f}  descs={r_descs:>5d}  "
              f"'{lbl(r_cui)}'")

    # 1. Literal duplicate check
    if len(rollups) != len(set(rollups)):
        print(f"\n  ⚠ LITERAL DUPLICATES FOUND")
    else:
        print(f"\n  ✓ No literal duplicates ({len(set(rollups))} unique)")

    # 2. Hierarchical redundancy: pairs where one is IS-A ancestor of the other
    print(f"\n  Hierarchical redundancy "
          f"(one rollup is an IS-A ancestor of another):")
    redundant = set()    # rollups to drop (less specific)
    pairs = []           # (ancestor, descendant) pairs found

    for a, b in combinations(rollups, 2):
        if is_isa_ancestor_of(a, b):
            pairs.append((a, b))     # a is ancestor; a is redundant
            redundant.add(a)
        elif is_isa_ancestor_of(b, a):
            pairs.append((b, a))     # b is ancestor; b is redundant
            redundant.add(b)

    if pairs:
        for anc, desc in pairs:
            print(f"    {anc} '{lbl(anc)[:40]}'")
            print(f"      ↑ is ancestor of ↑")
            print(f"    {desc} '{lbl(desc)[:40]}'")
            print(f"    -> drop '{lbl(anc)[:30]}' (less specific)\n")
    else:
        print(f"    (none — all rollups are siblings in IS-A, "
              f"no ancestor/descendant pairs)")

    # Suggested clean set
    kept = [r for r in rollups if r not in redundant]
    print(f"  After dropping IS-A ancestors of other rollups: "
          f"{len(kept)} kept (was {len(rollups)})")
    for r_cui in sorted(kept, key=lambda c: -ic_scores.get(c, 0.0)):
        r_ic = ic_scores.get(r_cui, 0.0)
        print(f"    {r_cui}  IC={r_ic:.3f}  '{lbl(r_cui)}'")


print("\n\nDONE")

"""
build_topics_neighborhoods.py
-----------------------------
Simplest possible topic build: each CUI's topic = {itself + its direct
graph neighbors}.

No algorithm beyond:
  1. Flatten suffix-bridge graph to direct CUI-CUI edges (SNOMED-only)
  2. For each CUI, topic = {cui} ∪ neighbors[cui]

That's it. Edges ARE the relations. Each neighborhood IS a topic.

Inputs (notebook globals):
  data, SNOMED_CUIS, TAGS (optional), LABELS (optional)
"""

import pickle
import datetime
import time
import os
import statistics
from collections import defaultdict, Counter


OUTPUT_PATH = "topic_lookup_neighborhoods.pkl"


def cui_of(s):
    return s.rsplit("-", 1)[0] if "-" in s else s


def flatten_graph(g, snomed_cuis):
    print(f"[1/3] Flattening suffix-bridge -> CUI-CUI edges (SNOMED-only) ...")
    neighbors = defaultdict(set)
    t0 = time.time()
    n_proc = 0
    for cui in snomed_cuis:
        if cui not in g:
            n_proc += 1
            continue
        for suffix in g.successors(cui):
            if "-" not in suffix:
                continue
            for pred in g.predecessors(suffix):
                if pred == cui or pred == "CUI" or "-" not in pred:
                    continue
                oc = cui_of(pred)
                if oc != cui and oc in snomed_cuis:
                    neighbors[cui].add(oc)
                    neighbors[oc].add(cui)
        n_proc += 1
        if n_proc % 100000 == 0:
            print(f"  {n_proc:,}/{len(snomed_cuis):,} ({time.time()-t0:.0f}s)")
    n_edges = sum(len(s) for s in neighbors.values()) // 2
    print(f"  -> {n_edges:,} undirected edges in {time.time()-t0:.0f}s")
    return dict(neighbors)


def build_neighborhood_topics(neighbors, snomed_cuis):
    """
    Each CUI's topic = {cui} ∪ neighbors[cui].
    The topic_id is the CUI itself (no hashing — each CUI defines its own
    topic). This means there are exactly as many topics as there are CUIs
    with at least one neighbor (others get a singleton topic = {self}).
    """
    print(f"[2/3] Building neighborhood topics ...")
    cui_topic_id = {}     # cui -> its own topic_id
    topic_to_cuis = {}    # topic_id -> set of member CUIs
    for cui in snomed_cuis:
        members = neighbors.get(cui, set()) | {cui}
        # Topic ID is just the CUI itself
        topic_to_cuis[cui] = members
        cui_topic_id[cui] = cui
    print(f"  -> {len(topic_to_cuis):,} topics (one per CUI)")
    return cui_topic_id, topic_to_cuis


def report(cui_topic_id, topic_to_cuis, snomed_cuis, neighbors, tags=None, labels=None):
    print(f"\n{'='*78}")
    print(f"  RESULTS")
    print(f"{'='*78}")
    n_total = len(snomed_cuis)
    n_topics = len(topic_to_cuis)
    sizes = sorted(len(cuis) for cuis in topic_to_cuis.values())
    print(f"  SNOMED CUIs                : {n_total:,}")
    print(f"  Topics (one per CUI)       : {n_topics:,}")
    print(f"  Topic size = 1 (no neighbors): {sum(1 for s in sizes if s == 1):,}")
    print(f"  Topic size distribution:")
    print(f"    min     : {sizes[0]}")
    print(f"    median  : {sizes[len(sizes)//2]}")
    print(f"    mean    : {statistics.mean(sizes):.1f}")
    print(f"    p90     : {sizes[int(0.9*len(sizes))]}")
    print(f"    p99     : {sizes[int(0.99*len(sizes))]}")
    print(f"    max     : {sizes[-1]:,}")

    # Focal CUIs
    focal = [
        "C0032285", "C0021368", "C0024109", "C1527304", "C0559470",
        "C0002792", "C2142181", "C0011849",
    ]
    print(f"\n  Focal CUI lookups:")
    for cui in focal:
        members = topic_to_cuis.get(cui, set())
        lbl = (labels or {}).get(cui, "?")[:30] if labels else "?"
        print(f"\n    {cui} '{lbl}': {len(members)} members")
        for m in sorted(members)[:6]:
            mlbl = (labels or {}).get(m, "?")[:35] if labels else "?"
            marker = " <-- self" if m == cui else ""
            print(f"      {m} '{mlbl}'{marker}")
        if len(members) > 6:
            print(f"      ... +{len(members)-6} more")

    # Pair-retrieval test (overlap of neighborhoods)
    pairs = [
        ("C1527304", "Allergic reaction", "C0559470", "Peanut allergy"),
        ("C1527304", "Allergic reaction", "C0002792", "Anaphylaxis"),
        ("C2142181", "Pain left knee jt", "C0231749", "Pain knee region"),
    ]
    print(f"\n  Retrieval test — overlap of neighborhoods:")
    for ca, la, cb, lb_ in pairs:
        ta = topic_to_cuis.get(ca, set())
        tb = topic_to_cuis.get(cb, set())
        overlap = ta & tb
        result = "MATCH" if overlap else "no match"
        print(f"    '{la}' <-> '{lb_}': {result}")
        if overlap:
            for c in sorted(overlap)[:3]:
                clbl = (labels or {}).get(c, "?")[:30] if labels else "?"
                print(f"        shared: {c} '{clbl}'")


def main():
    for v in ["data", "SNOMED_CUIS"]:
        if v not in globals():
            raise RuntimeError(f"Set '{v}' in notebook first")
    tags = TAGS if "TAGS" in globals() else None
    labels = LABELS if "LABELS" in globals() else None

    print("=" * 60)
    print("Neighborhood-based topic build (each CUI = its own topic)")
    print("=" * 60)
    print(f"  Graph       : {data.number_of_nodes():,} nodes")
    print(f"  SNOMED CUIs : {len(SNOMED_CUIS):,}")

    neighbors = flatten_graph(data, SNOMED_CUIS)
    cui_topic_id, topic_to_cuis = build_neighborhood_topics(neighbors, SNOMED_CUIS)
    report(cui_topic_id, topic_to_cuis, SNOMED_CUIS, neighbors, tags, labels)

    print(f"\n[3/3] Saving to {OUTPUT_PATH} ...")
    payload = {
        "built_at":            datetime.datetime.now().isoformat(),
        "method":              "neighborhood (each CUI's topic = self + 1-hop neighbors)",
        "source":              "network graph (team-provided)",
        "snomed_cuis":         SNOMED_CUIS,
        "cui_topic_id":        cui_topic_id,     # cui -> topic_id (which equals cui)
        "topic_to_cuis":       topic_to_cuis,    # cui -> set of members
        "flattened_neighbors": neighbors,
    }
    if tags:
        payload["tags"] = tags
    if labels:
        payload["labels"] = labels

    with open(OUTPUT_PATH, "wb") as f:
        pickle.dump(payload, f, protocol=pickle.HIGHEST_PROTOCOL)
    size_mb = os.path.getsize(OUTPUT_PATH) / 1024 / 1024
    print(f"  wrote {size_mb:.1f} MB")
    print("\nDONE")


main()

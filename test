    ("C0020649", "Hypopiesis"),
    ("C0020538", "Hypertension"),  # cross-check
]


print(f"Loading {PICKLE_PATH} ...")
with open(PICKLE_PATH, "rb") as f:
    p = pickle.load(f)

topic_to_cuis              = p["topic_to_cuis"]
main_topic_to_subtopic_ids = p["main_topic_to_subtopic_ids"]
subtopic_id_to_cuis        = p["subtopic_id_to_cuis"]
cui_to_subtopic_ids        = p["cui_to_subtopic_ids"]
subtopic_metadata          = p["subtopic_metadata"]
labels                     = p.get("labels", {})


def lbl(c):
    return labels.get(c, "?")[:45] if labels else "?"


# Summary table
print(f"\n{'='*100}")
print(f"  SUMMARY TABLE")
print(f"{'='*100}")
print(f"  {'CUI':<12s}  {'Expected':<32s}  {'Real label':<35s}  {'Main':>5s}  {'Subs':>5s}")

for cui, expected in CUIS_TO_TEST:
    actual = lbl(cui)
    main_sz = len(topic_to_cuis.get(cui, set()))
    sub_count = len(dict.fromkeys(main_topic_to_subtopic_ids.get(cui, [])))
    missing = "?" if cui not in topic_to_cuis else ""
    print(f"  {cui:<12s}  {expected[:32]:<32s}  {actual[:35]:<35s}  "
          f"{main_sz:>5d}  {sub_count:>5d}  {missing}")


# Detailed per CUI
for cui, expected in CUIS_TO_TEST:
    print(f"\n\n{'='*80}")
    print(f"  {cui}  expected: '{expected}'  actual: '{lbl(cui)}'")
    print(f"{'='*80}")

    main_members = topic_to_cuis.get(cui, set())
    print(f"  Main topic size: {len(main_members)}")

    if not main_members:
        print(f"  ⚠️ NOT IN SNOMED UNIVERSE")
        continue

    # First 6 main topic members
    print(f"  Main topic members (first 6):")
    for m in sorted(main_members)[:6]:
        marker = " <-- self" if m == cui else ""
        print(f"    {m}  '{lbl(m)}'{marker}")
    if len(main_members) > 6:
        print(f"    ... +{len(main_members)-6} more")

    own = list(dict.fromkeys(main_topic_to_subtopic_ids.get(cui, [])))
    print(f"\n  Sub-topics within this main topic: {len(own)}")
    if not own:
        print(f"    (none — star-shaped or topic < 3 members)")
        continue

    # Show up to 4 sub-topics, largest first
    own_sorted = sorted(own, key=lambda s: -subtopic_metadata[s]["size"])
    for sid in own_sorted[:4]:
        meta = subtopic_metadata[sid]
        members = subtopic_id_to_cuis[sid]
        print(f"\n    {sid} (size {meta['size']}):")
        for m in sorted(members):
            marker = " <-- self" if m == cui else ""
            print(f"      {m}  '{lbl(m)}'{marker}")
    if len(own_sorted) > 4:
        print(f"\n    ... +{len(own_sorted)-4} more sub-topics")


print("\n\nDONE")

"""
inspect_mrrel_rows.py
---------------------
For a list of CUIs, dump EVERY MRREL row they participate in.
Shows REL, RELA, other CUI, and whether the other CUI is in SNOMED.

This tells us exactly what relations are available for "orphan" CUIs
and whether we're filtering out useful hierarchy.

Requires notebook globals:
  cache (with mrrel_rows)
  SNOMED_CUIS
  LABELS
"""

from collections import Counter, defaultdict


CUIS_TO_INSPECT = [
    "C0007113",  # Rectal cancer
    "C0007121",  # Bronchogenic carcinoma
    "C0003838",  # Arterial occlusive disease
    "C0002884",  # Hypochromic anaemia
    "C0006370",  # Bulimia
]


# Index mrrel by CUI for fast lookup
print("Indexing MRREL by CUI...")
cui_to_rows = defaultdict(list)
for row in cache["mrrel_rows"]:
    if len(row) < 3:
        continue
    c1, c2, rel = row[0], row[1], row[2]
    rela = row[3] if len(row) > 3 else ""
    cui_to_rows[c1].append((c2, rel, rela))
    cui_to_rows[c2].append((c1, rel, rela))

print(f"Indexed {sum(len(v) for v in cui_to_rows.values()):,} CUI-row pairs\n")


for cui in CUIS_TO_INSPECT:
    label = LABELS.get(cui, "?")
    print(f"\n{'='*100}")
    print(f"CUI: {cui}  '{label}'")
    print(f"{'='*100}")

    rows = cui_to_rows.get(cui, [])
    print(f"  Total MRREL rows: {len(rows)}")

    if not rows:
        print("  (no rows at all)")
        continue

    # Break down by REL type
    rel_counts = Counter(r[1] for r in rows)
    print(f"\n  Breakdown by REL:")
    for rel, n in rel_counts.most_common():
        print(f"    {rel:>6}  : {n}")

    # Break down by RELA (the specific relation name)
    rela_counts = Counter(r[2] for r in rows if r[2])
    if rela_counts:
        print(f"\n  Breakdown by RELA (top 10):")
        for rela, n in rela_counts.most_common(10):
            print(f"    {rela:<40} : {n}")

    # Show all rows, grouped by REL
    print(f"\n  All rows (other_cui | REL | RELA | other label | in SNOMED?):")
    by_rel = defaultdict(list)
    for other_cui, rel, rela in rows:
        by_rel[rel].append((other_cui, rela))

    for rel in sorted(by_rel):
        print(f"\n    --- REL={rel} ({len(by_rel[rel])} rows) ---")
        # Show first 15 per REL type to avoid swamping
        shown = 0
        for other_cui, rela in by_rel[rel]:
            in_snomed = "SNOMED" if other_cui in SNOMED_CUIS else "OTHER"
            other_label = LABELS.get(other_cui, "?")
            print(f"      {other_cui}  [{rela:<25}]  [{in_snomed}]  '{other_label[:60]}'")
            shown += 1
            if shown >= 15:
                remaining = len(by_rel[rel]) - 15
                if remaining > 0:
                    print(f"      ... and {remaining} more rows")
                break

print(f"\n{'='*100}")
print("DONE")

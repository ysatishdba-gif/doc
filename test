"""
build_subtopics_final.py
------------------------
Final sub-topic build: keep ONLY size-3+ cliques.

Drops:
  - Component sub-topics (they're duplicates of main topics)
  - Size-2 cliques (they're just edges, already encoded in main topic)

Keeps:
  - Size-3+ maximal cliques (genuine tight clusters that add precision)

Inputs (notebook globals OR loadable pickle):
  Loads topic_lookup_neighborhoods.pkl directly.

Outputs:
  topic_lookup_final.pkl with:
    Main topic data (preserved from neighborhoods build)
    Sub-topic indices:
      main_topic_to_subtopic_ids
      subtopic_id_to_cuis
      subtopic_id_to_main_topics
      cui_to_subtopic_ids
      subtopic_metadata  (size only; method is always "clique")
"""

import pickle
import datetime
import hashlib
import time
import os
from collections import defaultdict


INPUT_PATH  = "topic_lookup_neighborhoods.pkl"
OUTPUT_PATH = "topic_lookup_final.pkl"

MIN_CLIQUE_SIZE = 3


def subtopic_id(members_frozenset):
    """Stable ID hashed from sorted member CUIs."""
    sorted_members = "|".join(sorted(members_frozenset))
    h = hashlib.sha1(sorted_members.encode()).hexdigest()[:14]
    return f"st_{h}"


def induced_subgraph(members, neighbors):
    members_set = set(members)
    return {cui: neighbors.get(cui, set()) & members_set for cui in members}


def bron_kerbosch(R, P, X, sub_adj, results, min_size=3, max_results=200):
    """Maximal cliques of size >= min_size."""
    if len(results) >= max_results:
        return
    if not P and not X:
        if len(R) >= min_size:
            results.append(frozenset(R))
        return
    for v in list(P):
        if len(results) >= max_results:
            return
        Nv = sub_adj.get(v, set())
        bron_kerbosch(R | {v}, P & Nv, X & Nv, sub_adj, results,
                      min_size, max_results)
        P = P - {v}
        X = X | {v}


def find_cliques_min_size(sub_adj, min_size=3):
    results = []
    bron_kerbosch(set(), set(sub_adj.keys()), set(), sub_adj, results,
                  min_size=min_size, max_results=200)
    return results


def build(payload):
    cui_topic_id        = payload["cui_topic_id"]
    topic_to_cuis       = payload["topic_to_cuis"]
    flattened_neighbors = payload["flattened_neighbors"]

    print(f"  main topics to scan: {len(topic_to_cuis):,}")

    main_topic_to_subtopic_ids = defaultdict(list)
    subtopic_id_to_cuis        = {}
    subtopic_id_to_main_topics = defaultdict(set)
    cui_to_subtopic_ids        = defaultdict(set)
    subtopic_metadata          = {}

    n_processed = 0
    n_topics_with_subtopics = 0
    t0 = time.time()

    for main_topic, members in topic_to_cuis.items():
        n_processed += 1
        if len(members) < MIN_CLIQUE_SIZE:
            continue   # can't have a size-3 sub-topic in a <3 member main topic

        sub_adj = induced_subgraph(members, flattened_neighbors)
        cliques = find_cliques_min_size(sub_adj, min_size=MIN_CLIQUE_SIZE)
        if not cliques:
            continue

        n_topics_with_subtopics += 1
        for clq in cliques:
            sid = subtopic_id(clq)
            if sid not in subtopic_id_to_cuis:
                subtopic_id_to_cuis[sid] = clq
                subtopic_metadata[sid] = {"size": len(clq)}
            main_topic_to_subtopic_ids[main_topic].append(sid)
            subtopic_id_to_main_topics[sid].add(main_topic)
            for c in clq:
                cui_to_subtopic_ids[c].add(sid)

        if n_processed % 50000 == 0:
            print(f"    processed {n_processed:,}/{len(topic_to_cuis):,} "
                  f"(sub-topics so far: {len(subtopic_id_to_cuis):,}, "
                  f"{time.time()-t0:.0f}s)")

    print(f"  done in {time.time()-t0:.0f}s")
    print(f"\n  Results:")
    print(f"    unique sub-topics       : {len(subtopic_id_to_cuis):,}")
    print(f"    main topics w/ sub-topic: {n_topics_with_subtopics:,}")
    print(f"    CUIs w/ at least 1 sub  : {len(cui_to_subtopic_ids):,}")

    sizes = sorted(meta["size"] for meta in subtopic_metadata.values())
    if sizes:
        print(f"\n  Sub-topic size distribution (all size>=3):")
        print(f"    min/median/p90/p99/max : "
              f"{sizes[0]} / {sizes[len(sizes)//2]} / "
              f"{sizes[int(0.9*len(sizes))]} / {sizes[int(0.99*len(sizes))]} / "
              f"{sizes[-1]}")

    return {
        "main_topic_to_subtopic_ids": dict(main_topic_to_subtopic_ids),
        "subtopic_id_to_cuis":        subtopic_id_to_cuis,
        "subtopic_id_to_main_topics": dict(subtopic_id_to_main_topics),
        "cui_to_subtopic_ids":        dict(cui_to_subtopic_ids),
        "subtopic_metadata":          subtopic_metadata,
    }


def main():
    print(f"Loading {INPUT_PATH} ...")
    with open(INPUT_PATH, "rb") as f:
        payload = pickle.load(f)
    print(f"  Main topics: {len(payload['topic_to_cuis']):,}")

    print(f"\n[1] Building size-{MIN_CLIQUE_SIZE}+ clique sub-topics ...")
    sub_data = build(payload)

    out = dict(payload)
    out.update(sub_data)
    out["subtopic_built_at"] = datetime.datetime.now().isoformat()
    out["subtopic_config"] = {
        "min_clique_size": MIN_CLIQUE_SIZE,
        "method": "maximal cliques only (no components, no size-2)",
    }

    print(f"\n[Saving] {OUTPUT_PATH}")
    with open(OUTPUT_PATH, "wb") as f:
        pickle.dump(out, f, protocol=pickle.HIGHEST_PROTOCOL)
    size_mb = os.path.getsize(OUTPUT_PATH) / 1024 / 1024
    print(f"  wrote {size_mb:.1f} MB")
    print("\nDONE")


main()

"""
trace_rollup_paths.py
---------------------
For each CUI, print ALL paths from leaf to root with IC values at each
level, and which level the algorithm picks as the rollup stop point.

Use this to analyze why the rollup algorithm picks specific ancestors.

Edit CUIS list. Run.
"""

import pickle

ROLLUP_PATH       = "rollup_index.pkl"
TOPIC_LOOKUP_PATH = "topic_lookup.pkl"

CUIS = [
    "C2142181",  # Pain of left knee joint  (good case — keep for compare)
    "C0571275",  # Allergy to ketoconazole  (many rollups — investigate)
    "C0021368",  # Inflammation             (Qualifier value pulled in)
]

MAX_PATHS_TO_SHOW = 10   # to keep output readable for hub CUIs


# ============================================================================
# Load
# ============================================================================

print(f"Loading {ROLLUP_PATH} ...")
with open(ROLLUP_PATH, "rb") as f:
    r = pickle.load(f)

cui_to_rollup     = r["cui_to_rollup_ancestors"]
ic_scores         = r["ic_scores"]
descendant_counts = r["descendant_counts"]
isa_parents       = r["isa_parents"]
isa_children      = r["isa_children"]
config            = r.get("config", {})

labels = {}
try:
    with open(TOPIC_LOOKUP_PATH, "rb") as f:
        t = pickle.load(f)
    labels = t.get("labels", {})
except FileNotFoundError:
    pass


def lbl(c):
    return labels.get(c, "?")


MIN_CHILDREN = config.get("min_children", 3)


# ============================================================================
# Reconstruct paths (same logic as build_rollup.py)
# ============================================================================

def all_paths_to_root(cui, max_paths=200, max_depth=30):
    paths = []
    def walk(current_path, visited):
        if len(paths) >= max_paths:
            return
        if len(current_path) >= max_depth:
            paths.append(list(current_path))
            return
        current = current_path[-1]
        parents = isa_parents.get(current, set()) - visited
        if not parents:
            paths.append(list(current_path))
            return
        for p in parents:
            current_path.append(p)
            visited.add(p)
            walk(current_path, visited)
            current_path.pop()
            visited.remove(p)
    walk([cui], {cui})
    return paths


def find_rollup_ancestor_traced(path, ic, isa_children, min_children):
    """Same as build_rollup.find_rollup_ancestor but returns extra trace info."""
    if len(path) == 1:
        return path[0], "single-node-path", None
    if len(path) == 2:
        return path[1], "two-node-path (direct parent)", None
    
    ics = [ic.get(node, 0.0) for node in path]
    deltas = [ics[i] - ics[i+1] for i in range(len(ics) - 1)]
    
    ic_stop_idx = None
    for i in range(1, len(deltas)):
        if deltas[i] > deltas[i-1]:
            ic_stop_idx = i
            break
    
    if ic_stop_idx is None:
        ic_stop_idx = min(2, len(path) - 1)
        reason_ic = f"IC drops smoothly to root, fallback to idx={ic_stop_idx}"
    else:
        reason_ic = (f"IC accel at idx={ic_stop_idx}: "
                     f"delta[{ic_stop_idx-1}]={deltas[ic_stop_idx-1]:.3f} -> "
                     f"delta[{ic_stop_idx}]={deltas[ic_stop_idx]:.3f}")
    
    candidate_idx = ic_stop_idx
    walked_up = []
    while candidate_idx < len(path) - 1:
        candidate = path[candidate_idx]
        n_kids = len(isa_children.get(candidate, set()))
        if n_kids >= min_children:
            return path[candidate_idx], reason_ic, walked_up if walked_up else None
        walked_up.append((candidate_idx, candidate, n_kids))
        candidate_idx += 1
    
    return path[-1], reason_ic, walked_up


# ============================================================================
# Display
# ============================================================================

for cui in CUIS:
    print(f"\n{'='*100}")
    print(f"  {cui}  '{lbl(cui)}'")
    print(f"  Rollups (final): {sorted(cui_to_rollup.get(cui, []))}")
    print(f"{'='*100}")
    
    paths = all_paths_to_root(cui)
    print(f"\n  Found {len(paths)} paths to root")
    if len(paths) > MAX_PATHS_TO_SHOW:
        print(f"  Showing first {MAX_PATHS_TO_SHOW} paths\n")
    
    for path_idx, path in enumerate(paths[:MAX_PATHS_TO_SHOW]):
        rollup, reason, walked_up = find_rollup_ancestor_traced(
            path, ic_scores, isa_children, MIN_CHILDREN
        )
        rollup_idx = path.index(rollup) if rollup in path else -1
        
        print(f"\n  ─── PATH {path_idx+1}  ─────────────────")
        print(f"  Stop reason: {reason}")
        if walked_up:
            print(f"  Walked past (too few children): {walked_up}")
        print(f"  Picked: idx={rollup_idx}  {rollup}  '{lbl(rollup)}'")
        print(f"\n  level  CUI         IC      delta   children  label")
        
        for i, node in enumerate(path):
            ic_node = ic_scores.get(node, 0.0)
            n_kids = len(isa_children.get(node, set()))
            
            if i == 0:
                delta_str = "     -"
            else:
                d = ic_scores.get(path[i-1], 0.0) - ic_node
                delta_str = f"{d:+.3f}"
            
            marker = "  ← PICKED" if i == rollup_idx else ""
            label = lbl(node)[:45]
            print(f"  {i:>5d}  {node}  {ic_node:.3f}  {delta_str}  "
                  f"{n_kids:>5d}    '{label}'{marker}")
    
    if len(paths) > MAX_PATHS_TO_SHOW:
        print(f"\n  ... {len(paths) - MAX_PATHS_TO_SHOW} more paths not shown")

print("\n\nDONE")

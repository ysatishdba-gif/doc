"""
inspect_isa_subgroups.py
------------------------
Per-CUI inspector. For each CUI, prints the topics it belongs to in the
final flat format:

  ================================================================================
  CUI  |  Label
  STY: ...
  -> N TOPIC(S)
    Topic ID: tp_<hash>
    Canonical: <CUI>
    Label    : <label>
    Size     : <N> CUIs
    Members  : [list]
"""

import pickle

PKL_PATH = "topic_with_isa_subgroups.pkl"

CUIS = [
    "C0032285",  # Pneumonia
    "C0011849",  # Diabetes mellitus
    "C0021368",  # Inflammation
    "C0024109",  # Lung
    "C2142181",  # Pain of left knee joint
    "C0559470",  # Allergy to peanut
    "C0013182",  # Allergy to drug
    "C0002792",  # Anaphylaxis
]

MAX_MEMBERS_TO_SHOW = 25  # cap per topic for readability


with open(PKL_PATH, "rb") as f:
    p = pickle.load(f)

topic_id_to_topic = p["topic_id_to_topic"]
cui_to_topic_ids  = p["cui_to_topic_ids"]
labels            = p.get("labels", {})
tags              = p.get("tags", {})  # may be empty


def lbl(c):
    return labels.get(c, "?")


def sty(c):
    t = tags.get(c)
    if not t:
        return "(no STY)"
    if isinstance(t, (set, frozenset, list)):
        return ", ".join(sorted(t))
    return str(t)


for cui in CUIS:
    print(f"\n{'='*80}")
    print(f"{cui}  |  {lbl(cui)}")
    print(f"STY: {sty(cui)}")

    topic_ids = cui_to_topic_ids.get(cui, [])
    print(f"-> {len(topic_ids)} TOPIC(S)")

    if not topic_ids:
        print("  (no topics — this CUI is not anchored by any IS-A ancestor "
              "in any of its main topics)")
        continue

    # Order topics by size (largest first) for readability
    sorted_topic_ids = sorted(
        topic_ids,
        key=lambda tid: -topic_id_to_topic[tid]["size"]
    )

    for tid in sorted_topic_ids:
        topic = topic_id_to_topic[tid]
        canonical = topic["canonical"]
        members   = topic["members"]
        size      = topic["size"]

        print()
        print(f"  Topic ID : {tid}")
        print(f"  Canonical: {canonical}")
        print(f"  Label    : {topic['label']}")
        print(f"  Size     : {size} CUIs")
        print(f"  Members  :")

        sorted_members = sorted(members)
        for m in sorted_members[:MAX_MEMBERS_TO_SHOW]:
            print(f"    {m}  '{lbl(m)}'")
        if size > MAX_MEMBERS_TO_SHOW:
            print(f"    ... and {size - MAX_MEMBERS_TO_SHOW} more")

print("\n" + "="*80)
print("DONE")

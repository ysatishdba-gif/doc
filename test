"""
build_subtopics_all_cliques.py
------------------------------
Final sub-topic build: keep ALL maximal cliques of size >= 2.

Drops:
  - Component sub-topics (they duplicate the main topic — no info added)

Keeps:
  - Size-2 cliques (edge pairs — give leaf-CUI precision)
  - Size-3+ cliques (tight clinical clusters)

Each unique sub-topic gets a stable hashed ID.
Bidirectional indexing for forward (main->subs) and reverse (sub->mains) lookup.

Reads:  topic_lookup_neighborhoods.pkl
Writes: topic_lookup_all_cliques.pkl
"""

import pickle
import datetime
import hashlib
import time
import os
from collections import defaultdict


INPUT_PATH      = "topic_lookup_neighborhoods.pkl"
OUTPUT_PATH     = "topic_lookup_all_cliques.pkl"
MIN_CLIQUE_SIZE = 2     # keep size-2 cliques (was 3 in previous build)
MAX_CLIQUES_PER_TOPIC = 1000  # safety cap for very dense topics


# ============================================================================
# Helpers
# ============================================================================

def subtopic_id(members_frozenset):
    """Stable ID hashed from sorted member CUIs."""
    sorted_members = "|".join(sorted(members_frozenset))
    h = hashlib.sha1(sorted_members.encode()).hexdigest()[:14]
    return f"st_{h}"


def induced_subgraph(members, neighbors):
    """Adjacency dict for the induced subgraph on these members."""
    members_set = set(members)
    return {cui: neighbors.get(cui, set()) & members_set for cui in members}


def bron_kerbosch(R, P, X, sub_adj, results, min_size, max_results):
    """Maximal cliques of size >= min_size, capped at max_results."""
    if len(results) >= max_results:
        return
    if not P and not X:
        if len(R) >= min_size:
            results.append(frozenset(R))
        return
    for v in list(P):
        if len(results) >= max_results:
            return
        Nv = sub_adj.get(v, set())
        bron_kerbosch(R | {v}, P & Nv, X & Nv, sub_adj, results,
                      min_size, max_results)
        P = P - {v}
        X = X | {v}


def find_cliques(sub_adj, min_size, max_results):
    results = []
    bron_kerbosch(set(), set(sub_adj.keys()), set(), sub_adj, results,
                  min_size=min_size, max_results=max_results)
    return results


# ============================================================================
# Main build
# ============================================================================

def build(payload):
    topic_to_cuis       = payload["topic_to_cuis"]
    flattened_neighbors = payload["flattened_neighbors"]

    print(f"  Main topics to process: {len(topic_to_cuis):,}")

    main_topic_to_subtopic_ids = defaultdict(list)
    subtopic_id_to_cuis        = {}
    subtopic_id_to_main_topics = defaultdict(set)
    cui_to_subtopic_ids        = defaultdict(set)
    subtopic_metadata          = {}

    n_processed = 0
    n_topics_with_subs = 0
    n_capped = 0
    size_distribution = defaultdict(int)
    t0 = time.time()

    for main_topic, members in topic_to_cuis.items():
        n_processed += 1

        if len(members) < MIN_CLIQUE_SIZE:
            continue

        sub_adj = induced_subgraph(members, flattened_neighbors)
        cliques = find_cliques(sub_adj, min_size=MIN_CLIQUE_SIZE,
                               max_results=MAX_CLIQUES_PER_TOPIC)

        if len(cliques) == MAX_CLIQUES_PER_TOPIC:
            n_capped += 1

        if not cliques:
            continue

        n_topics_with_subs += 1
        for clq in cliques:
            sid = subtopic_id(clq)
            if sid not in subtopic_id_to_cuis:
                subtopic_id_to_cuis[sid] = clq
                subtopic_metadata[sid] = {"size": len(clq)}
                size_distribution[len(clq)] += 1
            main_topic_to_subtopic_ids[main_topic].append(sid)
            subtopic_id_to_main_topics[sid].add(main_topic)
            for c in clq:
                cui_to_subtopic_ids[c].add(sid)

        if n_processed % 50000 == 0:
            print(f"    processed {n_processed:,}/{len(topic_to_cuis):,} "
                  f"(unique subs so far: {len(subtopic_id_to_cuis):,}, "
                  f"{time.time()-t0:.0f}s)")

    print(f"  done in {time.time()-t0:.0f}s")

    print(f"\n  Results:")
    print(f"    Unique sub-topics                 : {len(subtopic_id_to_cuis):,}")
    print(f"    Main topics with at least 1 sub   : {n_topics_with_subs:,}")
    print(f"    CUIs appearing in at least 1 sub  : {len(cui_to_subtopic_ids):,}")
    print(f"    Topics hitting clique cap         : {n_capped:,} "
          f"(of {MAX_CLIQUES_PER_TOPIC} each)")

    print(f"\n  Sub-topic size distribution:")
    for size in sorted(size_distribution):
        count = size_distribution[size]
        bar = "#" * min(50, count * 50 // max(size_distribution.values()))
        print(f"    size {size:>3d} : {count:>8,d}  {bar}")

    return {
        "main_topic_to_subtopic_ids": dict(main_topic_to_subtopic_ids),
        "subtopic_id_to_cuis":        subtopic_id_to_cuis,
        "subtopic_id_to_main_topics": dict(subtopic_id_to_main_topics),
        "cui_to_subtopic_ids":        dict(cui_to_subtopic_ids),
        "subtopic_metadata":          subtopic_metadata,
    }


def main():
    print(f"Loading {INPUT_PATH} ...")
    with open(INPUT_PATH, "rb") as f:
        payload = pickle.load(f)
    print(f"  Main topics: {len(payload['topic_to_cuis']):,}")

    print(f"\n[1] Building sub-topics (cliques size >= {MIN_CLIQUE_SIZE}, "
          f"capped {MAX_CLIQUES_PER_TOPIC}/topic) ...")
    sub_data = build(payload)

    out = dict(payload)
    out.update(sub_data)
    out["subtopic_built_at"] = datetime.datetime.now().isoformat()
    out["subtopic_config"] = {
        "min_clique_size":       MIN_CLIQUE_SIZE,
        "max_cliques_per_topic": MAX_CLIQUES_PER_TOPIC,
        "method":                "maximal cliques only, no component duplicates",
    }

    print(f"\n[Saving] {OUTPUT_PATH}")
    with open(OUTPUT_PATH, "wb") as f:
        pickle.dump(out, f, protocol=pickle.HIGHEST_PROTOCOL)
    size_mb = os.path.getsize(OUTPUT_PATH) / 1024 / 1024
    print(f"  wrote {size_mb:.1f} MB")
    print("\nDONE")


main()

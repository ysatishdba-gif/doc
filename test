"""
test_final.py
-------------
Test the filtered sub-topic build (size-3+ cliques only).

Loads topic_lookup_final.pkl. No notebook globals needed.
Edit CUIS_TO_TEST below.
"""

import pickle
from collections import Counter


PICKLE_PATH = "topic_lookup_final.pkl"

CUIS_TO_TEST = [
    "C0032285",  # Pneumonia
    "C0021368",  # Inflammation
    "C0024109",  # Lung
    "C0011849",  # Diabetes mellitus
    "C1527304",  # Allergic reaction
    "C0559470",  # Allergy to peanut
    "C0002792",  # Anaphylaxis
    "C0013182",  # Allergy to drug
    "C2142181",  # Pain of left knee joint
    "C1621958",  # Glioblastoma multiforme
    "C0016470",  # Food allergy
]


print(f"Loading {PICKLE_PATH} ...")
with open(PICKLE_PATH, "rb") as f:
    p = pickle.load(f)

topic_to_cuis              = p["topic_to_cuis"]
main_topic_to_subtopic_ids = p["main_topic_to_subtopic_ids"]
subtopic_id_to_cuis        = p["subtopic_id_to_cuis"]
subtopic_id_to_main_topics = p["subtopic_id_to_main_topics"]
cui_to_subtopic_ids        = p["cui_to_subtopic_ids"]
subtopic_metadata          = p["subtopic_metadata"]
labels                     = p.get("labels", {})


def lbl(c):
    return labels.get(c, "?")[:45] if labels else "?"


print(f"  Main topics: {len(topic_to_cuis):,}")
print(f"  Unique sub-topics (size>=3): {len(subtopic_id_to_cuis):,}")
print(f"  Ratio: {len(subtopic_id_to_cuis)/max(len(topic_to_cuis),1):.2f} sub-topics per main topic")


for cui in CUIS_TO_TEST:
    print(f"\n\n{'='*80}")
    print(f"  {cui}  '{lbl(cui)}'")
    print(f"{'='*80}")

    main_members = topic_to_cuis.get(cui, set())
    print(f"  Main topic size  : {len(main_members)}")

    sids = cui_to_subtopic_ids.get(cui, set())
    print(f"  In total {len(sids)} sub-topics (across all main topics)")

    own = list(dict.fromkeys(main_topic_to_subtopic_ids.get(cui, [])))
    print(f"\n  SUB-TOPICS within this main topic ({len(own)}):")
    if not own:
        print(f"    (no sub-topics — main topic is too small or graph is star-shaped)")

    # Sort by size descending
    own_sorted = sorted(own, key=lambda s: -subtopic_metadata[s]["size"])
    for sid in own_sorted[:8]:
        meta = subtopic_metadata[sid]
        members = subtopic_id_to_cuis[sid]
        n_main_topics = len(subtopic_id_to_main_topics[sid])
        print(f"\n    {sid}  size={meta['size']}  "
              f"appears_in_main_topics={n_main_topics}")
        for m in sorted(members):
            marker = " <-- self" if m == cui else ""
            print(f"      {m}  '{lbl(m)}'{marker}")
    if len(own_sorted) > 8:
        print(f"\n    ... +{len(own_sorted)-8} more sub-topics")


# Reverse lookup demo
print(f"\n\n{'#'*80}")
print(f"# REVERSE LOOKUP DEMO")
print(f"{'#'*80}")

# Pick the 5 largest sub-topics to show what they represent
top5 = sorted(subtopic_metadata.items(),
              key=lambda kv: -kv[1]["size"])[:5]
for sid, meta in top5:
    members = subtopic_id_to_cuis[sid]
    mains = subtopic_id_to_main_topics[sid]
    print(f"\n  {sid} (size {meta['size']}, appears in {len(mains)} main topics):")
    for m in sorted(members)[:8]:
        print(f"    {m}  '{lbl(m)}'")
    if len(members) > 8:
        print(f"    ... +{len(members)-8} more")


print("\n\nDONE")

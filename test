# Groups CUIs by their precomputed sibling_reach topics.
#
# Two output modes:
#   group()      → full output with members, scores, labels (for display)
#   topic_cuis() → {topic_cui: topic_label} dict (for matching)

import pickle
from collections import defaultdict


class SiblingReachGrouper:
    """
    Loads cui_topic_lookup.pkl and exposes:
      - topic_cuis(cuis)      → {cui: label} for matching
      - group(cuis, ...)      → grouped dict for display
    """

    def __init__(self, pickle_path="cui_topic_lookup.pkl"):
        with open(pickle_path, "rb") as f:
            self._lookup = pickle.load(f)
        print(f"SiblingReachGrouper: loaded {len(self._lookup):,} entries "
              f"from {pickle_path}")

    # ── For matching: {topic_cui: topic_label} ────────────────────────

    def topic_cuis(self, cuis):
        """
        Given an iterable of CUIs, return {topic_cui: topic_label} for
        all topics those CUIs map to via the sibling_reach lookup.
        Missing CUIs are silently skipped.
        """
        topics = {}
        for cui in cuis:
            entry = self._lookup.get(cui)
            if entry is None:
                continue
            for t in entry.get("topics", []):
                topics[t["topic_cui"]] = t["topic_label"]
        return topics

    # ── For display: grouped output with members ──────────────────────

    def group(self, cuis, ic_map=None, term_map=None, min_members=1):
        """
        Group CUIs by sibling_reach topic. Returns a structure suitable
        for printing / inspection.

        cuis        : iterable of CUIs
        ic_map      : {cui -> IC} for display (optional)
        term_map    : {cui -> preferred_term} for display (optional)
        min_members : drop topics with fewer members (default 1 = keep all)
        """
        cuis = list(cuis)
        bag = defaultdict(lambda: {"label": None, "members": set(), "score": 0.0})
        missing = []

        for cui in cuis:
            entry = self._lookup.get(cui)
            if entry is None:
                missing.append(cui)
                continue
            for topic in entry.get("topics", []):
                tcui = topic["topic_cui"]
                bag[tcui]["label"] = topic["topic_label"]
                bag[tcui]["members"].add(cui)
                s = topic.get("score", 0.0)
                if s > bag[tcui]["score"]:
                    bag[tcui]["score"] = s

        topics_out = []
        dropped_singletons = 0

        for tcui, data in sorted(
            bag.items(),
            key=lambda kv: (-len(kv[1]["members"]), -kv[1]["score"],
                            kv[1]["label"] or "")
        ):
            member_cuis = sorted(data["members"])

            if len(member_cuis) < min_members:
                dropped_singletons += 1
                continue

            members = [
                {
                    "cui"           : mc,
                    "preferred_term": (term_map or {}).get(mc, mc),
                    "ic"            : round((ic_map or {}).get(mc, 0.0), 4),
                }
                for mc in member_cuis
            ]

            topics_out.append({
                "topic_id"   : len(topics_out),
                "topic_cui"  : tcui,
                "topic_label": data["label"] or tcui,
                "score"      : round(data["score"], 4),
                "members"    : members,
            })

        return {
            "topics": topics_out,
            "metrics": {
                "input_cui_count"   : len(cuis),
                "topic_count"       : len(topics_out),
                "missing_cui_count" : len(missing),
                "dropped_singletons": dropped_singletons,
                "strategy"          : "siblingreach",
            },
            "missing_cuis": missing,
        }


def print_siblingreach(result):
    """Pretty-print a group() result."""
    m = result["metrics"]
    print(f"\n[siblingreach] {m['topic_count']} topics from {m['input_cui_count']} CUIs"
          f"  (missing: {m['missing_cui_count']}, "
          f"dropped singletons: {m['dropped_singletons']})")
    if result["missing_cuis"]:
        print(f"  missing CUIs: {result['missing_cuis']}")
    for topic in result["topics"]:
        print(f"  [{topic['topic_id']}] {topic['topic_label']}  "
              f"(score={topic['score']})  [{len(topic['members'])} members]")
        for mem in topic["members"]:
            print(f"    {mem['cui']}  {mem['preferred_term']}  IC={mem['ic']}")

"""
build_topics.py  (network-only, highest-IC convergence anchoring)
-----------------------------------------------------------------
Builds clinical topics from the network graph alone (no MRREL).

ANCHOR RULE (no IC FILTERING at formation — IC is used only as a RANKING):
  - Group  = a focal CUI + its network neighbors.
  - Convergence point = an in-group IS-A ancestor that groups >= MIN_COVERAGE
    members of the group (this kills size-2 fragments).
  - Each member anchors to its HIGHEST-IC convergence point — the most
    specific *meaningful* shared parent. IC is a ranking, NOT a floor:
      * Most-specific convergence anchor wins (e.g. Pneumonia over Disease).
      * Broad navigation nodes (huge descendant count = low IC) naturally
        lose the ranking, so they don't become anchors — without any floor.
  - A member may anchor under MULTIPLE convergence points only when it has
    multiple DISTINCT highest-IC parents via different paths (multi-parent),
    so we keep, per member, every convergence ancestor that is not itself
    dominated by a more-specific in-group convergence ancestor.

  NO MIN_ANCHOR_IC floor here. IC filtering is done later, at the adaptor.

PIPELINE:
  STAGE A : Flatten network graph -> neighbors
  STAGE B : (hierarchy + IC precomputed from isa_precomputed.pkl)
  STAGE C : Per group, anchor each member to its highest-IC convergence point(s)
  STAGE D : Dedup identical member sets (keep highest-IC anchor as name)

Inputs (notebook globals):
  netw            : network DiGraph
  isa_ancestors   : {cui: set(ancestor cuis)}   from isa_precomputed.pkl
  ic              : {cui: ic_score}              from isa_precomputed.pkl
  LABELS          : {cui: label}   (optional)

Output: topics.pkl
"""

import pickle, datetime, hashlib, os, time
from collections import defaultdict, Counter


OUTPUT_PATH  = "topics.pkl"
MIN_COVERAGE = 2          # convergence: anchor must group >= this many members
                          # (drops single-member anchors). NO IC floor here.


# ============================================================
# STAGE A: Flatten network graph -> neighbors
# ============================================================
def flatten_graph(graph, target_cuis):
    print("  [A] Flattening network graph...")
    t0 = time.time()
    neighbors = defaultdict(set)
    total = len(target_cuis)
    n = 0
    for cui in target_cuis:
        n += 1
        if n % 50000 == 0:
            print(f"      {n:,}/{total:,} ({time.time()-t0:.0f}s)")
        if cui not in graph:
            continue
        for suffix_child in graph.successors(cui):
            if "-" not in suffix_child:
                continue
            base = suffix_child.rsplit("-", 1)[0]
            if base != cui:
                continue
            for pred in graph.predecessors(suffix_child):
                if pred == cui or "-" not in pred:
                    continue
                other = pred.rsplit("-", 1)[0]
                if other == cui or other not in target_cuis:
                    continue
                neighbors[cui].add(other)
                neighbors[other].add(cui)
    edges = sum(len(v) for v in neighbors.values()) // 2
    print(f"      CUIs with neighbors: {len(neighbors):,}, edges: {edges:,} "
          f"({time.time()-t0:.0f}s)")
    return neighbors


# ============================================================
# STAGE C: highest-IC convergence anchoring
# ============================================================
def topic_id_for(members_fs):
    """ID from the MEMBER SET (stable regardless of which anchor names it)."""
    key = ",".join(sorted(members_fs))
    return "tp_" + hashlib.sha1(key.encode()).hexdigest()[:12]


def build_topics(target_cuis, neighbors, isa_ancestors, ic):
    print(f"  [C] Highest-IC convergence anchoring "
          f"(coverage>={MIN_COVERAGE}, IC=ranking only, no floor)...")
    t0 = time.time()
    canonical_to_members = defaultdict(set)
    total = len(target_cuis)
    n = 0
    n_no_anchor = 0

    # cache in-group ancestors per CUI? ancestors are global, but the
    # intersection with each group differs, so we just cache the raw set.
    anc_cache = {}
    def ancestors(cui):
        s = anc_cache.get(cui)
        if s is None:
            s = isa_ancestors.get(cui, set())
            anc_cache[cui] = s
        return s

    for focal in target_cuis:
        n += 1
        if n % 50000 == 0:
            print(f"      {n:,}/{total:,} ({time.time()-t0:.0f}s)")

        members = {focal} | neighbors.get(focal, set())
        if len(members) < 2:
            continue

        # in-group ancestors per member + coverage (how many members each groups)
        coverage = Counter()
        member_in_group = {}
        for m in members:
            anc = (ancestors(m) & members) - {m}
            member_in_group[m] = anc
            for a in anc:
                coverage[a] += 1

        # convergence points = in-group ancestors with coverage >= MIN_COVERAGE
        # each member anchors to its HIGHEST-IC convergence ancestor.
        any_assigned = False
        for m, anc in member_in_group.items():
            conv = [a for a in anc if coverage[a] >= MIN_COVERAGE]
            if not conv:
                continue
            # highest IC = most specific meaningful shared parent
            best_ic = max(ic.get(a, 0.0) for a in conv)
            # keep all convergence ancestors at the top IC (handles multi-parent
            # via different paths that are equally specific); usually just one.
            anchors = [a for a in conv if ic.get(a, 0.0) == best_ic]
            for a in anchors:
                canonical_to_members[a].add(a)
                canonical_to_members[a].add(m)
                any_assigned = True
        if not any_assigned:
            n_no_anchor += 1

    print(f"      done ({time.time()-t0:.0f}s) | "
          f"groups_no_convergence_anchor={n_no_anchor:,} | "
          f"raw_anchors={len(canonical_to_members):,}")
    return dict(canonical_to_members)


# ============================================================
# STAGE D: dedup identical member sets
# ============================================================
def dedup_member_sets(canonical_to_members, ic):
    print("  [D] Deduping identical member sets...")
    t0 = time.time()
    by_members = defaultdict(list)
    for anchor, mems in canonical_to_members.items():
        by_members[frozenset(mems)].append(anchor)
    deduped = {}
    n_merged = 0
    for mems_fs, anchors in by_members.items():
        # deterministic: highest IC, then CUI string
        keep = max(anchors, key=lambda a: (ic.get(a, 0.0), a))
        deduped[keep] = set(mems_fs)
        n_merged += len(anchors) - 1
    print(f"      merged {n_merged:,} duplicate-membership topics "
          f"({len(canonical_to_members):,} -> {len(deduped):,}) "
          f"({time.time()-t0:.0f}s)")
    return deduped


# ============================================================
# Main
# ============================================================
def main():
    required = ["netw", "isa_ancestors", "ic"]
    missing = [r for r in required if r not in globals()]
    if missing:
        raise RuntimeError(
            f"Missing required global(s): {missing}. "
            f"Load isa_precomputed.pkl (isa_ancestors, ic) and netw first.")

    print(f"BUILD START {datetime.datetime.now().isoformat()}")
    t_total = time.time()

    target_cuis = set(isa_ancestors.keys()) | set(ic.keys())
    print(f"  target CUIs: {len(target_cuis):,}")
    print(f"  MIN_COVERAGE={MIN_COVERAGE}  (IC used as ranking only, NO floor)")

    neighbors = flatten_graph(netw, target_cuis)
    raw = build_topics(target_cuis, neighbors, isa_ancestors, ic)
    canon_to_members = dedup_member_sets(raw, ic)

    print("  [pkg] Packaging topics...")
    topic_id_to_topic, canonical_to_topic_id = {}, {}
    cui_to_topic_ids = defaultdict(set)
    for canonical, mems in canon_to_members.items():
        fs = frozenset(mems)
        tp = topic_id_for(fs)
        topic_id_to_topic[tp] = {
            "canonical": canonical, "members": fs, "size": len(fs),
            "anchor_ic": ic.get(canonical, 0.0),
        }
        canonical_to_topic_id[canonical] = tp
        for m in fs:
            cui_to_topic_ids[m].add(tp)

    sizes = sorted(t["size"] for t in topic_id_to_topic.values())
    n_topics = len(topic_id_to_topic)
    def pct(p):
        if not sizes:
            return 0
        return sizes[min(len(sizes) - 1, int(p * (len(sizes) - 1)))]
    if sizes:
        print(f"\n  RESULT")
        print(f"    topics                : {n_topics:,}")
        print(f"    CUIs in >=1 topic     : {len(cui_to_topic_ids):,}")
        print(f"    topics per CUI (avg)  : "
              f"{sum(len(v) for v in cui_to_topic_ids.values())/max(len(cui_to_topic_ids),1):.2f}")
        print(f"    size min/med/p90/p99/max: "
              f"{sizes[0]}/{pct(.5)}/{pct(.9)}/{pct(.99)}/{sizes[-1]}")
        size2 = sum(1 for s in sizes if s == 2)
        print(f"    size-2 topics         : {size2:,} ({size2/n_topics*100:.1f}%)")

    payload = {
        "topic_id_to_topic":     topic_id_to_topic,
        "canonical_to_topic_id": canonical_to_topic_id,
        "cui_to_topic_ids":      {c: sorted(s) for c, s in cui_to_topic_ids.items()},
        "labels":                globals().get("LABELS", {}),
        "config": {
            "anchor_rule": "highest-IC convergence anchor (coverage>=MIN_COVERAGE); "
                           "IC used as RANKING only, NO floor; identical member "
                           "sets merged",
            "min_coverage":  MIN_COVERAGE,
            "ic_floor": None,
            "ic_role": "ranking_only",
            "hierarchy_source": "network isa (SNOMEDCT_US.isa)",
            "uses_mrrel": False,
            "topic_id_from": "member_set",
        },
        "built_at": datetime.datetime.now().isoformat(),
    }
    with open(OUTPUT_PATH, "wb") as f:
        pickle.dump(payload, f, protocol=pickle.HIGHEST_PROTOCOL)
    print(f"\n  saved {OUTPUT_PATH} ({os.path.getsize(OUTPUT_PATH)/1024/1024:.1f} MB)")
    print(f"TOTAL {time.time()-t_total:.0f}s")


main()
